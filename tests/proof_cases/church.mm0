-- Higher-order logic demo inspired by third_party/mm0/examples/hol.mm0.
--
-- This file keeps the object theory tiny, but it tries to show a few
-- frontend features in one place:
--   * Unicode notation for a small HOL-style ќї-calculus
--   * ќ≤ and ќЈ reasoning
--   * congruence-driven rewriting
--   * substitution rules whose raw binders disappear after normalization
--
-- There are two equalities in play:
--   * `вЙГ[A] t = u` is a Boolean-valued term
--   * `вЙ°[A] t = u` is a wff-level judgmental equality proposition

strict provable sort wff;

delimiter $ ( @ [ / ! ~ $ $ . : ; ) ] $;

term im: wff > wff > wff;
infixr im: $вКҐ$ prec 0;
infixr im: $|-$ prec 0;

term an: wff > wff > wff;
infixl an: $вИІ$ prec 1;
infixl an: $;$ prec 1;

axiom id (P: wff): $ P вКҐ P $;
axiom syl (P Q R: wff): $ P вКҐ Q $ > $ Q вКҐ R $ > $ P вКҐ R $;
axiom ian (G P Q: wff): $ G вКҐ P $ > $ G вКҐ Q $ > $ G вКҐ P вИІ Q $;
axiom anl (P Q: wff): $ P вИІ Q вКҐ P $;
axiom anr (P Q: wff): $ P вИІ Q вКҐ Q $;

term iff: wff > wff > wff;
infixr iff: $вЖФ$ prec 20;
infixr iff: $<->$ prec 20;

--| @relation wff iff iff_refl iff_trans iff_sym iff_mp
axiom iff_refl (P: wff): $ P вЖФ P $;
axiom iff_trans (P Q R: wff): $ P вЖФ Q $ > $ Q вЖФ R $ > $ P вЖФ R $;
axiom iff_sym (P Q: wff): $ P вЖФ Q $ > $ Q вЖФ P $;
axiom iff_mp (P Q: wff): $ P вЖФ Q $ > $ P $ > $ Q $;

-- Propositions, types, and terms.

strict sort type;

term bool: type;
notation bool: type = ($рЭФє$:max);

term fun: type > type > type;
infixr fun: $вЖТ$ prec 25;
infixr fun: $->$ prec 25;

term tyeq: type > type > wff;
infixl tyeq: $вЙР$ prec 15;

--| @relation type tyeq tyeq_refl tyeq_trans tyeq_sym _
axiom tyeq_refl (A: type): $ A вЙР A $;
axiom tyeq_trans (A B C: type):
  $ A вЙР B $ > $ B вЙР C $ > $ A вЙР C $;
axiom tyeq_sym (A B: type): $ A вЙР B $ > $ B вЙР A $;

--| @vars ќ± ќ≤ ќ≥ x y z p q r f g h u v w
sort term;

term ty: term > type > wff;
infixl ty: $:$ prec 2;

term app: term > term > term;
infixl app: $¬Ј$ prec 1000;
infixl app: $@$ prec 1000;

term lam {x: term}: type > term x > term;
notation lam {x: term} (A: type) (t: term x): term =
  ($ќї$:20) x ($:$:2) A ($.$:0) t;
notation lam {x: term} (A: type) (t: term x): term =
  ($\\$:20) x ($:$:2) A ($.$:0) t;

axiom appT (G: wff) (A B: type) (f x: term):
  $ G вКҐ f: A вЖТ B $ > $ G вКҐ x: A $ > $ G вКҐ f ¬Ј x: B $;

axiom lamT (G: wff) (A B: type) {x: term} (t: term x):
  $ G вИІ x: A вКҐ t: B $ > $ G вКҐ ќї x: A. t: A вЖТ B $;

term eq: type > term;
axiom eqT (G: wff) (A: type): $ G вКҐ eq A: A вЖТ A вЖТ рЭФє $;

def eqc (A: type) (t u: term): term = $ eq A ¬Ј t ¬Ј u $;
notation eqc (A: type) (t u: term): term =
  ($вЙГ[$:50) A ($]$:0) t ($=$:50) u;
notation eqc (A: type) (t u: term): term =
  ($=[$:50) A ($]$:0) t ($=$:50) u;

term jeq: type > term > term > wff;
notation jeq (A: type) (t u: term): wff =
  ($вЙ°[$:50) A ($]$:0) t ($=$:50) u;
notation jeq (A: type) (t u: term): wff =
  ($==[$:50) A ($]$:0) t ($=$:50) u;

term thm: term > wff;
coercion thm: term > wff;

def bic (p q: term): term = $ вЙГ[рЭФє] p = q $;
infixr bic: $вЗФ$ prec 20;
infixr bic: $<->$ prec 20;

axiom eqmp (G: wff) (P Q: term):
  $ G вКҐ P вЗФ Q $ > $ G вКҐ P $ > $ G вКҐ Q $;

axiom ded (G: wff) (P Q: term):
  $ G вИІ P вКҐ Q $ > $ G вИІ Q вКҐ P $ > $ G вКҐ P вЗФ Q $;

axiom thmR (G: wff) (A: term): $ G вКҐ A $ > $ G вКҐ A: рЭФє $;

axiom refl (G: wff) (A: type) (t: term):
  $ G вКҐ t: A $ > $ G вКҐ вЙ°[A] t = t $;

axiom aeq (G: wff) (A B: type) (f g a b: term):
  $ G вКҐ вЙ°[A вЖТ B] f = g $ > $ G вКҐ вЙ°[A] a = b $ >
  $ G вКҐ вЙ°[B] f ¬Ј a = g ¬Ј b $;

axiom leq (G: wff) (A B: type) {x: term} (a b: term x):
  $ G вИІ x: A вКҐ вЙ°[B] a = b $ >
  $ G вКҐ вЙ°[A вЖТ B] (ќї x: A. a) = (ќї x: A. b) $;

axiom beta (A B: type) {x: term} (G: wff x) (t: term x):
  $ G вКҐ (ќї x: A. t) ¬Ј x: B $ >
  $ G вКҐ вЙ°[B] (ќї x: A. t) ¬Ј x = t $;

axiom betat (A B: type) {x: term} (G: wff x) (t: term x):
  $ G вКҐ (ќї x: A. t) ¬Ј x: B $ >
  $ G вКҐ вЙГ[B] (ќї x: A. t) ¬Ј x = t $;

axiom inst (G: wff) (A: type) {x: term} (t a: term x):
  $ G вКҐ a: рЭФє $ > $ G вКҐ t: A $ > $ G вИІ вЙГ[A] x = t вКҐ a $ > $ G вКҐ a $;

axiom eta (G: wff) (A B: type) {x: term} (e: term x):
  $ G вКҐ e: A вЖТ B $ >
  $ G вКҐ вЙ°[A вЖТ B] (ќї x: A. e ¬Ј x) = e $;

axiom eqsym (G: wff) (A: type) (a b: term):
  $ G вКҐ вЙ°[A] a = b $ > $ G вКҐ вЙ°[A] b = a $;

axiom eqtrans (G: wff) (A: type) (a b c: term):
  $ G вКҐ вЙ°[A] a = b $ > $ G вКҐ вЙ°[A] b = c $ >
  $ G вКҐ вЙ°[A] a = c $;

axiom eqTR1 (G: wff) (A: type) (a b: term):
  $ G вКҐ вЙ°[A] a = b $ > $ G вКҐ a: A $;

axiom eqTR2 (G: wff) (A: type) (a b: term):
  $ G вКҐ вЙ°[A] a = b $ > $ G вКҐ b: A $;

-- Raw term-level equality used by the normalization machinery.

term teq: term > term > wff;
infixl teq: $вЙИ$ prec 15;

--| @relation term teq teq_refl teq_trans teq_sym _
axiom teq_refl (t: term): $ t вЙИ t $;
axiom teq_trans (t u v: term): $ t вЙИ u $ > $ u вЙИ v $ > $ t вЙИ v $;
axiom teq_sym (t u: term): $ t вЙИ u $ > $ u вЙИ t $;

--| @congr
axiom teq_congr (a b c d: term):
  $ a вЙИ b $ > $ c вЙИ d $ > $ (a вЙИ c) вЖФ (b вЙИ d) $;

--| @congr
axiom judg_congr (G H P Q: wff):
  $ G вЖФ H $ > $ P вЖФ Q $ > $ (G вКҐ P) вЖФ (H вКҐ Q) $;

--| @congr
axiom eq_congr (A B: type) (a b c d: term):
  $ A вЙР B $ > $ a вЙИ b $ > $ c вЙИ d $ > $ вЙ°[A] a = c вЖФ вЙ°[B] b = d $;

--| @congr
axiom app_congr (f g a b: term):
  $ f вЙИ g $ > $ a вЙИ b $ > $ f ¬Ј a вЙИ g ¬Ј b $;

-- Explicit substitution for term rewrites.

term sb {x: term}: term > term x > term;
notation sb {x: term} (t: term) (u: term x): term =
  ($[$:41) x ($/$:0) t ($]$:0) u;

--| @rewrite
axiom sb_var {x: term} (t: term): $ [x / t] x вЙИ t $;

--| @rewrite
axiom sb_irrel {x: term} (t u: term): $ [x / t] u вЙИ u $;

--| @rewrite
axiom sb_app {x: term} (t: term) (f a: term x):
  $ [x / t] (f ¬Ј a) вЙИ ([x / t] f) ¬Ј ([x / t] a) $;

-- Substitution rules. The raw binder `{x}` is hidden by normalization, so we
-- expose a cleaner user-facing surface with `@view`, `@abstract`, and
-- `@fresh`, as in the calculus demo.

--| @view {x: term} (G: wff) (A: type) (a b: term) (r: term x) (p q: term): $ G вКҐ вЙ°[A] a = b $ > $ G вКҐ вЙ°[A] p = q $
--| @abstract r p q x a b
--| @fresh x
--| @normalize conc
axiom subst_eq {x: term} (G: wff) (A: type) (a b: term) (r: term x):
  $ G вКҐ вЙ°[A] a = b $ >
  $ G вКҐ вЙ°[A] ([x / a] r) = ([x / b] r) $;

--| @view {x: term} (a b: term) (r: term x) (p q: term): $ a вЙИ b $ > $ p вЙИ q $
--| @abstract r p q x a b
--| @fresh x
--| @normalize conc
axiom subst_teq {x: term} (a b: term) (r: term x):
  $ a вЙИ b $ >
  $ ([x / a] r) вЙИ ([x / b] r) $;

-- Derived term-level equality rules used for the propositional basis.

axiom appTR1 (G: wff) (A B: type) (f x: term):
  $ G вКҐ f ¬Ј x: B $ > $ G вКҐ x: A $ > $ G вКҐ f: A вЖТ B $;

axiom appTR2 (G: wff) (A B: type) (f x: term):
  $ G вКҐ f ¬Ј x: B $ > $ G вКҐ f: A вЖТ B $ > $ G вКҐ x: A $;

axiom appTR22 (G: wff) (A B C: type) (f x y: term):
  $ G вКҐ f ¬Ј x ¬Ј y: C $ > $ G вКҐ f: A вЖТ B вЖТ C $ > $ G вКҐ x: A вИІ y: B $;

theorem eqcT (G: wff) (A: type) (t u: term):
  $ G вКҐ t: A $ > $ G вКҐ u: A $ > $ G вКҐ (вЙГ[A] t = u): рЭФє $;

axiom reflt (G: wff) (A: type) (t: term):
  $ G вКҐ t: A $ > $ G вКҐ вЙГ[A] t = t $;

axiom aeqt (G: wff) (A B: type) (f g a b: term):
  $ G вКҐ вЙГ[A вЖТ B] f = g $ > $ G вКҐ вЙГ[A] a = b $ >
  $ G вКҐ вЙГ[B] f ¬Ј a = g ¬Ј b $;

axiom leqt (G: wff) (A B: type) {x: term} (a b: term x):
  $ G вИІ x: A вКҐ вЙГ[B] a = b $ >
  $ G вКҐ вЙГ[A вЖТ B] (ќї x: A. a) = (ќї x: A. b) $;

axiom betac (G: wff) (A B: type) {x: term} (t: term x) (u: term):
  $ G вКҐ u: A $ > $ G вКҐ вЙГ[B] (ќї x: A. t) ¬Ј u = ([x / u] t) $;

axiom symt (G: wff) (A: type) (a b: term):
  $ G вКҐ вЙГ[A] a = b $ > $ G вКҐ вЙГ[A] b = a $;

axiom transt (G: wff) (A: type) (a b c: term):
  $ G вКҐ вЙГ[A] a = b $ > $ G вКҐ вЙГ[A] b = c $ >
  $ G вКҐ вЙГ[A] a = c $;

axiom eqR1 (G: wff) (A: type) (a b: term):
  $ G вКҐ вЙГ[A] a = b $ > $ G вКҐ a: A $;

axiom eqR2 (G: wff) (A: type) (a b: term):
  $ G вКҐ вЙГ[A] a = b $ > $ G вКҐ b: A $;

theorem aeq1 (G: wff) (A B: type) (f g a: term):
  $ G вКҐ вЙГ[A вЖТ B] f = g $ > $ G вКҐ a: A $ >
  $ G вКҐ вЙГ[B] f ¬Ј a = g ¬Ј a $;

theorem aeq2 (G: wff) (A B: type) (f a b: term):
  $ G вКҐ f: A вЖТ B $ > $ G вКҐ вЙГ[A] a = b $ >
  $ G вКҐ вЙГ[B] f ¬Ј a = f ¬Ј b $;

theorem bineq (G: wff) (A B C: type) (f a1 a2 b1 b2: term):
  $ G вКҐ f: A вЖТ B вЖТ C $ > $ G вКҐ вЙГ[A] a1 = a2 $ >
  $ G вКҐ вЙГ[B] b1 = b2 $ > $ G вКҐ вЙГ[C] f ¬Ј a1 ¬Ј b1 = f ¬Ј a2 ¬Ј b2 $;

theorem bineq1 (G: wff) (A B C: type) (f a1 a2 b: term):
  $ G вКҐ f: A вЖТ B вЖТ C $ > $ G вКҐ вЙГ[A] a1 = a2 $ > $ G вКҐ b: B $ >
  $ G вКҐ вЙГ[C] f ¬Ј a1 ¬Ј b = f ¬Ј a2 ¬Ј b $;

theorem bineq2 (G: wff) (A B C: type) (f a b1 b2: term):
  $ G вКҐ f: A вЖТ B вЖТ C $ > $ G вКҐ a: A $ > $ G вКҐ вЙГ[B] b1 = b2 $ >
  $ G вКҐ вЙГ[C] f ¬Ј a ¬Ј b1 = f ¬Ј a ¬Ј b2 $;

theorem sym (G: wff) (A: type) (a b: term):
  $ G вКҐ вЙГ[A] a = b $ > $ G вКҐ вЙГ[A] b = a $;

theorem trans (G: wff) (A: type) (a b c: term):
  $ G вКҐ вЙГ[A] a = b $ > $ G вКҐ вЙГ[A] b = c $ >
  $ G вКҐ вЙГ[A] a = c $;

theorem eqmpr (G: wff) (P Q: term):
  $ G вКҐ Q вЗФ P $ > $ G вКҐ P $ > $ G вКҐ Q $;

-- Small helper lemmas plus a few user-facing examples.

theorem weaken_ctx (G H P: wff):
  $ G вКҐ P $ > $ G вИІ H вКҐ P $;

theorem lamTR (A B: type) {x: term} (G: wff x) (t: term x):
  $ G вКҐ ќї x: A. t: A вЖТ B $ > $ G вИІ x: A вКҐ t: B $;

theorem betacv (G: wff) (A B: type) {x: term} (t u v: term x):
  $ G вИІ x: A вКҐ u: B $ >
  $ G вКҐ t: A $ >
  $ G вКҐ v: B $ >
  $ G вИІ вЙГ[A] x = t вКҐ вЙГ[B] u = v $ >
  $ G вКҐ вЙГ[B] (ќї x: A. u) ¬Ј t = v $;

theorem id_bool_has_type (G: wff) {x: term}:
  $ G вКҐ ќї x: рЭФє. x: рЭФє вЖТ рЭФє $;

theorem id_bool_refl (G: wff) {x: term}:
  $ G вКҐ вЙ°[рЭФє вЖТ рЭФє] (ќї x: рЭФє. x) = (ќї x: рЭФє. x) $;

theorem id_bool_beta (G: wff) {x: term}:
  $ G вКҐ x: рЭФє $ > $ G вКҐ вЙ°[рЭФє] ((ќї x: рЭФє. x) ¬Ј x) = x $;

theorem eq_subst_id (G: wff) {x y: term}:
  $ G вКҐ вЙ°[рЭФє] x = y $ >
  $ G вКҐ вЙ°[рЭФє] ((ќї x: рЭФє. x) ¬Ј x) = y $;

theorem id_bool_eta (G: wff) {x y: term}:
  $ G вКҐ вЙ°[рЭФє вЖТ рЭФє] (ќї x: рЭФє. (ќї y: рЭФє. y) ¬Ј x) = (ќї y: рЭФє. y) $;

def T {.x: term}: term =
  $ вЙГ[рЭФє вЖТ рЭФє] (ќї x: рЭФє. x) = (ќї x: рЭФє. x) $;
notation T: term = ($вК§$:max);

theorem T_DEF (G: wff) {x: term}:
  $ G вКҐ вЙГ[рЭФє] T = =[рЭФє вЖТ рЭФє] (ќї x: рЭФє. x) = (ќї x: рЭФє. x) $;

theorem TT (G: wff):
  $ G вКҐ T: рЭФє $;

theorem TRUTH (G: wff):
  $ G вКҐ T $;

theorem EQT_ELIM (G: wff) (P: term):
  $ G вКҐ P вЗФ T $ > $ G вКҐ P $;

theorem EQT_INTRO (G: wff) (P: term):
  $ G вКҐ P $ > $ G вКҐ P вЗФ T $;

def and {.x .y .f: term}: term =
  $ ќї x: рЭФє. ќї y: рЭФє. вЙГ[(рЭФє вЖТ рЭФє вЖТ рЭФє) вЖТ рЭФє]
      (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј x ¬Ј y) =
      (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј T ¬Ј T) $;

theorem AND_DEF (G: wff) {x y f: term}:
  $ G вКҐ вЙГ[рЭФє вЖТ рЭФє вЖТ рЭФє] and =
      (ќї x: рЭФє. ќї y: рЭФє. вЙГ[(рЭФє вЖТ рЭФє вЖТ рЭФє) вЖТ рЭФє]
        (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј x ¬Ј y) =
        (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј T ¬Ј T)) $;

theorem andT (G: wff):
  $ G вКҐ and: рЭФє вЖТ рЭФє вЖТ рЭФє $;

def andc (p q: term): term = $ and ¬Ј p ¬Ј q $;
infixl andc: $вЛП$ prec 35;

theorem andcT (G: wff) (p q: term):
  $ G вКҐ p: рЭФє $ > $ G вКҐ q: рЭФє $ > $ G вКҐ p вЛП q: рЭФє $;

def imp {.p .q: term}: term =
  $ ќї p: рЭФє. ќї q: рЭФє. p вЛП q вЗФ p $;

theorem IMP_DEF (G: wff) {p q: term}:
  $ G вКҐ вЙГ[рЭФє вЖТ рЭФє вЖТ рЭФє] imp =
      (ќї p: рЭФє. ќї q: рЭФє. p вЛП q вЗФ p) $;

theorem impT (G: wff):
  $ G вКҐ imp: рЭФє вЖТ рЭФє вЖТ рЭФє $;

def impc (p q: term): term = $ imp ¬Ј p ¬Ј q $;
infixr impc: $вЗТ$ prec 30;

theorem impcT (G: wff) (p q: term):
  $ G вКҐ p: рЭФє $ > $ G вКҐ q: рЭФє $ > $ G вКҐ p вЗТ q: рЭФє $;

theorem impR (G: wff) (p q: term):
  $ G вКҐ p вЗТ q $ > $ G вКҐ p: рЭФє вИІ q: рЭФє $;

theorem IMPC_DEF (G: wff) (a b: term):
  $ G вКҐ a: рЭФє $ > $ G вКҐ b: рЭФє $ > $ G вКҐ a вЗТ b вЗФ (a вЛП b вЗФ a) $;

axiom CONJ (G: wff) (p q: term):
  $ G вКҐ p $ > $ G вКҐ q $ > $ G вКҐ p вЛП q $;

axiom CONJUNCT1 (G: wff) (p q: term):
  $ G вКҐ p вЛП q $ > $ G вКҐ p $;

axiom CONJUNCT2 (G: wff) (p q: term):
  $ G вКҐ p вЛП q $ > $ G вКҐ q $;

theorem MP (G: wff) (p q: term):
  $ G вКҐ p вЗТ q $ > $ G вКҐ p $ > $ G вКҐ q $;

theorem DISCH (G: wff) (p q: term):
  $ G вКҐ p: рЭФє $ > $ G вКҐ q: рЭФє $ > $ G вИІ p вКҐ q $ > $ G вКҐ p вЗТ q $;

theorem UNDISCH (G: wff) (p q: term):
  $ G вКҐ p вЗТ q $ > $ G вИІ p вКҐ q $;

theorem IMP_ID (G: wff) (p: term):
  $ G вКҐ p: рЭФє $ > $ G вКҐ p вЗТ p $;

theorem IMP_TRANS (G: wff) (p q r: term):
  $ G вКҐ p вЗТ q $ > $ G вКҐ q вЗТ r $ > $ G вКҐ p вЗТ r $;

theorem CONJ_COMM (G: wff) (p q: term):
  $ G вКҐ p: рЭФє $ > $ G вКҐ q: рЭФє $ > $ G вКҐ p вЛП q вЗТ q вЛП p $;

theorem CONJ_ASSOC (G: wff) (p q r: term):
  $ G вКҐ p: рЭФє $ > $ G вКҐ q: рЭФє $ > $ G вКҐ r: рЭФє $ >
  $ G вКҐ (p вЛП q) вЛП r вЗТ p вЛП (q вЛП r) $;

theorem IMP_CONJ_CHAIN (G: wff) (p q r: term):
  $ G вКҐ p вЗТ q $ > $ G вКҐ q вЗТ r $ > $ G вКҐ p вЗТ q вЛП r $;

def all (A: type) {.P .x: term}: term =
  $ ќї P: A вЖТ рЭФє. вЙГ[A вЖТ рЭФє] P = (ќї x: A. T) $;

theorem FORALL_DEF (G: wff) (A: type) {P x: term}:
  $ G вКҐ вЙГ[(A вЖТ рЭФє) вЖТ рЭФє] all A =
      (ќї P: A вЖТ рЭФє. вЙГ[A вЖТ рЭФє] P = (ќї x: A. T)) $;

theorem allT (G: wff) (A: type):
  $ G вКҐ all A: (A вЖТ рЭФє) вЖТ рЭФє $;

def allc {x: term} (A: type) (t: term x): term =
  $ all A ¬Ј (ќї x: A. t) $;
notation allc {x: term} (A: type) (t: term x): term =
  ($!$:20) x ($:$:2) A ($.$:0) t;

theorem allcT (G: wff) (A: type) {x: term} (t: term x):
  $ G вИІ x: A вКҐ t: рЭФє $ > $ G вКҐ !x: A. t: рЭФє $;

theorem alleq (G: wff) (A: type) {x: term} (t u: term x):
  $ G вИІ x: A вКҐ t вЗФ u $ >
  $ G вКҐ all A ¬Ј (ќї x: A. t) вЗФ (all A ¬Ј (ќї x: A. u)) $;

def or {.p .q .r: term}: term =
  $ ќї p: рЭФє. ќї q: рЭФє. !r: рЭФє. (p вЗТ r) вЗТ (q вЗТ r) вЗТ r $;

theorem OR_DEF (G: wff) {p q r: term}:
  $ G вКҐ вЙГ[рЭФє вЖТ рЭФє вЖТ рЭФє] or =
      (ќї p: рЭФє. ќї q: рЭФє. !r: рЭФє. (p вЗТ r) вЗТ (q вЗТ r) вЗТ r) $;

theorem orT (G: wff):
  $ G вКҐ or: рЭФє вЖТ рЭФє вЖТ рЭФє $;

def orc (p q: term): term = $ or ¬Ј p ¬Ј q $;
infixl orc: $вИ®$ prec 31;
infixl orc: $\/$ prec 31;

theorem orcT (G: wff) (p q: term):
  $ G вКҐ p: рЭФє $ > $ G вКҐ q: рЭФє $ > $ G вКҐ p вИ® q: рЭФє $;

theorem ORC_DEF (G: wff) (a b: term) {r: term}:
  $ G вКҐ a: рЭФє $ > $ G вКҐ b: рЭФє $ >
  $ G вКҐ a вИ® b вЗФ (!r: рЭФє. (a вЗТ r) вЗТ (b вЗТ r) вЗТ r) $;

theorem orR (G: wff) (p q: term):
  $ G вКҐ p вИ® q $ > $ G вКҐ p: рЭФє вИІ q: рЭФє $;

def F {.p: term}: term =
  $ !p: рЭФє. p $;

theorem F_DEF (G: wff) {p: term}:
  $ G вКҐ F вЗФ (!p: рЭФє. p) $;

theorem FT (G: wff):
  $ G вКҐ F: рЭФє $;

def not {.p: term}: term =
  $ ќї p: рЭФє. p вЗТ F $;

theorem NOT_DEF (G: wff) {p: term}:
  $ G вКҐ вЙГ[рЭФє вЖТ рЭФє] not = (ќї p: рЭФє. p вЗТ F) $;

theorem notT (G: wff):
  $ G вКҐ not: рЭФє вЖТ рЭФє $;

def notc (p: term): term = $ not ¬Ј p $;
prefix notc: $¬ђ$ prec 100;
prefix notc: $~$ prec 100;

theorem notcT (G: wff) (p: term):
  $ G вКҐ p: рЭФє $ > $ G вКҐ ¬ђ p: рЭФє $;

theorem notR (G: wff) (p: term):
  $ G вКҐ ¬ђ p $ > $ G вКҐ p: рЭФє $;

theorem notc_def (G: wff) (p: term):
  $ G вКҐ p: рЭФє $ > $ G вКҐ ¬ђ p вЗФ (p вЗТ F) $;

theorem NOT_ELIM (G: wff) (p: term):
  $ G вКҐ ¬ђ p $ > $ G вКҐ p вЗТ F $;

theorem NOT_INTRO (G: wff) (p: term):
  $ G вКҐ p вЗТ F $ > $ G вКҐ ¬ђ p $;
