delimiter $ ( ) $;
provable sort wff;
sort ctx;

term imp (a b: wff): wff;
infixr imp: $Рєњ$ prec 25;
term and (a b: wff): wff;
infixr and: $РѕД$ prec 30;

-- Linear-time temporal operators.
term next (a: wff): wff;
prefix next: $РЌІ$ prec 40;
term globally (a: wff): wff;
prefix globally: $G$ prec 40;
term eventually (a: wff): wff;
prefix eventually: $F$ prec 40;

-- Atomic propositions for the request/response server.
term req: wff;
term res: wff;

term iff (a b: wff): wff;
infixr iff: $Рєћ$ prec 20;
term ctx_eq (g h: ctx): wff;
term emp: ctx;
notation emp: ctx = ($_$:max);

--| @acui ctx_assoc ctx_comm emp ctx_idem
term join (g h: ctx): ctx;
infixl join: $,$ prec 5;
term hyp (a: wff): ctx;
coercion hyp: wff > ctx;
term nd (g: ctx) (a: wff): wff;
infixl nd: $Ріб$ prec 0;

--| @relation wff iff iff_refl iff_trans iff_sym iff_mp
axiom iff_refl (a: wff): $ a Рєћ a $;
axiom iff_trans (a b c: wff):
  $ a Рєћ b $ > $ b Рєћ c $ > $ a Рєћ c $;
axiom iff_sym (a b: wff): $ a Рєћ b $ > $ b Рєћ a $;
axiom iff_mp (a b: wff): $ a Рєћ b $ > $ a $ > $ b $;

--| @relation ctx ctx_eq ctx_refl ctx_trans ctx_sym _
axiom ctx_refl (g: ctx): $ ctx_eq g g $;
axiom ctx_trans (g h i: ctx):
  $ ctx_eq g h $ > $ ctx_eq h i $ > $ ctx_eq g i $;
axiom ctx_sym (g h: ctx): $ ctx_eq g h $ > $ ctx_eq h g $;
axiom ctx_assoc (g h i: ctx):
  $ ctx_eq ((g , h) , i) (g , (h , i)) $;
axiom ctx_comm (g h: ctx): $ ctx_eq (g , h) (h , g) $;
axiom ctx_idem (g: ctx): $ ctx_eq (g , g) g $;
axiom ctx_unit (g: ctx): $ ctx_eq (emp , g) g $;

--| @congr
axiom join_congr (g1 g2 h1 h2: ctx):
  $ ctx_eq g1 g2 $ > $ ctx_eq h1 h2 $ >
  $ ctx_eq (g1 , h1) (g2 , h2) $;

--| @congr
axiom hyp_congr (a b: wff): $ a Рєћ b $ > $ ctx_eq (hyp a) (hyp b) $;

--| @congr
axiom nd_congr (g h: ctx) (a b: wff):
  $ ctx_eq g h $ > $ a Рєћ b $ > $ (g Ріб a) Рєћ (h Ріб b) $;

--| @congr
axiom imp_congr (a b c d: wff):
  $ a Рєћ b $ > $ c Рєћ d $ > $ (a Рєњ c) Рєћ (b Рєњ d) $;

--| @congr
axiom and_congr (a b c d: wff):
  $ a Рєћ b $ > $ c Рєћ d $ > $ (a РѕД c) Рєћ (b РѕД d) $;

--| @congr
axiom next_congr (a b: wff): $ a Рєћ b $ > $ РЌІ a Рєћ РЌІ b $;

--| @congr
axiom globally_congr (a b: wff): $ a Рєћ b $ > $ G a Рєћ G b $;

--| @congr
axiom eventually_congr (a b: wff): $ a Рєћ b $ > $ F a Рєћ F b $;

-- Propositional ND fragment.
axiom ax (g: ctx) (a: wff): $ g , a Ріб a $;

axiom imp_intro (g: ctx) (a b: wff):
  $ g , a Ріб b $ > $ g Ріб a Рєњ b $;

axiom imp_elim (g: ctx) (a b: wff):
  $ g Ріб a Рєњ b $ > $ g Ріб a $ > $ g Ріб b $;

axiom and_intro (g: ctx) (a b: wff):
  $ g Ріб a $ > $ g Ріб b $ > $ g Ріб a РѕД b $;

axiom and_elim_l (g: ctx) (a b: wff): $ g Ріб a РѕД b $ > $ g Ріб a $;
axiom and_elim_r (g: ctx) (a b: wff): $ g Ріб a РѕД b $ > $ g Ріб b $;

-- LTL inference rules.
--
-- These are sound under the standard "linear, discrete, infinite future"
-- semantics where worlds are natural-number stamps and Ріб asserts a fact
-- "now" given hypotheses "now". Note that necessitation (from `g Ріб a`,
-- conclude `g Ріб G a`) is NOT sound for arbitrary g Рђћ only the rules below
-- are admitted.

-- K-axiom (modus ponens under G).
axiom gop_K (g: ctx) (a b: wff):
  $ g Ріб G (a Рєњ b) $ > $ g Ріб G a $ > $ g Ріб G b $;

-- T-axiom (reflexivity: G refers to all worlds including the current one).
axiom gop_T (g: ctx) (a: wff): $ g Ріб G a $ > $ g Ріб a $;

-- Conjunction under G.
axiom gop_and (g: ctx) (a b: wff):
  $ g Ріб G a $ > $ g Ріб G b $ > $ g Ріб G (a РѕД b) $;

-- Pnueli's induction rule: from a step law and a base case, conclude
-- a global invariant.
axiom gop_ind (g: ctx) (a: wff):
  $ g Ріб G (a Рєњ РЌІ a) $ > $ g Ріб a $ > $ g Ріб G a $;

-- F-pair: an eventual `a` together with the always-implication `a Рєњ b`
-- yields an eventual state where both `b` and `a` hold simultaneously.
axiom fop_pair (g: ctx) (a b: wff):
  $ g Ріб F a $ > $ g Ріб G (a Рєњ b) $ > $ g Ріб F (b РѕД a) $;

-- Server specification: request/response with sticky bits, eventual
-- response, and causality.
axiom sr_req_sticky (g: ctx): $ g Ріб G (req Рєњ РЌІ req) $;
axiom sr_res_sticky (g: ctx): $ g Ріб G (res Рєњ РЌІ res) $;
axiom sr_responsive (g: ctx): $ g Ріб G (req Рєњ F res) $;
axiom sr_causal (g: ctx): $ g Ріб G (res Рєњ req) $;

-- Pnueli's induction principle, stated as a wff implication.
theorem gop_ind_thm (p: wff):
  $ emp Ріб ((G (p Рєњ РЌІ p)) Рєњ (p Рєњ G p)) $;

-- K-distribution stated as a wff implication.
theorem gop_K_thm (p q: wff):
  $ emp Ріб ((G (p Рєњ q)) Рєњ ((G p) Рєњ G q)) $;

-- Safety: a request, once issued, persists forever.
theorem stick_req: $ emp Ріб (req Рєњ G req) $;

-- Safety: a response, once issued, persists forever.
theorem stick_res: $ emp Ріб (res Рєњ G res) $;

-- Punchline. Combined safety + liveness for the server: every request
-- eventually reaches a moment at which the request and the response
-- both hold.
theorem req_response: $ emp Ріб (req Рєњ F (req РѕД res)) $;
