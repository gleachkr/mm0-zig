-- Adaptation of third_party/mm0/examples/peano.mm1 into the
-- ".mm0 + .auf" proof formalism used by this project.
--
-- peano.mm1 is ~7000 lines of Lisp-tactic proofs built on the Lukasiewicz
-- + Peano axiom base.  This file replays a self-contained chunk of its
-- propositional layer (lines 431-482 of peano.mm1) in explicit,
-- line-by-line Hilbert style: every modus ponens application is a
-- separate step citing ax_mp.  The classical theorems (contra, dne,
-- con2, con3, con1, mt) all go through.
--
-- The arithmetic section restricts itself to the algebraic fragment of
-- Peano (peano1 + peano2 + equality), since peano5 (induction) needs
-- universal quantifiers we haven't wired into this demo.

delimiter $ ( { ~ $  $ } ) , $;

strict provable sort wff;

term im (p q: wff): wff; infixr im: $->$ prec 25;
term not (p: wff): wff; prefix not: $~$ prec 41;

-- Lukasiewicz' axioms for classical propositional logic.
axiom ax_1 (a b: wff): $ a -> b -> a $;
axiom ax_2 (a b c: wff): $ (a -> b -> c) -> (a -> b) -> a -> c $;
axiom ax_3 (a b: wff): $ (~ a -> ~ b) -> b -> a $;
axiom ax_mp (a b: wff): $ a -> b $ > $ a $ > $ b $;

-- ---------------------------------------------------------------
-- Derived propositional theorems (replaying peano.mm1 lines 431+).
-- ---------------------------------------------------------------

theorem a1i (a b: wff): $ b $ > $ a -> b $;
theorem a2i (a b c: wff): $ a -> b -> c $ > $ (a -> b) -> a -> c $;
theorem mpd (a b c: wff): $ a -> b $ > $ a -> b -> c $ > $ a -> c $;
theorem mpi (a b c: wff): $ b $ > $ a -> b -> c $ > $ a -> c $;
theorem id (a: wff): $ a -> a $;
theorem idd (a b: wff): $ a -> b -> b $;
theorem syl (a b c: wff): $ b -> c $ > $ a -> b $ > $ a -> c $;
theorem rsyl (a b c: wff): $ a -> b $ > $ b -> c $ > $ a -> c $;
theorem a1d (a b c: wff): $ a -> b $ > $ a -> c -> b $;
theorem a2d (a b c d: wff):
  $ a -> b -> c -> d $ > $ a -> (b -> c) -> b -> d $;
theorem a3d (a b c: wff): $ a -> ~ b -> ~ c $ > $ a -> c -> b $;
theorem imim2 (a b c: wff): $ (b -> c) -> (a -> b) -> a -> c $;
theorem imim2i (a b c: wff): $ b -> c $ > $ (a -> b) -> a -> c $;
theorem com12 (a b c: wff): $ a -> b -> c $ > $ b -> a -> c $;
theorem mpcom (a b: wff): $ a -> (a -> b) -> b $;
theorem absurd (a b: wff): $ ~ a -> a -> b $;
theorem imidm (a b: wff): $ (a -> a -> b) -> a -> b $;
theorem contra (a: wff): $ (~ a -> a) -> a $;
theorem syld (a b c d: wff):
  $ a -> b -> c $ > $ a -> c -> d $ > $ a -> b -> d $;
theorem syl5 (a b c d: wff):
  $ b -> c $ > $ a -> c -> d $ > $ a -> b -> d $;
theorem dne (a: wff): $ ~ ~ a -> a $;
theorem con2 (a b: wff): $ (a -> ~ b) -> b -> ~ a $;
theorem notnot1 (a: wff): $ a -> ~ ~ a $;
theorem con3 (a b: wff): $ (a -> b) -> ~ b -> ~ a $;
theorem con1 (a b: wff): $ (~ a -> b) -> ~ b -> a $;
theorem mt (a b: wff): $ b -> a $ > $ ~ a $ > $ ~ b $;

-- ---------------------------------------------------------------
-- Peano arithmetic: zero, successor, equality.
--
-- We state the Peano/equality axioms in implication form so that the
-- contraposition machinery (con3) can lift peano2r into an inequality
-- rule.  peano.mm0 uses iff for peano2; we split it into the two
-- directions (peano2 forward, peano2r backward) to avoid needing
-- definitions + unfolding here.
-- ---------------------------------------------------------------

sort nat;

term d0: nat; prefix d0: $0$ prec max;
term suc (n: nat): nat;

term eq (a b: nat): wff; infixl eq: $=$ prec 50;

axiom peano1 (a: nat): $ ~ suc a = 0 $;
axiom peano2 (a b: nat): $ suc a = suc b -> a = b $;
axiom peano2r (a b: nat): $ a = b -> suc a = suc b $;

axiom eq_refl (a: nat): $ a = a $;
axiom eq_sym (a b: nat): $ a = b -> b = a $;
axiom eq_trans (a b c: nat): $ a = b -> b = c -> a = c $;

-- ---------------------------------------------------------------
-- Small arithmetic theorems built on top of the above.
-- ---------------------------------------------------------------

theorem eq_trans3 (a b c d: nat):
  $ a = b $ > $ b = c $ > $ c = d $ > $ a = d $;

theorem eq_euclid (a b c: nat):
  $ a = b $ > $ a = c $ > $ b = c $;

theorem suc_cong (a b: nat):
  $ a = b $ > $ suc (suc a) = suc (suc b) $;

theorem suc_zero_refl: $ suc 0 = suc 0 $;

theorem suc_chain (a b c: nat):
  $ a = b $ > $ b = c $ > $ suc a = suc c $;

-- Contrapositive flavour: con3 + peano2r gives an inequality rule, and
-- peano1 gives that 0 is never a successor.
theorem suc_inj_neg (a b: nat): $ ~ suc a = suc b $ > $ ~ a = b $;

theorem zero_ne_suc (a: nat): $ ~ 0 = suc a $;

theorem zero_ne_one: $ ~ 0 = suc 0 $;

-- Double-successor injection via peano2 twice.
theorem suc_cancel (a b: nat):
  $ suc (suc a) = suc (suc b) $ > $ a = b $;
