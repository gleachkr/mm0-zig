delimiter $ ( ) $;

-- Sorts
provable sort wff;

-- Terms
term im (a b: wff): wff; infixr im: $->$ prec 25;
term bi (a b: wff): wff; infixr bi: $<->$ prec 20;
term P: wff;
term Q: wff;
term R: wff;
term sb (a b: wff): wff;

-- Relation bundle
--| @relation wff bi biid bitr bisym mpbi

-- Relation axioms
axiom biid (a: wff): $ a <-> a $;
axiom bitr (a b c: wff): $ a <-> b $ > $ b <-> c $ > $ a <-> c $;
axiom bisym (a b: wff): $ a <-> b $ > $ b <-> a $;
axiom mpbi (a b: wff): $ a <-> b $ > $ a $ > $ b $;

-- Rewrite rules
--| @rewrite
axiom sb_im (a b c: wff): $ sb a (b -> c) <-> (sb a b -> sb a c) $;

--| @rewrite
axiom sb_P (a: wff): $ sb a P <-> a $;

-- Congruence for implication
--| @congr
axiom im_congr (a b c d: wff): $ a <-> b $ > $ c <-> d $ > $ (a -> c) <-> (b -> d) $;

-- A rule whose conclusion needs normalization
axiom all_elim (a b: wff): $ sb a b $;

-- Reuse one normalized proof line twice as a normalized hypothesis.
-- This exercises transported line reuse in the proof emitter.
axiom use_sub_twice (a b: wff): $ sb a b $ > $ sb a b $ > $ a $;

theorem test_repeat_ref: $ Q $;
