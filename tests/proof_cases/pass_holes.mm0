delimiter $ ( ) $;
provable sort wff;
term imp (a b: wff): wff; infixr imp: $->$ prec 25;
axiom ax_keep (a b: wff): $ a $ > $ a -> b -> a $;
axiom ax_elim (a b: wff): $ a -> b $ > $ b $;
theorem hole_explicit (a b: wff): $ a $ > $ a -> b -> a $;
theorem hole_infer_hyp (a b: wff): $ a -> b $ > $ b $;
