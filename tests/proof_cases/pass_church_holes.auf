l2: $ _ctx вК© ќї y: рЭФє. y: рЭФє вЖТ рЭФє $ by lamT [l1]
l3: $ _ctx вК© ќї x: рЭФє. ќї y: рЭФє. y: рЭФє вЖТ рЭФє вЖТ рЭФє $ by lamT [l2]

lemma proj1_eval (G: ctx) (p q: term) {x y: term}: $ G вК© p: рЭФє $ > $ G вК© q: рЭФє $ > $ G вК© вЙГ[рЭФє] (((ќї x: рЭФє. ќї y: рЭФє. x) ¬Ј p) ¬Ј q) = p $
--------------------------------------------------------
l1: $ G вК© ќї x: рЭФє. ќї y: рЭФє. x: рЭФє вЖТ рЭФє вЖТ рЭФє $ by proj1 []
l2: $ _wff $ by lamTR [l1]
l3: $ G , y: рЭФє вК© p: рЭФє $ by weaken [#1]
l4: $ _ctx вК© ќї y: рЭФє. p: рЭФє вЖТ рЭФє $ by lamT [l3]
l5: $ G , вЙГ[рЭФє] x = p вК© вЙГ[рЭФє] x = p $ by ax
l6: $ G , вЙГ[рЭФє] x = p , y: рЭФє вК© вЙГ[рЭФє] x = p $ by weaken [l5]
l7: $ _ctx вК© вЙГ[рЭФє вЖТ рЭФє] (ќї y: рЭФє. x) = (ќї y: рЭФє. p) $ by leqt [l6]
l8: $ G вК© вЙГ[рЭФє вЖТ рЭФє] ((ќї x: рЭФє. ќї y: рЭФє. x) ¬Ј p) = (ќї y: рЭФє. p) $ by betacv [l2, #1, l4, l7]
l9: $ G , вЙГ[рЭФє] y = q вК© p: рЭФє $ by weaken [#1]
l10: $ _ctx вК© _wff $ by reflt [l9]
l11: $ G вК© вЙГ[рЭФє] ((ќї y: рЭФє. p) ¬Ј q) = p $ by betacv [l3, #2, #1, l10]
l12: $ _wff $ by aeq1 [l8, #2]
l13: $ _wff $ by trans [l12, l11]

lemma proj2_eval (G: ctx) (p q: term) {x y: term}: $ G вК© p: рЭФє $ > $ G вК© q: рЭФє $ > $ G вК© вЙГ[рЭФє] (((ќї x: рЭФє. ќї y: рЭФє. y) ¬Ј p) ¬Ј q) = q $
--------------------------------------------------------
l1: $ G вК© ќї x: рЭФє. ќї y: рЭФє. y: рЭФє вЖТ рЭФє вЖТ рЭФє $ by proj2 []
l2: $ _wff $ by lamTR [l1]
l3: $ G , y: рЭФє вК© y: рЭФє $ by ax
l4: $ _ctx вК© ќї y: рЭФє. y: рЭФє вЖТ рЭФє $ by lamT [l3]
l5: $ G , вЙГ[рЭФє] x = p вК© ќї y: рЭФє. y: рЭФє вЖТ рЭФє $ by weaken [l4]
l6: $ _ctx вК© _wff $ by reflt [l5]
l7: $ G вК© вЙГ[рЭФє вЖТ рЭФє] ((ќї x: рЭФє. ќї y: рЭФє. y) ¬Ј p) = (ќї y: рЭФє. y) $ by betacv [l2, #1, l4, l6]
l8: $ G , вЙГ[рЭФє] y = q вК© вЙГ[рЭФє] y = q $ by ax
l9: $ G вК© вЙГ[рЭФє] ((ќї y: рЭФє. y) ¬Ј q) = q $ by betacv [l3, #2, #2, l8]
l10: $ _wff $ by aeq1 [l7, #2]
l11: $ _wff $ by trans [l10, l9]

lemma encoded_and_elim1 (G: ctx) (p q: term) {f: term}: $ G вК© p: рЭФє $ > $ G вК© q: рЭФє $ > $ G вК© вЙГ[(рЭФє вЖТ рЭФє вЖТ рЭФє) вЖТ рЭФє] (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј p ¬Ј q) = (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј T ¬Ј T) $ > $ G вК© p $
------------------------------------------------
l1: $ G вК© ќї x: рЭФє. ќї y: рЭФє. x: рЭФє вЖТ рЭФє вЖТ рЭФє $ by proj1 []
l2: $ G вК© вЙГ[рЭФє]
      ((ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј p ¬Ј q) ¬Ј (ќї x: рЭФє. ќї y: рЭФє. x)) =
      ((ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј T ¬Ј T) ¬Ј (ќї x: рЭФє. ќї y: рЭФє. x)) $ by aeq1 [#3, l1]
l3: $ _ctx вК© вЙГ[рЭФє] (((ќї x: рЭФє. ќї y: рЭФє. x) ¬Ј p) ¬Ј q) = p $ by proj1_eval [#1, #2]
l4: $ G вК© T: рЭФє $ by TT
l5: $ _ctx вК© вЙГ[рЭФє] (((ќї x: рЭФє. ќї y: рЭФє. x) ¬Ј T) ¬Ј T) = T $ by proj1_eval [l4, l4]
l6: $ G , f: рЭФє вЖТ рЭФє вЖТ рЭФє вК© f: рЭФє вЖТ рЭФє вЖТ рЭФє $ by ax
l7: $ G , f: рЭФє вЖТ рЭФє вЖТ рЭФє вК© p: рЭФє $ by weaken [#1]
l8: $ G , f: рЭФє вЖТ рЭФє вЖТ рЭФє вК© q: рЭФє $ by weaken [#2]
l9: $ _ctx вК© _wff $ by appT [l6, l7]
l10: $ _ctx вК© _wff $ by appT [l9, l8]
l11: $ G , вЙГ[рЭФє вЖТ рЭФє вЖТ рЭФє] f = (ќї x: рЭФє. ќї y: рЭФє. x) вК© вЙГ[рЭФє вЖТ рЭФє вЖТ рЭФє] f = (ќї x: рЭФє. ќї y: рЭФє. x) $ by ax
l12: $ G , вЙГ[рЭФє вЖТ рЭФє вЖТ рЭФє] f = (ќї x: рЭФє. ќї y: рЭФє. x) вК© p: рЭФє $ by weaken [#1]
l13: $ G , вЙГ[рЭФє вЖТ рЭФє вЖТ рЭФє] f = (ќї x: рЭФє. ќї y: рЭФє. x) вК© q: рЭФє $ by weaken [#2]
l14: $ _wff $ by aeq1 [l11, l12]
l15: $ _wff $ by aeq1 [l14, l13]
l16: $ G , вЙГ[рЭФє вЖТ рЭФє вЖТ рЭФє] f = (ќї x: рЭФє. ќї y: рЭФє. x) вК© вЙГ[рЭФє] (((ќї x: рЭФє. ќї y: рЭФє. x) ¬Ј p) ¬Ј q) = p $ by weaken [l3]
l17: $ _wff $ by trans [l15, l16]
l18: $ G вК© вЙГ[рЭФє] ((ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј p ¬Ј q) ¬Ј (ќї x: рЭФє. ќї y: рЭФє. x)) = p $ by betacv [l10, l1, #1, l17]
l19: $ G , f: рЭФє вЖТ рЭФє вЖТ рЭФє вК© T: рЭФє $ by weaken [l4]
l20: $ _ctx вК© _wff $ by appT [l6, l19]
l21: $ _ctx вК© _wff $ by appT [l20, l19]
l22: $ G , вЙГ[рЭФє вЖТ рЭФє вЖТ рЭФє] f = (ќї x: рЭФє. ќї y: рЭФє. x) вК© T: рЭФє $ by weaken [l4]
l23: $ _wff $ by aeq1 [l11, l22]
l24: $ _wff $ by aeq1 [l23, l22]
l25: $ G , вЙГ[рЭФє вЖТ рЭФє вЖТ рЭФє] f = (ќї x: рЭФє. ќї y: рЭФє. x) вК© вЙГ[рЭФє] (((ќї x: рЭФє. ќї y: рЭФє. x) ¬Ј T) ¬Ј T) = T $ by weaken [l5]
l26: $ _wff $ by trans [l24, l25]
l27: $ G вК© вЙГ[рЭФє] ((ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј T ¬Ј T) ¬Ј (ќї x: рЭФє. ќї y: рЭФє. x)) = T $ by betacv [l21, l1, l4, l26]
l28: $ _ctx вК© _wff $ by sym [l18]
l29: $ _wff $ by trans [l28, l2]
l30: $ _wff $ by trans [l29, l27]
l31: $ _ctx вК© _wff $ by EQT_ELIM [l30]

lemma encoded_and_elim2 (G: ctx) (p q: term) {f: term}: $ G вК© p: рЭФє $ > $ G вК© q: рЭФє $ > $ G вК© вЙГ[(рЭФє вЖТ рЭФє вЖТ рЭФє) вЖТ рЭФє] (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј p ¬Ј q) = (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј T ¬Ј T) $ > $ G вК© q $
------------------------------------------------
l1: $ G вК© ќї x: рЭФє. ќї y: рЭФє. y: рЭФє вЖТ рЭФє вЖТ рЭФє $ by proj2 []
