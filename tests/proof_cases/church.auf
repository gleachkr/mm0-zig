eqcT
----
l1: $ G вКҐ eq A: A вЖТ A вЖТ рЭФє $ by eqT 
l2: $ G вКҐ eq A ¬Ј t: A вЖТ рЭФє $ by appT [l1, #1]
l3: $ G вКҐ вЙГ[A] t = u: рЭФє $ by appT [l2, #2]

aeq1
----
l1: $ G вКҐ вЙГ[A] a = a $ by reflt [#2]
l2: $ G вКҐ вЙГ[B] f ¬Ј a = g ¬Ј a $ by aeqt [#1, l1]

aeq2
----
l1: $ G вКҐ вЙГ[A вЖТ B] f = f $ by reflt [#1]
l2: $ G вКҐ вЙГ[B] f ¬Ј a = f ¬Ј b $ by aeqt [l1, #2]

bineq
-----
l1: $ G вКҐ вЙГ[B вЖТ C] f ¬Ј a1 = f ¬Ј a2 $ by aeq2 [#1, #2]
l2: $ G вКҐ вЙГ[C] f ¬Ј a1 ¬Ј b1 = f ¬Ј a2 ¬Ј b2 $ by aeqt [l1, #3]

bineq1
------
l1: $ G вКҐ вЙГ[B] b = b $ by reflt [#3]
l2: $ G вКҐ вЙГ[C] f ¬Ј a1 ¬Ј b = f ¬Ј a2 ¬Ј b $ by bineq [#1, #2, l1]

bineq2
------
l1: $ G вКҐ вЙГ[A] a = a $ by reflt [#2]
l2: $ G вКҐ вЙГ[C] f ¬Ј a ¬Ј b1 = f ¬Ј a ¬Ј b2 $ by bineq [#1, l1, #3]

sym
---
l1: $ G вКҐ вЙГ[A] b = a $ by symt [#1]

trans
-----
l1: $ G вКҐ вЙГ[A] a = c $ by transt [#1, #2]

eqmpr
-----
l1: $ G вКҐ P вЗФ Q $ by symt [#1]
l2: $ G вКҐ Q $ by eqmp [l1, #2]

weaken_ctx
----------
l1: $ G вИІ H вКҐ G $ by anl 
l2: $ G вИІ H вКҐ P $ by syl [l1, #1]

lamTR
-----
l1: $ G вИІ x: A вКҐ ќї x: A. t: A вЖТ B $ by weaken_ctx [#1]
l2: $ G вИІ x: A вКҐ x: A $ by anr 
l3: $ G вИІ x: A вКҐ (ќї x: A. t) ¬Ј x: B $ by appT [l1, l2]
l4: $ G вИІ x: A вКҐ вЙ°[B] (ќї x: A. t) ¬Ј x = t $ by beta [l3]
l5: $ G вИІ x: A вКҐ t: B $ by eqTR2 [l4]

betacv
------
l1: $ G вКҐ ќї x: A. u: A вЖТ B $ by lamT [#1]
l2: $ G вКҐ (ќї x: A. u) ¬Ј t: B $ by appT [l1, #2]
l3: $ G вКҐ вЙГ[B] (ќї x: A. u) ¬Ј t = v: рЭФє $ by eqcT [l2, #3]
l4: $ G вИІ вЙГ[A] x = t вКҐ ќї x: A. u: A вЖТ B $ by weaken_ctx [l1]
l5: $ G вИІ вЙГ[A] x = t вКҐ вЙГ[A] x = t $ by anr 
l6: $ G вИІ вЙГ[A] x = t вКҐ вЙГ[A] t = x $ by sym [l5]
l7: $ G вИІ вЙГ[A] x = t вКҐ вЙГ[B] (ќї x: A. u) ¬Ј t = (ќї x: A. u) ¬Ј x $ by aeq2 [l4, l6]
l8: $ G вИІ вЙГ[A] x = t вКҐ x: A $ by eqR1 [l5]
l9: $ G вИІ вЙГ[A] x = t вКҐ (ќї x: A. u) ¬Ј x: B $ by appT [l4, l8]
l10: $ G вИІ вЙГ[A] x = t вКҐ вЙГ[B] (ќї x: A. u) ¬Ј x = u $ by betat [l9]
l11: $ G вИІ вЙГ[A] x = t вКҐ вЙГ[B] (ќї x: A. u) ¬Ј x = v $ by trans [l10, #4]
l12: $ G вИІ вЙГ[A] x = t вКҐ вЙГ[B] (ќї x: A. u) ¬Ј t = v $ by trans [l7, l11]
l13: $ G вКҐ вЙГ[B] (ќї x: A. u) ¬Ј t = v $ by inst [l3, #2, l12]

cbv
---
l1: $ G вКҐ ќї x: A. t: A вЖТ B $ by lamT [#1]
l2: $ G вКҐ вЙГ[A вЖТ B] (ќї y: A. (ќї x: A. t) ¬Ј y) = (ќї x: A. t) $ by etat [l1]
l3: $ G вКҐ вЙГ[A вЖТ B] (ќї x: A. t) = (ќї y: A. (ќї x: A. t) ¬Ј y) $ by sym [l2]
l4: $ G вИІ y: A вИІ x: A вКҐ G вИІ y: A $ by anl 
l5: $ G вИІ y: A вКҐ G $ by anl 
l6: $ G вИІ y: A вИІ x: A вКҐ G $ by syl [l4, l5]
l7: $ G вИІ y: A вИІ x: A вКҐ x: A $ by anr 
l8: $ G вИІ y: A вИІ x: A вКҐ G вИІ x: A $ by ian [l6, l7]
l9: $ G вИІ y: A вИІ x: A вКҐ t: B $ by syl [l8, #1]
l10: $ G вИІ y: A вКҐ y: A $ by anr 
l11: $ G вИІ y: A вИІ вЙГ[A] x = y вКҐ G вИІ y: A $ by anl 
l12: $ G вИІ y: A вИІ вЙГ[A] x = y вКҐ G $ by syl [l11, l5]
l13: $ G вИІ y: A вИІ вЙГ[A] x = y вКҐ вЙГ[A] x = y $ by anr 
l14: $ G вИІ y: A вИІ вЙГ[A] x = y вКҐ G вИІ вЙГ[A] x = y $ by ian [l12, l13]
l15: $ G вИІ y: A вИІ вЙГ[A] x = y вКҐ вЙГ[B] t = u $ by syl [l14, #3]
l16: $ G вИІ y: A вКҐ вЙГ[B] (ќї x: A. t) ¬Ј y = u $ by betacv [l9, l10, #2, l15]
l17: $ G вКҐ вЙГ[A вЖТ B] (ќї y: A. (ќї x: A. t) ¬Ј y) = (ќї y: A. u) $ by leqt [l16]
l18: $ G вКҐ вЙГ[A вЖТ B] (ќї x: A. t) = (ќї y: A. u) $ by trans [l3, l17]

id_bool_has_type
----------------
l1: $ G вИІ x: рЭФє вКҐ x: рЭФє $ by anr 
l2: $ G вКҐ ќї x: рЭФє. x: рЭФє вЖТ рЭФє $ by lamT [l1]

id_bool_refl
------------
l1: $ G вКҐ ќї x: рЭФє. x: рЭФє вЖТ рЭФє $ by id_bool_has_type 
l2: $ G вКҐ вЙ°[рЭФє вЖТ рЭФє] (ќї x: рЭФє. x) = (ќї x: рЭФє. x) $ by refl [l1]

id_bool_beta
------------
l1: $ G вКҐ ќї x: рЭФє. x: рЭФє вЖТ рЭФє $ by id_bool_has_type 
l2: $ G вКҐ (ќї x: рЭФє. x) ¬Ј x: рЭФє $ by appT [l1, #1]
l3: $ G вКҐ вЙ°[рЭФє] ((ќї x: рЭФє. x) ¬Ј x) = x $ by beta [l2]

eq_subst_id
-------------
l1: $ G вКҐ x: рЭФє $ by eqTR1 [#1]
l2: $ G вКҐ вЙ°[рЭФє] ((ќї x: рЭФє. x) ¬Ј x) = x $ by id_bool_beta [l1]
l3: $ G вКҐ вЙ°[рЭФє] ((ќї x: рЭФє. x) ¬Ј x) = y $ by eqtrans [l2, #1]

id_bool_eta
-----------
l1: $ G вКҐ ќї y: рЭФє. y: рЭФє вЖТ рЭФє $ by id_bool_has_type 
l2: $ G вКҐ вЙ°[рЭФє вЖТ рЭФє] (ќї x: рЭФє. (ќї y: рЭФє. y) ¬Ј x) = (ќї y: рЭФє. y) $ by eta [l1]

T_DEF
-----
l1: $ G вКҐ ќї x: рЭФє. x: рЭФє вЖТ рЭФє $ by id_bool_has_type 
l2: $ G вКҐ вЙГ[рЭФє вЖТ рЭФє] (ќї x: рЭФє. x) = (ќї x: рЭФє. x): рЭФє $ by eqcT [l1, l1]
l3: $ G вКҐ вЙГ[рЭФє] (вЙГ[рЭФє вЖТ рЭФє] (ќї x: рЭФє. x) = (ќї x: рЭФє. x)) = (вЙГ[рЭФє вЖТ рЭФє] (ќї x: рЭФє. x) = (ќї x: рЭФє. x)) $ by reflt [l2]

TT
--
l1: $ G вКҐ вЙГ[рЭФє] T = =[рЭФє вЖТ рЭФє] (ќї x: рЭФє. x) = (ќї x: рЭФє. x) $ by T_DEF 
l2: $ G вКҐ T: рЭФє $ by eqR1 [l1]

TRUTH
-----
l1: $ G вКҐ вЙГ[рЭФє] T = =[рЭФє вЖТ рЭФє] (ќї x: рЭФє. x) = (ќї x: рЭФє. x) $ by T_DEF 
l2: $ G вКҐ ќї x: рЭФє. x: рЭФє вЖТ рЭФє $ by id_bool_has_type 
l3: $ G вКҐ вЙГ[рЭФє вЖТ рЭФє] (ќї x: рЭФє. x) = (ќї x: рЭФє. x) $ by reflt [l2]
l4: $ G вКҐ T $ by eqmpr [l1, l3]

EQT_ELIM
--------
l1: $ G вКҐ T вЗФ P $ by symt [#1]
l2: $ G вКҐ T $ by TRUTH 
l3: $ G вКҐ P $ by eqmp [l1, l2]

EQT_INTRO
---------
l1: $ G вИІ P вКҐ T $ by TRUTH 
l2: $ G вИІ T вКҐ P $ by weaken_ctx [#1]
l3: $ G вКҐ P вЗФ T $ by ded [l1, l2]

AND_DEF
-------
l1: $ G вИІ x: рЭФє вИІ y: рЭФє вИІ f: рЭФє вЖТ рЭФє вЖТ рЭФє вКҐ f: рЭФє вЖТ рЭФє вЖТ рЭФє $ by anr 
l2: $ G вИІ x: рЭФє вИІ y: рЭФє вИІ f: рЭФє вЖТ рЭФє вЖТ рЭФє вКҐ G вИІ x: рЭФє вИІ y: рЭФє $ by anl 
l3: $ G вИІ x: рЭФє вИІ y: рЭФє вКҐ G вИІ x: рЭФє $ by anl 
l4: $ G вИІ x: рЭФє вИІ y: рЭФє вИІ f: рЭФє вЖТ рЭФє вЖТ рЭФє вКҐ G вИІ x: рЭФє $ by syl [l2, l3]
l5: $ G вИІ x: рЭФє вКҐ x: рЭФє $ by anr 
l6: $ G вИІ x: рЭФє вИІ y: рЭФє вИІ f: рЭФє вЖТ рЭФє вЖТ рЭФє вКҐ x: рЭФє $ by syl [l4, l5]
l7: $ G вИІ x: рЭФє вИІ y: рЭФє вКҐ y: рЭФє $ by anr 
l8: $ G вИІ x: рЭФє вИІ y: рЭФє вИІ f: рЭФє вЖТ рЭФє вЖТ рЭФє вКҐ y: рЭФє $ by syl [l2, l7]
l9: $ G вИІ x: рЭФє вИІ y: рЭФє вИІ f: рЭФє вЖТ рЭФє вЖТ рЭФє вКҐ f ¬Ј x: рЭФє вЖТ рЭФє $ by appT [l1, l6]
l10: $ G вИІ x: рЭФє вИІ y: рЭФє вИІ f: рЭФє вЖТ рЭФє вЖТ рЭФє вКҐ f ¬Ј x ¬Ј y: рЭФє $ by appT [l9, l8]
l11: $ G вИІ x: рЭФє вИІ y: рЭФє вКҐ ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј x ¬Ј y: (рЭФє вЖТ рЭФє вЖТ рЭФє) вЖТ рЭФє $ by lamT [l10]
l12: $ G вКҐ T: рЭФє $ by TT 
l13: $ G вИІ x: рЭФє вКҐ T: рЭФє $ by weaken_ctx [l12]
l14: $ G вИІ x: рЭФє вИІ y: рЭФє вКҐ T: рЭФє $ by weaken_ctx [l13]
l15: $ G вИІ x: рЭФє вИІ y: рЭФє вИІ f: рЭФє вЖТ рЭФє вЖТ рЭФє вКҐ T: рЭФє $ by weaken_ctx [l14]
l16: $ G вИІ x: рЭФє вИІ y: рЭФє вИІ f: рЭФє вЖТ рЭФє вЖТ рЭФє вКҐ f ¬Ј T: рЭФє вЖТ рЭФє $ by appT [l1, l15]
l17: $ G вИІ x: рЭФє вИІ y: рЭФє вИІ f: рЭФє вЖТ рЭФє вЖТ рЭФє вКҐ f ¬Ј T ¬Ј T: рЭФє $ by appT [l16, l15]
l18: $ G вИІ x: рЭФє вИІ y: рЭФє вКҐ ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј T ¬Ј T: (рЭФє вЖТ рЭФє вЖТ рЭФє) вЖТ рЭФє $ by lamT [l17]
l19: $ G вИІ x: рЭФє вИІ y: рЭФє вКҐ вЙГ[(рЭФє вЖТ рЭФє вЖТ рЭФє) вЖТ рЭФє] (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј x ¬Ј y) = (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј T ¬Ј T): рЭФє $ by eqcT [l11, l18]
l20: $ G вИІ x: рЭФє вКҐ ќї y: рЭФє. вЙГ[(рЭФє вЖТ рЭФє вЖТ рЭФє) вЖТ рЭФє] (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј x ¬Ј y) = (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј T ¬Ј T): рЭФє вЖТ рЭФє $ by lamT [l19]
l21: $ G вКҐ ќї x: рЭФє. ќї y: рЭФє. вЙГ[(рЭФє вЖТ рЭФє вЖТ рЭФє) вЖТ рЭФє] (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј x ¬Ј y) = (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј T ¬Ј T): рЭФє вЖТ рЭФє вЖТ рЭФє $ by lamT [l20]
l22: $ G вКҐ вЙГ[рЭФє вЖТ рЭФє вЖТ рЭФє] (ќї x: рЭФє. ќї y: рЭФє. вЙГ[(рЭФє вЖТ рЭФє вЖТ рЭФє) вЖТ рЭФє] (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј x ¬Ј y) = (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј T ¬Ј T)) = ((ќї x: рЭФє. ќї y: рЭФє. вЙГ[(рЭФє вЖТ рЭФє вЖТ рЭФє) вЖТ рЭФє] (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј x ¬Ј y) = (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј T ¬Ј T))) $ by reflt [l21]

andT
----
l1: $ G вКҐ вЙГ[рЭФє вЖТ рЭФє вЖТ рЭФє] and = (ќї x: рЭФє. ќї y: рЭФє. вЙГ[(рЭФє вЖТ рЭФє вЖТ рЭФє) вЖТ рЭФє] (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј x ¬Ј y) = (ќї f: рЭФє вЖТ рЭФє вЖТ рЭФє. f ¬Ј T ¬Ј T)) $ by AND_DEF 
l2: $ G вКҐ and: рЭФє вЖТ рЭФє вЖТ рЭФє $ by eqR1 [l1]

andcT
-----
l1: $ G вКҐ and: рЭФє вЖТ рЭФє вЖТ рЭФє $ by andT 
l2: $ G вКҐ and ¬Ј p: рЭФє вЖТ рЭФє $ by appT [l1, #1]
l3: $ G вКҐ p вЛП q: рЭФє $ by appT [l2, #2]

IMP_DEF
-------
l1: $ G вИІ p: рЭФє вИІ q: рЭФє вКҐ G вИІ p: рЭФє $ by anl 
l2: $ G вИІ p: рЭФє вКҐ p: рЭФє $ by anr 
l3: $ G вИІ p: рЭФє вИІ q: рЭФє вКҐ p: рЭФє $ by syl [l1, l2]
l4: $ G вИІ p: рЭФє вИІ q: рЭФє вКҐ q: рЭФє $ by anr 
l5: $ G вИІ p: рЭФє вИІ q: рЭФє вКҐ p вЛП q: рЭФє $ by andcT [l3, l4]
l6: $ G вИІ p: рЭФє вИІ q: рЭФє вКҐ p вЛП q вЗФ p: рЭФє $ by eqcT [l5, l3]
l7: $ G вИІ p: рЭФє вКҐ ќї q: рЭФє. p вЛП q вЗФ p: рЭФє вЖТ рЭФє $ by lamT [l6]
l8: $ G вКҐ ќї p: рЭФє. ќї q: рЭФє. p вЛП q вЗФ p: рЭФє вЖТ рЭФє вЖТ рЭФє $ by lamT [l7]
l9: $ G вКҐ вЙГ[рЭФє вЖТ рЭФє вЖТ рЭФє] (ќї p: рЭФє. ќї q: рЭФє. p вЛП q вЗФ p) = ((ќї p: рЭФє. ќї q: рЭФє. p вЛП q вЗФ p)) $ by reflt [l8]

impT
----
l1: $ G вКҐ вЙГ[рЭФє вЖТ рЭФє вЖТ рЭФє] (ќї p: рЭФє. ќї q: рЭФє. p вЛП q вЗФ p) =
      ((ќї p: рЭФє. ќї q: рЭФє. p вЛП q вЗФ p)) $ by IMP_DEF 
l2: $ G вКҐ ќї p: рЭФє. ќї q: рЭФє. p вЛП q вЗФ p: рЭФє вЖТ рЭФє вЖТ рЭФє $ by eqR1 [l1]

impcT
-----
l1: $ G вКҐ imp: рЭФє вЖТ рЭФє вЖТ рЭФє $ by impT 
l2: $ G вКҐ imp ¬Ј p: рЭФє вЖТ рЭФє $ by appT [l1, #1]
l3: $ G вКҐ p вЗТ q: рЭФє $ by appT [l2, #2]

impR
----
l1: $ G вКҐ p вЗТ q: рЭФє $ by thmR [#1]
l2: $ G вКҐ imp: рЭФє вЖТ рЭФє вЖТ рЭФє $ by impT 
l3: $ G вКҐ p: рЭФє вИІ q: рЭФє $ by appTR22 [l1, l2]

IMPC_DEF
--------
l1: $ G вКҐ вЙГ[рЭФє вЖТ рЭФє вЖТ рЭФє] imp = (ќї p: рЭФє. ќї q: рЭФє. p вЛП q вЗФ p) $ by IMP_DEF 
l2: $ G вКҐ вЙГ[рЭФє вЖТ рЭФє] imp ¬Ј a = ((ќї p: рЭФє. ќї q: рЭФє. p вЛП q вЗФ p) ¬Ј a) $ by aeq1 [l1, #1]
l3: $ G вИІ p: рЭФє вИІ q: рЭФє вКҐ G вИІ p: рЭФє $ by anl 
l4: $ G вИІ p: рЭФє вКҐ p: рЭФє $ by anr 
l5: $ G вИІ p: рЭФє вИІ q: рЭФє вКҐ p: рЭФє $ by syl [l3, l4]
