l31: $ G вКҐ вЙГ[рЭФє] (вЙГ[A вЖТ рЭФє] (ќї x: A. u) = (ќї x: A. T)) = (all A ¬Ј (ќї x: A. u)) $ by sym [l30]
l32: $ G вКҐ вЙГ[рЭФє] all A ¬Ј (ќї x: A. t) = (вЙГ[A вЖТ рЭФє] (ќї x: A. u) = (ќї x: A. T)) $ by trans [l22, l10]
l33: $ G вКҐ all A ¬Ј (ќї x: A. t) вЗФ (all A ¬Ј (ќї x: A. u)) $ by trans [l32, l31]

all_def
-------
l1: $ G вКҐ вЙГ[(A вЖТ рЭФє) вЖТ рЭФє] all A = (ќї f: A вЖТ рЭФє. вЙГ[A вЖТ рЭФє] f = (ќї x: A. T)) $ by FORALL_DEF 
l2: $ G вКҐ вЙГ[рЭФє] all A ¬Ј P = ((ќї f: A вЖТ рЭФє. вЙГ[A вЖТ рЭФє] f = (ќї x: A. T)) ¬Ј P) $ by aeq1 [l1, #1]
l3: $ G вКҐ T: рЭФє $ by TT 
