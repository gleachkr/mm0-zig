l11: $ G ∧ q: 𝔹 ∧ y: A ⊢ (λ x: A. p) · y ⇒ q: 𝔹 $ by impcT [l9, l10]
l12: $ G ∧ q: 𝔹 ∧ x: A ⊢ q: 𝔹 $ by weaken_ctx [l3]
l13: $ G ∧ q: 𝔹 ∧ x: A ⊢ G ∧ q: 𝔹 $ by anl 
l14: $ G ∧ q: 𝔹 ⊢ G $ by anl 
l15: $ G ∧ q: 𝔹 ∧ x: A ⊢ G $ by syl [l13, l14]
l16: $ G ∧ q: 𝔹 ∧ x: A ⊢ x: A $ by anr 
l17: $ G ∧ q: 𝔹 ∧ x: A ⊢ G ∧ x: A $ by ian [l15, l16]
l18: $ G ∧ q: 𝔹 ∧ x: A ⊢ p: 𝔹 $ by syl [l17, #1]
l19: $ G ∧ q: 𝔹 ∧ x: A ⊢ p ⇒ q: 𝔹 $ by impcT [l18, l12]
l20: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ G ∧ q: 𝔹 $ by anl 
l21: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ G $ by syl [l20, l5]
l22: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ λ x: A. p: A → 𝔹 $ by syl [l21, l1]
l23: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ ≃[A] y = x $ by anr 
l24: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ ≃[𝔹] (λ x: A. p) · y = (λ x: A. p) · x $ by aeq2 [l22, l23]
l25: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ x: A $ by eqR2 [l23]
l26: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ (λ x: A. p) · x: 𝔹 $ by appT [l22, l25]
l27: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ ≃[𝔹] (λ x: A. p) · x = p $ by betat [l26]
l28: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ q: 𝔹 $ by weaken_ctx [l3]
l29: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ imp: 𝔹 → 𝔹 → 𝔹 $ by impT 
l30: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ ((λ x: A. p) · y ⇒ q) ⇔ ((λ x: A. p) · x ⇒ q) $ by bineq1 [l29, l24, l28]
l31: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ ((λ x: A. p) · x ⇒ q) ⇔ (p ⇒ q) $ by bineq1 [l29, l27, l28]
l32: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ ((λ x: A. p) · y ⇒ q) ⇔ (p ⇒ q) $ by trans [l30, l31]
l33: $ G ∧ q: 𝔹 ⊢ ≃[A → 𝔹] (λ y: A. (λ x: A. p) · y ⇒ q) = (λ x: A. p ⇒ q) $ by cbv [l11, l19, l32]
l34: $ G ∧ q: 𝔹 ⊢ all A: (A → 𝔹) → 𝔹 $ by allT 
l35: $ G ∧ q: 𝔹 ⊢ (!y: A. (λ x: A. p) · y ⇒ q) ⇔ (!x: A. p ⇒ q) $ by aeq2 [l34, l33]
l36: $ G ∧ q: 𝔹 ⊢ imp: 𝔹 → 𝔹 → 𝔹 $ by impT 
l37: $ G ∧ q: 𝔹 ⊢ ((!y: A. (λ x: A. p) · y ⇒ q) ⇒ q) ⇔ ((!x: A. p ⇒ q) ⇒ q) $ by bineq1 [l36, l35, l3]
l38: $ G ⊢ (!q: 𝔹. (!y: A. (λ x: A. p) · y ⇒ q) ⇒ q) ⇔ (!q: 𝔹. (!x: A. p ⇒ q) ⇒ q) $ by alleq [l37]
l39: $ G ⊢ ex A · (λ x: A. p) ⇔ (!q: 𝔹. (!x: A. p ⇒ q) ⇒ q) $ by trans [l2, l38]

existsp
-------
l1: $ G ⊢ ex A · P ⇔ (!q: 𝔹. (!y: A. P · y ⇒ q) ⇒ q) $ by ex_def [#1]
l2: $ G ∧ q: 𝔹 ⊢ G $ by anl 
l3: $ G ∧ q: 𝔹 ⊢ q: 𝔹 $ by anr 
l4: $ G ∧ q: 𝔹 ⊢ P: A → 𝔹 $ by weaken_ctx [#1]
l5: $ G ∧ q: 𝔹 ∧ y: A ⊢ P: A → 𝔹 $ by weaken_ctx [l4]
l6: $ G ∧ q: 𝔹 ∧ y: A ⊢ y: A $ by anr 
l7: $ G ∧ q: 𝔹 ∧ y: A ⊢ P · y: 𝔹 $ by appT [l5, l6]
l8: $ G ∧ q: 𝔹 ∧ y: A ⊢ G ∧ q: 𝔹 $ by anl 
l9: $ G ∧ q: 𝔹 ∧ y: A ⊢ q: 𝔹 $ by syl [l8, l3]
l10: $ G ∧ q: 𝔹 ∧ y: A ⊢ P · y ⇒ q: 𝔹 $ by impcT [l7, l9]
l11: $ G ∧ q: 𝔹 ⊢ !y: A. P · y ⇒ q: 𝔹 $ by allcT [l10]
l12: $ G ∧ q: 𝔹 ⊢ x: A $ by weaken_ctx [#2]
l13: $ G ∧ q: 𝔹 ⊢ P · x $ by weaken_ctx [#3]
l14: $ G ∧ q: 𝔹 ⊢ P · x: 𝔹 $ by thmR [l13]
l15: $ G ∧ q: 𝔹 ⊢ P · x ⇒ q: 𝔹 $ by impcT [l14, l3]
l16: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ P: A → 𝔹 $ by weaken_ctx [l4]
l17: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ ≃[A] y = x $ by anr 
l18: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ ≃[𝔹] P · y = P · x $ by aeq2 [l16, l17]
l19: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ G ∧ q: 𝔹 $ by anl 
l20: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ q: 𝔹 $ by syl [l19, l3]
l21: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ imp: 𝔹 → 𝔹 → 𝔹 $ by impT 
l22: $ G ∧ q: 𝔹 ∧ ≃[A] y = x ⊢ P · y ⇒ q ⇔ P · x ⇒ q $ by bineq1 [l21, l18, l20]
l23: $ G ∧ q: 𝔹 ⊢ (!y: A. P · y ⇒ q) ⇒ P · x ⇒ q $ by spec [l10, l12, l15, l22]
l24: $ G ∧ q: 𝔹 ∧ !y: A. P · y ⇒ q ⊢ (!y: A. P · y ⇒ q) ⇒ P · x ⇒ q $ by weaken_ctx [l23]
l25: $ G ∧ q: 𝔹 ∧ !y: A. P · y ⇒ q ⊢ !y: A. P · y ⇒ q $ by anr 
l26: $ G ∧ q: 𝔹 ∧ !y: A. P · y ⇒ q ⊢ P · x ⇒ q $ by MP [l24, l25]
l27: $ G ∧ q: 𝔹 ∧ !y: A. P · y ⇒ q ⊢ P · x $ by weaken_ctx [l13]
l28: $ G ∧ q: 𝔹 ∧ !y: A. P · y ⇒ q ⊢ q $ by MP [l26, l27]
l29: $ G ∧ q: 𝔹 ⊢ (!y: A. P · y ⇒ q) ⇒ q $ by DISCH [l11, l3, l28]
l30: $ G ⊢ !q: 𝔹. (!y: A. P · y ⇒ q) ⇒ q $ by GEN [l29]
l31: $ G ⊢ ex A · P $ by eqmpr [l1, l30]

CHOOSE
------
l1: $ G ⊢ ex A · (λ x: A. p): 𝔹 $ by thmR [#2]
l2: $ G ⊢ ex A: (A → 𝔹) → 𝔹 $ by exT 
l3: $ G ⊢ λ x: A. p: A → 𝔹 $ by appTR2 [l1, l2]
l4: $ G ∧ x: A ⊢ p: 𝔹 $ by lamTR [l3]
l5: $ G ⊢ ex A · (λ x: A. p) ⇔ (!r: 𝔹. (!x: A. p ⇒ r) ⇒ r) $ by exc_def [l4]
l6: $ G ⊢ !r: 𝔹. (!x: A. p ⇒ r) ⇒ r $ by eqmp [l5, #2]
l7: $ G ∧ x: A ⊢ q: 𝔹 $ by weaken_ctx [#1]
l8: $ G ∧ x: A ⊢ p ⇒ q: 𝔹 $ by impcT [l4, l7]
l9: $ G ⊢ !x: A. p ⇒ q: 𝔹 $ by allcT [l8]
l10: $ G ∧ r: 𝔹 ∧ x: A ⊢ G ∧ r: 𝔹 $ by anl 
l11: $ G ∧ r: 𝔹 ⊢ G $ by anl 
l12: $ G ∧ r: 𝔹 ∧ x: A ⊢ G $ by syl [l10, l11]
l13: $ G ∧ r: 𝔹 ∧ x: A ⊢ x: A $ by anr 
l14: $ G ∧ r: 𝔹 ∧ x: A ⊢ G ∧ x: A $ by ian [l12, l13]
l15: $ G ∧ r: 𝔹 ∧ x: A ⊢ p: 𝔹 $ by syl [l14, l4]
l16: $ G ∧ r: 𝔹 ⊢ r: 𝔹 $ by anr 
l17: $ G ∧ r: 𝔹 ∧ x: A ⊢ r: 𝔹 $ by weaken_ctx [l16]
l18: $ G ∧ r: 𝔹 ∧ x: A ⊢ p ⇒ r: 𝔹 $ by impcT [l15, l17]
l19: $ G ∧ r: 𝔹 ⊢ !x: A. p ⇒ r: 𝔹 $ by allcT [l18]
l20: $ G ∧ ≃[𝔹] r = q ⊢ ≃[𝔹] r = q $ by anr 
l21: $ G ∧ ≃[𝔹] r = q ∧ x: A ⊢ ≃[𝔹] r = q $ by weaken_ctx [l20]
l22: $ G ∧ ≃[𝔹] r = q ∧ x: A ⊢ G ∧ ≃[𝔹] r = q $ by anl 
l23: $ G ∧ ≃[𝔹] r = q ⊢ G $ by anl 
l24: $ G ∧ ≃[𝔹] r = q ∧ x: A ⊢ G $ by syl [l22, l23]
l25: $ G ∧ ≃[𝔹] r = q ∧ x: A ⊢ x: A $ by anr 
l26: $ G ∧ ≃[𝔹] r = q ∧ x: A ⊢ G ∧ x: A $ by ian [l24, l25]
l27: $ G ∧ ≃[𝔹] r = q ∧ x: A ⊢ p: 𝔹 $ by syl [l26, l4]
l28: $ G ∧ ≃[𝔹] r = q ∧ x: A ⊢ imp: 𝔹 → 𝔹 → 𝔹 $ by impT 
l29: $ G ∧ ≃[𝔹] r = q ∧ x: A ⊢ p ⇒ r ⇔ p ⇒ q $ by bineq2 [l28, l27, l21]
l30: $ G ∧ ≃[𝔹] r = q ⊢ (!x: A. p ⇒ r) ⇔ (!x: A. p ⇒ q) $ by alleq [l29]
l31: $ G ∧ ≃[𝔹] r = q ⊢ imp: 𝔹 → 𝔹 → 𝔹 $ by impT 
l32: $ G ∧ ≃[𝔹] r = q ⊢ ((!x: A. p ⇒ r) ⇒ r) ⇔ ((!x: A. p ⇒ q) ⇒ q) $ by bineq [l31, l30, l20]
l33: $ G ⊢ ((!x: A. p ⇒ q) ⇒ q): 𝔹 $ by impcT [l9, #1]
l34: $ G ⊢ ((!x: A. p ⇒ q) ⇒ q) $ by SPEC [#1, l33, l32, l6]
l35: $ G ∧ x: A ⊢ p ⇒ q $ by DISCH [l4, l7, #3]
l36: $ G ⊢ !x: A. p ⇒ q $ by GEN [l35]
l37: $ G ⊢ q $ by MP [l34, l36]

EXISTS
------
l1: $ G ⊢ λ x: A. a: A → 𝔹 $ by lamT [#1]
l2: $ G ⊢ b: 𝔹 $ by thmR [#4]
l3: $ G ⊢ ≃[𝔹] (λ x: A. a) · t = b $ by betacv [#1, #2, l2, #3]
l4: $ G ⊢ (λ x: A. a) · t $ by eqmpr [l3, #4]
l5: $ G ⊢ ex A · (λ x: A. a) $ by existsp [l1, #2, l4]

ceqmpr
------
l1: $ G ⊩ P ⇔ Q $ by csym [#1]
l2: $ G ⊩ Q $ by ceqmp [l1, #2]

ceqTR2
------
l1: $ G ⊩ ≃[A] b = a $ by csym [#1]
l2: $ G ⊩ b: A $ by ceqTR1 [l1]

ccbv
----
l1: $ G ⊩ λ x: A. t: A → B $ by clamT [#1]
l2: $ G ⊩ ≃[A → B] (λ y: A. (λ x: A. t) · y) = (λ x: A. t) $ by cetat [l1]
l3: $ G ⊩ ≃[A → B] (λ x: A. t) = (λ y: A. (λ x: A. t) · y) $ by csym [l2]
l4: $ G , y: A , x: A ⊩ t: B $ by cweaken [#1]
l5: $ G , y: A ⊩ y: A $ by cax
l6: $ G , y: A , ≃[A] x = y ⊩ ≃[B] t = u $ by cweaken [#3]
l7: $ G , y: A ⊩ ≃[B] (λ x: A. t) · y = u $ by cbetacv [l4, l5, #2, l6]
l8: $ G ⊩ ≃[A → B] (λ y: A. (λ x: A. t) · y) = (λ y: A. u) $ by cleqt [l7]
l9: $ G ⊩ ≃[A → B] (λ x: A. t) = (λ y: A. u) $ by ctrans [l3, l8]

ceqcT
-----
l1: $ G ⊩ eq A: A → A → 𝔹 $ by ceqT
l2: $ G ⊩ eq A · t: A → 𝔹 $ by cappT [l1, #1]
l3: $ G ⊩ ≃[A] t = u: 𝔹 $ by cappT [l2, #2]

cT_DEF
------
l1: $ G , x: 𝔹 ⊩ x: 𝔹 $ by cax
l2: $ G ⊩ λ x: 𝔹. x: 𝔹 → 𝔹 $ by clamT [l1]
l3: $ G ⊩ T $ by creflt [l2]
l4: $ G ⊩ T: 𝔹 $ by cthmR [l3]
l5: $ G ⊩ ≃[𝔹] T = T $ by creflt [l4]

cTT
---
l1: $ G ⊩ ≃[𝔹] T = =[𝔹 → 𝔹] (λ x: 𝔹. x) = (λ x: 𝔹. x) $ by cT_DEF
l2: $ G ⊩ T: 𝔹 $ by ceqTR1 [l1]

cTRUTH
------
l1: $ G , x: 𝔹 ⊩ x: 𝔹 $ by cax
l2: $ G ⊩ λ x: 𝔹. x: 𝔹 → 𝔹 $ by clamT [l1]
l3: $ G ⊩ T $ by creflt [l2]

cEQT_ELIM
---------
l1: $ G ⊩ T $ by cTRUTH
l2: $ G ⊩ P $ by ceqmpr [#1, l1]

cEQT_INTRO
----------
l1: $ G ⊩ T $ by cTRUTH
l2: $ G , P ⊩ T $ by cweaken [l1]
l3: $ G , T ⊩ P $ by cweaken [#1]
l4: $ G ⊩ P ⇔ T $ by cded [l2, l3]

cAND_DEF
--------
l1: $ G , x: 𝔹 , y: 𝔹 , f: 𝔹 → 𝔹 → 𝔹 ⊩ f: 𝔹 → 𝔹 → 𝔹 $ by cax
l2: $ G , x: 𝔹 , y: 𝔹 , f: 𝔹 → 𝔹 → 𝔹 ⊩ x: 𝔹 $ by cax
l3: $ G , x: 𝔹 , y: 𝔹 , f: 𝔹 → 𝔹 → 𝔹 ⊩ y: 𝔹 $ by cax
l4: $ G , x: 𝔹 , y: 𝔹 , f: 𝔹 → 𝔹 → 𝔹 ⊩ f · x: 𝔹 → 𝔹 $ by cappT [l1, l2]
l5: $ G , x: 𝔹 , y: 𝔹 , f: 𝔹 → 𝔹 → 𝔹 ⊩ f · x · y: 𝔹 $ by cappT [l4, l3]
l6: $ G , x: 𝔹 , y: 𝔹 ⊩ λ f: 𝔹 → 𝔹 → 𝔹. f · x · y: (𝔹 → 𝔹 → 𝔹) → 𝔹 $ by clamT [l5]
l7: $ G ⊩ T: 𝔹 $ by cTT
l8: $ G , x: 𝔹 , y: 𝔹 , f: 𝔹 → 𝔹 → 𝔹 ⊩ T: 𝔹 $ by cweaken [l7]
l9: $ G , x: 𝔹 , y: 𝔹 , f: 𝔹 → 𝔹 → 𝔹 ⊩ f · T: 𝔹 → 𝔹 $ by cappT [l1, l8]
l10: $ G , x: 𝔹 , y: 𝔹 , f: 𝔹 → 𝔹 → 𝔹 ⊩ f · T · T: 𝔹 $ by cappT [l9, l8]
l11: $ G , x: 𝔹 , y: 𝔹 ⊩ λ f: 𝔹 → 𝔹 → 𝔹. f · T · T: (𝔹 → 𝔹 → 𝔹) → 𝔹 $ by clamT [l10]
l12: $ G , x: 𝔹 , y: 𝔹 ⊩ ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹] (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) = (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T): 𝔹 $ by ceqcT [l6, l11]
l13: $ G , x: 𝔹 ⊩ λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹] (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) = (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T): 𝔹 → 𝔹 $ by clamT [l12]
l14: $ G ⊩ λ x: 𝔹. λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹] (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) = (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T): 𝔹 → 𝔹 → 𝔹 $ by clamT [l13]
l15: $ G ⊩ ≃[𝔹 → 𝔹 → 𝔹] and = (λ x: 𝔹. λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹] (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) = (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T)) $ by creflt [l14]

candT
-----
l1: $ G ⊩ ≃[𝔹 → 𝔹 → 𝔹] and = (λ x: 𝔹. λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹] (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) = (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T)) $ by cAND_DEF
l2: $ G ⊩ and: 𝔹 → 𝔹 → 𝔹 $ by ceqTR1 [l1]

candcT
------
l1: $ G ⊩ and: 𝔹 → 𝔹 → 𝔹 $ by candT
l2: $ G ⊩ and · p: 𝔹 → 𝔹 $ by cappT [l1, #1]
l3: $ G ⊩ p ⋏ q: 𝔹 $ by cappT [l2, #2]

cIMP_DEF
--------
l1: $ G , p: 𝔹 , q: 𝔹 ⊩ p: 𝔹 $ by cax
l2: $ G , p: 𝔹 , q: 𝔹 ⊩ q: 𝔹 $ by cax
l3: $ G , p: 𝔹 , q: 𝔹 ⊩ p ⋏ q: 𝔹 $ by candcT [l1, l2]
l4: $ G , p: 𝔹 , q: 𝔹 ⊩ p ⋏ q ⇔ p: 𝔹 $ by ceqcT [l3, l1]
l5: $ G , p: 𝔹 ⊩ λ q: 𝔹. p ⋏ q ⇔ p: 𝔹 → 𝔹 $ by clamT [l4]
l6: $ G ⊩ λ p: 𝔹. λ q: 𝔹. p ⋏ q ⇔ p: 𝔹 → 𝔹 → 𝔹 $ by clamT [l5]
l7: $ G ⊩ ≃[𝔹 → 𝔹 → 𝔹] imp = (λ p: 𝔹. λ q: 𝔹. p ⋏ q ⇔ p) $ by creflt [l6]

cIMPC_DEF
---------
l1: $ G ⊩ ≃[𝔹 → 𝔹 → 𝔹] imp = (λ p: 𝔹. λ q: 𝔹. p ⋏ q ⇔ p) $ by cIMP_DEF
l2: $ G ⊩ ≃[𝔹 → 𝔹] imp · a = ((λ p: 𝔹. λ q: 𝔹. p ⋏ q ⇔ p) · a) $ by caeq1 [l1, #1]
l3: $ G ⊩ λ p: 𝔹. λ q: 𝔹. p ⋏ q ⇔ p: 𝔹 → 𝔹 → 𝔹 $ by ceqTR2 [l1]
l4: $ G , p: 𝔹 ⊩ λ q: 𝔹. p ⋏ q ⇔ p: 𝔹 → 𝔹 $ by clamTR [l3]
l5: $ G , q: 𝔹 ⊩ a: 𝔹 $ by cweaken [#1]
l6: $ G , q: 𝔹 ⊩ q: 𝔹 $ by cax
l7: $ G , q: 𝔹 ⊩ a ⋏ q: 𝔹 $ by candcT [l5, l6]
l8: $ G , q: 𝔹 ⊩ a ⋏ q ⇔ a: 𝔹 $ by ceqcT [l7, l5]
l9: $ G ⊩ λ q: 𝔹. a ⋏ q ⇔ a: 𝔹 → 𝔹 $ by clamT [l8]
l10: $ G , ≃[𝔹] p = a , q: 𝔹 ⊩ ≃[𝔹] p = a $ by cax
l11: $ G , ≃[𝔹] p = a , q: 𝔹 ⊩ q: 𝔹 $ by cax
l12: $ G , ≃[𝔹] p = a , q: 𝔹 ⊩ p: 𝔹 $ by ceqTR1 [l10]
l13: $ G , ≃[𝔹] p = a , q: 𝔹 ⊩ a: 𝔹 $ by ceqTR2 [l10]
l14: $ G , ≃[𝔹] p = a , q: 𝔹 ⊩ and: 𝔹 → 𝔹 → 𝔹 $ by candT
l15: $ G , ≃[𝔹] p = a , q: 𝔹 ⊩ p ⋏ q ⇔ a ⋏ q $ by cbineq1 [l14, l10, l11]
l16: $ G , ≃[𝔹] p = a , q: 𝔹 ⊩ eq 𝔹: 𝔹 → 𝔹 → 𝔹 $ by ceqT
l17: $ G , ≃[𝔹] p = a , q: 𝔹 ⊩ (p ⋏ q ⇔ p) ⇔ (a ⋏ q ⇔ a) $ by cbineq [l16, l15, l10]
l18: $ G , ≃[𝔹] p = a ⊩ ≃[𝔹 → 𝔹] (λ q: 𝔹. p ⋏ q ⇔ p) = (λ q: 𝔹. a ⋏ q ⇔ a) $ by cleqt [l17]
l19: $ G ⊩ ≃[𝔹 → 𝔹] ((λ p: 𝔹. λ q: 𝔹. p ⋏ q ⇔ p) · a) = (λ q: 𝔹. a ⋏ q ⇔ a) $ by cbetacv [l4, #1, l9, l18]
l20: $ G ⊩ ≃[𝔹 → 𝔹] imp · a = (λ q: 𝔹. a ⋏ q ⇔ a) $ by ctrans [l2, l19]
l21: $ G ⊩ a ⋏ b: 𝔹 $ by candcT [#1, #2]
l22: $ G ⊩ a ⋏ b ⇔ a: 𝔹 $ by ceqcT [l21, #1]
l23: $ G , ≃[𝔹] q = b ⊩ ≃[𝔹] q = b $ by cax
l24: $ G , ≃[𝔹] q = b ⊩ a: 𝔹 $ by cweaken [#1]
l25: $ G , ≃[𝔹] q = b ⊩ and: 𝔹 → 𝔹 → 𝔹 $ by candT
l26: $ G , ≃[𝔹] q = b ⊩ a ⋏ q ⇔ a ⋏ b $ by cbineq2 [l25, l24, l23]
l27: $ G , ≃[𝔹] q = b ⊩ eq 𝔹: 𝔹 → 𝔹 → 𝔹 $ by ceqT
l28: $ G , ≃[𝔹] q = b ⊩ ≃[𝔹] a = a $ by creflt [l24]
l29: $ G , ≃[𝔹] q = b ⊩ (a ⋏ q ⇔ a) ⇔ (a ⋏ b ⇔ a) $ by cbineq [l27, l26, l28]
l30: $ G ⊩ ≃[𝔹] ((λ q: 𝔹. a ⋏ q ⇔ a) · b) = (a ⋏ b ⇔ a) $ by cbetacv [l8, #2, l22, l29]
l31: $ G ⊩ ≃[𝔹] imp · a · b = ((λ q: 𝔹. a ⋏ q ⇔ a) · b) $ by caeq1 [l20, #2]
l32: $ G ⊩ imp · a · b ⇔ (a ⋏ b ⇔ a) $ by ctrans [l31, l30]

cIMPEQ1
-------
l1: $ G ⊩ p: 𝔹 $ by ceqTR1 [#1]
l2: $ G ⊩ pp: 𝔹 $ by ceqTR2 [#1]
l3: $ G ⊩ p ⇒ q ⇔ (p ⋏ q ⇔ p) $ by cIMPC_DEF [l1, #2]
l4: $ G ⊩ pp ⇒ q ⇔ (pp ⋏ q ⇔ pp) $ by cIMPC_DEF [l2, #2]
l5: $ G ⊩ and: 𝔹 → 𝔹 → 𝔹 $ by candT
l6: $ G ⊩ p ⋏ q ⇔ pp ⋏ q $ by cbineq1 [l5, #1, #2]
l7: $ G ⊩ eq 𝔹: 𝔹 → 𝔹 → 𝔹 $ by ceqT
l8: $ G ⊩ (p ⋏ q ⇔ p) ⇔ (pp ⋏ q ⇔ pp) $ by cbineq [l7, l6, #1]
l9: $ G ⊩ (pp ⋏ q ⇔ pp) ⇔ pp ⇒ q $ by csym [l4]
l10: $ G ⊩ p ⇒ q ⇔ (pp ⋏ q ⇔ pp) $ by ctrans [l3, l8]
l11: $ G ⊩ p ⇒ q ⇔ pp ⇒ q $ by ctrans [l10, l9]

cIMPEQ2
-------
l1: $ G ⊩ q: 𝔹 $ by ceqTR1 [#2]
l2: $ G ⊩ qq: 𝔹 $ by ceqTR2 [#2]
l3: $ G ⊩ p ⇒ q ⇔ (p ⋏ q ⇔ p) $ by cIMPC_DEF [#1, l1]
l4: $ G ⊩ p ⇒ qq ⇔ (p ⋏ qq ⇔ p) $ by cIMPC_DEF [#1, l2]
l5: $ G ⊩ and: 𝔹 → 𝔹 → 𝔹 $ by candT
l6: $ G ⊩ p ⋏ q ⇔ p ⋏ qq $ by cbineq2 [l5, #1, #2]
l7: $ G ⊩ eq 𝔹: 𝔹 → 𝔹 → 𝔹 $ by ceqT
l8: $ G ⊩ ≃[𝔹] p = p $ by creflt [#1]
l9: $ G ⊩ (p ⋏ q ⇔ p) ⇔ (p ⋏ qq ⇔ p) $ by cbineq [l7, l6, l8]
l10: $ G ⊩ (p ⋏ qq ⇔ p) ⇔ p ⇒ qq $ by csym [l4]
l11: $ G ⊩ p ⇒ q ⇔ (p ⋏ qq ⇔ p) $ by ctrans [l3, l9]
l12: $ G ⊩ p ⇒ q ⇔ p ⇒ qq $ by ctrans [l11, l10]

cFORALL_DEF
-----------
l1: $ G , P: A → 𝔹 ⊩ P: A → 𝔹 $ by cax
l2: $ G ⊩ T: 𝔹 $ by cTT
l3: $ G , P: A → 𝔹 ⊩ T: 𝔹 $ by cweaken [l2]
l4: $ G , P: A → 𝔹 , x: A ⊩ T: 𝔹 $ by cweaken [l3]
l5: $ G , P: A → 𝔹 ⊩ λ x: A. T: A → 𝔹 $ by clamT [l4]
l6: $ G , P: A → 𝔹 ⊩ ≃[A → 𝔹] P = (λ x: A. T): 𝔹 $ by ceqcT [l1, l5]
l7: $ G ⊩ λ P: A → 𝔹. ≃[A → 𝔹] P = (λ x: A. T): (A → 𝔹) → 𝔹 $ by clamT [l6]
l8: $ G ⊩ ≃[(A → 𝔹) → 𝔹] (λ P: A → 𝔹. ≃[A → 𝔹] P = (λ x: A. T)) = ((λ P: A → 𝔹. ≃[A → 𝔹] P = (λ x: A. T))) $ by creflt [l7]

callT
-----
l1: $ G ⊩ ≃[(A → 𝔹) → 𝔹] all A = (λ f: A → 𝔹. ≃[A → 𝔹] f = (λ y: A. T)) $ by cFORALL_DEF
l2: $ G ⊩ all A: (A → 𝔹) → 𝔹 $ by ceqTR1 [l1]

ccallcT
-------
l1: $ G ⊩ all A: (A → 𝔹) → 𝔹 $ by callT
l2: $ G ⊩ λ x: A. t: A → 𝔹 $ by clamT [#1]
l3: $ G ⊩ !x: A. t: 𝔹 $ by cappT [l1, l2]

calleq
------
l1: $ G ⊩ ≃[A → 𝔹] (λ x: A. t) = (λ x: A. u) $ by cleqt [#1]
l2: $ G ⊩ all A: (A → 𝔹) → 𝔹 $ by callT
l3: $ G ⊩ ≃[𝔹] all A · (λ x: A. t) = all A · (λ x: A. u) $ by caeq2 [l2, l1]

cchoose_eq
----------
l1: $ G , ≃[𝔹] r = q ⊩ ≃[𝔹] r = q $ by cax
l2: $ G , ≃[𝔹] r = q ⊩ r: 𝔹 $ by ceqTR1 [l1]
l3: $ G , ≃[𝔹] r = q ⊩ (!x: A. p ⇒ q): 𝔹 $ by ceqTR2 [#1]
l4: $ G , ≃[𝔹] r = q ⊩ ((!x: A. p ⇒ r) ⇒ r) ⇔ ((!x: A. p ⇒ q) ⇒ r) $ by cIMPEQ1 [#1, l2]
l5: $ G , ≃[𝔹] r = q ⊩ ((!x: A. p ⇒ q) ⇒ r) ⇔ ((!x: A. p ⇒ q) ⇒ q) $ by cIMPEQ2 [l3, l1]
l6: $ G , ≃[𝔹] r = q ⊩ ((!x: A. p ⇒ r) ⇒ r) ⇔ ((!x: A. p ⇒ q) ⇒ q) $ by ctrans [l4, l5]

cchoose_targetT
---------------
l1: $ G ⊩ !x: A. p ⇒ q: 𝔹 $ by cthmR [#1]
l2: $ G ⊩ ((!x: A. p ⇒ q) ⇒ q) ⇔ (((!x: A. p ⇒ q) ⋏ q) ⇔ (!x: A. p ⇒ q)) $ by cIMPC_DEF [l1, #2]
l3: $ G ⊩ ((!x: A. p ⇒ q) ⇒ q): 𝔹 $ by ceqTR1 [l2]

call_def
--------
l1: $ G ⊩ ≃[(A → 𝔹) → 𝔹] all A = (λ f: A → 𝔹. ≃[A → 𝔹] f = (λ x: A. T)) $ by cFORALL_DEF
l2: $ G ⊩ ≃[𝔹] all A · P = ((λ f: A → 𝔹. ≃[A → 𝔹] f = (λ x: A. T)) · P) $ by caeq1 [l1, #1]
l3: $ G ⊩ T: 𝔹 $ by cTT
l4: $ G , x: A ⊩ T: 𝔹 $ by cweaken [l3]
l5: $ G ⊩ λ x: A. T: A → 𝔹 $ by clamT [l4]
l6: $ G , f: A → 𝔹 ⊩ f: A → 𝔹 $ by cax
l7: $ G , f: A → 𝔹 ⊩ λ x: A. T: A → 𝔹 $ by cweaken [l5]
l8: $ G , f: A → 𝔹 ⊩ ≃[A → 𝔹] f = (λ x: A. T): 𝔹 $ by ceqcT [l6, l7]
l9: $ G ⊩ ≃[A → 𝔹] P = (λ x: A. T): 𝔹 $ by ceqcT [#1, l5]
l10: $ G , ≃[A → 𝔹] f = P ⊩ ≃[A → 𝔹] f = P $ by cax
l11: $ G , ≃[A → 𝔹] f = P ⊩ eq (A → 𝔹): (A → 𝔹) → (A → 𝔹) → 𝔹 $ by ceqT
l12: $ G , ≃[A → 𝔹] f = P ⊩ λ x: A. T: A → 𝔹 $ by cweaken [l5]
l13: $ G , ≃[A → 𝔹] f = P ⊩ ≃[𝔹] (≃[A → 𝔹] f = (λ x: A. T)) = (≃[A → 𝔹] P = (λ x: A. T)) $ by cbineq1 [l11, l10, l12]
l14: $ G ⊩ ≃[𝔹] ((λ f: A → 𝔹. ≃[A → 𝔹] f = (λ x: A. T)) · P) = (≃[A → 𝔹] P = (λ x: A. T)) $ by cbetacv [l8, #1, l9, l13]
l15: $ G ⊩ all A · P ⇔ (≃[A → 𝔹] P = (λ x: A. T)) $ by ctrans [l2, l14]

cspecp
------
l1: $ G ⊩ all A · P: 𝔹 $ by cthmR [#2]
l2: $ G ⊩ all A: (A → 𝔹) → 𝔹 $ by callT
l3: $ G ⊩ P: A → 𝔹 $ by cappTR2 [l1, l2]
l4: $ G ⊩ all A · P ⇔ (≃[A → 𝔹] P = (λ x: A. T)) $ by call_def [l3]
l5: $ G ⊩ ≃[A → 𝔹] P = (λ x: A. T) $ by ceqmp [l4, #2]
l6: $ G ⊩ ≃[𝔹] P · t = ((λ x: A. T) · t) $ by caeq1 [l5, #1]
l7: $ G ⊩ T: 𝔹 $ by cTT
l8: $ G , x: A ⊩ T: 𝔹 $ by cweaken [l7]
l9: $ G ⊩ ≃[𝔹] T = T $ by creflt [l7]
l10: $ G , ≃[A] x = t ⊩ ≃[𝔹] T = T $ by cweaken [l9]
l11: $ G ⊩ ≃[𝔹] ((λ x: A. T) · t) = T $ by cbetacv [l8, #1, l7, l10]
l12: $ G ⊩ ≃[𝔹] P · t = T $ by ctrans [l6, l11]
l13: $ G ⊩ P · t $ by cEQT_ELIM [l12]

cspec
-----
l1: $ G ⊩ !x: A. a: 𝔹 $ by ccallcT [#1]
l2: $ G , !x: A. a ⊩ b: 𝔹 $ by cweaken [#3]
l3: $ G , !x: A. a ⊩ t: A $ by cweaken [#2]
l4: $ G , !x: A. a ⊩ !x: A. a $ by cax
l5: $ G , !x: A. a ⊩ (λ x: A. a) · t $ by cspecp [l3, l4]
