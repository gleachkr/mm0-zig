l1: $ G вКҐ ¬ђ p: рЭФє $ by thmR [#1]
l2: $ G вКҐ not: рЭФє вЖТ рЭФє $ by notT 
l3: $ G вКҐ p: рЭФє $ by appTR2 [l1, l2]

notc_def
--------
l1: $ G вКҐ F: рЭФє $ by FT 
l2: $ G вИІ q: рЭФє вКҐ F: рЭФє $ by weaken_ctx [l1]
l3: $ G вИІ q: рЭФє вКҐ q: рЭФє $ by anr 
l4: $ G вИІ q: рЭФє вКҐ q вЗТ F: рЭФє $ by impcT [l3, l2]
l5: $ G вКҐ ќї q: рЭФє. q вЗТ F: рЭФє вЖТ рЭФє $ by lamT [l4]
l6: $ G вКҐ вЙГ[рЭФє вЖТ рЭФє] not = (ќї q: рЭФє. q вЗТ F) $ by NOT_DEF 
l7: $ G вКҐ вЙГ[рЭФє] not ¬Ј p = ((ќї q: рЭФє. q вЗТ F) ¬Ј p) $ by aeq1 [l6, #1]
l8: $ G вКҐ imp: рЭФє вЖТ рЭФє вЖТ рЭФє $ by impT 
l9: $ G вКҐ imp ¬Ј p: рЭФє вЖТ рЭФє $ by appT [l8, #1]
l10: $ G вКҐ imp ¬Ј p ¬Ј F: рЭФє $ by appT [l9, l1]
l11: $ G вИІ вЙГ[рЭФє] q = p вКҐ вЙГ[рЭФє] q = p $ by anr 
l12: $ G вИІ вЙГ[рЭФє] q = p вКҐ imp: рЭФє вЖТ рЭФє вЖТ рЭФє $ by impT 
l13: $ G вИІ вЙГ[рЭФє] q = p вКҐ вЙГ[рЭФє вЖТ рЭФє] imp ¬Ј q = imp ¬Ј p $ by aeq2 [l12, l11]
l14: $ G вИІ вЙГ[рЭФє] q = p вКҐ F: рЭФє $ by weaken_ctx [l1]
l15: $ G вИІ вЙГ[рЭФє] q = p вКҐ вЙГ[рЭФє] imp ¬Ј q ¬Ј F = imp ¬Ј p ¬Ј F $ by aeq1 [l13, l14]
l16: $ G вКҐ вЙГ[рЭФє] ((ќї q: рЭФє. q вЗТ F) ¬Ј p) = imp ¬Ј p ¬Ј F $ by betacv [l4, #1, l10, l15]
l17: $ G вКҐ not ¬Ј p вЗФ (imp ¬Ј p ¬Ј F) $ by trans [l7, l16]

NOT_ELIM
--------
l1: $ G вКҐ p: рЭФє $ by notR [#1]
l2: $ G вКҐ ¬ђ p вЗФ (p вЗТ F) $ by notc_def [l1]
l3: $ G вКҐ p вЗТ F $ by eqmp [l2, #1]

NOT_INTRO
---------
l1: $ G вКҐ p: рЭФє вИІ F: рЭФє $ by impR [#1]
l2: $ p: рЭФє вИІ F: рЭФє вКҐ p: рЭФє $ by anl 
l3: $ G вКҐ p: рЭФє $ by syl [l1, l2]
l4: $ G вКҐ ¬ђ p вЗФ (p вЗТ F) $ by notc_def [l3]
l5: $ G вКҐ ¬ђ p $ by eqmpr [l4, #1]

EQF_INTRO
---------
l1: $ G вКҐ p вЗТ F $ by NOT_ELIM [#1]
l2: $ G вКҐ p: рЭФє $ by notR [#1]
l3: $ G вКҐ F: рЭФє $ by FT 
l4: $ G вИІ F вКҐ F $ by anr 
l5: $ G вИІ F вКҐ p: рЭФє $ by weaken_ctx [l2]
l6: $ G вИІ F вКҐ p $ by CONTR [l5, l4]
l7: $ G вКҐ F вЗТ p $ by DISCH [l3, l2, l6]
l8: $ G вКҐ p вЗФ F $ by IMP_ANTISYM [l1, l7]

EQF_ELIM
--------
l1: $ G вКҐ p вЗТ F $ by EQ_IMP1 [#1]
l2: $ G вКҐ ¬ђ p $ by NOT_INTRO [l1]

NOT_FALSE
---------
l1: $ G вКҐ F: рЭФє $ by FT 
l2: $ G вКҐ F вЗТ F $ by IMP_ID [l1]
l3: $ G вКҐ ¬ђ F $ by NOT_INTRO [l2]
