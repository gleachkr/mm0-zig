l8: $ G ∧ q: 𝔹 ∧ y: A ⊢ y: A $ by anr 
l9: $ G ∧ q: 𝔹 ∧ y: A ⊢ (λ x: A. p) · y: 𝔹 $ by appT [l7, l8]
