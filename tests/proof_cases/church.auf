l7: $ G вИІ f: A вЖТ рЭФє вКҐ ќї x: A. T: A вЖТ рЭФє $ by weaken_ctx [l5]
l8: $ G вИІ f: A вЖТ рЭФє вКҐ вЙГ[A вЖТ рЭФє] f = (ќї x: A. T): рЭФє $ by eqcT [l6, l7]
l9: $ G вКҐ вЙГ[A вЖТ рЭФє] P = (ќї x: A. T): рЭФє $ by eqcT [#1, l5]
l10: $ G вИІ вЙГ[A вЖТ рЭФє] f = P вКҐ вЙГ[A вЖТ рЭФє] f = P $ by anr 
l11: $ G вИІ вЙГ[A вЖТ рЭФє] f = P вКҐ eq (A вЖТ рЭФє): (A вЖТ рЭФє) вЖТ (A вЖТ рЭФє) вЖТ рЭФє $ by eqT 
l12: $ G вИІ вЙГ[A вЖТ рЭФє] f = P вКҐ ќї x: A. T: A вЖТ рЭФє $ by weaken_ctx [l5]
l13: $ G вИІ вЙГ[A вЖТ рЭФє] f = P вКҐ вЙГ[рЭФє] (вЙГ[A вЖТ рЭФє] f = (ќї x: A. T)) = (вЙГ[A вЖТ рЭФє] P = (ќї x: A. T)) $ by bineq1 [l11, l10, l12]
l14: $ G вКҐ вЙГ[рЭФє] ((ќї f: A вЖТ рЭФє. вЙГ[A вЖТ рЭФє] f = (ќї x: A. T)) ¬Ј P) = (вЙГ[A вЖТ рЭФє] P = (ќї x: A. T)) $ by betacv [l8, #1, l9, l13]
l15: $ G вКҐ all A ¬Ј P вЗФ (вЙГ[A вЖТ рЭФє] P = (ќї x: A. T)) $ by trans [l2, l14]

specp
