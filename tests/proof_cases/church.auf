l7: $ G ⊢ !x: 𝔹. (p ⇒ x) ⇒ (q ⇒ x) ⇒ x $ by eqmp [l6, #1]
l8: $ G ∧ ≃[𝔹] x = r ⊢ p: 𝔹 $ by weaken_ctx [l3]
l9: $ G ∧ ≃[𝔹] x = r ⊢ q: 𝔹 $ by weaken_ctx [l5]
l10: $ G ∧ ≃[𝔹] x = r ⊢ ≃[𝔹] x = r $ by anr 
l11: $ G ∧ ≃[𝔹] x = r ⊢ x: 𝔹 $ by eqR1 [l10]
l12: $ G ∧ ≃[𝔹] x = r ⊢ r: 𝔹 $ by eqR2 [l10]
l13: $ G ∧ ≃[𝔹] x = r ⊢ imp: 𝔹 → 𝔹 → 𝔹 $ by impT 
l14: $ G ∧ ≃[𝔹] x = r ⊢ p ⇒ x: 𝔹 $ by impcT [l8, l11]
l15: $ G ∧ ≃[𝔹] x = r ⊢ p ⇒ r: 𝔹 $ by impcT [l8, l12]
l16: $ G ∧ ≃[𝔹] x = r ⊢ q ⇒ x: 𝔹 $ by impcT [l9, l11]
l17: $ G ∧ ≃[𝔹] x = r ⊢ q ⇒ r: 𝔹 $ by impcT [l9, l12]
l18: $ G ∧ ≃[𝔹] x = r ⊢ p ⇒ x ⇔ p ⇒ r $ by bineq2 [l13, l8, l10]
l19: $ G ∧ ≃[𝔹] x = r ⊢ q ⇒ x ⇔ q ⇒ r $ by bineq2 [l13, l9, l10]
l20: $ G ∧ ≃[𝔹] x = r ⊢ (q ⇒ x) ⇒ x ⇔ (q ⇒ r) ⇒ r $ by bineq [l13, l19, l10]
l21: $ G ∧ ≃[𝔹] x = r ⊢ (p ⇒ x) ⇒ (q ⇒ x) ⇒ x ⇔ (p ⇒ r) ⇒ (q ⇒ r) ⇒ r $ by bineq [l13, l18, l20]
l22: $ G ⊢ p ⇒ r: 𝔹 $ by impcT [l3, #2]
l23: $ G ⊢ q ⇒ r: 𝔹 $ by impcT [l5, #2]
l24: $ G ⊢ (q ⇒ r) ⇒ r: 𝔹 $ by impcT [l23, #2]
l25: $ G ⊢ (p ⇒ r) ⇒ (q ⇒ r) ⇒ r: 𝔹 $ by impcT [l22, l24]
l26: $ G ⊢ (p ⇒ r) ⇒ (q ⇒ r) ⇒ r $ by SPEC [#2, l25, l21, l7]
l27: $ G ⊢ p ⇒ r $ by DISCH [l3, #2, #3]
l28: $ G ⊢ (q ⇒ r) ⇒ r $ by MP [l26, l27]
l29: $ G ⊢ q ⇒ r $ by DISCH [l5, #2, #4]
l30: $ G ⊢ r $ by MP [l28, l29]

cF_DEF
------
l1: $ G , p: 𝔹 ⊩ p: 𝔹 $ by cax
l2: $ G ⊩ !p: 𝔹. p: 𝔹 $ by ccallcT [l1]
l3: $ G ⊩ ≃[𝔹] (!p: 𝔹. p) = (!p: 𝔹. p) $ by creflt [l2]

cFT
---
l1: $ G ⊩ F ⇔ (!p: 𝔹. p) $ by cF_DEF
l2: $ G ⊩ F: 𝔹 $ by ceqTR1 [l1]

cCONTR
------
l1: $ G ⊩ F ⇔ (!q: 𝔹. q) $ by cF_DEF
l2: $ G ⊩ !q: 𝔹. q $ by ceqmp [l1, #2]
l3: $ G , ≃[𝔹] q = p ⊩ q ⇔ p $ by cax
l4: $ G ⊩ p $ by cSPEC [#1, #1, l3, l2]

F_DEF
-----
l1: $ G ∧ p: 𝔹 ⊢ p: 𝔹 $ by anr 
l2: $ G ⊢ !p: 𝔹. p: 𝔹 $ by allcT [l1]
l3: $ G ⊢ ≃[𝔹] (!p: 𝔹. p) = (!p: 𝔹. p) $ by reflt [l2]

FT
--
l1: $ G ⊢ F ⇔ (!p: 𝔹. p) $ by F_DEF 
l2: $ G ⊢ F: 𝔹 $ by eqR1 [l1]

CONTR
-----
l1: $ G ⊢ F ⇔ (!q: 𝔹. q) $ by F_DEF 
l2: $ G ⊢ !q: 𝔹. q $ by eqmp [l1, #2]
l3: $ G ∧ ≃[𝔹] q = p ⊢ q ⇔ p $ by anr 
l4: $ G ⊢ p $ by SPEC [#1, #1, l3, l2]

cNOT_DEF
--------
l1: $ G , p: 𝔹 ⊩ p: 𝔹 $ by cax
l2: $ G ⊩ F: 𝔹 $ by cFT
l3: $ G , p: 𝔹 ⊩ F: 𝔹 $ by cweaken [l2]
l4: $ G , p: 𝔹 ⊩ p ⇒ F ⇔ (p ⋏ F ⇔ p) $ by cIMPC_DEF [l1, l3]
l5: $ G , p: 𝔹 ⊩ p ⇒ F: 𝔹 $ by ceqTR1 [l4]
l6: $ G ⊩ λ p: 𝔹. p ⇒ F: 𝔹 → 𝔹 $ by clamT [l5]
l7: $ G ⊩ ≃[𝔹 → 𝔹] (λ p: 𝔹. p ⇒ F) = ((λ p: 𝔹. p ⇒ F)) $ by creflt [l6]

cnotT
-----
l1: $ G ⊩ ≃[𝔹 → 𝔹] not = (λ p: 𝔹. p ⇒ F) $ by cNOT_DEF
l2: $ G ⊩ not: 𝔹 → 𝔹 $ by ceqTR1 [l1]

NOT_DEF
-------
l1: $ G ∧ p: 𝔹 ⊢ p: 𝔹 $ by anr 
l2: $ G ⊢ F: 𝔹 $ by FT 
l3: $ G ∧ p: 𝔹 ⊢ F: 𝔹 $ by weaken_ctx [l2]
l4: $ G ∧ p: 𝔹 ⊢ p ⇒ F: 𝔹 $ by impcT [l1, l3]
l5: $ G ⊢ λ p: 𝔹. p ⇒ F: 𝔹 → 𝔹 $ by lamT [l4]
l6: $ G ⊢ ≃[𝔹 → 𝔹] (λ p: 𝔹. p ⇒ F) = ((λ p: 𝔹. p ⇒ F)) $ by reflt [l5]

notT
----
l1: $ G ⊢ ≃[𝔹 → 𝔹] not = (λ p: 𝔹. p ⇒ F) $ by NOT_DEF 
l2: $ G ⊢ not: 𝔹 → 𝔹 $ by eqR1 [l1]

cnotcT
------
l1: $ G ⊩ not: 𝔹 → 𝔹 $ by cnotT
l2: $ G ⊩ ¬ p: 𝔹 $ by cappT [l1, #1]

cnotR
-----
l1: $ G ⊩ ¬ p: 𝔹 $ by cthmR [#1]
l2: $ G ⊩ not: 𝔹 → 𝔹 $ by cnotT
l3: $ G ⊩ p: 𝔹 $ by cappTR2 [l1, l2]

cnotc_def
---------
l1: $ G ⊩ F: 𝔹 $ by cFT
l2: $ G , q: 𝔹 ⊩ q: 𝔹 $ by cax
l3: $ G , q: 𝔹 ⊩ F: 𝔹 $ by cweaken [l1]
l4: $ G , q: 𝔹 ⊩ q ⇒ F ⇔ (q ⋏ F ⇔ q) $ by cIMPC_DEF [l2, l3]
l5: $ G , q: 𝔹 ⊩ q ⇒ F: 𝔹 $ by ceqTR1 [l4]
l6: $ G ⊩ ≃[𝔹 → 𝔹] not = (λ q: 𝔹. q ⇒ F) $ by cNOT_DEF
l7: $ G ⊩ ≃[𝔹] not · p = ((λ q: 𝔹. q ⇒ F) · p) $ by caeq1 [l6, #1]
l8: $ G ⊩ p ⇒ F ⇔ (p ⋏ F ⇔ p) $ by cIMPC_DEF [#1, l1]
l9: $ G ⊩ p ⇒ F: 𝔹 $ by ceqTR1 [l8]
l10: $ G , ≃[𝔹] q = p ⊩ ≃[𝔹] q = p $ by cax
l11: $ G , ≃[𝔹] q = p ⊩ F: 𝔹 $ by cweaken [l1]
l12: $ G , ≃[𝔹] q = p ⊩ q: 𝔹 $ by ceqTR1 [l10]
l13: $ G , ≃[𝔹] q = p ⊩ p: 𝔹 $ by ceqTR2 [l10]
l14: $ G , ≃[𝔹] q = p ⊩ and: 𝔹 → 𝔹 → 𝔹 $ by candT
l15: $ G , ≃[𝔹] q = p ⊩ q ⋏ F ⇔ p ⋏ F $ by cbineq1 [l14, l10, l11]
l16: $ G , ≃[𝔹] q = p ⊩ eq 𝔹: 𝔹 → 𝔹 → 𝔹 $ by ceqT
l17: $ G , ≃[𝔹] q = p ⊩ (q ⋏ F ⇔ q) ⇔ (p ⋏ F ⇔ p) $ by cbineq [l16, l15, l10]
l18: $ G , ≃[𝔹] q = p ⊩ q ⇒ F ⇔ (q ⋏ F ⇔ q) $ by cIMPC_DEF [l12, l11]
l19: $ G , ≃[𝔹] q = p ⊩ p ⇒ F ⇔ (p ⋏ F ⇔ p) $ by cIMPC_DEF [l13, l11]
l20: $ G , ≃[𝔹] q = p ⊩ (p ⋏ F ⇔ p) ⇔ p ⇒ F $ by csym [l19]
l21: $ G , ≃[𝔹] q = p ⊩ q ⇒ F ⇔ (p ⋏ F ⇔ p) $ by ctrans [l18, l17]
l22: $ G , ≃[𝔹] q = p ⊩ q ⇒ F ⇔ p ⇒ F $ by ctrans [l21, l20]
l23: $ G ⊩ ≃[𝔹] ((λ q: 𝔹. q ⇒ F) · p) = (p ⇒ F) $ by cbetacv [l5, #1, l9, l22]
l24: $ G ⊩ ¬ p ⇔ (p ⇒ F) $ by ctrans [l7, l23]

cNOT_ELIM
---------
l1: $ G ⊩ p: 𝔹 $ by cnotR [#1]
l2: $ G ⊩ ¬ p ⇔ (p ⇒ F) $ by cnotc_def [l1]
l3: $ G ⊩ p ⇒ F $ by ceqmp [l2, #1]

cNOT_INTRO
----------
l1: $ G ⊩ ¬ p ⇔ (p ⇒ F) $ by cnotc_def [#1]
l2: $ G ⊩ ¬ p $ by ceqmpr [l1, #2]

cNOT_FALSE
----------
l1: $ G ⊩ F: 𝔹 $ by cFT
l2: $ G , F ⊩ F $ by cax
l3: $ G ⊩ F ⇒ F $ by cDISCH [l1, l1, l2]
l4: $ G ⊩ ¬ F $ by cNOT_INTRO [l1, l3]

cIMP_ANTISYM
------------
l1: $ G , p ⊩ p ⇒ q $ by cweaken [#1]
l2: $ G , p ⊩ p $ by cax
l3: $ G , p ⊩ q $ by cMP [l1, l2]
l4: $ G , q ⊩ q ⇒ p $ by cweaken [#2]
l5: $ G , q ⊩ q $ by cax
l6: $ G , q ⊩ p $ by cMP [l4, l5]
l7: $ G ⊩ p ⇔ q $ by cded [l3, l6]

cEQ_IMP1
--------
l1: $ G ⊩ p: 𝔹 $ by ceqTR1 [#1]
l2: $ G ⊩ q: 𝔹 $ by ceqTR2 [#1]
l3: $ G , p ⊩ p ⇔ q $ by cweaken [#1]
l4: $ G , p ⊩ p $ by cax
l5: $ G , p ⊩ q $ by ceqmp [l3, l4]
l6: $ G ⊩ p ⇒ q $ by cDISCH [l1, l2, l5]

cEQ_IMP2
--------
l1: $ G ⊩ q ⇔ p $ by csym [#1]
l2: $ G ⊩ q ⇒ p $ by cEQ_IMP1 [l1]

cIMP_ID
-------
l1: $ G , p ⊩ p $ by cax
l2: $ G ⊩ p ⇒ p $ by cDISCH [#1, #1, l1]

cIMP_TRANS
----------
l1: $ G ⊩ p ⇒ q: 𝔹 $ by cthmR [#1]
l2: $ G ⊩ ≃[𝔹 → 𝔹 → 𝔹] imp = (λ x: 𝔹. λ y: 𝔹. x ⋏ y ⇔ x) $ by cIMP_DEF
l3: $ G ⊩ imp: 𝔹 → 𝔹 → 𝔹 $ by ceqTR1 [l2]
l4: $ G ⊩ p: 𝔹 $ by cappTR21 [l1, l3]
l5: $ G ⊩ q ⇒ r: 𝔹 $ by cthmR [#2]
l6: $ G ⊩ r: 𝔹 $ by cappTR22 [l5, l3]
l7: $ G , p ⊩ p ⇒ q $ by cweaken [#1]
l8: $ G , p ⊩ p $ by cax
l9: $ G , p ⊩ q $ by cMP [l7, l8]
l10: $ G , p ⊩ q ⇒ r $ by cweaken [#2]
l11: $ G , p ⊩ r $ by cMP [l10, l9]
l12: $ G ⊩ p ⇒ r $ by cDISCH [l4, l6, l11]

cEQF_INTRO
----------
l1: $ G ⊩ p: 𝔹 $ by cnotR [#1]
l2: $ G ⊩ p ⇒ F $ by cNOT_ELIM [#1]
l3: $ G , F ⊩ p: 𝔹 $ by cweaken [l1]
l4: $ G , F ⊩ F $ by cax
l5: $ G , F ⊩ p $ by cCONTR [l3, l4]
l6: $ G ⊩ F: 𝔹 $ by cFT
l7: $ G ⊩ F ⇒ p $ by cDISCH [l6, l1, l5]
l8: $ G ⊩ p ⇔ F $ by cIMP_ANTISYM [l2, l7]

cEQF_ELIM
---------
l1: $ G ⊩ p ⇒ F $ by cEQ_IMP1 [#1]
l2: $ G ⊩ p: 𝔹 $ by ceqTR1 [#1]
l3: $ G ⊩ ¬ p $ by cNOT_INTRO [l2, l1]

notcT
-----
l1: $ G ⊢ not: 𝔹 → 𝔹 $ by notT 
l2: $ G ⊢ ¬ p: 𝔹 $ by appT [l1, #1]

notR
----
l1: $ G ⊢ ¬ p: 𝔹 $ by thmR [#1]
l2: $ G ⊢ not: 𝔹 → 𝔹 $ by notT 
l3: $ G ⊢ p: 𝔹 $ by appTR2 [l1, l2]

notc_def
--------
l1: $ G ⊢ F: 𝔹 $ by FT 
l2: $ G ∧ q: 𝔹 ⊢ F: 𝔹 $ by weaken_ctx [l1]
l3: $ G ∧ q: 𝔹 ⊢ q: 𝔹 $ by anr 
l4: $ G ∧ q: 𝔹 ⊢ q ⇒ F: 𝔹 $ by impcT [l3, l2]
l5: $ G ⊢ λ q: 𝔹. q ⇒ F: 𝔹 → 𝔹 $ by lamT [l4]
l6: $ G ⊢ ≃[𝔹 → 𝔹] not = (λ q: 𝔹. q ⇒ F) $ by NOT_DEF 
l7: $ G ⊢ ≃[𝔹] not · p = ((λ q: 𝔹. q ⇒ F) · p) $ by aeq1 [l6, #1]
l8: $ G ⊢ imp: 𝔹 → 𝔹 → 𝔹 $ by impT 
l9: $ G ⊢ imp · p: 𝔹 → 𝔹 $ by appT [l8, #1]
l10: $ G ⊢ imp · p · F: 𝔹 $ by appT [l9, l1]
l11: $ G ∧ ≃[𝔹] q = p ⊢ ≃[𝔹] q = p $ by anr 
l12: $ G ∧ ≃[𝔹] q = p ⊢ imp: 𝔹 → 𝔹 → 𝔹 $ by impT 
l13: $ G ∧ ≃[𝔹] q = p ⊢ ≃[𝔹 → 𝔹] imp · q = imp · p $ by aeq2 [l12, l11]
l14: $ G ∧ ≃[𝔹] q = p ⊢ F: 𝔹 $ by weaken_ctx [l1]
l15: $ G ∧ ≃[𝔹] q = p ⊢ ≃[𝔹] imp · q · F = imp · p · F $ by aeq1 [l13, l14]
l16: $ G ⊢ ≃[𝔹] ((λ q: 𝔹. q ⇒ F) · p) = imp · p · F $ by betacv [l4, #1, l10, l15]
l17: $ G ⊢ not · p ⇔ (imp · p · F) $ by trans [l7, l16]

NOT_ELIM
--------
l1: $ G ⊢ p: 𝔹 $ by notR [#1]
l2: $ G ⊢ ¬ p ⇔ (p ⇒ F) $ by notc_def [l1]
l3: $ G ⊢ p ⇒ F $ by eqmp [l2, #1]

NOT_INTRO
---------
l1: $ G ⊢ p: 𝔹 ∧ F: 𝔹 $ by impR [#1]
l2: $ p: 𝔹 ∧ F: 𝔹 ⊢ p: 𝔹 $ by anl 
l3: $ G ⊢ p: 𝔹 $ by syl [l1, l2]
l4: $ G ⊢ ¬ p ⇔ (p ⇒ F) $ by notc_def [l3]
l5: $ G ⊢ ¬ p $ by eqmpr [l4, #1]

EQF_INTRO
---------
l1: $ G ⊢ p ⇒ F $ by NOT_ELIM [#1]
l2: $ G ⊢ p: 𝔹 $ by notR [#1]
l3: $ G ⊢ F: 𝔹 $ by FT 
l4: $ G ∧ F ⊢ F $ by anr 
l5: $ G ∧ F ⊢ p: 𝔹 $ by weaken_ctx [l2]
l6: $ G ∧ F ⊢ p $ by CONTR [l5, l4]
l7: $ G ⊢ F ⇒ p $ by DISCH [l3, l2, l6]
l8: $ G ⊢ p ⇔ F $ by IMP_ANTISYM [l1, l7]

EQF_ELIM
--------
l1: $ G ⊢ p ⇒ F $ by EQ_IMP1 [#1]
l2: $ G ⊢ ¬ p $ by NOT_INTRO [l1]

NOT_FALSE
---------
l1: $ G ⊢ F: 𝔹 $ by FT 
l2: $ G ⊢ F ⇒ F $ by IMP_ID [l1]
l3: $ G ⊢ ¬ F $ by NOT_INTRO [l2]
