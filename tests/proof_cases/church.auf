eqcT
----
l1: $ G ⊢ eq A: A → A → 𝔹 $ by eqT 
l2: $ G ⊢ eq A · t: A → 𝔹 $ by appT [l1, #1]
l3: $ G ⊢ ≃[A] t = u: 𝔹 $ by appT [l2, #2]

aeq1
----
l1: $ G ⊢ ≃[A] a = a $ by reflt [#2]
l2: $ G ⊢ ≃[B] f · a = g · a $ by aeqt [#1, l1]

aeq2
----
l1: $ G ⊢ ≃[A → B] f = f $ by reflt [#1]
l2: $ G ⊢ ≃[B] f · a = f · b $ by aeqt [l1, #2]

bineq
-----
l1: $ G ⊢ ≃[B → C] f · a1 = f · a2 $ by aeq2 [#1, #2]
l2: $ G ⊢ ≃[C] f · a1 · b1 = f · a2 · b2 $ by aeqt [l1, #3]

bineq1
------
l1: $ G ⊢ ≃[B] b = b $ by reflt [#3]
l2: $ G ⊢ ≃[C] f · a1 · b = f · a2 · b $ by bineq [#1, #2, l1]

bineq2
------
l1: $ G ⊢ ≃[A] a = a $ by reflt [#2]
l2: $ G ⊢ ≃[C] f · a · b1 = f · a · b2 $ by bineq [#1, l1, #3]

sym
---
l1: $ G ⊢ ≃[A] b = a $ by symt [#1]

trans
-----
l1: $ G ⊢ ≃[A] a = c $ by transt [#1, #2]

eqmpr
-----
l1: $ G ⊢ P ⇔ Q $ by symt [#1]
l2: $ G ⊢ Q $ by eqmp [l1, #2]

weaken_ctx
----------
l1: $ G ∧ H ⊢ G $ by anl 
l2: $ G ∧ H ⊢ P $ by syl [l1, #1]

lamTR
-----
l1: $ G ∧ x: A ⊢ λ x: A. t: A → B $ by weaken_ctx [#1]
l2: $ G ∧ x: A ⊢ x: A $ by anr 
l3: $ G ∧ x: A ⊢ (λ x: A. t) · x: B $ by appT [l1, l2]
l4: $ G ∧ x: A ⊢ ≡[B] (λ x: A. t) · x = t $ by beta [l3]
l5: $ G ∧ x: A ⊢ t: B $ by eqTR2 [l4]

betacv
------
l1: $ G ⊢ λ x: A. u: A → B $ by lamT [#1]
l2: $ G ⊢ (λ x: A. u) · t: B $ by appT [l1, #2]
l3: $ G ⊢ ≃[B] (λ x: A. u) · t = v: 𝔹 $ by eqcT [l2, #3]
l4: $ G ∧ ≃[A] x = t ⊢ λ x: A. u: A → B $ by weaken_ctx [l1]
l5: $ G ∧ ≃[A] x = t ⊢ ≃[A] x = t $ by anr 
l6: $ G ∧ ≃[A] x = t ⊢ ≃[A] t = x $ by sym [l5]
l7: $ G ∧ ≃[A] x = t ⊢ ≃[B] (λ x: A. u) · t = (λ x: A. u) · x $ by aeq2 [l4, l6]
l8: $ G ∧ ≃[A] x = t ⊢ x: A $ by eqR1 [l5]
l9: $ G ∧ ≃[A] x = t ⊢ (λ x: A. u) · x: B $ by appT [l4, l8]
l10: $ G ∧ ≃[A] x = t ⊢ ≃[B] (λ x: A. u) · x = u $ by betat [l9]
l11: $ G ∧ ≃[A] x = t ⊢ ≃[B] (λ x: A. u) · x = v $ by trans [l10, #4]
l12: $ G ∧ ≃[A] x = t ⊢ ≃[B] (λ x: A. u) · t = v $ by trans [l7, l11]
l13: $ G ⊢ ≃[B] (λ x: A. u) · t = v $ by inst [l3, #2, l12]

cbv
---
l1: $ G ⊢ λ x: A. t: A → B $ by lamT [#1]
l2: $ G ⊢ ≃[A → B] (λ y: A. (λ x: A. t) · y) = (λ x: A. t) $ by etat [l1]
l3: $ G ⊢ ≃[A → B] (λ x: A. t) = (λ y: A. (λ x: A. t) · y) $ by sym [l2]
l4: $ G ∧ y: A ∧ x: A ⊢ G ∧ y: A $ by anl 
l5: $ G ∧ y: A ⊢ G $ by anl 
l6: $ G ∧ y: A ∧ x: A ⊢ G $ by syl [l4, l5]
l7: $ G ∧ y: A ∧ x: A ⊢ x: A $ by anr 
l8: $ G ∧ y: A ∧ x: A ⊢ G ∧ x: A $ by ian [l6, l7]
l9: $ G ∧ y: A ∧ x: A ⊢ t: B $ by syl [l8, #1]
l10: $ G ∧ y: A ⊢ y: A $ by anr 
l11: $ G ∧ y: A ∧ ≃[A] x = y ⊢ G ∧ y: A $ by anl 
l12: $ G ∧ y: A ∧ ≃[A] x = y ⊢ G $ by syl [l11, l5]
l13: $ G ∧ y: A ∧ ≃[A] x = y ⊢ ≃[A] x = y $ by anr 
l14: $ G ∧ y: A ∧ ≃[A] x = y ⊢ G ∧ ≃[A] x = y $ by ian [l12, l13]
l15: $ G ∧ y: A ∧ ≃[A] x = y ⊢ ≃[B] t = u $ by syl [l14, #3]
l16: $ G ∧ y: A ⊢ ≃[B] (λ x: A. t) · y = u $ by betacv [l9, l10, #2, l15]
l17: $ G ⊢ ≃[A → B] (λ y: A. (λ x: A. t) · y) = (λ y: A. u) $ by leqt [l16]
l18: $ G ⊢ ≃[A → B] (λ x: A. t) = (λ y: A. u) $ by trans [l3, l17]

id_bool_has_type
----------------
l1: $ G ∧ x: 𝔹 ⊢ x: 𝔹 $ by anr 
l2: $ G ⊢ λ x: 𝔹. x: 𝔹 → 𝔹 $ by lamT [l1]

id_bool_refl
------------
l1: $ G ⊢ λ x: 𝔹. x: 𝔹 → 𝔹 $ by id_bool_has_type 
l2: $ G ⊢ ≡[𝔹 → 𝔹] (λ x: 𝔹. x) = (λ x: 𝔹. x) $ by refl [l1]

id_bool_beta
------------
l1: $ G ⊢ λ x: 𝔹. x: 𝔹 → 𝔹 $ by id_bool_has_type 
l2: $ G ⊢ (λ x: 𝔹. x) · x: 𝔹 $ by appT [l1, #1]
l3: $ G ⊢ ≡[𝔹] ((λ x: 𝔹. x) · x) = x $ by beta [l2]

eq_subst_id
-------------
l1: $ G ⊢ x: 𝔹 $ by eqTR1 [#1]
l2: $ G ⊢ ≡[𝔹] ((λ x: 𝔹. x) · x) = x $ by id_bool_beta [l1]
l3: $ G ⊢ ≡[𝔹] ((λ x: 𝔹. x) · x) = y $ by eqtrans [l2, #1]

id_bool_eta
-----------
l1: $ G ⊢ λ y: 𝔹. y: 𝔹 → 𝔹 $ by id_bool_has_type 
l2: $ G ⊢ ≡[𝔹 → 𝔹] (λ x: 𝔹. (λ y: 𝔹. y) · x) = (λ y: 𝔹. y) $ by eta [l1]

T_DEF
-----
l1: $ G ⊢ λ x: 𝔹. x: 𝔹 → 𝔹 $ by id_bool_has_type 
l2: $ G ⊢ ≃[𝔹 → 𝔹] (λ x: 𝔹. x) = (λ x: 𝔹. x): 𝔹 $ by eqcT [l1, l1]
l3: $ G ⊢ ≃[𝔹] (≃[𝔹 → 𝔹] (λ x: 𝔹. x) = (λ x: 𝔹. x)) = (≃[𝔹 → 𝔹] (λ x: 𝔹. x) = (λ x: 𝔹. x)) $ by reflt [l2]

TT
--
l1: $ G ⊢ ≃[𝔹] T = =[𝔹 → 𝔹] (λ x: 𝔹. x) = (λ x: 𝔹. x) $ by T_DEF 
l2: $ G ⊢ T: 𝔹 $ by eqR1 [l1]

TRUTH
-----
l1: $ G ⊢ ≃[𝔹] T = =[𝔹 → 𝔹] (λ x: 𝔹. x) = (λ x: 𝔹. x) $ by T_DEF 
l2: $ G ⊢ λ x: 𝔹. x: 𝔹 → 𝔹 $ by id_bool_has_type 
l3: $ G ⊢ ≃[𝔹 → 𝔹] (λ x: 𝔹. x) = (λ x: 𝔹. x) $ by reflt [l2]
l4: $ G ⊢ T $ by eqmpr [l1, l3]

EQT_ELIM
--------
l1: $ G ⊢ T ⇔ P $ by symt [#1]
l2: $ G ⊢ T $ by TRUTH 
l3: $ G ⊢ P $ by eqmp [l1, l2]

EQT_INTRO
---------
l1: $ G ∧ P ⊢ T $ by TRUTH 
l2: $ G ∧ T ⊢ P $ by weaken_ctx [#1]
l3: $ G ⊢ P ⇔ T $ by ded [l1, l2]

AND_DEF
-------
l1: $ G ∧ x: 𝔹 ∧ y: 𝔹 ∧ f: 𝔹 → 𝔹 → 𝔹 ⊢ f: 𝔹 → 𝔹 → 𝔹 $ by anr 
l2: $ G ∧ x: 𝔹 ∧ y: 𝔹 ∧ f: 𝔹 → 𝔹 → 𝔹 ⊢ G ∧ x: 𝔹 ∧ y: 𝔹 $ by anl 
l3: $ G ∧ x: 𝔹 ∧ y: 𝔹 ⊢ G ∧ x: 𝔹 $ by anl 
l4: $ G ∧ x: 𝔹 ∧ y: 𝔹 ∧ f: 𝔹 → 𝔹 → 𝔹 ⊢ G ∧ x: 𝔹 $ by syl [l2, l3]
l5: $ G ∧ x: 𝔹 ⊢ x: 𝔹 $ by anr 
l6: $ G ∧ x: 𝔹 ∧ y: 𝔹 ∧ f: 𝔹 → 𝔹 → 𝔹 ⊢ x: 𝔹 $ by syl [l4, l5]
l7: $ G ∧ x: 𝔹 ∧ y: 𝔹 ⊢ y: 𝔹 $ by anr 
l8: $ G ∧ x: 𝔹 ∧ y: 𝔹 ∧ f: 𝔹 → 𝔹 → 𝔹 ⊢ y: 𝔹 $ by syl [l2, l7]
l9: $ G ∧ x: 𝔹 ∧ y: 𝔹 ∧ f: 𝔹 → 𝔹 → 𝔹 ⊢ f · x: 𝔹 → 𝔹 $ by appT [l1, l6]
l10: $ G ∧ x: 𝔹 ∧ y: 𝔹 ∧ f: 𝔹 → 𝔹 → 𝔹 ⊢ f · x · y: 𝔹 $ by appT [l9, l8]
l11: $ G ∧ x: 𝔹 ∧ y: 𝔹 ⊢ λ f: 𝔹 → 𝔹 → 𝔹. f · x · y: (𝔹 → 𝔹 → 𝔹) → 𝔹 $ by lamT [l10]
l12: $ G ⊢ T: 𝔹 $ by TT 
l13: $ G ∧ x: 𝔹 ⊢ T: 𝔹 $ by weaken_ctx [l12]
l14: $ G ∧ x: 𝔹 ∧ y: 𝔹 ⊢ T: 𝔹 $ by weaken_ctx [l13]
l15: $ G ∧ x: 𝔹 ∧ y: 𝔹 ∧ f: 𝔹 → 𝔹 → 𝔹 ⊢ T: 𝔹 $ by weaken_ctx [l14]
l16: $ G ∧ x: 𝔹 ∧ y: 𝔹 ∧ f: 𝔹 → 𝔹 → 𝔹 ⊢ f · T: 𝔹 → 𝔹 $ by appT [l1, l15]
l17: $ G ∧ x: 𝔹 ∧ y: 𝔹 ∧ f: 𝔹 → 𝔹 → 𝔹 ⊢ f · T · T: 𝔹 $ by appT [l16, l15]
l18: $ G ∧ x: 𝔹 ∧ y: 𝔹 ⊢ λ f: 𝔹 → 𝔹 → 𝔹. f · T · T: (𝔹 → 𝔹 → 𝔹) → 𝔹 $ by lamT [l17]
l19: $ G ∧ x: 𝔹 ∧ y: 𝔹 ⊢ ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹] (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) = (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T): 𝔹 $ by eqcT [l11, l18]
l20: $ G ∧ x: 𝔹 ⊢ λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹] (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) = (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T): 𝔹 → 𝔹 $ by lamT [l19]
l21: $ G ⊢ λ x: 𝔹. λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹] (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) = (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T): 𝔹 → 𝔹 → 𝔹 $ by lamT [l20]
l22: $ G ⊢ ≃[𝔹 → 𝔹 → 𝔹] (λ x: 𝔹. λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹] (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) = (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T)) = ((λ x: 𝔹. λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹] (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) = (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T))) $ by reflt [l21]

andT
----
l1: $ G ⊢ ≃[𝔹 → 𝔹 → 𝔹] and = (λ x: 𝔹. λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹] (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) = (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T)) $ by AND_DEF 
l2: $ G ⊢ and: 𝔹 → 𝔹 → 𝔹 $ by eqR1 [l1]

andcT
-----
l1: $ G ⊢ and: 𝔹 → 𝔹 → 𝔹 $ by andT 
l2: $ G ⊢ and · p: 𝔹 → 𝔹 $ by appT [l1, #1]
l3: $ G ⊢ p ⋏ q: 𝔹 $ by appT [l2, #2]

IMP_DEF
-------
l1: $ G ∧ p: 𝔹 ∧ q: 𝔹 ⊢ G ∧ p: 𝔹 $ by anl 
l2: $ G ∧ p: 𝔹 ⊢ p: 𝔹 $ by anr 
l3: $ G ∧ p: 𝔹 ∧ q: 𝔹 ⊢ p: 𝔹 $ by syl [l1, l2]
l4: $ G ∧ p: 𝔹 ∧ q: 𝔹 ⊢ q: 𝔹 $ by anr 
l5: $ G ∧ p: 𝔹 ∧ q: 𝔹 ⊢ p ⋏ q: 𝔹 $ by andcT [l3, l4]
l6: $ G ∧ p: 𝔹 ∧ q: 𝔹 ⊢ p ⋏ q ⇔ p: 𝔹 $ by eqcT [l5, l3]
l7: $ G ∧ p: 𝔹 ⊢ λ q: 𝔹. p ⋏ q ⇔ p: 𝔹 → 𝔹 $ by lamT [l6]
l8: $ G ⊢ λ p: 𝔹. λ q: 𝔹. p ⋏ q ⇔ p: 𝔹 → 𝔹 → 𝔹 $ by lamT [l7]
l9: $ G ⊢ ≃[𝔹 → 𝔹 → 𝔹] (λ p: 𝔹. λ q: 𝔹. p ⋏ q ⇔ p) = ((λ p: 𝔹. λ q: 𝔹. p ⋏ q ⇔ p)) $ by reflt [l8]

impT
----
l1: $ G ⊢ ≃[𝔹 → 𝔹 → 𝔹] (λ p: 𝔹. λ q: 𝔹. p ⋏ q ⇔ p) =
      ((λ p: 𝔹. λ q: 𝔹. p ⋏ q ⇔ p)) $ by IMP_DEF 
l2: $ G ⊢ λ p: 𝔹. λ q: 𝔹. p ⋏ q ⇔ p: 𝔹 → 𝔹 → 𝔹 $ by eqR1 [l1]

impcT
-----
l1: $ G ⊢ imp: 𝔹 → 𝔹 → 𝔹 $ by impT 
l2: $ G ⊢ imp · p: 𝔹 → 𝔹 $ by appT [l1, #1]
l3: $ G ⊢ p ⇒ q: 𝔹 $ by appT [l2, #2]

impR
----
l1: $ G ⊢ p ⇒ q: 𝔹 $ by thmR [#1]
l2: $ G ⊢ imp: 𝔹 → 𝔹 → 𝔹 $ by impT 
l3: $ G ⊢ p: 𝔹 ∧ q: 𝔹 $ by appTR22 [l1, l2]

IMPC_DEF
--------
l1: $ G ⊢ ≃[𝔹 → 𝔹 → 𝔹] imp = (λ p: 𝔹. λ q: 𝔹. p ⋏ q ⇔ p) $ by IMP_DEF 
l2: $ G ⊢ ≃[𝔹 → 𝔹] imp · a = ((λ p: 𝔹. λ q: 𝔹. p ⋏ q ⇔ p) · a) $ by aeq1 [l1, #1]
l3: $ G ∧ p: 𝔹 ∧ q: 𝔹 ⊢ G ∧ p: 𝔹 $ by anl 
l4: $ G ∧ p: 𝔹 ⊢ p: 𝔹 $ by anr 
l5: $ G ∧ p: 𝔹 ∧ q: 𝔹 ⊢ p: 𝔹 $ by syl [l3, l4]
l6: $ G ∧ p: 𝔹 ∧ q: 𝔹 ⊢ q: 𝔹 $ by anr 
l7: $ G ∧ p: 𝔹 ∧ q: 𝔹 ⊢ p ⋏ q: 𝔹 $ by andcT [l5, l6]
l8: $ G ∧ p: 𝔹 ∧ q: 𝔹 ⊢ p ⋏ q ⇔ p: 𝔹 $ by eqcT [l7, l5]
l9: $ G ∧ p: 𝔹 ⊢ λ q: 𝔹. p ⋏ q ⇔ p: 𝔹 → 𝔹 $ by lamT [l8]
l10: $ G ∧ q: 𝔹 ⊢ a: 𝔹 $ by weaken_ctx [#1]
l11: $ G ∧ q: 𝔹 ⊢ q: 𝔹 $ by anr 
l12: $ G ∧ q: 𝔹 ⊢ a ⋏ q: 𝔹 $ by andcT [l10, l11]
l13: $ G ∧ q: 𝔹 ⊢ a ⋏ q ⇔ a: 𝔹 $ by eqcT [l12, l10]
l14: $ G ⊢ λ q: 𝔹. a ⋏ q ⇔ a: 𝔹 → 𝔹 $ by lamT [l13]
l15: $ G ∧ ≃[𝔹] p = a ∧ q: 𝔹 ⊢ G ∧ ≃[𝔹] p = a $ by anl 
l16: $ G ∧ ≃[𝔹] p = a ⊢ ≃[𝔹] p = a $ by anr 
l17: $ G ∧ ≃[𝔹] p = a ∧ q: 𝔹 ⊢ ≃[𝔹] p = a $ by syl [l15, l16]
l18: $ G ∧ ≃[𝔹] p = a ∧ q: 𝔹 ⊢ q: 𝔹 $ by anr 
l19: $ G ∧ ≃[𝔹] p = a ∧ q: 𝔹 ⊢ and: 𝔹 → 𝔹 → 𝔹 $ by andT 
l20: $ G ∧ ≃[𝔹] p = a ∧ q: 𝔹 ⊢ ≃[𝔹] (p ⋏ q) = (a ⋏ q) $ by bineq1 [l19, l17, l18]
l21: $ G ∧ ≃[𝔹] p = a ∧ q: 𝔹 ⊢ eq 𝔹: 𝔹 → 𝔹 → 𝔹 $ by eqT 
l22: $ G ∧ ≃[𝔹] p = a ∧ q: 𝔹 ⊢ ≃[𝔹] (p ⋏ q ⇔ p) = (a ⋏ q ⇔ a) $ by bineq [l21, l20, l17]
l23: $ G ∧ ≃[𝔹] p = a ⊢ ≃[𝔹 → 𝔹] (λ q: 𝔹. p ⋏ q ⇔ p) = (λ q: 𝔹. a ⋏ q ⇔ a) $ by leqt [l22]
l24: $ G ⊢ ≃[𝔹 → 𝔹] ((λ p: 𝔹. λ q: 𝔹. p ⋏ q ⇔ p) · a) = (λ q: 𝔹. a ⋏ q ⇔ a) $ by betacv [l9, #1, l14, l23]
l25: $ G ⊢ ≃[𝔹 → 𝔹] imp · a = (λ q: 𝔹. a ⋏ q ⇔ a) $ by trans [l2, l24]
l26: $ G ⊢ a ⋏ b: 𝔹 $ by andcT [#1, #2]
l27: $ G ⊢ a ⋏ b ⇔ a: 𝔹 $ by eqcT [l26, #1]
l28: $ G ∧ ≃[𝔹] q = b ⊢ ≃[𝔹] q = b $ by anr 
l29: $ G ∧ ≃[𝔹] q = b ⊢ and: 𝔹 → 𝔹 → 𝔹 $ by andT 
l30: $ G ∧ ≃[𝔹] q = b ⊢ a: 𝔹 $ by weaken_ctx [#1]
l31: $ G ∧ ≃[𝔹] q = b ⊢ ≃[𝔹] (a ⋏ q) = (a ⋏ b) $ by bineq2 [l29, l30, l28]
l32: $ G ∧ ≃[𝔹] q = b ⊢ eq 𝔹: 𝔹 → 𝔹 → 𝔹 $ by eqT 
l33: $ G ∧ ≃[𝔹] q = b ⊢ ≃[𝔹] a = a $ by reflt [l30]
l34: $ G ∧ ≃[𝔹] q = b ⊢ ≃[𝔹] (a ⋏ q ⇔ a) = (a ⋏ b ⇔ a) $ by bineq [l32, l31, l33]
l35: $ G ⊢ ≃[𝔹] ((λ q: 𝔹. a ⋏ q ⇔ a) · b) = (a ⋏ b ⇔ a) $ by betacv [l13, #2, l27, l34]
l36: $ G ⊢ ≃[𝔹] imp · a · b = ((λ q: 𝔹. a ⋏ q ⇔ a) · b) $ by aeq1 [l25, #2]
l37: $ G ⊢ imp · a · b ⇔ (a ⋏ b ⇔ a) $ by trans [l36, l35]

MP
--
l1: $ G ⊢ p: 𝔹 ∧ q: 𝔹 $ by impR [#1]
l2: $ p: 𝔹 ∧ q: 𝔹 ⊢ q: 𝔹 $ by anr 
l3: $ G ⊢ q: 𝔹 $ by syl [l1, l2]
l4: $ G ⊢ p: 𝔹 $ by thmR [#2]
l5: $ G ⊢ p ⇒ q ⇔ (p ⋏ q ⇔ p) $ by IMPC_DEF [l4, l3]
l6: $ G ⊢ p ⋏ q ⇔ p $ by eqmp [l5, #1]
l7: $ G ⊢ p ⋏ q $ by eqmpr [l6, #2]
l8: $ G ⊢ q $ by CONJUNCT2 [l7]

DISCH
-----
l1: $ G ∧ p ⋏ q ⊢ p ⋏ q $ by anr 
l2: $ G ∧ p ⋏ q ⊢ p $ by CONJUNCT1 [l1]
l3: $ G ∧ p ⊢ p $ by anr 
l4: $ G ∧ p ⊢ G ∧ p $ by id 
l5: $ G ∧ p ⊢ q $ by syl [l4, #3]
l6: $ G ∧ p ⊢ p ⋏ q $ by CONJ [l3, l5]
l7: $ G ⊢ p ⋏ q ⇔ p $ by ded [l2, l6]
l8: $ G ⊢ p ⇒ q ⇔ (p ⋏ q ⇔ p) $ by IMPC_DEF [#1, #2]
l9: $ G ⊢ p ⇒ q $ by eqmpr [l8, l7]

UNDISCH
--------
l1: $ G ⊢ p: 𝔹 ∧ q: 𝔹 $ by impR [#1]
l2: $ p: 𝔹 ∧ q: 𝔹 ⊢ p: 𝔹 $ by anl 
l3: $ G ⊢ p: 𝔹 $ by syl [l1, l2]
l4: $ G ∧ p ⊢ p ⇒ q $ by weaken_ctx [#1]
l5: $ G ∧ p ⊢ p $ by anr 
l6: $ G ∧ p ⊢ q $ by MP [l4, l5]

IMP_ANTISYM
-----------
l1: $ G ∧ p ⊢ q $ by UNDISCH [#1]
l2: $ G ∧ q ⊢ p $ by UNDISCH [#2]
l3: $ G ⊢ p ⇔ q $ by ded [l1, l2]

EQ_IMP1
-------
l1: $ G ⊢ p: 𝔹 $ by eqR1 [#1]
l2: $ G ⊢ q: 𝔹 $ by eqR2 [#1]
l3: $ G ∧ p ⊢ p ⇔ q $ by weaken_ctx [#1]
l4: $ G ∧ p ⊢ p $ by anr 
l5: $ G ∧ p ⊢ q $ by eqmp [l3, l4]
l6: $ G ⊢ p ⇒ q $ by DISCH [l1, l2, l5]

EQ_IMP2
-------
l1: $ G ⊢ q ⇔ p $ by sym [#1]
l2: $ G ⊢ q ⇒ p $ by EQ_IMP1 [l1]

IMP_ID
------
l1: $ G ∧ p ⊢ p $ by anr 
l2: $ G ⊢ p ⇒ p $ by DISCH [#1, #1, l1]

IMP_TRANS
---------
l1: $ G ⊢ p: 𝔹 ∧ q: 𝔹 $ by impR [#1]
l2: $ p: 𝔹 ∧ q: 𝔹 ⊢ p: 𝔹 $ by anl 
l3: $ G ⊢ p: 𝔹 $ by syl [l1, l2]
l4: $ G ⊢ q: 𝔹 ∧ r: 𝔹 $ by impR [#2]
l5: $ q: 𝔹 ∧ r: 𝔹 ⊢ r: 𝔹 $ by anr 
l6: $ G ⊢ r: 𝔹 $ by syl [l4, l5]
l7: $ G ∧ p ⊢ q $ by UNDISCH [#1]
l8: $ G ∧ p ⊢ q ⇒ r $ by weaken_ctx [#2]
l9: $ G ∧ p ⊢ r $ by MP [l8, l7]
l10: $ G ⊢ p ⇒ r $ by DISCH [l3, l6, l9]

CONJ_COMM
---------
l1: $ G ⊢ p ⋏ q: 𝔹 $ by andcT [#1, #2]
l2: $ G ⊢ q ⋏ p: 𝔹 $ by andcT [#2, #1]
l3: $ G ∧ p ⋏ q ⊢ p ⋏ q $ by anr 
l4: $ G ∧ p ⋏ q ⊢ q $ by CONJUNCT2 [l3]
l5: $ G ∧ p ⋏ q ⊢ p $ by CONJUNCT1 [l3]
l6: $ G ∧ p ⋏ q ⊢ q ⋏ p $ by CONJ [l4, l5]
l7: $ G ⊢ p ⋏ q ⇒ q ⋏ p $ by DISCH [l1, l2, l6]

CONJ_ASSOC
----------
l1: $ G ⊢ p ⋏ q: 𝔹 $ by andcT [#1, #2]
l2: $ G ⊢ (p ⋏ q) ⋏ r: 𝔹 $ by andcT [l1, #3]
l3: $ G ⊢ q ⋏ r: 𝔹 $ by andcT [#2, #3]
l4: $ G ⊢ p ⋏ (q ⋏ r): 𝔹 $ by andcT [#1, l3]
l5: $ G ∧ (p ⋏ q) ⋏ r ⊢ (p ⋏ q) ⋏ r $ by anr 
l6: $ G ∧ (p ⋏ q) ⋏ r ⊢ p ⋏ q $ by CONJUNCT1 [l5]
l7: $ G ∧ (p ⋏ q) ⋏ r ⊢ p $ by CONJUNCT1 [l6]
l8: $ G ∧ (p ⋏ q) ⋏ r ⊢ q $ by CONJUNCT2 [l6]
l9: $ G ∧ (p ⋏ q) ⋏ r ⊢ r $ by CONJUNCT2 [l5]
l10: $ G ∧ (p ⋏ q) ⋏ r ⊢ q ⋏ r $ by CONJ [l8, l9]
l11: $ G ∧ (p ⋏ q) ⋏ r ⊢ p ⋏ (q ⋏ r) $ by CONJ [l7, l10]
l12: $ G ⊢ (p ⋏ q) ⋏ r ⇒ p ⋏ (q ⋏ r) $ by DISCH [l2, l4, l11]

IMP_CONJ_CHAIN
--------------
l1: $ G ⊢ p: 𝔹 ∧ q: 𝔹 $ by impR [#1]
l2: $ p: 𝔹 ∧ q: 𝔹 ⊢ p: 𝔹 $ by anl 
l3: $ G ⊢ p: 𝔹 $ by syl [l1, l2]
l4: $ G ⊢ q: 𝔹 ∧ r: 𝔹 $ by impR [#2]
l5: $ q: 𝔹 ∧ r: 𝔹 ⊢ q: 𝔹 $ by anl 
l6: $ G ⊢ q: 𝔹 $ by syl [l4, l5]
l7: $ q: 𝔹 ∧ r: 𝔹 ⊢ r: 𝔹 $ by anr 
l8: $ G ⊢ r: 𝔹 $ by syl [l4, l7]
l9: $ G ⊢ q ⋏ r: 𝔹 $ by andcT [l6, l8]
l10: $ G ∧ p ⊢ q $ by UNDISCH [#1]
l11: $ G ∧ p ⊢ q ⇒ r $ by weaken_ctx [#2]
l12: $ G ∧ p ⊢ r $ by MP [l11, l10]
l13: $ G ∧ p ⊢ q ⋏ r $ by CONJ [l10, l12]
l14: $ G ⊢ p ⇒ q ⋏ r $ by DISCH [l3, l9, l13]

FORALL_DEF
----------
l1: $ G ∧ P: A → 𝔹 ⊢ P: A → 𝔹 $ by anr 
l2: $ G ⊢ T: 𝔹 $ by TT 
l3: $ G ∧ P: A → 𝔹 ⊢ T: 𝔹 $ by weaken_ctx [l2]
l4: $ G ∧ P: A → 𝔹 ∧ x: A ⊢ T: 𝔹 $ by weaken_ctx [l3]
l5: $ G ∧ P: A → 𝔹 ⊢ λ x: A. T: A → 𝔹 $ by lamT [l4]
l6: $ G ∧ P: A → 𝔹 ⊢ ≃[A → 𝔹] P = (λ x: A. T): 𝔹 $ by eqcT [l1, l5]
l7: $ G ⊢ λ P: A → 𝔹. ≃[A → 𝔹] P = (λ x: A. T): (A → 𝔹) → 𝔹 $ by lamT [l6]
l8: $ G ⊢ ≃[(A → 𝔹) → 𝔹] (λ P: A → 𝔹. ≃[A → 𝔹] P = (λ x: A. T)) = ((λ P: A → 𝔹. ≃[A → 𝔹] P = (λ x: A. T))) $ by reflt [l7]

allT
----
l1: $ G ⊢ ≃[(A → 𝔹) → 𝔹] all A = (λ p: A → 𝔹. ≃[A → 𝔹] p = (λ x: A. T)) $ by FORALL_DEF 
l2: $ G ⊢ all A: (A → 𝔹) → 𝔹 $ by eqR1 [l1]

allcT
-----
l1: $ G ⊢ all A: (A → 𝔹) → 𝔹 $ by allT 
l2: $ G ⊢ λ x: A. t: A → 𝔹 $ by lamT [#1]
l3: $ G ⊢ !x: A. t: 𝔹 $ by appT [l1, l2]

alleq
-----
l1: $ G ∧ x: A ⊢ t: 𝔹 $ by eqR1 [#1]
l2: $ G ∧ x: A ⊢ u: 𝔹 $ by eqR2 [#1]
l3: $ G ⊢ λ x: A. t: A → 𝔹 $ by lamT [l1]
l4: $ G ⊢ λ x: A. u: A → 𝔹 $ by lamT [l2]
l5: $ G ⊢ T: 𝔹 $ by TT 
l6: $ G ∧ x: A ⊢ T: 𝔹 $ by weaken_ctx [l5]
l7: $ G ⊢ λ x: A. T: A → 𝔹 $ by lamT [l6]
l8: $ G ⊢ ≃[A → 𝔹] (λ x: A. t) = (λ x: A. u) $ by leqt [#1]
l9: $ G ⊢ eq (A → 𝔹): (A → 𝔹) → (A → 𝔹) → 𝔹 $ by eqT 
l10: $ G ⊢ ≃[𝔹] (≃[A → 𝔹] (λ x: A. t) = (λ x: A. T)) = (≃[A → 𝔹] (λ x: A. u) = (λ x: A. T)) $ by bineq1 [l9, l8, l7]
l11: $ G ⊢ ≃[(A → 𝔹) → 𝔹] all A = (λ f: A → 𝔹. ≃[A → 𝔹] f = (λ x: A. T)) $ by FORALL_DEF 
l12: $ G ⊢ ≃[𝔹] all A · (λ x: A. t) = ((λ f: A → 𝔹. ≃[A → 𝔹] f = (λ x: A. T)) · (λ x: A. t)) $ by aeq1 [l11, l3]
l13: $ G ∧ f: A → 𝔹 ⊢ f: A → 𝔹 $ by anr 
l14: $ G ∧ f: A → 𝔹 ⊢ λ x: A. T: A → 𝔹 $ by weaken_ctx [l7]
l15: $ G ∧ f: A → 𝔹 ⊢ ≃[A → 𝔹] f = (λ x: A. T): 𝔹 $ by eqcT [l13, l14]
l16: $ G ⊢ ≃[A → 𝔹] (λ x: A. t) = (λ x: A. T): 𝔹 $ by eqcT [l3, l7]
l17: $ G ∧ ≃[A → 𝔹] f = (λ x: A. t) ⊢ ≃[A → 𝔹] f = (λ x: A. t) $ by anr 
l18: $ G ∧ ≃[A → 𝔹] f = (λ x: A. t) ⊢ eq (A → 𝔹): (A → 𝔹) → (A → 𝔹) → 𝔹 $ by eqT 
l19: $ G ∧ ≃[A → 𝔹] f = (λ x: A. t) ⊢ λ x: A. T: A → 𝔹 $ by weaken_ctx [l7]
l20: $ G ∧ ≃[A → 𝔹] f = (λ x: A. t) ⊢ ≃[𝔹] (≃[A → 𝔹] f = (λ x: A. T)) = (≃[A → 𝔹] (λ x: A. t) = (λ x: A. T)) $ by bineq1 [l18, l17, l19]
l21: $ G ⊢ ≃[𝔹] ((λ f: A → 𝔹. ≃[A → 𝔹] f = (λ x: A. T)) · (λ x: A. t)) = (≃[A → 𝔹] (λ x: A. t) = (λ x: A. T)) $ by betacv [l15, l3, l16, l20]
l22: $ G ⊢ ≃[𝔹] all A · (λ x: A. t) = (≃[A → 𝔹] (λ x: A. t) = (λ x: A. T)) $ by trans [l12, l21]
l23: $ G ⊢ ≃[𝔹] all A · (λ x: A. u) = ((λ f: A → 𝔹. ≃[A → 𝔹] f = (λ x: A. T)) · (λ x: A. u)) $ by aeq1 [l11, l4]
l24: $ G ⊢ ≃[A → 𝔹] (λ x: A. u) = (λ x: A. T): 𝔹 $ by eqcT [l4, l7]
l25: $ G ∧ ≃[A → 𝔹] f = (λ x: A. u) ⊢ ≃[A → 𝔹] f = (λ x: A. u) $ by anr 
l26: $ G ∧ ≃[A → 𝔹] f = (λ x: A. u) ⊢ eq (A → 𝔹): (A → 𝔹) → (A → 𝔹) → 𝔹 $ by eqT 
l27: $ G ∧ ≃[A → 𝔹] f = (λ x: A. u) ⊢ λ x: A. T: A → 𝔹 $ by weaken_ctx [l7]
l28: $ G ∧ ≃[A → 𝔹] f = (λ x: A. u) ⊢ ≃[𝔹] (≃[A → 𝔹] f = (λ x: A. T)) = (≃[A → 𝔹] (λ x: A. u) = (λ x: A. T)) $ by bineq1 [l26, l25, l27]
l29: $ G ⊢ ≃[𝔹] ((λ f: A → 𝔹. ≃[A → 𝔹] f = (λ x: A. T)) · (λ x: A. u)) = (≃[A → 𝔹] (λ x: A. u) = (λ x: A. T)) $ by betacv [l15, l4, l24, l28]
l30: $ G ⊢ ≃[𝔹] all A · (λ x: A. u) = (≃[A → 𝔹] (λ x: A. u) = (λ x: A. T)) $ by trans [l23, l29]
l31: $ G ⊢ ≃[𝔹] (≃[A → 𝔹] (λ x: A. u) = (λ x: A. T)) = (all A · (λ x: A. u)) $ by sym [l30]
l32: $ G ⊢ ≃[𝔹] all A · (λ x: A. t) = (≃[A → 𝔹] (λ x: A. u) = (λ x: A. T)) $ by trans [l22, l10]
l33: $ G ⊢ all A · (λ x: A. t) ⇔ (all A · (λ x: A. u)) $ by trans [l32, l31]

all_def
-------
l1: $ G ⊢ ≃[(A → 𝔹) → 𝔹] all A = (λ f: A → 𝔹. ≃[A → 𝔹] f = (λ x: A. T)) $ by FORALL_DEF 
l2: $ G ⊢ ≃[𝔹] all A · P = ((λ f: A → 𝔹. ≃[A → 𝔹] f = (λ x: A. T)) · P) $ by aeq1 [l1, #1]
l3: $ G ⊢ T: 𝔹 $ by TT 
l4: $ G ∧ x: A ⊢ T: 𝔹 $ by weaken_ctx [l3]
l5: $ G ⊢ λ x: A. T: A → 𝔹 $ by lamT [l4]
l6: $ G ∧ f: A → 𝔹 ⊢ f: A → 𝔹 $ by anr 
l7: $ G ∧ f: A → 𝔹 ⊢ λ x: A. T: A → 𝔹 $ by weaken_ctx [l5]
l8: $ G ∧ f: A → 𝔹 ⊢ ≃[A → 𝔹] f = (λ x: A. T): 𝔹 $ by eqcT [l6, l7]
l9: $ G ⊢ ≃[A → 𝔹] P = (λ x: A. T): 𝔹 $ by eqcT [#1, l5]
l10: $ G ∧ ≃[A → 𝔹] f = P ⊢ ≃[A → 𝔹] f = P $ by anr 
l11: $ G ∧ ≃[A → 𝔹] f = P ⊢ eq (A → 𝔹): (A → 𝔹) → (A → 𝔹) → 𝔹 $ by eqT 
l12: $ G ∧ ≃[A → 𝔹] f = P ⊢ λ x: A. T: A → 𝔹 $ by weaken_ctx [l5]
l13: $ G ∧ ≃[A → 𝔹] f = P ⊢ ≃[𝔹] (≃[A → 𝔹] f = (λ x: A. T)) = (≃[A → 𝔹] P = (λ x: A. T)) $ by bineq1 [l11, l10, l12]
l14: $ G ⊢ ≃[𝔹] ((λ f: A → 𝔹. ≃[A → 𝔹] f = (λ x: A. T)) · P) = (≃[A → 𝔹] P = (λ x: A. T)) $ by betacv [l8, #1, l9, l13]
l15: $ G ⊢ all A · P ⇔ (≃[A → 𝔹] P = (λ x: A. T)) $ by trans [l2, l14]

specp
-----
l1: $ G ⊢ all A · P: 𝔹 $ by thmR [#2]
l2: $ G ⊢ all A: (A → 𝔹) → 𝔹 $ by allT 
l3: $ G ⊢ P: A → 𝔹 $ by appTR2 [l1, l2]
l4: $ G ⊢ all A · P ⇔ (≃[A → 𝔹] P = (λ x: A. T)) $ by all_def [l3]
l5: $ G ⊢ ≃[A → 𝔹] P = (λ x: A. T) $ by eqmp [l4, #2]
l6: $ G ⊢ ≃[𝔹] P · t = ((λ x: A. T) · t) $ by aeq1 [l5, #1]
l7: $ G ⊢ T: 𝔹 $ by TT 
l8: $ G ∧ x: A ⊢ T: 𝔹 $ by weaken_ctx [l7]
l9: $ G ⊢ ≃[𝔹] T = T $ by reflt [l7]
l10: $ G ∧ ≃[A] x = t ⊢ ≃[𝔹] T = T $ by weaken_ctx [l9]
l11: $ G ⊢ ≃[𝔹] ((λ x: A. T) · t) = T $ by betacv [l8, #1, l7, l10]
l12: $ G ⊢ ≃[𝔹] P · t = T $ by trans [l6, l11]
l13: $ G ⊢ P · t $ by EQT_ELIM [l12]

spec
----
l1: $ G ⊢ !x: A. a: 𝔹 $ by allcT [#1]
l2: $ G ∧ !x: A. a ⊢ b: 𝔹 $ by weaken_ctx [#3]
l3: $ G ∧ !x: A. a ⊢ t: A $ by weaken_ctx [#2]
l4: $ G ∧ !x: A. a ⊢ !x: A. a $ by anr 
l5: $ G ∧ !x: A. a ⊢ (λ x: A. a) · t $ by specp [l3, l4]
l6: $ G ⊢ ≃[𝔹] (λ x: A. a) · t = b $ by betacv [#1, #2, #3, #4]
l7: $ G ∧ !x: A. a ⊢ ≃[𝔹] (λ x: A. a) · t = b $ by weaken_ctx [l6]
l8: $ G ∧ !x: A. a ⊢ b $ by eqmp [l7, l5]
l9: $ G ⊢ (!x: A. a) ⇒ b $ by DISCH [l1, #3, l8]

SPEC
----
l1: $ G ⊢ !x: A. a: 𝔹 $ by thmR [#4]
l2: $ G ⊢ all A: (A → 𝔹) → 𝔹 $ by allT 
l3: $ G ⊢ λ x: A. a: A → 𝔹 $ by appTR2 [l1, l2]
l4: $ G ∧ x: A ⊢ a: 𝔹 $ by lamTR [l3]
l5: $ G ⊢ (!x: A. a) ⇒ b $ by spec [l4, #1, #2, #3]
l6: $ G ⊢ b $ by MP [l5, #4]

GEN
---
l1: $ G ∧ x: A ⊢ a: 𝔹 $ by thmR [#1]
l2: $ G ⊢ λ x: A. a: A → 𝔹 $ by lamT [l1]
l3: $ G ⊢ T: 𝔹 $ by TT 
l4: $ G ∧ x: A ⊢ T: 𝔹 $ by weaken_ctx [l3]
l5: $ G ⊢ λ x: A. T: A → 𝔹 $ by lamT [l4]
l6: $ G ⊢ ≃[(A → 𝔹) → 𝔹] all A = (λ f: A → 𝔹. ≃[A → 𝔹] f = (λ x: A. T)) $ by FORALL_DEF 
l7: $ G ⊢ ≃[𝔹] all A · (λ x: A. a) = ((λ f: A → 𝔹. ≃[A → 𝔹] f = (λ x: A. T)) · (λ x: A. a)) $ by aeq1 [l6, l2]
l8: $ G ∧ f: A → 𝔹 ⊢ f: A → 𝔹 $ by anr 
l9: $ G ∧ f: A → 𝔹 ⊢ λ x: A. T: A → 𝔹 $ by weaken_ctx [l5]
l10: $ G ∧ f: A → 𝔹 ⊢ ≃[A → 𝔹] f = (λ x: A. T): 𝔹 $ by eqcT [l8, l9]
l11: $ G ∧ x: A ⊢ a ⇔ T $ by EQT_INTRO [#1]
l12: $ G ⊢ ≃[A → 𝔹] (λ x: A. a) = (λ x: A. T) $ by leqt [l11]
l13: $ G ∧ ≃[A → 𝔹] f = (λ x: A. a) ⊢ ≃[A → 𝔹] f = (λ x: A. a) $ by anr 
l14: $ G ∧ ≃[A → 𝔹] f = (λ x: A. a) ⊢ eq (A → 𝔹): (A → 𝔹) → (A → 𝔹) → 𝔹 $ by eqT 
l15: $ G ∧ ≃[A → 𝔹] f = (λ x: A. a) ⊢ λ x: A. T: A → 𝔹 $ by weaken_ctx [l5]
l16: $ G ∧ ≃[A → 𝔹] f = (λ x: A. a) ⊢ ≃[𝔹] (≃[A → 𝔹] f = (λ x: A. T)) = (≃[A → 𝔹] (λ x: A. a) = (λ x: A. T)) $ by bineq1 [l14, l13, l15]
l17: $ G ⊢ ≃[A → 𝔹] (λ x: A. a) = (λ x: A. T): 𝔹 $ by thmR [l12]
l18: $ G ⊢ ≃[𝔹] ((λ f: A → 𝔹. ≃[A → 𝔹] f = (λ x: A. T)) · (λ x: A. a)) = (≃[A → 𝔹] (λ x: A. a) = (λ x: A. T)) $ by betacv [l10, l2, l17, l16]
l19: $ G ⊢ all A · (λ x: A. a) ⇔ (≃[A → 𝔹] (λ x: A. a) = (λ x: A. T)) $ by trans [l7, l18]
l20: $ G ⊢ !x: A. a $ by eqmpr [l19, l12]

EXISTS_DEF
----------
l1: $ G ∧ P: A → 𝔹 ∧ q: 𝔹 ∧ x: A ⊢ G ∧ P: A → 𝔹 ∧ q: 𝔹 $ by anl 
l2: $ G ∧ P: A → 𝔹 ∧ q: 𝔹 ⊢ G ∧ P: A → 𝔹 $ by anl 
l3: $ G ∧ P: A → 𝔹 ∧ q: 𝔹 ∧ x: A ⊢ G ∧ P: A → 𝔹 $ by syl [l1, l2]
l4: $ G ∧ P: A → 𝔹 ⊢ P: A → 𝔹 $ by anr 
l5: $ G ∧ P: A → 𝔹 ∧ q: 𝔹 ∧ x: A ⊢ P: A → 𝔹 $ by syl [l3, l4]
l6: $ G ∧ P: A → 𝔹 ∧ q: 𝔹 ∧ x: A ⊢ x: A $ by anr 
l7: $ G ∧ P: A → 𝔹 ∧ q: 𝔹 ∧ x: A ⊢ P · x: 𝔹 $ by appT [l5, l6]
l8: $ G ∧ P: A → 𝔹 ∧ q: 𝔹 ⊢ q: 𝔹 $ by anr 
l9: $ G ∧ P: A → 𝔹 ∧ q: 𝔹 ∧ x: A ⊢ q: 𝔹 $ by syl [l1, l8]
l10: $ G ∧ P: A → 𝔹 ∧ q: 𝔹 ∧ x: A ⊢ P · x ⇒ q: 𝔹 $ by impcT [l7, l9]
l11: $ G ∧ P: A → 𝔹 ∧ q: 𝔹 ⊢ !x: A. P · x ⇒ q: 𝔹 $ by allcT [l10]
l12: $ G ∧ P: A → 𝔹 ∧ q: 𝔹 ⊢ (!x: A. P · x ⇒ q) ⇒ q: 𝔹 $ by impcT [l11, l8]
l13: $ G ∧ P: A → 𝔹 ⊢ !q: 𝔹. (!x: A. P · x ⇒ q) ⇒ q: 𝔹 $ by allcT [l12]
l14: $ G ⊢ λ P: A → 𝔹. !q: 𝔹. (!x: A. P · x ⇒ q) ⇒ q: (A → 𝔹) → 𝔹 $ by lamT [l13]
l15: $ G ⊢ ≃[(A → 𝔹) → 𝔹] (λ P: A → 𝔹. !q: 𝔹. (!x: A. P · x ⇒ q) ⇒ q) = ((λ P: A → 𝔹. !q: 𝔹. (!x: A. P · x ⇒ q) ⇒ q)) $ by reflt [l14]

exT
---
l1: $ G ⊢ ≃[(A → 𝔹) → 𝔹] ex A = (λ f: A → 𝔹. !q: 𝔹. (!x: A. f · x ⇒ q) ⇒ q) $ by EXISTS_DEF 
l2: $ G ⊢ ex A: (A → 𝔹) → 𝔹 $ by eqR1 [l1]

ex_def
------
l1: $ G ⊢ ≃[(A → 𝔹) → 𝔹] ex A = (λ f: A → 𝔹. !q: 𝔹. (!x: A. f · x ⇒ q) ⇒ q) $ by EXISTS_DEF 
l2: $ G ⊢ ≃[𝔹] ex A · P = ((λ f: A → 𝔹. !q: 𝔹. (!x: A. f · x ⇒ q) ⇒ q) · P) $ by aeq1 [l1, #1]
l3: $ G ⊢ λ f: A → 𝔹. !q: 𝔹. (!x: A. f · x ⇒ q) ⇒ q: (A → 𝔹) → 𝔹 $ by eqR2 [l1]
l4: $ G ∧ f: A → 𝔹 ⊢ !q: 𝔹. (!x: A. f · x ⇒ q) ⇒ q: 𝔹 $ by lamTR [l3]
l5: $ G ∧ q: 𝔹 ⊢ P: A → 𝔹 $ by weaken_ctx [#1]
l6: $ G ∧ q: 𝔹 ∧ x: A ⊢ P: A → 𝔹 $ by weaken_ctx [l5]
l7: $ G ∧ q: 𝔹 ∧ x: A ⊢ x: A $ by anr 
l8: $ G ∧ q: 𝔹 ∧ x: A ⊢ P · x: 𝔹 $ by appT [l6, l7]
l9: $ G ∧ q: 𝔹 ⊢ q: 𝔹 $ by anr 
l10: $ G ∧ q: 𝔹 ∧ x: A ⊢ q: 𝔹 $ by weaken_ctx [l9]
l11: $ G ∧ q: 𝔹 ∧ x: A ⊢ P · x ⇒ q: 𝔹 $ by impcT [l8, l10]
l12: $ G ∧ q: 𝔹 ⊢ !x: A. P · x ⇒ q: 𝔹 $ by allcT [l11]
l13: $ G ∧ q: 𝔹 ⊢ (!x: A. P · x ⇒ q) ⇒ q: 𝔹 $ by impcT [l12, l9]
l14: $ G ⊢ !q: 𝔹. (!x: A. P · x ⇒ q) ⇒ q: 𝔹 $ by allcT [l13]
l15: $ G ∧ ≃[A → 𝔹] f = P ⊢ ≃[A → 𝔹] f = P $ by anr 
l16: $ G ∧ ≃[A → 𝔹] f = P ∧ q: 𝔹 ⊢ ≃[A → 𝔹] f = P $ by weaken_ctx [l15]
l17: $ G ∧ ≃[A → 𝔹] f = P ∧ q: 𝔹 ∧ x: A ⊢ ≃[A → 𝔹] f = P $ by weaken_ctx [l16]
l18: $ G ∧ ≃[A → 𝔹] f = P ∧ q: 𝔹 ∧ x: A ⊢ x: A $ by anr 
l19: $ G ∧ ≃[A → 𝔹] f = P ∧ q: 𝔹 ∧ x: A ⊢ ≃[𝔹] f · x = P · x $ by aeq1 [l17, l18]
l20: $ G ∧ ≃[A → 𝔹] f = P ∧ q: 𝔹 ⊢ q: 𝔹 $ by anr 
l21: $ G ∧ ≃[A → 𝔹] f = P ∧ q: 𝔹 ∧ x: A ⊢ q: 𝔹 $ by weaken_ctx [l20]
l22: $ G ∧ ≃[A → 𝔹] f = P ∧ q: 𝔹 ∧ x: A ⊢ imp: 𝔹 → 𝔹 → 𝔹 $ by impT 
l23: $ G ∧ ≃[A → 𝔹] f = P ∧ q: 𝔹 ∧ x: A ⊢ f · x ⇒ q ⇔ P · x ⇒ q $ by bineq1 [l22, l19, l21]
l24: $ G ∧ ≃[A → 𝔹] f = P ∧ q: 𝔹 ⊢ (!x: A. f · x ⇒ q) ⇔ (!x: A. P · x ⇒ q) $ by alleq [l23]
l25: $ G ∧ ≃[A → 𝔹] f = P ∧ q: 𝔹 ⊢ imp: 𝔹 → 𝔹 → 𝔹 $ by impT 
l26: $ G ∧ ≃[A → 𝔹] f = P ∧ q: 𝔹 ⊢ ((!x: A. f · x ⇒ q) ⇒ q) ⇔ ((!x: A. P · x ⇒ q) ⇒ q) $ by bineq1 [l25, l24, l20]
l27: $ G ∧ ≃[A → 𝔹] f = P ⊢ (!q: 𝔹. (!x: A. f · x ⇒ q) ⇒ q) ⇔ (!q: 𝔹. (!x: A. P · x ⇒ q) ⇒ q) $ by alleq [l26]
l28: $ G ⊢ ≃[𝔹] ((λ f: A → 𝔹. !q: 𝔹. (!x: A. f · x ⇒ q) ⇒ q) · P) = (!q: 𝔹. (!x: A. P · x ⇒ q) ⇒ q) $ by betacv [l4, #1, l14, l27]
l29: $ G ⊢ ex A · P ⇔ (!q: 𝔹. (!x: A. P · x ⇒ q) ⇒ q) $ by trans [l2, l28]

excT
----
l1: $ G ⊢ ex A: (A → 𝔹) → 𝔹 $ by exT 
l2: $ G ⊢ λ x: A. t: A → 𝔹 $ by lamT [#1]
l3: $ G ⊢ ex A · (λ x: A. t): 𝔹 $ by appT [l1, l2]

exeq
----
l1: $ G ∧ x: A ⊢ t: 𝔹 $ by eqR1 [#1]
l2: $ G ∧ x: A ⊢ u: 𝔹 $ by eqR2 [#1]
l3: $ G ⊢ λ x: A. t: A → 𝔹 $ by lamT [l1]
l4: $ G ⊢ λ x: A. u: A → 𝔹 $ by lamT [l2]
l5: $ G ⊢ ex A: (A → 𝔹) → 𝔹 $ by exT 
l6: $ G ⊢ ≃[A → 𝔹] (λ x: A. t) = (λ x: A. u) $ by leqt [#1]
l7: $ G ⊢ ex A · (λ x: A. t) ⇔ (ex A · (λ x: A. u)) $ by aeq2 [l5, l6]

exc_def
-------
l1: $ G ⊢ λ x: A. p: A → 𝔹 $ by lamT [#1]
l2: $ G ⊢ ex A · (λ x: A. p) ⇔ (!q: 𝔹. (!y: A. (λ x: A. p) · y ⇒ q) ⇒ q) $ by ex_def [l1]
l3: $ G ∧ q: 𝔹 ⊢ q: 𝔹 $ by anr 
l4: $ G ∧ q: 𝔹 ∧ y: A ⊢ G ∧ q: 𝔹 $ by anl 
l5: $ G ∧ q: 𝔹 ⊢ G $ by anl 
