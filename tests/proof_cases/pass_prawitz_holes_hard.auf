l7: $ _wff $ by and_elim_l [l6]
l8: $ _wff $ by and_elim_r [l6]
l9: $ _wff $ by and_intro [l8, l7]
l10: $ _wff $ by imp_intro [l9]
-- Combine
l11: $ _wff $ by iff_intro [l5, l10]

