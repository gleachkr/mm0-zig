delimiter $ ( ) $;
provable sort wff;
term imp (a b: wff): wff; infixr imp: $->$ prec 25;
term iff (a b: wff): wff; infixr iff: $<->$ prec 20;
term P: wff;
term Q: wff;
term sb (a b: wff): wff;
def id (a: wff): wff = $ a -> a $;
--| @relation wff iff biid bitr bisym mpbi
axiom biid (a: wff): $ a <-> a $;
axiom bitr (a b c: wff): $ a <-> b $ > $ b <-> c $ > $ a <-> c $;
axiom bisym (a b: wff): $ a <-> b $ > $ b <-> a $;
axiom mpbi (a b: wff): $ a <-> b $ > $ a $ > $ b $;
--| @rewrite
axiom sb_im (a b c: wff): $ sb a (b -> c) <-> (sb a b -> sb a c) $;
--| @rewrite
axiom sb_P (a: wff): $ sb a P <-> a $;
--| @congr
axiom im_congr (a b c d: wff):
  $ a <-> b $ > $ c <-> d $ > $ (a -> c) <-> (b -> d) $;
axiom ax_id (a: wff): $ id a $;
--| @normalize hyp0
axiom use_sub (a b: wff): $ sb a b $ > $ a $;
theorem def_rewrite_hyp (a: wff): $ Q $;
