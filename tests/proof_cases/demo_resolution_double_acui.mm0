delimiter $ ( ) $;
provable sort wff;
sort lit;
sort clause;
sort cnf;

term iff (a b: wff): wff;
infixr iff: $<->$ prec 20;
term clause_eq (a b: clause): wff;
term cnf_eq (a b: cnf): wff;
term derives (s: cnf): wff;

term p: lit;
term q: lit;
term r: lit;
term neg (x: lit): lit;

term clause_bot: clause;
--| @acui clause_assoc clause_comm clause_bot clause_idem
term disj (a b: clause): clause;
term clit (x: lit): clause;
term cnf_top: cnf;
--| @acui cnf_assoc cnf_comm cnf_top cnf_idem
term join (a b: cnf): cnf;
term cl (c: clause): cnf;

--| @relation wff iff iff_refl iff_trans iff_sym iff_mp
axiom iff_refl (a: wff): $ a <-> a $;
axiom iff_trans (a b c: wff):
  $ a <-> b $ > $ b <-> c $ > $ a <-> c $;
axiom iff_sym (a b: wff): $ a <-> b $ > $ b <-> a $;
axiom iff_mp (a b: wff): $ a <-> b $ > $ a $ > $ b $;

--| @relation clause clause_eq clause_refl clause_trans clause_sym _
axiom clause_refl (a: clause): $ clause_eq a a $;
axiom clause_trans (a b c: clause):
  $ clause_eq a b $ > $ clause_eq b c $ > $ clause_eq a c $;
axiom clause_sym (a b: clause): $ clause_eq a b $ > $ clause_eq b a $;

--| @relation cnf cnf_eq cnf_refl cnf_trans cnf_sym _
axiom cnf_refl (a: cnf): $ cnf_eq a a $;
axiom cnf_trans (a b c: cnf):
  $ cnf_eq a b $ > $ cnf_eq b c $ > $ cnf_eq a c $;
axiom cnf_sym (a b: cnf): $ cnf_eq a b $ > $ cnf_eq b a $;

axiom clause_assoc (a b c: clause):
  $ clause_eq (disj (disj a b) c) (disj a (disj b c)) $;
axiom clause_comm (a b: clause): $ clause_eq (disj a b) (disj b a) $;
axiom clause_idem (a: clause): $ clause_eq (disj a a) a $;
axiom clause_unit (a: clause): $ clause_eq (disj clause_bot a) a $;

axiom cnf_assoc (a b c: cnf):
  $ cnf_eq (join (join a b) c) (join a (join b c)) $;
axiom cnf_comm (a b: cnf): $ cnf_eq (join a b) (join b a) $;
axiom cnf_idem (a: cnf): $ cnf_eq (join a a) a $;
axiom cnf_unit (a: cnf): $ cnf_eq (join cnf_top a) a $;

--| @congr
axiom disj_congr (a1 a2 b1 b2: clause):
  $ clause_eq a1 a2 $ > $ clause_eq b1 b2 $ >
  $ clause_eq (disj a1 b1) (disj a2 b2) $;

--| @congr
axiom join_congr (a1 a2 b1 b2: cnf):
  $ cnf_eq a1 a2 $ > $ cnf_eq b1 b2 $ >
  $ cnf_eq (join a1 b1) (join a2 b2) $;

--| @congr
axiom cl_congr (a b: clause):
  $ clause_eq a b $ > $ cnf_eq (cl a) (cl b) $;

--| @congr
axiom derives_congr (a b: cnf):
  $ cnf_eq a b $ > $ derives a <-> derives b $;

--| @normalize hyp0 conc
axiom resolve (g d: cnf) (a b: clause) (x: lit):
  $ derives (join g (join (cl (disj a (clit x)))
      (join (cl (disj b (clit (neg x)))) d))) $
  > $ derives (join g (join (cl (disj a b)) d)) $;

theorem resolution_demo:
  $ derives (join (cl (disj (clit p) (clit q)))
      (join (cl (disj (clit (neg p)) (clit r)))
      (join (cl (clit (neg q))) (cl (clit (neg r)))))) $
  > $ derives (cl clause_bot) $;
