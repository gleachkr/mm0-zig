-- A graph-based set theory slice culminating in Cantor's theorem and
-- the Cantor-Bernstein theorem.
--
-- The set-forming operations are primitive, with axioms matching the
-- intended Zermelo basis.  Function-like notions are definitions over
-- sets of ordered pairs, not primitive predicates.
--
-- Organization:
--   1.  logical syntax, equality, and congruence;
--   2.  propositional and first-order proof plumbing;
--   3.  Zermelo set-forming primitives;
--   4.  derived set operations;
--   5.  ordered pairs, graph membership, and image predicates;
--   6.  substitution rewrites;
--   7.  subset, separation, and image lemmas;
--   8.  equality transport;
--   9.  function-like graph predicates;
--  10.  Cantor's theorem via the diagonal set;
--  11.  Cantor-Bernstein fixed-point scaffold;
--  12.  the Cantor-Bernstein theorem.
--
-- Proof-specific trusted helpers are marked "Proof debt" below.  The
-- intent is to keep these easy to find while the theorem is still being
-- streamlined.

delimiter $ ( ) { } [ / ] , | $;

strict provable sort wff;
--| @vars x y z u v w X Y a b c d
sort set;

term im (p q: wff): wff;
infixr im: $тЖТ$ prec 25;
infixr im: $->$ prec 25;

term not (p: wff): wff;
prefix not: $┬м$ prec 41;
prefix not: $~$ prec 41;

term and (p q: wff): wff;
infixr and: $тИз$ prec 30;
infixr and: $/\\$ prec 30;

term or (p q: wff): wff;
infixr or: $тИи$ prec 28;
infixr or: $\\/$ prec 28;

term bi (p q: wff): wff;
infixr bi: $тЖФ$ prec 20;
infixr bi: $<->$ prec 20;

term bot: wff;
prefix bot: $тКе$ prec max;
prefix bot: $F.$ prec max;

term all {x: set} (p: wff x): wff;
prefix all: $тИА$ prec 41;
prefix all: $A.$ prec 41;

term ex {x: set} (p: wff x): wff;
prefix ex: $тИГ$ prec 41;
prefix ex: $E.$ prec 41;

term sb_f {x: set} (t: set x) (p: wff x): wff;
notation sb_f {x: set} (t: set x) (p: wff x): wff =
  ($[$:41) x ($/$:0) t ($]$:0) p;
term sb_s {x: set} (t: set x) (s: set x): set;
notation sb_s {x: set} (t: set x) (s: set x): set =
  ($тЯж$:41) x ($/$:0) t ($тЯз$:0) s;

term set_eq (a b: set): wff;
infixl set_eq: $=$ prec 50;

term mem (x A: set): wff;
infixl mem: $тИИ$ prec 50;
infixl mem: $e.$ prec 50;

def not_mem (x A: set): wff = $ ┬м (x тИИ A) $;
infixl not_mem: $тИЙ$ prec 50;
infixl not_mem: $notin$ prec 50;

-- --------------------------------------------------------------------------
-- Logical syntax, equality, and congruence
-- --------------------------------------------------------------------------
--| @relation wff bi biid bitr bisym mpbi
axiom biid (p: wff): $ p тЖФ p $;
axiom bitr (p q r: wff): $ p тЖФ q $ > $ q тЖФ r $ > $ p тЖФ r $;
axiom bisym (p q: wff): $ p тЖФ q $ > $ q тЖФ p $;
axiom mpbi (p q: wff): $ p тЖФ q $ > $ p $ > $ q $;
axiom bi1 (p q: wff): $ (p тЖФ q) тЖТ (p тЖТ q) $;
axiom bi_intro (p q: wff): $ p тЖТ q $ > $ q тЖТ p $ > $ p тЖФ q $;

--| @relation set set_eq setid settr setsym _
axiom setid (a: set): $ a = a $;
axiom settr (a b c: set): $ a = b $ > $ b = c $ > $ a = c $;
axiom setsym (a b: set): $ a = b $ > $ b = a $;

--| @congr
axiom set_eq_congr (a b c d: set):
  $ a = b $ > $ c = d $ > $ (a = c) тЖФ (b = d) $;

--| @congr
axiom im_congr (p q r s: wff):
  $ p тЖФ q $ > $ r тЖФ s $ > $ (p тЖТ r) тЖФ (q тЖТ s) $;

--| @congr
axiom not_congr (p q: wff): $ p тЖФ q $ > $ ┬м p тЖФ ┬м q $;

--| @congr
axiom and_congr (p q r s: wff):
  $ p тЖФ q $ > $ r тЖФ s $ > $ (p тИз r) тЖФ (q тИз s) $;

--| @congr
axiom or_congr (p q r s: wff):
  $ p тЖФ q $ > $ r тЖФ s $ > $ (p тИи r) тЖФ (q тИи s) $;

--| @congr
axiom bi_congr (p q r s: wff):
  $ p тЖФ q $ > $ r тЖФ s $ > $ (p тЖФ r) тЖФ (q тЖФ s) $;

--| @congr
axiom all_congr {x: set} (p q: wff x):
  $ p тЖФ q $ > $ тИА x p тЖФ тИА x q $;

--| @congr
axiom ex_congr {x: set} (p q: wff x):
  $ p тЖФ q $ > $ тИГ x p тЖФ тИГ x q $;

--| @congr
axiom mem_congr (x y A B: set):
  $ x = y $ > $ A = B $ > $ (x тИИ A) тЖФ (y тИИ B) $;

--| @congr
axiom not_mem_congr (x y A B: set):
  $ x = y $ > $ A = B $ > $ (x тИЙ A) тЖФ (y тИЙ B) $;

-- --------------------------------------------------------------------------
-- Propositional and first-order proof plumbing
-- --------------------------------------------------------------------------
-- Basic implication and negation rules used by the proof script.
axiom h1 (p q: wff): $ p тЖТ (q тЖТ p) $;
axiom h2 (p q r: wff):
  $ (p тЖТ (q тЖТ r)) тЖТ ((p тЖТ q) тЖТ (p тЖТ r)) $;
axiom imp_not_self (p: wff): $ p тЖТ ┬м p $ > $ p тЖТ тКе $;
axiom imp_not_to_self (p: wff): $ ┬м p тЖТ p $ > $ ┬м p тЖТ тКе $;
axiom mp (p q: wff): $ p тЖТ q $ > $ p $ > $ q $;
theorem not_to_imp (p: wff): $ ┬м p $ > $ p тЖТ тКе $;
axiom contra_imp (p q r: wff):
  $ p тЖТ (q тЖТ r) $ > $ ┬м r тЖТ (p тЖТ ┬м q) $;
theorem imp_id (p: wff): $ p тЖТ p $;
theorem imp_trans (p q r: wff): $ p тЖТ q $ > $ q тЖТ r $ > $ p тЖТ r $;
theorem imp_const (p q: wff): $ q $ > $ p тЖТ q $;
theorem imp_const2 (p q r: wff): $ r $ > $ p тЖТ (q тЖТ r) $;
theorem imp_const3 (p q r s: wff):
  $ s $ > $ p тЖТ (q тЖТ (r тЖТ s)) $;
theorem imp_lift (p q r: wff): $ p тЖТ r $ > $ p тЖТ (q тЖТ r) $;
theorem imp_mp_right (p q r: wff):
  $ q $ > $ p тЖТ (q тЖТ r) $ > $ p тЖТ r $;
theorem imp_swap (p q r: wff): $ p тЖТ (q тЖТ r) $ > $ q тЖТ (p тЖТ r) $;
theorem imp_apply_under (p q r: wff):
  $ p тЖТ (q тЖТ r) $ > $ p тЖТ q $ > $ p тЖТ r $;
theorem imp_apply_under2 (p q r s: wff):
  $ p тЖТ (q тЖТ (r тЖТ s)) $ > $ p тЖТ (q тЖТ r) $ >
  $ p тЖТ (q тЖТ s) $;
theorem imp_apply_under3 (p q r s t: wff):
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ t))) $ >
  $ p тЖТ (q тЖТ (r тЖТ s)) $ > $ p тЖТ (q тЖТ (r тЖТ t)) $;
theorem imp_apply_under4 (p q r s t u: wff):
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ (t тЖТ u)))) $ >
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ t))) $ >
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ u))) $;
theorem imp_lift_under2 (p q r s: wff):
  $ p тЖТ (q тЖТ s) $ > $ p тЖТ (q тЖТ (r тЖТ s)) $;
theorem imp_lift_under3 (p q r s t: wff):
  $ p тЖТ (q тЖТ (r тЖТ t)) $ > $ p тЖТ (q тЖТ (r тЖТ (s тЖТ t))) $;
theorem imp_trans_under (p q r s: wff):
  $ p тЖТ (q тЖТ r) $ > $ p тЖТ (r тЖТ s) $ > $ p тЖТ (q тЖТ s) $;
theorem imp_trans_under2 (p q r s t: wff):
  $ p тЖТ (q тЖТ (r тЖТ s)) $ > $ p тЖТ (q тЖТ (s тЖТ t)) $ >
  $ p тЖТ (q тЖТ (r тЖТ t)) $;
theorem imp_trans_under3 (p q r s t u: wff):
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ t))) $ >
  $ p тЖТ (q тЖТ (r тЖТ (t тЖТ u))) $ >
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ u))) $;
theorem imp_swap_imp (p q r: wff):
  $ (p тЖТ (q тЖТ r)) тЖТ (q тЖТ (p тЖТ r)) $;
theorem imp_swap_under (p q r s: wff):
  $ p тЖТ (q тЖТ (r тЖТ s)) $ > $ p тЖТ (r тЖТ (q тЖТ s)) $;
theorem imp_swap_under2 (p q r s t: wff):
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ t))) $ >
  $ p тЖТ (q тЖТ (s тЖТ (r тЖТ t))) $;
axiom not_intro (p q r: wff):
  $ p тЖТ (q тЖТ r) $ > $ p тЖТ (q тЖТ ┬м r) $ > $ p тЖТ ┬м q $;
axiom not_intro_under2 (p q r s: wff):
  $ p тЖТ (q тЖТ (r тЖТ s)) $ >
  $ p тЖТ (q тЖТ (r тЖТ ┬м s)) $ > $ p тЖТ (q тЖТ ┬м r) $;
axiom cases_imp_under3 (p q r s t: wff):
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ t))) $ >
  $ p тЖТ (q тЖТ (r тЖТ (┬м s тЖТ t))) $ > $ p тЖТ (q тЖТ (r тЖТ t)) $;
axiom and1 (p q: wff): $ p тЖТ (q тЖТ p тИз q) $;
theorem and_intro (p q: wff): $ p $ > $ q $ > $ p тИз q $;
theorem and_intro_imp (p q r: wff):
  $ p тЖТ q $ > $ p тЖТ r $ > $ p тЖТ q тИз r $;
theorem and_intro_imp_imp (p q r: wff):
  $ (p тЖТ q) тЖТ ((p тЖТ r) тЖТ (p тЖТ q тИз r)) $;
theorem and_intro_imp_under (p q r s: wff):
  $ p тЖТ (q тЖТ r) $ > $ p тЖТ (q тЖТ s) $ >
  $ p тЖТ (q тЖТ r тИз s) $;
theorem and_intro_imp_under2 (p q r s t: wff):
  $ p тЖТ (q тЖТ (r тЖТ s)) $ > $ p тЖТ (q тЖТ (r тЖТ t)) $ >
  $ p тЖТ (q тЖТ (r тЖТ s тИз t)) $;
theorem and_intro_imp_under3 (p q r s t u: wff):
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ t))) $ >
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ u))) $ >
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ t тИз u))) $;
axiom and_elim_l_imp (p q: wff): $ p тИз q тЖТ p $;
axiom and_elim_r_imp (p q: wff): $ p тИз q тЖТ q $;
theorem and_elim_l (p q: wff): $ p тИз q $ > $ p $;
theorem and_elim_r (p q: wff): $ p тИз q $ > $ q $;
theorem and_mp_right (q r s: wff):
  $ r $ > $ (q тИз r) тЖТ s $ > $ q тЖТ s $;
theorem and_mp_right_imp (q r s: wff):
  $ (q тИз r) тЖТ s $ > $ r тЖТ (q тЖТ s) $;
axiom or_intro_l_imp (p q: wff): $ p тЖТ p тИи q $;
axiom or_intro_r_imp (p q: wff): $ q тЖТ p тИи q $;
axiom excluded_middle (p: wff): $ p тИи ┬м p $;
axiom or_elim_imp (p q r: wff):
  $ p тЖТ r $ > $ q тЖТ r $ > $ p тИи q тЖТ r $;
axiom or_elim_imp_under (p q r s: wff):
  $ s тЖТ (p тЖТ r) $ > $ s тЖТ (q тЖТ r) $ > $ s тЖТ (p тИи q тЖТ r) $;
axiom or_elim_imp_under2 (p q r s t: wff):
  $ s тЖТ (t тЖТ (p тЖТ r)) $ > $ s тЖТ (t тЖТ (q тЖТ r)) $ >
  $ s тЖТ (t тЖТ ((p тИи q) тЖТ r)) $;
axiom or_elim_imp_under3 (p q r s t u: wff):
  $ s тЖТ (t тЖТ (u тЖТ (p тЖТ r))) $ >
  $ s тЖТ (t тЖТ (u тЖТ (q тЖТ r))) $ >
  $ s тЖТ (t тЖТ (u тЖТ ((p тИи q) тЖТ r))) $;
axiom contradiction_imp_under (p q r s: wff):
  $ p тЖТ (q тЖТ r) $ > $ p тЖТ (q тЖТ ┬м r) $ > $ p тЖТ (q тЖТ s) $;
axiom contradiction_imp_under3 (p q r s t u: wff):
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ t))) $ >
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ ┬м t))) $ >
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ u))) $;

theorem bi_imp (p q: wff): $ p тЖФ q $ > $ p тЖТ q $;
theorem bi_imp_rev (p q: wff): $ p тЖФ q $ > $ q тЖТ p $;
theorem bi_imp_imp (p q r: wff):
  $ p тЖТ (q тЖФ r) $ > $ p тЖТ (q тЖТ r) $;

-- Classical proof by cases, specialized to contradiction.
axiom cases_bot (p: wff): $ p тЖТ тКе $ > $ ┬м p тЖТ тКе $ > $ тКе $;
theorem double_neg_elim (p: wff): $ ┬м ┬м p тЖТ p $;

-- --------------------------------------------------------------------------
-- Zermelo set-forming primitives
-- --------------------------------------------------------------------------
term empty: set;
prefix empty: $тИЕ$ prec max;

term pairset (a b: set): set;
term union (A: set): set;
term power (A: set): set;
prefix power: $ЁЭТл$ prec 80;
term sep (A: set) {x: set} (p: wff x): set;
notation sep (A: set) {x: set} (p: wff x): set =
  (${$:max) x ($тИИ$:50) A ($|$:0) p ($}$:0);

--| @view {u: set} (t: set) (p: wff u) (q: wff): $ тИА u p тЖТ q $
--| @recover t q p u
axiom all_elim_imp {u: set} (t: set) (p: wff u):
  $ тИА u p тЖТ [u/t] p $;
axiom all_elim_self_imp {u: set} (p: wff u): $ тИА u p тЖТ p $;

axiom all_intro_imp {u: set} (p: wff) (q: wff u):
  $ p тЖТ q $ > $ p тЖТ тИА u q $;

axiom all_intro {u: set} (p: wff u): $ p $ > $ тИА u p $;

--| @view {u: set} (t: set) (p: wff u) (q: wff): $ q $ > $ тИГ u p $
--| @recover t q p u
axiom ex_intro {u: set} (t: set) (p: wff u):
  $ [u/t] p $ > $ тИГ u p $;

--| @view {u: set} (t: set) (p: wff u) (q r: wff): $ q тЖТ r $ > $ q тЖТ тИГ u p $
--| @recover t r p u
axiom ex_intro_imp {u: set} (t: set) (p: wff u) (q: wff):
  $ q тЖТ [u/t] p $ > $ q тЖТ тИГ u p $;

axiom ex_elim_imp {u: set} (p: wff u) (q: wff):
  $ тИА u (p тЖТ q) $ > $ тИГ u p тЖТ q $;
axiom ex_elim_imp_under2 {u: set} (p: wff u) (q r s: wff):
  $ q тЖТ (r тЖТ (p тЖТ s)) $ > $ q тЖТ (r тЖТ ((тИГ u p) тЖТ s)) $;

--| @view {u: set} (a b: set) (p: wff u) (q r: wff): $ a = b тЖТ (q тЖТ r) $
--| @abstract p q r u a b
--| @fresh u
axiom eq_replace_imp {u: set} (a b: set) (p: wff u):
  $ a = b тЖТ ([u/a] p тЖТ [u/b] p) $;

--| @rewrite
axiom sb_f_im {u: set} (t: set) (p q: wff u):
  $ [u/t] (p тЖТ q) тЖФ ([u/t] p тЖТ [u/t] q) $;

--| @rewrite
axiom sb_f_and {u: set} (t: set) (p q: wff u):
  $ [u/t] (p тИз q) тЖФ ([u/t] p тИз [u/t] q) $;

--| @rewrite
axiom sb_f_or {u: set} (t: set) (p q: wff u):
  $ [u/t] (p тИи q) тЖФ ([u/t] p тИи [u/t] q) $;

--| @rewrite
axiom sb_f_bi {u: set} (t: set) (p q: wff u):
  $ [u/t] (p тЖФ q) тЖФ ([u/t] p тЖФ [u/t] q) $;

--| @rewrite
axiom sb_f_all {u v: set} (t: set) (p: wff u v):
  $ [u/t] (тИА v p) тЖФ тИА v [u/t] p $;

--| @rewrite
axiom sb_f_ex {u v: set} (t: set) (p: wff u v):
  $ [u/t] (тИГ v p) тЖФ тИГ v [u/t] p $;

--| @rewrite
axiom sb_f_not {u: set} (t: set) (p: wff u):
  $ [u/t] (┬м p) тЖФ ┬м [u/t] p $;

--| @rewrite
axiom sb_f_id {u: set} (p: wff u): $ [u/u] p тЖФ p $;

-- Extensionality and proof-friendly forms of the Zermelo operations.
def subset (A B: set) (.x: set): wff =
  $ тИА x (x тИИ A тЖТ x тИИ B) $;
infixr subset: $тКЖ$ prec 25;

theorem subset_intro_imp (A B: set) {x: set}:
  $ x тИИ A тЖТ x тИИ B $ > $ A тКЖ B $;
theorem subset_intro_imp_imp (A B: set) (p: wff) {x: set}:
  $ p тЖТ (x тИИ A тЖТ x тИИ B) $ > $ p тЖТ (A тКЖ B) $;

axiom ext (A B: set): $ A тКЖ B $ > $ B тКЖ A $ > $ A = B $;

axiom empty_elim (x: set): $ x тИИ тИЕ тЖТ тКе $;

axiom pairset_intro_left (x y: set): $ x тИИ pairset x y $;
axiom pairset_intro_right (x y: set): $ y тИИ pairset x y $;
axiom pairset_elim (x y z: set):
  $ x тИИ pairset y z $ > $ x = y тИи x = z $;

axiom union_intro (x y A: set):
  $ x тИИ y $ > $ y тИИ A $ > $ x тИИ union A $;

axiom power_intro (A B: set): $ B тКЖ A $ > $ B тИИ power A $;
axiom power_elim (A B: set): $ B тИИ power A $ > $ B тКЖ A $;

axiom sep_intro {x: set} (A: set) (p: wff x):
  $ x тИИ A $ > $ p $ > $ x тИИ {x тИИ A | p} $;
--| @view {x: set} (t A: set) (p: wff x) (q: wff): $ t тИИ A $ > $ q тЖТ t тИИ {x тИИ A | p} $
--| @recover t q p x
axiom sep_intro_imp {x: set} (t A: set) (p: wff x):
  $ t тИИ A $ > $ [x/t] p тЖТ t тИИ {x тИИ A | p} $;
--| @view {x: set} (t A: set) (p: wff x) (q r: wff): $ q тЖТ (r тЖТ t тИИ {x тИИ A | p}) $
--| @recover t r p x
axiom sep_intro_imp_imp {x: set} (t A: set) (p: wff x):
  $ t тИИ A тЖТ ([x/t] p тЖТ t тИИ {x тИИ A | p}) $;
--| @view {x: set} (t A: set) (p: wff x) (q r s: wff): $ q тЖТ r $ > $ q тЖТ s $ > $ q тЖТ t тИИ {x тИИ A | p} $
--| @recover t q p x
axiom sep_intro_imp2 {x: set} (t A: set) (p: wff x) (q: wff):
  $ q тЖТ t тИИ A $ > $ q тЖТ [x/t] p $ >
  $ q тЖТ t тИИ {x тИИ A | p} $;
axiom sep_elim_left {x: set} (A: set) (p: wff x):
  $ x тИИ {x тИИ A | p} $ > $ x тИИ A $;
--| @view {x: set} (t A: set) (p: wff x) (q: wff): $ t тИИ {x тИИ A | p} тЖТ q $
--| @recover t q p x
axiom sep_elim_left_imp {x: set} (t A: set) (p: wff x):
  $ t тИИ {x тИИ A | p} тЖТ t тИИ A $;
axiom sep_elim_right {x: set} (A: set) (p: wff x):
  $ x тИИ {x тИИ A | p} $ > $ p $;
--| @view {x: set} (t A: set) (p: wff x) (q: wff): $ t тИИ {x тИИ A | p} тЖТ q $
--| @recover t q p x
axiom sep_elim_right_imp {x: set} (t A: set) (p: wff x):
  $ t тИИ {x тИИ A | p} тЖТ [x/t] p $;
axiom sep_subset {x: set} (A: set) (p: wff x):
  $ {x тИИ A | p} тКЖ A $;

-- --------------------------------------------------------------------------
-- Derived set operations
-- --------------------------------------------------------------------------
def setdiff (A B: set) (.x: set): set = $ {x тИИ A | x тИЙ B} $;
infixl setdiff: $тИЦ$ prec 60;
infixl setdiff: $\\$ prec 60;

def in_all_subsets (S x: set) (.X: set): wff =
  $ тИА X (X тИИ S тЖТ x тИИ X) $;

--| @congr
axiom in_all_subsets_congr (S T x y: set):
  $ S = T $ > $ x = y $ > $ in_all_subsets S x тЖФ in_all_subsets T y $;

def inter_subsets (A S: set) (.x: set): set =
  $ {x тИИ A | in_all_subsets S x} $;

-- --------------------------------------------------------------------------
-- Ordered pairs, graph membership, and image predicates
-- --------------------------------------------------------------------------
def singleton (a: set): set = $ pairset a a $;
def opair (a b: set): set = $ pairset (singleton a) (pairset a b) $;
notation opair (a b: set): set =
  ($тЯи$:max) a ($,$:0) b ($тЯй$:0);
--| @congr
axiom opair_congr (a c b d: set):
  $ a = c $ > $ b = d $ > $ тЯи a , b тЯй = тЯи c , d тЯй $;
axiom opair_eq_left_imp (a b c d: set): $ тЯи a , b тЯй = тЯи c , d тЯй тЖТ a = c $;
axiom opair_eq_right_imp (a b c d: set): $ тЯи a , b тЯй = тЯи c , d тЯй тЖТ b = d $;
theorem opair_eq_left (a b c d: set): $ тЯи a , b тЯй = тЯи c , d тЯй $ > $ a = c $;
theorem opair_eq_right (a b c d: set): $ тЯи a , b тЯй = тЯи c , d тЯй $ > $ b = d $;
def maps (f x y: set): wff = $ тЯи x , y тЯй тИИ f $;

--| @congr
axiom maps_congr (f g x y a b: set):
  $ f = g $ > $ x = y $ > $ a = b $ > $ maps f x a тЖФ maps g y b $;

def has_preimage (f X y: set) (.x: set): wff =
  $ тИГ x (x тИИ X тИз maps f x y) $;

--| @congr
axiom has_preimage_congr (f g X Y y z: set):
  $ f = g $ > $ X = Y $ > $ y = z $ >
  $ has_preimage f X y тЖФ has_preimage g Y z $;

def image (f X B: set) (.y: set): set =
  $ {y тИИ B | has_preimage f X y} $;

-- Ordered-pair carrier for graphs from A to B.  A Kuratowski pair of
-- elements of AтИкB lies in ЁЭТл(ЁЭТл(AтИкB)), so separation over this set can
-- carve out graph-like subsets without taking graph formation primitive.
def pair_carrier (A B: set): set =
  $ ЁЭТл (ЁЭТл (union (pairset A B))) $;
axiom opair_mem_pair_carrier_imp (A B x y: set):
  $ x тИИ A тЖТ (y тИИ B тЖТ тЯи x , y тЯй тИИ pair_carrier A B) $;


-- --------------------------------------------------------------------------
-- Substitution rewrites
-- --------------------------------------------------------------------------
--| @rewrite
axiom sb_s_var {u: set} (t: set u): $ (тЯж u / t тЯз u) = t $;

--| @rewrite
axiom sb_s_other {u v: set} (t: set u): $ (тЯж u / t тЯз v) = v $;

--| @rewrite
axiom sb_s_irrel {u: set} (t: set u) (s: set): $ (тЯж u / t тЯз s) = s $;

--| @rewrite
axiom sb_s_pairset {u: set} (t a b: set u):
  $ (тЯж u / t тЯз (pairset a b)) =
    pairset (тЯж u / t тЯз a) (тЯж u / t тЯз b) $;

--| @rewrite
axiom sb_s_union {u: set} (t A: set u):
  $ (тЯж u / t тЯз (union A)) = union (тЯж u / t тЯз A) $;

--| @rewrite
axiom sb_s_power {u: set} (t A: set u):
  $ (тЯж u / t тЯз (power A)) = power (тЯж u / t тЯз A) $;

--| @rewrite
axiom sb_s_sep {u v: set} (t A: set u) (p: wff u v):
  $ (тЯж u / t тЯз {v тИИ A | p}) =
    {v тИИ (тЯж u / t тЯз A) | [u/t] p} $;

--| @rewrite
axiom sb_s_singleton {u: set} (t a: set u):
  $ (тЯж u / t тЯз (singleton a)) = singleton (тЯж u / t тЯз a) $;

--| @rewrite
axiom sb_s_opair {u: set} (t a b: set u):
  $ (тЯж u / t тЯз тЯи a , b тЯй) =
    тЯи (тЯж u / t тЯз a) , (тЯж u / t тЯз b) тЯй $;

--| @rewrite
axiom sb_f_mem {u: set} (t a A: set u):
  $ [u/t] (a тИИ A) тЖФ (тЯж u / t тЯз a) тИИ (тЯж u / t тЯз A) $;

--| @rewrite
axiom sb_f_not_mem {u: set} (t a A: set u):
  $ [u/t] (a тИЙ A) тЖФ (тЯж u / t тЯз a) тИЙ (тЯж u / t тЯз A) $;

--| @rewrite
axiom sb_f_set_eq {u: set} (t a b: set u):
  $ [u/t] (a = b) тЖФ (тЯж u / t тЯз a) = (тЯж u / t тЯз b) $;

--| @rewrite
axiom sb_f_maps {u: set} (t f x y: set u):
  $ [u/t] (maps f x y) тЖФ
    maps (тЯж u / t тЯз f) (тЯж u / t тЯз x) (тЯж u / t тЯз y) $;

--| @rewrite
axiom sb_f_has_preimage {u: set} (t f X y: set u):
  $ [u/t] (has_preimage f X y) тЖФ
    has_preimage (тЯж u / t тЯз f) (тЯж u / t тЯз X) (тЯж u / t тЯз y) $;

--| @rewrite
axiom sb_f_in_all_subsets {u: set} (t S x: set u):
  $ [u/t] (in_all_subsets S x) тЖФ
    in_all_subsets (тЯж u / t тЯз S) (тЯж u / t тЯз x) $;


-- --------------------------------------------------------------------------
-- Subset, separation, and image lemmas
-- --------------------------------------------------------------------------
theorem inter_subsets_intro_imp2 (A S x: set) (p: wff) {X: set}:
  $ p тЖТ x тИИ A $ >
  $ p тЖТ тИА X (X тИИ S тЖТ x тИИ X) $ >
  $ p тЖТ x тИИ inter_subsets A S $;

theorem subset_elim_imp (A B x: set): $ A тКЖ B $ > $ x тИИ A тЖТ x тИИ B $;
theorem subset_elim_imp_imp (A B x: set):
  $ (A тКЖ B) тЖТ (x тИИ A тЖТ x тИИ B) $;
theorem subset_not_mem_imp (A B x: set):
  $ A тКЖ B $ > $ x тИЙ B тЖТ x тИЙ A $;
theorem subset_not_mem_imp_imp (A B x: set):
  $ (A тКЖ B) тЖТ (x тИЙ B тЖТ x тИЙ A) $;

theorem setdiff_subset (A B: set): $ A тИЦ B тКЖ A $;
theorem setdiff_elim_left (A B x: set): $ x тИИ A тИЦ B тЖТ x тИИ A $;
theorem setdiff_elim_right (A B x: set): $ x тИИ A тИЦ B тЖТ x тИЙ B $;
theorem setdiff_intro (A B x: set):
  $ x тИИ A $ > $ x тИЙ B тЖТ x тИИ A тИЦ B $;
theorem setdiff_intro_imp2 (A B x: set) (p: wff):
  $ p тЖТ x тИИ A $ > $ p тЖТ x тИЙ B $ > $ p тЖТ x тИИ A тИЦ B $;
theorem setdiff_intro_imp2_under (A B x: set) (p q: wff):
  $ p тЖТ (q тЖТ x тИИ A) $ > $ p тЖТ (q тЖТ x тИЙ B) $ >
  $ p тЖТ (q тЖТ x тИИ A тИЦ B) $;
theorem setdiff_antitone_right (A B C: set):
  $ B тКЖ C $ > $ A тИЦ C тКЖ A тИЦ B $;
-- Classical elimination for set difference, derived from separation and
-- double-negation elimination.
theorem setdiff_missing_imp (A B x: set):
  $ x тИИ A тЖТ (x тИЙ A тИЦ B тЖТ x тИИ B) $;
theorem setdiff_antitone_right_imp_imp (A B C: set):
  $ (B тКЖ C) тЖТ (A тИЦ C тКЖ A тИЦ B) $;

theorem image_subset (f X B: set): $ image f X B тКЖ B $;
theorem image_elim_mem (f X B y: set):
  $ y тИИ image f X B тЖТ y тИИ B $;
theorem image_has_preimage (f X B y: set) {x: set}:
  $ y тИИ image f X B тЖТ тИГ x (x тИИ X тИз maps f x y) $;
theorem image_intro (f X B x y: set):
  $ y тИИ B $ > $ x тИИ X $ > $ maps f x y $ > $ y тИИ image f X B $;
theorem image_intro_imp_under2 (f X B x y: set) (p q: wff):
  $ p тЖТ (q тЖТ y тИИ B) $ > $ p тЖТ (q тЖТ x тИИ X) $ >
  $ p тЖТ (q тЖТ maps f x y) $ > $ p тЖТ (q тЖТ y тИИ image f X B) $;
theorem has_preimage_mono_imp (f X Y y: set):
  $ X тКЖ Y $ > $ has_preimage f X y тЖТ has_preimage f Y y $;
theorem has_preimage_mono_imp_imp (f X Y y: set):
  $ (X тКЖ Y) тЖТ (has_preimage f X y тЖТ has_preimage f Y y) $;
theorem image_mono (f X Y B: set):
  $ X тКЖ Y $ > $ image f X B тКЖ image f Y B $;
theorem image_mono_imp_imp (f X Y B: set):
  $ (X тКЖ Y) тЖТ (image f X B тКЖ image f Y B) $;

theorem inter_subsets_subset (A S: set): $ inter_subsets A S тКЖ A $;
theorem inter_subsets_elim (A S x X: set):
  $ x тИИ inter_subsets A S $ > $ X тИИ S $ > $ x тИИ X $;
theorem inter_subsets_elim_imp (A S x X: set):
  $ X тИИ S $ > $ x тИИ inter_subsets A S тЖТ x тИИ X $;
theorem inter_subsets_elim_imp_imp (A S x X: set):
  $ X тИИ S тЖТ (x тИИ inter_subsets A S тЖТ x тИИ X) $;
theorem inter_subsets_intro (A S x: set) {X: set}:
  $ x тИИ A $ > $ тИА X (X тИИ S тЖТ x тИИ X) тЖТ x тИИ inter_subsets A S $;

-- --------------------------------------------------------------------------
-- Equality transport
-- --------------------------------------------------------------------------

theorem mem_arg_eq_left_imp_imp (x y A: set):
  $ x = y тЖТ (y тИИ A тЖТ x тИИ A) $;
theorem mem_arg_eq_left_imp (x y A: set):
  $ x = y $ > $ y тИИ A тЖТ x тИИ A $;
theorem mem_arg_eq_left (x y A: set):
  $ x = y $ > $ y тИИ A $ > $ x тИИ A $;
theorem not_mem_eq_imp (x A B: set):
  $ A = B $ > $ x тИЙ A тЖТ x тИЙ B $;
theorem mem_eq_imp (x A B: set):
  $ A = B $ > $ x тИИ A тЖТ x тИИ B $;
theorem mem_eq_imp_imp (x A B: set):
  $ A = B тЖТ (x тИИ A тЖТ x тИИ B) $;
theorem set_sym_imp (a b: set): $ a = b тЖТ b = a $;
theorem set_eq_from_common_left (a b c: set):
  $ a = b $ > $ a = c $ > $ b = c $;
theorem set_eq_from_common_left_imp_imp (a b c: set):
  $ a = b тЖТ (a = c тЖТ b = c) $;
theorem settr_imp_left (a b c: set):
  $ a = b $ > $ b = c тЖТ a = c $;
theorem settr_imp_left_imp (a b c: set):
  $ a = b тЖТ (b = c тЖТ a = c) $;
theorem settr_imp_right (a b c: set):
  $ b = c $ > $ a = b тЖТ a = c $;
theorem settr_imp_right_imp (a b c: set):
  $ b = c тЖТ (a = b тЖТ a = c) $;
theorem opair_rights_eq_imp (x y z u v w t: set):
  $ тЯи x , z тЯй = тЯи u , v тЯй тЖТ (тЯи y , z тЯй = тЯи w , t тЯй тЖТ v = t) $;
theorem opair_lefts_eq_imp (x y z u v w t: set):
  $ тЯи x , z тЯй = тЯи u , v тЯй тЖТ (тЯи y , z тЯй = тЯи w , t тЯй тЖТ
    (u = w тЖТ x = y)) $;
theorem maps_arg_eq_left_imp (f x y z: set):
  $ x = y тЖТ (maps f y z тЖТ maps f x z) $;
theorem maps_arg_eq_right_imp (f x y z: set):
  $ y = z тЖТ (maps f x y тЖТ maps f x z) $;

-- --------------------------------------------------------------------------
-- Function-like graph predicates
-- --------------------------------------------------------------------------
def functional (f: set) (.x .y .z: set): wff =
  $ тИА x тИА y тИА z ((maps f x y тИз maps f x z) тЖТ y = z) $;

theorem functional_elim_imp (f x y z: set):
  $ functional f $ > $ maps f x z $ > $ maps f x y тЖТ y = z $;
theorem functional_elim_imp_imp (f x y z: set):
  $ functional f $ > $ maps f x z тЖТ (maps f x y тЖТ y = z) $;

theorem functional_elim (f x y z: set):
  $ functional f $ > $ maps f x y $ > $ maps f x z $ > $ y = z $;

def domain_on (f A: set) (.x .y: set): wff =
  $ тИА x (x тИИ A тЖФ тИГ y maps f x y) $;

theorem domain_on_maps_mem_imp (f A x y: set):
  $ domain_on f A $ > $ maps f x y тЖТ x тИИ A $;
theorem domain_on_maps_mem (f A x y: set):
  $ domain_on f A $ > $ maps f x y $ > $ x тИИ A $;
theorem domain_on_has_maps_imp (f A x: set) {a: set}:
  $ domain_on f A $ > $ x тИИ A тЖТ тИГ a maps f x a $;

def range_sub (f B: set) (.x .y: set): wff =
  $ тИА y ((тИГ x maps f x y) тЖТ y тИИ B) $;

theorem range_sub_elim_imp (f B x y: set):
  $ range_sub f B $ > $ maps f x y тЖТ y тИИ B $;
theorem range_sub_elim (f B x y: set):
  $ range_sub f B $ > $ maps f x y $ > $ y тИИ B $;
theorem range_sub_intro (f B: set) {x y: set}:
  $ тИА y тИА x (maps f x y тЖТ y тИИ B) $ > $ range_sub f B $;

def function (f A B: set): wff =
  $ functional f тИз (domain_on f A тИз range_sub f B) $;
theorem function_intro (f A B: set):
  $ functional f $ > $ domain_on f A $ > $ range_sub f B $ >
  $ function f A B $;
theorem function_functional (f A B: set):
  $ function f A B $ > $ functional f $;
theorem function_domain_on (f A B: set):
  $ function f A B $ > $ domain_on f A $;
theorem function_range_sub (f A B: set):
  $ function f A B $ > $ range_sub f B $;
theorem function_maps_range (f A B x y: set):
  $ function f A B $ > $ maps f x y $ > $ y тИИ B $;
theorem function_maps_range_imp (f A B x y: set):
  $ function f A B $ > $ maps f x y тЖТ y тИИ B $;
theorem function_maps_domain_imp (f A B x y: set):
  $ function f A B $ > $ maps f x y тЖТ x тИИ A $;
theorem function_maps_domain (f A B x y: set):
  $ function f A B $ > $ maps f x y $ > $ x тИИ A $;
theorem function_unique (f A B x y z: set):
  $ function f A B $ > $ maps f x y $ > $ maps f x z $ > $ y = z $;
theorem function_unique_imp (f A B x y z: set):
  $ function f A B $ > $ maps f x z $ > $ maps f x y тЖТ y = z $;

def injective (f A B: set) (.x .y .z: set): wff =
  $ function f A B тИз
    тИА x тИА y тИА z
      (((x тИИ A тИз y тИИ A) тИз (maps f x z тИз maps f y z)) тЖТ x = y) $;
theorem injective_intro (f A B: set) {x y z: set}:
  $ function f A B $ >
  $ тИА x тИА y тИА z
      (((x тИИ A тИз y тИИ A) тИз (maps f x z тИз maps f y z)) тЖТ x = y) $ >
  $ injective f A B $;
theorem injective_function (f A B: set):
  $ injective f A B $ > $ function f A B $;
theorem injective_functional (f A B: set):
  $ injective f A B $ > $ functional f $;
theorem injective_domain_on (f A B: set):
  $ injective f A B $ > $ domain_on f A $;
theorem injective_range_sub (f A B: set):
  $ injective f A B $ > $ range_sub f B $;
theorem injective_maps_range (f A B x y: set):
  $ injective f A B $ > $ maps f x y $ > $ y тИИ B $;
theorem injective_maps_range_imp (f A B x y: set):
  $ injective f A B $ > $ maps f x y тЖТ y тИИ B $;
theorem injective_maps_domain_imp (f A B x y: set):
  $ injective f A B $ > $ maps f x y тЖТ x тИИ A $;
theorem injective_maps_domain (f A B x y: set):
  $ injective f A B $ > $ maps f x y $ > $ x тИИ A $;
theorem injective_elim (f A B x y z: set):
  $ injective f A B $ > $ x тИИ A $ > $ y тИИ A $ >
  $ maps f x z $ > $ maps f y z $ > $ x = y $;
theorem injective_elim_imp (f A B x y z: set):
  $ injective f A B $ > $ x тИИ A $ > $ y тИИ A $ >
  $ maps f x z $ > $ maps f y z тЖТ x = y $;
theorem injective_elim_imp_under (f A B x y z: set) (p: wff):
  $ injective f A B $ > $ x тИИ A $ > $ p тЖТ y тИИ A $ >
  $ maps f x z $ > $ p тЖТ maps f y z $ > $ p тЖТ x = y $;
theorem injective_elim_eq_right (f A B x y z t: set):
  $ injective f A B $ > $ x тИИ A $ > $ y тИИ A $ > $ z = t $ >
  $ maps f x z $ > $ maps f y t $ > $ x = y $;
theorem functional_elim_eq_left (f x y z t: set):
  $ functional f $ > $ x = y $ > $ maps f x z $ >
  $ maps f y t $ > $ z = t $;
theorem injective_elim_eq_right_under4
    (f A B x y z t: set) (p q r s: wff):
  $ injective f A B $ > $ p тЖТ (q тЖТ (r тЖТ (s тЖТ x тИИ A))) $ >
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ y тИИ A))) $ >
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ z = t))) $ >
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ maps f x z))) $ >
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ maps f y t))) $ >
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ x = y))) $;
theorem functional_elim_eq_left_under4
    (f x y z t: set) (p q r s: wff):
  $ functional f $ > $ p тЖТ (q тЖТ (r тЖТ (s тЖТ x = y))) $ >
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ maps f x z))) $ >
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ maps f y t))) $ >
  $ p тЖТ (q тЖТ (r тЖТ (s тЖТ z = t))) $;
-- This is the core "out" branch fact for the CB construction: if an
-- injective g sends t to w, and w appears in the g-image of B тИЦ C,
-- then t cannot lie in C.
theorem image_preimage_not_mem_imp (g B A C t w: set):
  $ injective g B A $ > $ t тИИ B $ > $ maps g t w $ >
  $ w тИИ image g (B тИЦ C) A тЖТ t тИЙ C $;
-- Proof debt: this is only the three-hypothesis lifted form of the
-- previous theorem.  It should become a derived lifting lemma.
axiom image_preimage_not_mem_imp_under3
    (g B A C t w: set) (p q r: wff):
  $ injective g B A $ > $ p тЖТ (q тЖТ (r тЖТ t тИИ B)) $ >
  $ p тЖТ (q тЖТ (r тЖТ maps g t w)) $ >
  $ p тЖТ (q тЖТ (r тЖТ
    (w тИИ image g (B тИЦ C) A тЖТ t тИЙ C))) $;

-- Surjectivity and bijectivity for graph-coded functions.
def surj (f A B: set) (.y: set): wff =
  $ function f A B тИз тИА y (y тИИ B тЖТ has_preimage f A y) $;
theorem surj_intro (f A B: set) {y: set}:
  $ function f A B $ > $ тИА y (y тИИ B тЖТ has_preimage f A y) $ >
  $ surj f A B $;
theorem surj_function (f A B: set):
  $ surj f A B $ > $ function f A B $;

def bijective (f A B: set): wff =
  $ injective f A B тИз surj f A B $;
theorem bijective_intro (f A B: set):
  $ injective f A B $ > $ surj f A B $ > $ bijective f A B $;
theorem bijective_injective (f A B: set):
  $ bijective f A B $ > $ injective f A B $;
theorem bijective_surj (f A B: set):
  $ bijective f A B $ > $ surj f A B $;

theorem surj_has_preimage (f A B y: set) {x: set}:
  $ surj f A B $ > $ y тИИ B $ >
  $ тИГ x (x тИИ A тИз maps f x y) $;

-- --------------------------------------------------------------------------
-- Cantor's theorem via the diagonal set
-- --------------------------------------------------------------------------
-- The diagonal set for Cantor's theorem.  The predicate says that x is
-- missed by every y to which f maps x; functionality then connects this
-- graph-based definition to the usual "x тИЙ f(x)" reading.
def misses (f x: set) (.y: set): wff =
  $ тИА y (maps f x y тЖТ x тИЙ y) $;

--| @rewrite
axiom sb_f_misses_self {x: set} (t f: set):
  $ [x/t] (misses f x) тЖФ misses f t $;

def diag (A f: set) (.x: set): set = $ {x тИИ A | misses f x} $;

-- Proof debt: this Hilbert-choice-style witness packages the proof-side
-- existential witness used by the diagonal argument.
term surj_wit (f A y: set): set;

axiom preimage_wit_pair (f A y: set) {x: set}:
  $ тИГ x (x тИИ A тИз maps f x y) $ >
  $ surj_wit f A y тИИ A тИз maps f (surj_wit f A y) y $;

theorem cantor (A f: set):
  $ function f A (power A) $ >
  $ surj f A (power A) $ >
  $ тКе $;

-- --------------------------------------------------------------------------
-- Cantor-Bernstein fixed-point scaffold
-- --------------------------------------------------------------------------
-- The standard fixed-point proof uses the
-- monotone operator ╬ж(X) = A тИЦ g[B тИЦ f[X]].  The core set is the
-- intersection of all prefixed points of ╬ж.
def cb_step (A B f g X: set): set =
  $ A тИЦ image g (B тИЦ image f X B) A $;

def cb_prefixed (A B f g X: set): wff = $ cb_step A B f g X тКЖ X $;

--| @rewrite
axiom sb_f_cb_prefixed {u: set} (t A B f g X: set u):
  $ [u/t] (cb_prefixed A B f g X) тЖФ
    cb_prefixed (тЯж u / t тЯз A) (тЯж u / t тЯз B) (тЯж u / t тЯз f)
      (тЯж u / t тЯз g) (тЯж u / t тЯз X) $;

--| @congr
axiom cb_prefixed_congr (A C B D f h g k X Y: set):
  $ A = C $ > $ B = D $ > $ f = h $ > $ g = k $ > $ X = Y $ >
  $ cb_prefixed A B f g X тЖФ cb_prefixed C D h k Y $;

def cb_prefixeds (A B f g: set) (.X: set): set =
  $ {X тИИ ЁЭТл A | cb_prefixed A B f g X} $;

def cb_core (A B f g: set): set =
  $ inter_subsets A (cb_prefixeds A B f g) $;

-- The induced graph sends x by f on the core, and by the inverse of g on
-- its complement.  Proving this is a bijection is the Cantor-Bernstein
-- construction target.
def cb_bijection (A B f g: set) (.p .x .y: set): set =
  $ {p тИИ pair_carrier A B |
      тИГ x тИГ y
        (p = тЯи x , y тЯй тИз
          ((x тИИ cb_core A B f g тИз maps f x y) тИи
           (x тИЙ cb_core A B f g тИз maps g y x)))} $;

-- --------------------------------------------------------------------------
-- The Cantor-Bernstein theorem
-- --------------------------------------------------------------------------
-- The construction packages cb_bijection into a 
-- bijection between A and B given mutual injections.
theorem cantor_bernstein (A B f g: set):
  $ injective f A B $ > $ injective g B A $ >
  $ bijective (cb_bijection A B f g) A B $;
