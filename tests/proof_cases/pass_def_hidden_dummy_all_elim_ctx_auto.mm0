delimiter $ ( ) [ / ] $;
provable sort wff;
sort ctx;
strict sort obj;
--| @vars x y z
sort mor;

term imp (a b: wff): wff;
infixr imp: $‚Üí$ prec 25;
infixr imp: $->$ prec 25;
term and (a b: wff): wff;
infixr and: $‚àß$ prec 30;
infixr and: $/\\$ prec 30;
term iff (a b: wff): wff;
infixr iff: $‚Üî$ prec 20;
infixr iff: $<->$ prec 20;
term all {x: mor} (p: wff x): wff;
prefix all: $‚àÄ$ prec 41;
prefix all: $A.$ prec 41;

term mor_eq (f g: mor): wff;
infixl mor_eq: $~$ prec 15;
term hom (f: mor) (A B: obj): wff;
term id (A: obj): mor;
term comp (f g: mor): mor;
infixl comp: $‚àò$ prec 35;
infixl comp: $o$ prec 35;
term pb_med (f g h k a b: mor): mor;

term sb_m {x: mor} (t: mor x) (a: mor x): mor;
notation sb_m {x: mor} (t: mor x) (a: mor x): mor =
  ($subst$:41) x ($/$:0) t a;
term sb_f {x: mor} (t: mor x) (p: wff x): wff;
notation sb_f {x: mor} (t: mor x) (p: wff x): wff =
  ($[$:41) x ($/$:0) t ($]$:0) p;

term ctx_eq (g h: ctx): wff;
term emp: ctx;
notation emp: ctx = ($_$:max);
--| @acui ctx_assoc ctx_comm emp ctx_idem
term join (g h: ctx): ctx;
infixl join: $,$ prec 5;
term hyp (a: wff): ctx;
coercion hyp: wff > ctx;
term nd (g: ctx) (a: wff): wff;
infixl nd: $‚ä¢$ prec 0;

--| @relation wff iff iff_refl iff_trans iff_sym iff_mp
axiom iff_refl (a: wff): $ a ‚Üî a $;
axiom iff_trans (a b c: wff):
  $ a ‚Üî b $ > $ b ‚Üî c $ > $ a ‚Üî c $;
axiom iff_sym (a b: wff): $ a ‚Üî b $ > $ b ‚Üî a $;
axiom iff_mp (a b: wff): $ a ‚Üî b $ > $ a $ > $ b $;

--| @relation mor mor_eq mor_refl_raw mor_trans_raw mor_sym_raw _
axiom mor_refl_raw (f: mor): $ f ~ f $;
axiom mor_trans_raw (f g h: mor):
  $ f ~ g $ > $ g ~ h $ > $ f ~ h $;
axiom mor_sym_raw (f g: mor): $ f ~ g $ > $ g ~ f $;

--| @relation ctx ctx_eq ctx_refl ctx_trans ctx_sym _
axiom ctx_refl (g: ctx): $ ctx_eq g g $;
axiom ctx_trans (g h i: ctx):
  $ ctx_eq g h $ > $ ctx_eq h i $ > $ ctx_eq g i $;
axiom ctx_sym (g h: ctx): $ ctx_eq g h $ > $ ctx_eq h g $;
axiom ctx_assoc (g h i: ctx):
  $ ctx_eq ((g , h) , i) (g , (h , i)) $;
axiom ctx_comm (g h: ctx): $ ctx_eq (g , h) (h , g) $;
axiom ctx_idem (g: ctx): $ ctx_eq (g , g) g $;
axiom ctx_unit (g: ctx): $ ctx_eq (emp , g) g $;

--| @congr
axiom join_congr (g1 g2 h1 h2: ctx):
  $ ctx_eq g1 g2 $ > $ ctx_eq h1 h2 $ >
  $ ctx_eq (g1 , h1) (g2 , h2) $;

--| @congr
axiom hyp_congr (a b: wff): $ a ‚Üî b $ > $ ctx_eq (hyp a) (hyp b) $;

--| @congr
axiom nd_congr (g h: ctx) (a b: wff):
  $ ctx_eq g h $ > $ a ‚Üî b $ > $ (g ‚ä¢ a) ‚Üî (h ‚ä¢ b) $;

--| @congr
axiom imp_congr (a b c d: wff):
  $ a ‚Üî b $ > $ c ‚Üî d $ > $ (a ‚Üí c) ‚Üî (b ‚Üí d) $;

--| @congr
axiom and_congr (a b c d: wff):
  $ a ‚Üî b $ > $ c ‚Üî d $ > $ (a ‚àß c) ‚Üî (b ‚àß d) $;

--| @congr
axiom all_congr {x: mor} (p q: wff x):
  $ p ‚Üî q $ > $ ‚àÄ x p ‚Üî ‚àÄ x q $;

--| @congr
axiom mor_eq_congr (f1 f2 g1 g2: mor):
  $ f1 ~ f2 $ > $ g1 ~ g2 $ > $ (f1 ~ g1) ‚Üî (f2 ~ g2) $;

--| @congr
axiom hom_congr (f g: mor) (A B: obj):
  $ f ~ g $ > $ hom f A B ‚Üî hom g A B $;

--| @congr
axiom comp_congr (f1 f2 g1 g2: mor):
  $ f1 ~ f2 $ > $ g1 ~ g2 $ > $ f1 ‚àò g1 ~ f2 ‚àò g2 $;

--| @rewrite
axiom comp_assoc (f g h: mor): $ (f ‚àò g) ‚àò h ~ f ‚àò (g ‚àò h) $;

--| @rewrite
axiom sb_m_var {x: mor} (t: mor x): $ subst x / t x ~ t $;

--| @rewrite
axiom sb_m_other {x y: mor} (t: mor x): $ subst x / t y ~ y $;

--| @rewrite
axiom sb_m_irrel {x: mor} (t: mor x) (a: mor): $ subst x / t a ~ a $;

--| @rewrite
axiom sb_m_id {x: mor} (t: mor x) (A: obj): $ subst x / t (id A) ~ id A $;

--| @rewrite
axiom sb_m_comp {x: mor} (t: mor x) (a b: mor x):
  $ subst x / t (a ‚àò b) ~ (subst x / t a ‚àò subst x / t b) $;

--| @rewrite
axiom sb_m_pb_med {x: mor} (t: mor x) (f g h k a b: mor x):
  $ subst x / t (pb_med f g h k a b) ~
    pb_med (subst x / t f) (subst x / t g) (subst x / t h)
      (subst x / t k) (subst x / t a) (subst x / t b) $;

--| @rewrite
axiom sb_f_mor_eq {x: mor} (t: mor x) (a b: mor x):
  $ [x/t] (a ~ b) ‚Üî (subst x / t a ~ subst x / t b) $;

--| @rewrite
axiom sb_f_hom {x: mor} (t: mor x) (a: mor x) (A B: obj):
  $ [x/t] hom a A B ‚Üî hom (subst x / t a) A B $;

--| @rewrite
axiom sb_f_imp {x: mor} (t: mor x) (p q: wff x):
  $ [x/t] (p ‚Üí q) ‚Üî ([x/t] p ‚Üí [x/t] q) $;

--| @rewrite
axiom sb_f_and {x: mor} (t: mor x) (p q: wff x):
  $ [x/t] (p ‚àß q) ‚Üî ([x/t] p ‚àß [x/t] q) $;

--| @rewrite
axiom sb_f_all {x y: mor} (t: mor x) (p: wff x y):
  $ [x/t] (‚àÄ y p) ‚Üî ‚àÄ y ([x/t] p) $;

axiom ax (g: ctx) (a: wff): $ g , a ‚ä¢ a $;

axiom imp_intro (g: ctx) (a b: wff): $ g , a ‚ä¢ b $ > $ g ‚ä¢ a ‚Üí b $;

axiom imp_elim (g h: ctx) (a b: wff):
  $ g ‚ä¢ a ‚Üí b $ > $ h ‚ä¢ a $ > $ g , h ‚ä¢ b $;

axiom and_elim_l (g: ctx) (a b: wff): $ g ‚ä¢ a ‚àß b $ > $ g ‚ä¢ a $;

axiom and_elim_r (g: ctx) (a b: wff): $ g ‚ä¢ a ‚àß b $ > $ g ‚ä¢ b $;

axiom all_intro (g: ctx) {x: mor} (p: wff x): $ g ‚ä¢ p $ > $ g ‚ä¢ ‚àÄ x p $;

--| @view {x: mor} (g: ctx x) (t: mor x) (p: wff x) (q: wff): $ g ‚ä¢ ‚àÄ x p $ > $ g ‚ä¢ q $
--| @recover t q p x
axiom all_elim {x: mor} (g: ctx) (t: mor x) (p: wff x):
  $ g ‚ä¢ ‚àÄ x p $ > $ g ‚ä¢ [x/t] p $;

axiom mor_refl (g: ctx) (f: mor): $ g ‚ä¢ f ~ f $;

axiom mor_sym (g: ctx) (f h: mor): $ g ‚ä¢ f ~ h $ > $ g ‚ä¢ h ~ f $;

axiom mor_trans (g: ctx) (f h i: mor):
  $ g ‚ä¢ f ~ h $ > $ g ‚ä¢ h ~ i $ > $ g ‚ä¢ f ~ i $;

axiom comp_right (g: ctx) (f h i: mor):
  $ g ‚ä¢ f ~ h $ > $ g ‚ä¢ f ‚àò i ~ h ‚àò i $;

axiom comp_left (g: ctx) (f h i: mor):
  $ g ‚ä¢ f ~ h $ > $ g ‚ä¢ i ‚àò f ~ i ‚àò h $;

axiom pb_med_unique (g0: ctx) (f g h k a b u: mor):
  $ g0 ‚ä¢ f ‚àò a ~ g ‚àò b $ >
  $ g0 ‚ä¢ h ‚àò u ~ a $ >
  $ g0 ‚ä¢ k ‚àò u ~ b $ >
  $ g0 ‚ä¢ u ~ pb_med f g h k a b $;

--| @congr
axiom pb_med_congr_full (f1 f2 g1 g2 h1 h2 k1 k2 a1 a2 b1 b2: mor):
  $ f1 ~ f2 $ >
  $ g1 ~ g2 $ >
  $ h1 ~ h2 $ >
  $ k1 ~ k2 $ >
  $ a1 ~ a2 $ >
  $ b1 ~ b2 $ >
  $ pb_med f1 g1 h1 k1 a1 b1 ~ pb_med f2 g2 h2 k2 a2 b2 $;

axiom pb_med_congr (g0: ctx) (f g h k a1 b1 a2 b2: mor):
  $ g0 ‚ä¢ a1 ~ b1 $ >
  $ g0 ‚ä¢ a2 ~ b2 $ >
  $ g0 ‚ä¢ pb_med f g h k a1 a2 ~ pb_med f g h k b1 b2 $;

def mono {.a .b: mor} (f: mor): wff =
  $ ‚àÄ a ‚àÄ b ((f ‚àò a ~ f ‚àò b) ‚Üí (a ~ b)) $;

def pullback {.a .b .u: mor} (f g h k: mor): wff =
  $ (f ‚àò h ~ g ‚àò k) ‚àß
    ‚àÄ a ‚àÄ b ‚àÄ u
      ((f ‚àò a ~ g ‚àò b) ‚Üí
        ((h ‚àò u ~ a) ‚Üí
          ((k ‚àò u ~ b) ‚Üí
            (u ~ pb_med f g h k a b)))) $;

axiom pullback_eq (g0: ctx) (f g h k: mor):
  $ g0 ‚ä¢ pullback f g h k $ > $ g0 ‚ä¢ f ‚àò h ~ g ‚àò k $;


theorem pass_def_hidden_dummy_all_elim_ctx_auto {alpha y a: mor}
    (f g h k: mor):
  $ mono f , pullback f g h k , (k ‚àò alpha ~ k ‚àò alpha) ‚ä¢
    ‚àÄ y ((f ‚àò (h ‚àò alpha) ~ f ‚àò y) ‚Üí (h ‚àò alpha ~ y)) $;
