l4: $ G ∧ p: 𝔹 ⊢ p ⇒ F: 𝔹 $ by impcT [l1, l3]
l5: $ G ⊢ λ p: 𝔹. p ⇒ F: 𝔹 → 𝔹 $ by lamT [l4]
l6: $ G ⊢ ≃[𝔹 → 𝔹] (λ p: 𝔹. p ⇒ F) = ((λ p: 𝔹. p ⇒ F)) $ by reflt (A := $ 𝔹 → 𝔹 $, t := $ λ p: 𝔹. p ⇒ F $) [l5]

notT
----
l1: $ G ⊢ ≃[𝔹 → 𝔹] not = (λ p: 𝔹. p ⇒ F) $ by NOT_DEF []
l2: $ G ⊢ not: 𝔹 → 𝔹 $ by eqR1 [l1]

notcT
-----
l1: $ G ⊢ not: 𝔹 → 𝔹 $ by notT []
l2: $ G ⊢ ¬ p: 𝔹 $ by appT [l1, #1]

notR
----
l1: $ G ⊢ ¬ p: 𝔹 $ by thmR [#1]
l2: $ G ⊢ not: 𝔹 → 𝔹 $ by notT []
l3: $ G ⊢ p: 𝔹 $ by appTR2 [l1, l2]

notc_def
--------
l1: $ G ⊢ F: 𝔹 $ by FT []
l2: $ G ∧ q: 𝔹 ⊢ F: 𝔹 $ by weaken_ctx [l1]
l3: $ G ∧ q: 𝔹 ⊢ q: 𝔹 $ by anr []
l4: $ G ∧ q: 𝔹 ⊢ q ⇒ F: 𝔹 $ by impcT [l3, l2]
l5: $ G ⊢ λ q: 𝔹. q ⇒ F: 𝔹 → 𝔹 $ by lamT [l4]
l6: $ G ⊢ ≃[𝔹 → 𝔹] not = (λ q: 𝔹. q ⇒ F) $ by NOT_DEF (p := $ q $) []
l7: $ G ⊢ ≃[𝔹] not · p = ((λ q: 𝔹. q ⇒ F) · p) $ by aeq1 [l6, #1]
l8: $ G ⊢ imp: 𝔹 → 𝔹 → 𝔹 $ by impT []
l9: $ G ⊢ imp · p: 𝔹 → 𝔹 $ by appT [l8, #1]
l10: $ G ⊢ imp · p · F: 𝔹 $ by appT [l9, l1]
l11: $ G ∧ ≃[𝔹] q = p ⊢ ≃[𝔹] q = p $ by anr []
l12: $ G ∧ ≃[𝔹] q = p ⊢ imp: 𝔹 → 𝔹 → 𝔹 $ by impT []
l13: $ G ∧ ≃[𝔹] q = p ⊢ ≃[𝔹 → 𝔹] imp · q = imp · p $ by aeq2 [l12, l11]
l14: $ G ∧ ≃[𝔹] q = p ⊢ F: 𝔹 $ by weaken_ctx [l1]
l15: $ G ∧ ≃[𝔹] q = p ⊢ ≃[𝔹] imp · q · F = imp · p · F $ by aeq1 (A := $ 𝔹 $, B := $ 𝔹 $, f := $ imp · q $, g := $ imp · p $, a := $ F $) [l13, l14]
l16: $ G ⊢ ≃[𝔹] ((λ q: 𝔹. q ⇒ F) · p) = imp · p · F $ by betacv (x := $ q $, A := $ 𝔹 $, B := $ 𝔹 $, t := $ p $, u := $ q ⇒ F $, v := $ imp · p · F $) [l4, #1, l10, l15]
l17: $ G ⊢ not · p ⇔ (imp · p · F) $ by trans (A := $ 𝔹 $, a := $ not · p $, b := $ ((λ q: 𝔹. q ⇒ F) · p) $, c := $ imp · p · F $) [l7, l16]

NOT_ELIM
--------
l1: $ G ⊢ p: 𝔹 $ by notR [#1]
l2: $ G ⊢ ¬ p ⇔ (p ⇒ F) $ by notc_def [l1]
l3: $ G ⊢ p ⇒ F $ by eqmp [l2, #1]

NOT_INTRO
---------
l1: $ G ⊢ p: 𝔹 ∧ F: 𝔹 $ by impR [#1]
l2: $ p: 𝔹 ∧ F: 𝔹 ⊢ p: 𝔹 $ by anl []
l3: $ G ⊢ p: 𝔹 $ by syl [l1, l2]
l4: $ G ⊢ ¬ p ⇔ (p ⇒ F) $ by notc_def [l3]
l5: $ G ⊢ ¬ p $ by eqmpr [l4, #1]

normalize_subst_nested
----------------------
l1: $ ((λ y: 𝔹. y) · x) · ((λ y: 𝔹. y) · x) ≈ z · z $ by subst_teq [#1]

double_id_congr_chain
---------------------
l1: $ G ⊢ y: 𝔹 $ by eqTR2 [#1]
l2: $ G ⊢ ≡[𝔹 → 𝔹] (λ y: 𝔹. y) = (λ y: 𝔹. y) $ by id_bool_refl []
l3: $ G ⊢ ≡[𝔹] ((λ x: 𝔹. x) · x) = y $ by eq_subst_id [#1]
l4: $ G ⊢ ≡[𝔹] ((λ y: 𝔹. y) · ((λ x: 𝔹. x) · x)) = ((λ y: 𝔹. y) · y) $ by aeq [l2, l3]
l5: $ G ⊢ ≡[𝔹] ((λ y: 𝔹. y) · y) = y $ by id_bool_beta [l1]
l6: $ G ⊢ ≡[𝔹] ((λ y: 𝔹. y) · ((λ x: 𝔹. x) · x)) = y $ by eqtrans [l4, l5]

subst_eq_demo
-------------
l1: $ G ⊢ ≡[𝔹] ((λ y: 𝔹. y) · x) · ((λ y: 𝔹. y) · x) = z · z $ by subst_eq [#1]

square_id_subst
---------------
l1: $ G ⊢ ≡[𝔹] ((λ x: 𝔹. x) · x) = y $ by eq_subst_id [#1]
l2: $ G ⊢ ≡[𝔹] ((λ x: 𝔹. x) · x) · ((λ x: 𝔹. x) · x) = y · y $ by subst_eq [l1]
