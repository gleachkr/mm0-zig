delimiter $ ( ) [ / ] $;
provable sort wff;
sort ctx;
strict sort obj;
--| @vars x y z a b u alpha beta
sort mor;

term imp (a b: wff): wff;
infixr imp: $тЖТ$ prec 25;
infixr imp: $->$ prec 25;
term and (a b: wff): wff;
infixr and: $тИз$ prec 30;
infixr and: $/\\$ prec 30;
term iff (a b: wff): wff;
infixr iff: $тЖФ$ prec 20;
infixr iff: $<->$ prec 20;
term all {x: mor} (p: wff x): wff;
prefix all: $тИА$ prec 41;
prefix all: $A.$ prec 41;

term mor_eq (f g: mor): wff;
infixl mor_eq: $~$ prec 15;
term id (A: obj): mor;
term comp (f g: mor): mor;
infixl comp: $тИШ$ prec 35;
infixl comp: $o$ prec 35;
term pb_med (f g h k a b: mor): mor;

term sb_m {x: mor} (t: mor x) (a: mor x): mor;
notation sb_m {x: mor} (t: mor x) (a: mor x): mor =
  ($subst$:41) x ($/$:0) t a;
term sb_f {x: mor} (t: mor x) (p: wff x): wff;
notation sb_f {x: mor} (t: mor x) (p: wff x): wff =
  ($[$:41) x ($/$:0) t ($]$:0) p;

term ctx_eq (g h: ctx): wff;
term emp: ctx;
notation emp: ctx = ($_$:max);
--| @acui ctx_assoc ctx_comm emp ctx_idem
term join (g h: ctx): ctx;
infixl join: $,$ prec 5;
term hyp (a: wff): ctx;
coercion hyp: wff > ctx;
term nd (g: ctx) (a: wff): wff;
infixl nd: $тКв$ prec 0;

--| @relation wff iff iff_refl iff_trans iff_sym iff_mp
axiom iff_refl (a: wff): $ a тЖФ a $;
axiom iff_trans (a b c: wff):
  $ a тЖФ b $ > $ b тЖФ c $ > $ a тЖФ c $;
axiom iff_sym (a b: wff): $ a тЖФ b $ > $ b тЖФ a $;
axiom iff_mp (a b: wff): $ a тЖФ b $ > $ a $ > $ b $;

--| @relation mor mor_eq mor_refl_raw mor_trans_raw mor_sym_raw _
axiom mor_refl_raw (f: mor): $ f ~ f $;
axiom mor_trans_raw (f g h: mor):
  $ f ~ g $ > $ g ~ h $ > $ f ~ h $;
axiom mor_sym_raw (f g: mor): $ f ~ g $ > $ g ~ f $;

--| @relation ctx ctx_eq ctx_refl ctx_trans ctx_sym _
axiom ctx_refl (g: ctx): $ ctx_eq g g $;
axiom ctx_trans (g h i: ctx):
  $ ctx_eq g h $ > $ ctx_eq h i $ > $ ctx_eq g i $;
axiom ctx_sym (g h: ctx): $ ctx_eq g h $ > $ ctx_eq h g $;
axiom ctx_assoc (g h i: ctx):
  $ ctx_eq ((g , h) , i) (g , (h , i)) $;
axiom ctx_comm (g h: ctx): $ ctx_eq (g , h) (h , g) $;
axiom ctx_idem (g: ctx): $ ctx_eq (g , g) g $;
axiom ctx_unit (g: ctx): $ ctx_eq (emp , g) g $;

--| @congr
axiom join_congr (g1 g2 h1 h2: ctx):
  $ ctx_eq g1 g2 $ > $ ctx_eq h1 h2 $ >
  $ ctx_eq (g1 , h1) (g2 , h2) $;

--| @congr
axiom hyp_congr (a b: wff): $ a тЖФ b $ > $ ctx_eq (hyp a) (hyp b) $;

--| @congr
axiom nd_congr (g h: ctx) (a b: wff):
  $ ctx_eq g h $ > $ a тЖФ b $ > $ (g тКв a) тЖФ (h тКв b) $;

--| @congr
axiom imp_congr (a b c d: wff):
  $ a тЖФ b $ > $ c тЖФ d $ > $ (a тЖТ c) тЖФ (b тЖТ d) $;

--| @congr
axiom and_congr (a b c d: wff):
  $ a тЖФ b $ > $ c тЖФ d $ > $ (a тИз c) тЖФ (b тИз d) $;

--| @congr
axiom all_congr {x: mor} (p q: wff x):
  $ p тЖФ q $ > $ тИА x p тЖФ тИА x q $;

--| @congr
axiom mor_eq_congr (f1 f2 g1 g2: mor):
  $ f1 ~ f2 $ > $ g1 ~ g2 $ > $ (f1 ~ g1) тЖФ (f2 ~ g2) $;

--| @congr
axiom comp_congr (f1 f2 g1 g2: mor):
  $ f1 ~ f2 $ > $ g1 ~ g2 $ > $ f1 тИШ g1 ~ f2 тИШ g2 $;

--| @rewrite
axiom comp_assoc (f g h: mor): $ (f тИШ g) тИШ h ~ f тИШ (g тИШ h) $;

--| @rewrite
axiom sb_m_var {x: mor} (t: mor x): $ subst x / t x ~ t $;

--| @rewrite
axiom sb_m_other {x y: mor} (t: mor x): $ subst x / t y ~ y $;

--| @rewrite
axiom sb_m_irrel {x: mor} (t: mor x) (a: mor): $ subst x / t a ~ a $;

--| @rewrite
axiom sb_m_id {x: mor} (t: mor x) (A: obj):
  $ subst x / t (id A) ~ id A $;

--| @rewrite
axiom sb_m_comp {x: mor} (t: mor x) (a b: mor x):
  $ subst x / t (a тИШ b) ~ (subst x / t a тИШ subst x / t b) $;

--| @rewrite
axiom sb_m_pb_med {x: mor} (t: mor x) (f g h k a b: mor x):
  $ subst x / t (pb_med f g h k a b) ~
    pb_med (subst x / t f) (subst x / t g) (subst x / t h)
      (subst x / t k) (subst x / t a) (subst x / t b) $;

--| @rewrite
axiom sb_f_mor_eq {x: mor} (t: mor x) (a b: mor x):
  $ [x/t] (a ~ b) тЖФ (subst x / t a ~ subst x / t b) $;

--| @rewrite
axiom sb_f_imp {x: mor} (t: mor x) (p q: wff x):
  $ [x/t] (p тЖТ q) тЖФ ([x/t] p тЖТ [x/t] q) $;

--| @rewrite
axiom sb_f_and {x: mor} (t: mor x) (p q: wff x):
  $ [x/t] (p тИз q) тЖФ ([x/t] p тИз [x/t] q) $;

--| @rewrite
axiom sb_f_all {x y: mor} (t: mor x) (p: wff x y):
  $ [x/t] (тИА y p) тЖФ тИА y ([x/t] p) $;

axiom ax (g: ctx) (a: wff): $ g , a тКв a $;

axiom imp_elim (g h: ctx) (a b: wff):
  $ g тКв a тЖТ b $ > $ h тКв a $ > $ g , h тКв b $;

axiom and_elim_l (g: ctx) (a b: wff): $ g тКв a тИз b $ > $ g тКв a $;

axiom and_elim_r (g: ctx) (a b: wff): $ g тКв a тИз b $ > $ g тКв b $;

--| @view {x: mor} (g: ctx x) (t: mor x) (p: wff x) (q: wff): $ g тКв тИА x p $ > $ g тКв q $
--| @recover t q p x
axiom all_elim {x: mor} (g: ctx) (t: mor x) (p: wff x):
  $ g тКв тИА x p $ > $ g тКв [x/t] p $;

axiom mor_refl (g: ctx) (f: mor): $ g тКв f ~ f $;

axiom mor_sym (g: ctx) (f h: mor): $ g тКв f ~ h $ > $ g тКв h ~ f $;

axiom mor_trans (g: ctx) (f h i: mor):
  $ g тКв f ~ h $ > $ g тКв h ~ i $ > $ g тКв f ~ i $;

axiom comp_right (g: ctx) (f h i: mor):
  $ g тКв f ~ h $ > $ g тКв f тИШ i ~ h тИШ i $;

axiom comp_left (g: ctx) (f h i: mor):
  $ g тКв f ~ h $ > $ g тКв i тИШ f ~ i тИШ h $;

--| @congr
axiom pb_med_congr (f1 f2 g1 g2 h1 h2 k1 k2 a1 a2 b1 b2: mor):
  $ f1 ~ f2 $ >
  $ g1 ~ g2 $ >
  $ h1 ~ h2 $ >
  $ k1 ~ k2 $ >
  $ a1 ~ a2 $ >
  $ b1 ~ b2 $ >
  $ pb_med f1 g1 h1 k1 a1 b1 ~ pb_med f2 g2 h2 k2 a2 b2 $;

def mono {.a .b: mor} (f: mor): wff =
  $ тИА a тИА b ((f тИШ a ~ f тИШ b) тЖТ (a ~ b)) $;

def pullback {.a .b .u: mor} (f g h k: mor): wff =
  $ (f тИШ h ~ g тИШ k) тИз
    тИА a тИА b тИА u
      ((f тИШ a ~ g тИШ b) тЖТ
        ((h тИШ u ~ a) тЖТ
          ((k тИШ u ~ b) тЖТ
            (u ~ pb_med f g h k a b)))) $;

theorem mono_direct {alpha beta : mor} (f: mor):
  $ mono f , (f тИШ alpha ~ f тИШ beta) тКв alpha ~ beta $;

theorem pullback_eq_direct { a b u : mor } (f g h k: mor):
  $ pullback f g h k тКв f тИШ h ~ g тИШ k $;

theorem pullback_use_direct (f g h k a b u: mor):
  $ pullback f g h k тКв
      (f тИШ a ~ g тИШ b) тЖТ
        ((h тИШ u ~ a) тЖТ
          ((k тИШ u ~ b) тЖТ
            (u ~ pb_med f g h k a b))) $;

theorem mono_pullback_step {alpha beta : mor} (f g h k: mor):
  $ mono f , pullback f g h k , (k тИШ alpha ~ k тИШ beta) тКв
      h тИШ alpha ~ h тИШ beta $;
