-- The proof progression is:
--   * a Π identity warmup
--   * Bool and Nat computation examples
--   * judgemental equality chaining
--   * an internal identity toolkit built by path induction
--   * addition laws, ending in commutativity
--
-- ==================================================================
-- SECTION 0: Structural helpers
-- ==================================================================

weaken2
-------

l1: $ g , x : T1 ⊢ J $ by weaken [#1]
l2: $ g , x : T1 , y : T2 ⊢ J $ by weaken [l1]

weaken3
-------

l1: $ g , x : T1 , y : T2 ⊢ J $ by weaken2 [#1]
l2: $ g , x : T1 , y : T2 , z : T3 ⊢ J $ by weaken [l1]

-- ==================================================================
-- SECTION 1: Π warmup
-- ==================================================================

id_ty
-----

l1: $ g , x : A ⊢ Ty A $ by weaken [#1]
l2: $ g , x : A ⊢ x : A $ by var
l3: $ g ⊢ (λ x : A. x) : (Π x : A. A) $ by lam_intro [#1, l1, l2]

app_id_beta
-----------

l1: $ g ⊢ Ty A $ by has_ty_regular [#1]
l2: $ g ⊢ (λ x : A. x) : (Π x : A. A) $ by id_ty [l1]
l3: $ g ⊢ ≡[A] ((λ x : A. x) · u) = u $ by app_beta [l2, #1]

-- ==================================================================
-- SECTION 2: Bool warmup
-- ==================================================================

bool_not_ty
-----------

l1: $ g ⊢ false : Bool $ by false_intro
l2: $ g ⊢ true : Bool $ by true_intro
l3: $ g ⊢ ¬ b : Bool $ by bool_elim [l1, l2, #1]

bool_not_true
-------------

l1: $ g ⊢ false : Bool $ by false_intro
l2: $ g ⊢ true : Bool $ by true_intro
l3: $ g ⊢ ≡[Bool] (¬ true) = false $ by bool_beta_true [l1, l2]

bool_not_false
--------------

l1: $ g ⊢ false : Bool $ by false_intro
l2: $ g ⊢ true : Bool $ by true_intro
l3: $ g ⊢ ≡[Bool] (¬ false) = true $ by bool_beta_false [l1, l2]

-- ==================================================================
-- SECTION 3: Nat warmup
-- ==================================================================

one_ty
------

l1: $ g ⊢ zero : Nat $ by zero_intro
l2: $ g ⊢ suc zero : Nat $ by suc_intro [l1]

nat_rec_ty
----------

l1: $ g ⊢ Ty A $ by has_ty_regular [#1]
l2: $ g , k : Nat ⊢ Ty A $ by weaken [l1]
l3: $ g , k : Nat , ih : const_ty k A ⊢ s : (A → A) $ by weaken2 [#2]
l4: $ g , k : Nat , ih : const_ty k A ⊢ ih : const_ty k A $ by var
l5: $ g , k : Nat , ih : const_ty k A ⊢ s · ih : A $
  by app_elim [l3, l4]
l6: $ g ⊢ nat_ind k ih (const_ty k A) z (s · ih) n :
  [k/n] (const_ty k A) $ by nat_ind_elim [l2, #1, l5, #3]

nat_rec_zero
------------

l1: $ g ⊢ Ty A $ by has_ty_regular [#1]
l2: $ g , k : Nat ⊢ Ty A $ by weaken [l1]
l3: $ g , k : Nat , ih : const_ty k A ⊢ s : (A → A) $ by weaken2 [#2]
l4: $ g , k : Nat , ih : const_ty k A ⊢ ih : const_ty k A $ by var
l5: $ g , k : Nat , ih : const_ty k A ⊢ s · ih : A $
  by app_elim [l3, l4]
l6: $ g ⊢ ≡[[k/zero] (const_ty k A)]
  (nat_ind k ih (const_ty k A) z (s · ih) zero) = z $
  by nat_ind_zero [l2, #1, l5]

nat_rec_suc
-----------

l1: $ g ⊢ Ty A $ by has_ty_regular [#1]
l2: $ g , k : Nat ⊢ Ty A $ by weaken [l1]
l3: $ g , k : Nat , ih : const_ty k A ⊢ s : (A → A) $ by weaken2 [#2]
l4: $ g , k : Nat , ih : const_ty k A ⊢ ih : const_ty k A $ by var
l5: $ g , k : Nat , ih : const_ty k A ⊢ s · ih : A $
  by app_elim [l3, l4]
l6: $ g ⊢ ≡[[k/suc n] (const_ty k A)]
  (nat_ind k ih (const_ty k A) z (s · ih) (suc n)) =
  (⟦ ih / nat_ind k ih (const_ty k A) z (s · ih) n ⟧
      (⟦ k / n ⟧ (s · ih))) $
  by nat_ind_suc [l2, #1, l5, #3]

-- ==================================================================
-- SECTION 4: Typed equality warmup
-- ==================================================================

double_step_ty
--------------

l1: $ g ⊢ Ty Nat $ by nat_form
l2: $ g , k : Nat ⊢ Ty Nat $ by nat_form
l3: $ g , k : Nat ⊢ k : Nat $ by var
l4: $ g , k : Nat ⊢ suc k : Nat $ by suc_intro [l3]
l5: $ g , k : Nat ⊢ suc (suc k) : Nat $ by suc_intro [l4]
l6: $ g ⊢ (λ k : Nat. suc (suc k)) : (Nat → Nat) $
  by lam_intro [l1, l2, l5]

nat_rec_two_step_one
--------------------

l1: $ g ⊢ zero : Nat $ by zero_intro
l2: $ g ⊢ (λ k : Nat. suc (suc k)) : (Nat → Nat) $ by double_step_ty
l3: $ g ⊢ ≡[Nat] (nat_rec Nat zero (λ k : Nat. suc (suc k))
  (suc zero)) = ((λ k : Nat. suc (suc k)) ·
  (nat_rec Nat zero (λ k : Nat. suc (suc k)) zero)) $
  by nat_rec_suc [l1, l2, l1]
l4: $ g ⊢ ≡[Nat] (nat_rec Nat zero (λ k : Nat. suc (suc k)) zero) = zero $
  by nat_rec_zero [l1, l2]
l5: $ g ⊢ ≡[Nat] ((λ k : Nat. suc (suc k)) ·
  (nat_rec Nat zero (λ k : Nat. suc (suc k)) zero)) =
  ((λ k : Nat. suc (suc k)) · zero) $ by app_eq_right [l2, l4]
l6: $ g ⊢ ≡[Nat] ((λ k : Nat. suc (suc k)) · zero) =
  (suc (suc zero)) $ by app_beta [l2, l1]
l7: $ g ⊢ ≡[Nat] (nat_rec Nat zero (λ k : Nat. suc (suc k))
  (suc zero)) = ((λ k : Nat. suc (suc k)) · zero) $
  by eq_tm_trans [l3, l5]
l8: $ g ⊢ ≡[Nat] (nat_rec Nat zero (λ k : Nat. suc (suc k))
  (suc zero)) = (suc (suc zero)) $ by eq_tm_trans [l7, l6]

-- ==================================================================
-- SECTION 5: Identity warmup
-- ==================================================================

id_sym_ty
---------

l1: $ g , x : A , y : A ⊢ y : A $ by var
l2: $ g , x : A ⊢ x : A $ by var
l3: $ g , x : A , y : A , q : Id A x y ⊢ y : A $ by weaken [l1]
l4: $ g , x : A , y : A , q : Id A x y ⊢ x : A $ by weaken2 [l2]
l5: $ g , x : A , y : A , q : Id A x y ⊢ Ty (Id A y x) $
  by Id_form [l3, l4]
l6: $ g , x : A ⊢ refl A x : Id A x x $ by refl_intro [l2]
l7: $ g ⊢ J x y q A (Id A y x) (refl A x) s t p :
  [x/s] [y/t] [q/p] (Id A y x) $ by J_elim [l5, l6, #1]

id_sym_refl
-----------

l1: $ g , x : A , y : A ⊢ y : A $ by var
l2: $ g , x : A ⊢ x : A $ by var
l3: $ g , x : A , y : A , q : Id A x y ⊢ y : A $ by weaken [l1]
l4: $ g , x : A , y : A , q : Id A x y ⊢ x : A $ by weaken2 [l2]
l5: $ g , x : A , y : A , q : Id A x y ⊢ Ty (Id A y x) $
  by Id_form [l3, l4]
l6: $ g , x : A ⊢ refl A x : Id A x x $ by refl_intro [l2]
l7: $ g ⊢ ≡[[x/s] [y/s] [q/refl A s] (Id A y x)]
  (J x y q A (Id A y x) (refl A x) s s (refl A s)) =
  (⟦ x / s ⟧ (refl A x)) $ by J_beta [l5, l6, #1]

id_trans_ty
-----------

l1: $ g ⊢ u : A $ by Id_right_regular [#2]
l2: $ g , x : A ⊢ x : A $ by var
l3: $ g , x : A , y : A ⊢ y : A $ by var
l4: $ g , x : A , y : A , z : Id A x y ⊢ u : A $ by weaken3 [l1]
l5: $ g , x : A , y : A , z : Id A x y ⊢ x : A $ by weaken2 [l2]
l6: $ g , x : A , y : A , z : Id A x y ⊢ y : A $ by weaken [l3]
l7: $ g , x : A , y : A , z : Id A x y ⊢ Ty (Id A y u) $
  by Id_form [l6, l4]
l8: $ g , x : A , y : A , z : Id A x y ⊢ Ty (Id A x u) $
  by Id_form [l5, l4]
l9: $ g , x : A , y : A , z : Id A x y , w : Id A y u ⊢
  Ty (Id A x u) $ by weaken [l8]
l10: $ g , x : A , y : A , z : Id A x y ⊢ Ty (Id A y u → Id A x u) $
  by pi_form [l7, l9]
l11: $ g , x : A ⊢ u : A $ by weaken [l1]
l12: $ g , x : A ⊢ Ty (Id A x u) $ by Id_form [l2, l11]
l13: $ g , x : A ⊢ (λ w : Id A x u. w) : (Id A x u → Id A x u) $
  by id_ty [l12]
l14: $ g ⊢ J x y z A (Id A y u → Id A x u)
  (λ w : Id A x u. w) s t p : (Id A t u → Id A s u) $
  by J_elim [l10, l13, #1]
l15: $ g ⊢ (J x y z A (Id A y u → Id A x u)
  (λ w : Id A x u. w) s t p) · q : Id A s u $ by app_elim [l14, #2]

id_trans_refl_left
------------------

l1: $ g ⊢ s : A $ by Id_left_regular [#1]
l2: $ g ⊢ u : A $ by Id_right_regular [#1]
l3: $ g , x : A ⊢ x : A $ by var
l4: $ g , x : A , y : A ⊢ y : A $ by var
l5: $ g , x : A , y : A , z : Id A x y ⊢ u : A $ by weaken3 [l2]
l6: $ g , x : A , y : A , z : Id A x y ⊢ x : A $ by weaken2 [l3]
l7: $ g , x : A , y : A , z : Id A x y ⊢ y : A $ by weaken [l4]
l8: $ g , x : A , y : A , z : Id A x y ⊢ Ty (Id A y u) $
  by Id_form [l7, l5]
l9: $ g , x : A , y : A , z : Id A x y ⊢ Ty (Id A x u) $
  by Id_form [l6, l5]
l10: $ g , x : A , y : A , z : Id A x y , w : Id A y u ⊢
  Ty (Id A x u) $ by weaken [l9]
l11: $ g , x : A , y : A , z : Id A x y ⊢ Ty (Id A y u → Id A x u) $
  by pi_form [l8, l10]
l12: $ g , x : A ⊢ u : A $ by weaken [l2]
l13: $ g , x : A ⊢ Ty (Id A x u) $ by Id_form [l3, l12]
l14: $ g , x : A ⊢ (λ w : Id A x u. w) : (Id A x u → Id A x u) $
  by id_ty [l13]
l15: $ g ⊢ ≡[[x/s] [y/s] [z/refl A s] (Id A y u → Id A x u)]
  (J x y z A (Id A y u → Id A x u) (λ w : Id A x u. w)
    s s (refl A s)) = (⟦ x / s ⟧ (λ w : Id A x u. w)) $
  by J_beta [l11, l14, l1]
l16: $ g ⊢ ≡[Id A s u]
  ((J x y z A (Id A y u → Id A x u) (λ w : Id A x u. w)
    s s (refl A s)) · q) = ((λ w : Id A s u. w) · q) $
  by app_eq_left [l15, #1]
l17: $ g ⊢ Ty (Id A s u) $ by Id_form [l1, l2]
l18: $ g , w : Id A s u ⊢ Ty (Id A s u) $ by weaken [l17]
l19: $ g , w : Id A s u ⊢ w : Id A s u $ by var
l20: $ g ⊢ (λ w : Id A s u. w) : (Id A s u → Id A s u) $
  by lam_intro [l17, l18, l19]
l21: $ g ⊢ ≡[Id A s u] ((λ w : Id A s u. w) · q) = q $
  by app_beta [l20, #1]
l22: $ g ⊢ ≡[Id A s u]
  ((J x y z A (Id A y u → Id A x u) (λ w : Id A x u. w)
    s s (refl A s)) · q) = q $ by eq_tm_trans [l16, l21]

ap_ty
-----

l1: $ g , x : A ⊢ f : (A → B) $ by weaken [#1]
l2: $ g , x : A ⊢ x : A $ by var
l3: $ g , x : A , y : A ⊢ y : A $ by var
l4: $ g , x : A , y : A , q : Id A x y ⊢ f : (A → B) $
  by weaken3 [#1]
l5: $ g , x : A , y : A , q : Id A x y ⊢ x : A $ by weaken2 [l2]
l6: $ g , x : A , y : A , q : Id A x y ⊢ y : A $ by weaken [l3]
l7: $ g , x : A , y : A , q : Id A x y ⊢ f · x : B $
  by app_elim [l4, l5]
l8: $ g , x : A , y : A , q : Id A x y ⊢ f · y : B $
  by app_elim [l4, l6]
l9: $ g , x : A , y : A , q : Id A x y ⊢ Ty (Id B (f · x) (f · y)) $
  by Id_form [l7, l8]
l10: $ g , x : A ⊢ f · x : B $ by app_elim [l1, l2]
l11: $ g , x : A ⊢ refl B (f · x) : Id B (f · x) (f · x) $
  by refl_intro [l10]
l12: $ g ⊢ J x y q A (Id B (f · x) (f · y))
  (refl B (f · x)) s t p : Id B (f · s) (f · t) $
  by J_elim [l9, l11, #2]

ap_refl
-------

l1: $ g , x : A ⊢ f : (A → B) $ by weaken [#1]
l2: $ g , x : A ⊢ x : A $ by var
l3: $ g , x : A , y : A ⊢ y : A $ by var
l4: $ g , x : A , y : A , q : Id A x y ⊢ f : (A → B) $
  by weaken3 [#1]
l5: $ g , x : A , y : A , q : Id A x y ⊢ x : A $ by weaken2 [l2]
l6: $ g , x : A , y : A , q : Id A x y ⊢ y : A $ by weaken [l3]
l7: $ g , x : A , y : A , q : Id A x y ⊢ f · x : B $
  by app_elim [l4, l5]
l8: $ g , x : A , y : A , q : Id A x y ⊢ f · y : B $
  by app_elim [l4, l6]
l9: $ g , x : A , y : A , q : Id A x y ⊢ Ty (Id B (f · x) (f · y)) $
  by Id_form [l7, l8]
l10: $ g , x : A ⊢ f · x : B $ by app_elim [l1, l2]
l11: $ g , x : A ⊢ refl B (f · x) : Id B (f · x) (f · x) $
  by refl_intro [l10]
l12: $ g ⊢ ≡[Id B (f · s) (f · s)]
  (J x y q A (Id B (f · x) (f · y)) (refl B (f · x))
    s s (refl A s)) = (refl B (f · s)) $
  by J_beta [l9, l11, #2]

ap_suc_ty
---------

l1: $ g , x : Nat ⊢ x : Nat $ by var
l2: $ g , x : Nat ⊢ suc x : Nat $ by suc_intro [l1]
l3: $ g , x : Nat , y : Nat ⊢ y : Nat $ by var
l4: $ g , x : Nat , y : Nat , q : Id Nat x y ⊢ suc x : Nat $
  by weaken2 [l2]
l5: $ g , x : Nat , y : Nat , q : Id Nat x y ⊢ y : Nat $ by weaken [l3]
l6: $ g , x : Nat , y : Nat , q : Id Nat x y ⊢ suc y : Nat $
  by suc_intro [l5]
l7: $ g , x : Nat , y : Nat , q : Id Nat x y ⊢
  Ty (Id Nat (suc x) (suc y)) $ by Id_form [l4, l6]
l8: $ g , x : Nat ⊢ refl Nat (suc x) : Id Nat (suc x) (suc x) $
  by refl_intro [l2]
l9: $ g ⊢ ap_suc s t p : Id Nat (suc s) (suc t) $
  by J_elim [l7, l8, #1]

ap_suc_refl
-----------

l1: $ g , x : Nat ⊢ x : Nat $ by var
l2: $ g , x : Nat ⊢ suc x : Nat $ by suc_intro [l1]
l3: $ g , x : Nat , y : Nat ⊢ y : Nat $ by var
l4: $ g , x : Nat , y : Nat , q : Id Nat x y ⊢ suc x : Nat $
  by weaken2 [l2]
l5: $ g , x : Nat , y : Nat , q : Id Nat x y ⊢ y : Nat $ by weaken [l3]
l6: $ g , x : Nat , y : Nat , q : Id Nat x y ⊢ suc y : Nat $
  by suc_intro [l5]
l7: $ g , x : Nat , y : Nat , q : Id Nat x y ⊢
  Ty (Id Nat (suc x) (suc y)) $ by Id_form [l4, l6]
l8: $ g , x : Nat ⊢ refl Nat (suc x) : Id Nat (suc x) (suc x) $
  by refl_intro [l2]
l9: $ g ⊢ ≡[Id Nat (suc s) (suc s)]
  (ap_suc s s (refl Nat s)) = refl Nat (suc s) $
  by J_beta [l7, l8, #1]

transport_ty
------------

l1: $ g , x : A , y : A , q : Id A x y ⊢ Ty B $ by weaken2 [#1]
l2: $ g , x : A , y : A , q : Id A x y ⊢ Ty ([x/y] B) $
  by sb_ty_var_form [#1]
l3: $ g , x : A , y : A , q : Id A x y , w : B ⊢ Ty ([x/y] B) $
  by weaken [l2]
l4: $ g , x : A , y : A , q : Id A x y ⊢ Ty (B → [x/y] B) $
  by pi_form [l1, l3]
l5: $ g , x : A ⊢ (λ w : B. w) : (B → B) $ by id_ty [#1]
l6: $ g ⊢ J x y q A (B → [x/y] B) (λ w : B. w) s t p :
  ([x/s] B → [x/t] B) $
  by J_elim [l4, l5, #2]
l7: $ g ⊢ (J x y q A (B → [x/y] B) (λ w : B. w) s t p) · u :
  [x/t] B $ by app_elim [l6, #3]

transport_refl
--------------

l1: $ g , x : A , y : A , q : Id A x y ⊢ Ty B $ by weaken2 [#1]
l2: $ g , x : A , y : A , q : Id A x y ⊢ Ty ([x/y] B) $
  by sb_ty_var_form [#1]
l3: $ g , x : A , y : A , q : Id A x y , w : B ⊢ Ty ([x/y] B) $
  by weaken [l2]
l4: $ g , x : A , y : A , q : Id A x y ⊢ Ty (B → [x/y] B) $
  by pi_form [l1, l3]
l5: $ g , x : A ⊢ (λ w : B. w) : (B → B) $ by id_ty [#1]
l6: $ g ⊢ ≡[[x/s] [y/s] [q/refl A s] (B → [x/y] B)]
  (J x y q A (B → [x/y] B) (λ w : B. w) s s (refl A s)) =
  (⟦ x / s ⟧ (λ w : B. w)) $ by J_beta [l4, l5, #2]
l7: $ g ⊢ ≡[[x/s] B]
  ((J x y q A (B → [x/y] B) (λ w : B. w) s s (refl A s)) · u) =
  ((λ w : [x/s] B. w) · u) $ by app_eq_left [l6, #3]
l8: $ g ⊢ Ty ([x/s] B) $ by sb_ty_form [#1, #2]
l9: $ g ⊢ (λ w : [x/s] B. w) : ([x/s] B → [x/s] B) $
  by id_ty [l8]
l10: $ g ⊢ ≡[[x/s] B] ((λ w : [x/s] B. w) · u) = u $
  by app_beta [l9, #3]
l11: $ g ⊢ ≡[[x/s] B]
  ((J x y q A (B → [x/y] B) (λ w : B. w) s s (refl A s)) · u) = u $
  by eq_tm_trans [l7, l10]

-- ==================================================================
-- SECTION 6: Arithmetic warmup
-- ==================================================================

suc_fn_ty
---------

l1: $ g ⊢ Ty Nat $ by nat_form
l2: $ g , k : Nat ⊢ Ty Nat $ by nat_form
l3: $ g , k : Nat ⊢ k : Nat $ by var
l4: $ g , k : Nat ⊢ suc k : Nat $ by suc_intro [l3]
l5: $ g ⊢ suc_fn : (Nat → Nat) $ by lam_intro [l1, l2, l4]

add_ty
------

l1: $ g ⊢ suc_fn : (Nat → Nat) $ by suc_fn_ty
l2: $ g ⊢ m + n : Nat $ by nat_rec_ty [#2, l1, #1]

add_zero_left
-------------

l1: $ g ⊢ suc_fn : (Nat → Nat) $ by suc_fn_ty
l2: $ g ⊢ ≡[Nat] (zero + n) = n $ by nat_rec_zero [#1, l1]

add_suc_left
------------

l1: $ g ⊢ Ty Nat $ by nat_form
l2: $ g , k : Nat ⊢ Ty Nat $ by nat_form
l3: $ g , k : Nat ⊢ k : Nat $ by var
l4: $ g , k : Nat ⊢ suc k : Nat $ by suc_intro [l3]
l5: $ g ⊢ (λ k : Nat. suc k) : (Nat → Nat) $
  by lam_intro [l1, l2, l4]
l6: $ g ⊢ m + n : Nat $ by add_ty [#1, #2]
l7: $ g ⊢ ≡[Nat] ((suc m) + n) =
  ((λ k : Nat. suc k) · (m + n)) $ by nat_rec_suc [#2, l5, #1]
l8: $ g ⊢ ≡[Nat] ((λ k : Nat. suc k) · (m + n)) = suc (m + n) $
  by app_beta [l5, l6]
l9: $ g ⊢ ≡[Nat] ((suc m) + n) = suc (m + n) $
  by eq_tm_trans [l7, l8]

one_plus_one
------------

l1: $ g ⊢ zero : Nat $ by zero_intro
l2: $ g ⊢ suc zero : Nat $ by suc_intro [l1]
l3: $ g ⊢ ≡[Nat] ((suc zero) + (suc zero)) =
  suc (zero + (suc zero)) $ by add_suc_left [l1, l2]
l4: $ g ⊢ ≡[Nat] (zero + (suc zero)) = suc zero $
  by add_zero_left [l2]
l5: $ g ⊢ ≡[Nat] suc (zero + (suc zero)) = suc (suc zero) $
  by suc_eq [l4]
l6: $ g ⊢ ≡[Nat] ((suc zero) + (suc zero)) = (suc (suc zero)) $
  by eq_tm_trans [l3, l5]

add_zero_right
--------------

l1: $ g , k : Nat ⊢ k : Nat $ by var
l2: $ g , k : Nat ⊢ zero : Nat $ by zero_intro
l3: $ g , k : Nat ⊢ k + zero : Nat $ by add_ty [l1, l2]
l4: $ g , k : Nat ⊢ Ty (Id Nat (k + zero) k) $
  by Id_form [l3, l1]
l5: $ g ⊢ zero : Nat $ by zero_intro
l6: $ g ⊢ ≡[Nat] (zero + zero) = zero $ by add_zero_left [l5]
l7: $ g ⊢ refl Nat (zero + zero) : Id Nat (zero + zero) zero $
  by eq_tm_to_Id [l6]
l8: $ g , k : Nat , ih : Id Nat (k + zero) k ⊢ k : Nat $
  by weaken [l1]
l9: $ g , k : Nat , ih : Id Nat (k + zero) k ⊢ zero : Nat $
  by zero_intro
l10: $ g , k : Nat , ih : Id Nat (k + zero) k ⊢
  ≡[Nat] ((suc k) + zero) = suc (k + zero) $
  by add_suc_left [l8, l9]
l11: $ g , k : Nat , ih : Id Nat (k + zero) k ⊢
  refl Nat ((suc k) + zero) : Id Nat ((suc k) + zero) (suc (k + zero)) $
  by eq_tm_to_Id [l10]
l12: $ g , k : Nat , ih : Id Nat (k + zero) k ⊢
  ih : Id Nat (k + zero) k $ by var
l13: $ g , k : Nat , ih : Id Nat (k + zero) k ⊢
  ap_suc (k + zero) k ih : Id Nat (suc (k + zero)) (suc k) $
  by ap_suc_ty [l12]
l14: $ g , k : Nat , ih : Id Nat (k + zero) k ⊢
  id_trans Nat ((suc k) + zero) (suc (k + zero)) (suc k)
    (refl Nat ((suc k) + zero)) (ap_suc (k + zero) k ih) :
  Id Nat ((suc k) + zero) (suc k) $
  by id_trans_ty [l11, l13]
l15: $ g ⊢ add_zero_right_p m : Id Nat (m + zero) m $
  by nat_ind_elim [l4, l7, l14, #1]

add_suc_right
-------------

l1: $ g , k : Nat ⊢ k : Nat $ by var
l2: $ g , k : Nat ⊢ n : Nat $ by weaken [#2]
l3: $ g , k : Nat ⊢ suc n : Nat $ by suc_intro [l2]
l4: $ g , k : Nat ⊢ k + suc n : Nat $ by add_ty [l1, l3]
l5: $ g , k : Nat ⊢ k + n : Nat $ by add_ty [l1, l2]
l6: $ g , k : Nat ⊢ suc (k + n) : Nat $ by suc_intro [l5]
l7: $ g , k : Nat ⊢ Ty (Id Nat (k + suc n) (suc (k + n))) $
  by Id_form [l4, l6]
l8: $ g ⊢ suc n : Nat $ by suc_intro [#2]
l9: $ g ⊢ ≡[Nat] (zero + suc n) = suc n $ by add_zero_left [l8]
l10: $ g ⊢ refl Nat (zero + suc n) : Id Nat (zero + suc n) (suc n) $
  by eq_tm_to_Id [l9]
l11: $ g ⊢ ≡[Nat] (zero + n) = n $ by add_zero_left [#2]
l12: $ g ⊢ ≡[Nat] suc (zero + n) = suc n $ by suc_eq [l11]
l13: $ g ⊢ refl Nat (suc (zero + n)) : Id Nat (suc (zero + n)) (suc n) $
  by eq_tm_to_Id [l12]
l14: $ g ⊢ id_sym Nat (suc (zero + n)) (suc n)
  (refl Nat (suc (zero + n))) : Id Nat (suc n) (suc (zero + n)) $
  by id_sym_ty [l13]
l15: $ g ⊢ id_trans Nat (zero + suc n) (suc n) (suc (zero + n))
  (refl Nat (zero + suc n))
  (id_sym Nat (suc (zero + n)) (suc n)
    (refl Nat (suc (zero + n)))) :
  Id Nat (zero + suc n) (suc (zero + n)) $
  by id_trans_ty [l10, l14]
l16: $ g , k : Nat , ih : Id Nat (k + suc n) (suc (k + n)) ⊢ k : Nat $
  by weaken [l1]
l17: $ g , k : Nat , ih : Id Nat (k + suc n) (suc (k + n)) ⊢ n : Nat $
  by weaken [l2]
l18: $ g , k : Nat , ih : Id Nat (k + suc n) (suc (k + n)) ⊢ suc n : Nat $
  by suc_intro [l17]
l19: $ g , k : Nat , ih : Id Nat (k + suc n) (suc (k + n)) ⊢
  ≡[Nat] ((suc k) + suc n) = suc (k + suc n) $
  by add_suc_left [l16, l18]
l20: $ g , k : Nat , ih : Id Nat (k + suc n) (suc (k + n)) ⊢
  refl Nat ((suc k) + suc n) :
  Id Nat ((suc k) + suc n) (suc (k + suc n)) $
  by eq_tm_to_Id [l19]
l21: $ g , k : Nat , ih : Id Nat (k + suc n) (suc (k + n)) ⊢
  ih : Id Nat (k + suc n) (suc (k + n)) $ by var
l22: $ g , k : Nat , ih : Id Nat (k + suc n) (suc (k + n)) ⊢
  ap_suc (k + suc n) (suc (k + n)) ih :
  Id Nat (suc (k + suc n)) (suc (suc (k + n))) $
  by ap_suc_ty [l21]
l23: $ g , k : Nat , ih : Id Nat (k + suc n) (suc (k + n)) ⊢
  ≡[Nat] ((suc k) + n) = suc (k + n) $ by add_suc_left [l16, l17]
l24: $ g , k : Nat , ih : Id Nat (k + suc n) (suc (k + n)) ⊢
  refl Nat ((suc k) + n) : Id Nat ((suc k) + n) (suc (k + n)) $
  by eq_tm_to_Id [l23]
l25: $ g , k : Nat , ih : Id Nat (k + suc n) (suc (k + n)) ⊢
  ap_suc ((suc k) + n) (suc (k + n)) (refl Nat ((suc k) + n)) :
  Id Nat (suc ((suc k) + n)) (suc (suc (k + n))) $
  by ap_suc_ty [l24]
l26: $ g , k : Nat , ih : Id Nat (k + suc n) (suc (k + n)) ⊢
  id_sym Nat (suc ((suc k) + n)) (suc (suc (k + n)))
    (ap_suc ((suc k) + n) (suc (k + n)) (refl Nat ((suc k) + n))) :
  Id Nat (suc (suc (k + n))) (suc ((suc k) + n)) $
  by id_sym_ty [l25]
l27: $ g , k : Nat , ih : Id Nat (k + suc n) (suc (k + n)) ⊢
  id_trans Nat (suc (k + suc n)) (suc (suc (k + n)))
    (suc ((suc k) + n)) (ap_suc (k + suc n) (suc (k + n)) ih)
    (id_sym Nat (suc ((suc k) + n)) (suc (suc (k + n)))
      (ap_suc ((suc k) + n) (suc (k + n))
        (refl Nat ((suc k) + n)))) :
  Id Nat (suc (k + suc n)) (suc ((suc k) + n)) $
  by id_trans_ty [l22, l26]
l28: $ g , k : Nat , ih : Id Nat (k + suc n) (suc (k + n)) ⊢
  id_trans Nat ((suc k) + suc n) (suc (k + suc n))
    (suc ((suc k) + n)) (refl Nat ((suc k) + suc n))
    (id_trans Nat (suc (k + suc n)) (suc (suc (k + n)))
      (suc ((suc k) + n)) (ap_suc (k + suc n) (suc (k + n)) ih)
      (id_sym Nat (suc ((suc k) + n)) (suc (suc (k + n)))
        (ap_suc ((suc k) + n) (suc (k + n))
          (refl Nat ((suc k) + n))))) :
  Id Nat ((suc k) + suc n) (suc ((suc k) + n)) $
  by id_trans_ty [l20, l27]
l29: $ g ⊢ add_suc_right_p m n : Id Nat (m + suc n) (suc (m + n)) $
  by nat_ind_elim [l7, l15, l28, #1]

add_comm
--------

l1: $ g , k : Nat ⊢ k : Nat $ by var
l2: $ g , k : Nat ⊢ n : Nat $ by weaken [#2]
l3: $ g , k : Nat ⊢ k + n : Nat $ by add_ty [l1, l2]
l4: $ g , k : Nat ⊢ n + k : Nat $ by add_ty [l2, l1]
l5: $ g , k : Nat ⊢ Ty (Id Nat (k + n) (n + k)) $
  by Id_form [l3, l4]
l6: $ g ⊢ ≡[Nat] (zero + n) = n $ by add_zero_left [#2]
l7: $ g ⊢ refl Nat (zero + n) : Id Nat (zero + n) n $
  by eq_tm_to_Id [l6]
l8: $ g ⊢ add_zero_right_p n : Id Nat (n + zero) n $
  by add_zero_right [#2]
l9: $ g ⊢ id_sym Nat (n + zero) n (add_zero_right_p n) :
  Id Nat n (n + zero) $ by id_sym_ty [l8]
l10: $ g ⊢ id_trans Nat (zero + n) n (n + zero)
  (refl Nat (zero + n)) (id_sym Nat (n + zero) n (add_zero_right_p n)) :
  Id Nat (zero + n) (n + zero) $
  by id_trans_ty [l7, l9]
l11: $ g , k : Nat , ih : Id Nat (k + n) (n + k) ⊢ k : Nat $
  by weaken [l1]
l12: $ g , k : Nat , ih : Id Nat (k + n) (n + k) ⊢ n : Nat $
  by weaken [l2]
l13: $ g , k : Nat , ih : Id Nat (k + n) (n + k) ⊢
  ≡[Nat] ((suc k) + n) = suc (k + n) $ by add_suc_left [l11, l12]
l14: $ g , k : Nat , ih : Id Nat (k + n) (n + k) ⊢
  refl Nat ((suc k) + n) : Id Nat ((suc k) + n) (suc (k + n)) $
  by eq_tm_to_Id [l13]
l15: $ g , k : Nat , ih : Id Nat (k + n) (n + k) ⊢
  ih : Id Nat (k + n) (n + k) $ by var
l16: $ g , k : Nat , ih : Id Nat (k + n) (n + k) ⊢
  ap_suc (k + n) (n + k) ih : Id Nat (suc (k + n)) (suc (n + k)) $
  by ap_suc_ty [l15]
l17: $ g , k : Nat , ih : Id Nat (k + n) (n + k) ⊢
  add_suc_right_p n k : Id Nat (n + suc k) (suc (n + k)) $
  by add_suc_right [l12, l11]
l18: $ g , k : Nat , ih : Id Nat (k + n) (n + k) ⊢
  id_sym Nat (n + suc k) (suc (n + k)) (add_suc_right_p n k) :
  Id Nat (suc (n + k)) (n + suc k) $
  by id_sym_ty [l17]
l19: $ g , k : Nat , ih : Id Nat (k + n) (n + k) ⊢
  id_trans Nat (suc (k + n)) (suc (n + k)) (n + suc k)
    (ap_suc (k + n) (n + k) ih)
    (id_sym Nat (n + suc k) (suc (n + k)) (add_suc_right_p n k)) :
  Id Nat (suc (k + n)) (n + suc k) $
  by id_trans_ty [l16, l18]
l20: $ g , k : Nat , ih : Id Nat (k + n) (n + k) ⊢
  id_trans Nat ((suc k) + n) (suc (k + n)) (n + suc k)
    (refl Nat ((suc k) + n))
    (id_trans Nat (suc (k + n)) (suc (n + k)) (n + suc k)
      (ap_suc (k + n) (n + k) ih)
      (id_sym Nat (n + suc k) (suc (n + k)) (add_suc_right_p n k))) :
  Id Nat ((suc k) + n) (n + suc k) $
  by id_trans_ty [l14, l19]
l21: $ g ⊢ add_comm_p m n : Id Nat (m + n) (n + m) $
  by nat_ind_elim [l5, l10, l20, #1]
