l27: $ G , ≃[𝔹] x = p , y: 𝔹 ⊩ λ f: 𝔹 → 𝔹 → 𝔹. f · T · T:
      (𝔹 → 𝔹 → 𝔹) → 𝔹 $ by weaken [l16]
l28: $ G , ≃[𝔹] x = p , y: 𝔹 , f: 𝔹 → 𝔹 → 𝔹 ⊩
      ≃[𝔹] f · x · y = f · p · y $ by bineq1 [l24, l23, l26]
l29: $ G , ≃[𝔹] x = p , y: 𝔹 ⊩ ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
      (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) =
      (λ f: 𝔹 → 𝔹 → 𝔹. f · p · y) $ by leqt [l28]
l30: $ G , ≃[𝔹] x = p , y: 𝔹 ⊩ eq ((𝔹 → 𝔹 → 𝔹) → 𝔹):
      ((𝔹 → 𝔹 → 𝔹) → 𝔹) → ((𝔹 → 𝔹 → 𝔹) → 𝔹) → 𝔹 $ by eqT
l31: $ G , ≃[𝔹] x = p , y: 𝔹 ⊩
      ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
        (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) =
