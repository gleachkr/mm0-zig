lamTR
------
l1: $ G , x: A ⊩ λ x: A. t: A → B $ by weaken [#1]
l2: $ G , x: A ⊩ x: A $ by ax
l3: $ _wff $ by appT [l1, l2]
l4: $ _wff $ by betat [l3]
l5: $ _wff $ by eqTR2 [l4]

cbv
----
l1: $ _wff $ by lamT [#1]
l2: $ _wff $ by etat (x := $ y $) [l1]
l3: $ _wff $ by sym [l2]
l4: $ G , y: A , x: A ⊩ t: B $ by weaken [#1]
l5: $ G , y: A ⊩ y: A $ by ax
l6: $ G , y: A , ≃[A] x = y ⊩ ≃[B] t = u $ by weaken [#3]
l7: $ G , y: A ⊩ ≃[B] (λ x: A. t) · y = u $ by betacv [l4, l5, #2, l6]
l8: $ _wff $ by leqt [l7]
l9: $ _wff $ by trans [l3, l8]

eqcT
-----
l1: $ G ⊩ eq A: A → A → 𝔹 $ by eqT
l2: $ _wff $ by appT [l1, #1]
l3: $ _wff $ by appT [l2, #2]

T_DEF
------
l1: $ G , x: 𝔹 ⊩ x: 𝔹 $ by ax
l2: $ _wff $ by lamT [l1]
l3: $ _wff $ by reflt [l2]
l4: $ _wff $ by thmR [l3]
l5: $ _wff $ by reflt [l4]

TT
---
l1: $ G ⊩ ≃[𝔹] T = =[𝔹 → 𝔹] (λ x: 𝔹. x) = (λ x: 𝔹. x) $ by T_DEF
l2: $ _wff $ by eqTR1 [l1]

TRUTH
------
l1: $ G , x: 𝔹 ⊩ x: 𝔹 $ by ax
l2: $ _wff $ by lamT [l1]
l3: $ _wff $ by reflt [l2]

EQT_ELIM
---------
l1: $ G ⊩ T $ by TRUTH
l2: $ _wff $ by eqmpr [#1, l1]

EQT_INTRO
----------
l1: $ G ⊩ T $ by TRUTH
l2: $ G , P ⊩ T $ by weaken [l1]
l3: $ G , T ⊩ P $ by weaken [#1]
l4: $ _wff $ by ded [l2, l3]

AND_DEF
--------
l1: $ G , x: 𝔹 , y: 𝔹 , f: 𝔹 → 𝔹 → 𝔹 ⊩ f: 𝔹 → 𝔹 → 𝔹 $ by ax
