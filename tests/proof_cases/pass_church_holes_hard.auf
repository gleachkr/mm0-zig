l6: $ G ⊩ ≃[𝔹 → 𝔹] not = (λ q: 𝔹. q ⇒ F) $ by NOT_DEF
l7: $ G ⊩ ≃[𝔹] not · p = ((λ q: 𝔹. q ⇒ F) · p) $ by aeq1 [l6, #1]
l8: $ G ⊩ p ⇒ F ⇔ (p ⋏ F ⇔ p) $ by IMPC_DEF [#1, l1]
l9: $ G ⊩ p ⇒ F: 𝔹 $ by eqTR1 [l8]
l10: $ G , ≃[𝔹] q = p ⊩ ≃[𝔹] q = p $ by ax
l11: $ G , ≃[𝔹] q = p ⊩ F: 𝔹 $ by weaken [l1]
l12: $ _wff $ by eqTR1 [l10]
l13: $ _wff $ by eqTR2 [l10]
l14: $ G , ≃[𝔹] q = p ⊩ and: 𝔹 → 𝔹 → 𝔹 $ by andT
l15: $ G , ≃[𝔹] q = p ⊩ q ⋏ F ⇔ p ⋏ F $ by bineq1 [l14, l10, l11]
l16: $ G , ≃[𝔹] q = p ⊩ eq 𝔹: 𝔹 → 𝔹 → 𝔹 $ by eqT
l17: $ G , ≃[𝔹] q = p ⊩ (q ⋏ F ⇔ q) ⇔ (p ⋏ F ⇔ p) $ by bineq [l16, l15, l10]
l18: $ G , ≃[𝔹] q = p ⊩ q ⇒ F ⇔ (q ⋏ F ⇔ q) $ by IMPC_DEF [l12, l11]
l19: $ G , ≃[𝔹] q = p ⊩ p ⇒ F ⇔ (p ⋏ F ⇔ p) $ by IMPC_DEF [l13, l11]
l20: $ G , ≃[𝔹] q = p ⊩ (p ⋏ F ⇔ p) ⇔ p ⇒ F $ by sym [l19]
l21: $ G , ≃[𝔹] q = p ⊩ q ⇒ F ⇔ (p ⋏ F ⇔ p) $ by trans [l18, l17]
l22: $ G , ≃[𝔹] q = p ⊩ q ⇒ F ⇔ p ⇒ F $ by trans [l21, l20]
l23: $ G ⊩ ≃[𝔹] ((λ q: 𝔹. q ⇒ F) · p) = (p ⇒ F) $ by betacv [l5, #1, l9, l22]
l24: $ G ⊩ ¬ p ⇔ (p ⇒ F) $ by trans [l7, l23]

NOT_ELIM
---------
l1: $ G ⊩ p: 𝔹 $ by notR [#1]
l2: $ G ⊩ ¬ p ⇔ (p ⇒ F) $ by notc_def [l1]
l3: $ G ⊩ p ⇒ F $ by eqmp [l2, #1]

NOT_INTRO
----------
l1: $ G ⊩ ¬ p ⇔ (p ⇒ F) $ by notc_def [#1]
l2: $ _wff $ by eqmpr [l1, #2]

NOT_FALSE
----------
l1: $ G ⊩ F: 𝔹 $ by FT
l2: $ G , F ⊩ F $ by ax
l3: $ G ⊩ F ⇒ F $ by DISCH [l1, l1, l2]
l4: $ G ⊩ ¬ F $ by NOT_INTRO [l1, l3]

IMP_ANTISYM
------------
l1: $ G , p ⊩ p ⇒ q $ by weaken [#1]
l2: $ G , p ⊩ p $ by ax
l3: $ _wff $ by MP [l1, l2]
l4: $ G , q ⊩ q ⇒ p $ by weaken [#2]
l5: $ G , q ⊩ q $ by ax
l6: $ _wff $ by MP [l4, l5]
l7: $ G ⊩ p ⇔ q $ by ded [l3, l6]

EQ_IMP1
--------
l1: $ _wff $ by eqTR1 [#1]
l2: $ _wff $ by eqTR2 [#1]
l3: $ G , p ⊩ p ⇔ q $ by weaken [#1]
l4: $ G , p ⊩ p $ by ax
l5: $ _wff $ by eqmp [l3, l4]
l6: $ G ⊩ p ⇒ q $ by DISCH [l1, l2, l5]

EQ_IMP2
--------
l1: $ G ⊩ q ⇔ p $ by sym [#1]
l2: $ G ⊩ q ⇒ p $ by EQ_IMP1 [l1]

IMP_ID
-------
l1: $ G , p ⊩ p $ by ax
l2: $ G ⊩ p ⇒ p $ by DISCH [#1, #1, l1]

IMP_TRANS
----------
l1: $ _wff $ by impR1 [#1]
l2: $ _wff $ by impR2 [#2]
l3: $ G , p ⊩ p ⇒ q $ by weaken [#1]
l4: $ G , p ⊩ p $ by ax
l5: $ _wff $ by MP [l3, l4]
l6: $ G , p ⊩ q ⇒ r $ by weaken [#2]
l7: $ _wff $ by MP [l6, l5]
l8: $ G ⊩ p ⇒ r $ by DISCH [l1, l2, l7]

CONJ_COMM
----------
l1: $ G ⊩ p ⋏ q: 𝔹 $ by andcT [#1, #2]
l2: $ G ⊩ q ⋏ p: 𝔹 $ by andcT [#2, #1]
l3: $ G , p ⋏ q ⊩ p ⋏ q $ by ax
l4: $ _wff $ by CONJUNCT2 [l3]
l5: $ _wff $ by CONJUNCT1 [l3]
l6: $ G , p ⋏ q ⊩ q ⋏ p $ by CONJ [l4, l5]
l7: $ G ⊩ p ⋏ q ⇒ q ⋏ p $ by DISCH [l1, l2, l6]

CONJ_ASSOC
-----------
l1: $ G ⊩ p ⋏ q: 𝔹 $ by andcT [#1, #2]
l2: $ G ⊩ (p ⋏ q) ⋏ r: 𝔹 $ by andcT [l1, #3]
l3: $ G ⊩ q ⋏ r: 𝔹 $ by andcT [#2, #3]
l4: $ G ⊩ p ⋏ (q ⋏ r): 𝔹 $ by andcT [#1, l3]
l5: $ G , (p ⋏ q) ⋏ r ⊩ (p ⋏ q) ⋏ r $ by ax
l6: $ G , (p ⋏ q) ⋏ r ⊩ p ⋏ q $ by CONJUNCT1 [l5]
l7: $ _wff $ by CONJUNCT1 [l6]
l8: $ _wff $ by CONJUNCT2 [l6]
l9: $ _wff $ by CONJUNCT2 [l5]
l10: $ G , (p ⋏ q) ⋏ r ⊩ q ⋏ r $ by CONJ [l8, l9]
l11: $ G , (p ⋏ q) ⋏ r ⊩ p ⋏ (q ⋏ r) $ by CONJ [l7, l10]
l12: $ G ⊩ (p ⋏ q) ⋏ r ⇒ p ⋏ (q ⋏ r) $ by DISCH [l2, l4, l11]

IMP_CONJ_CHAIN
---------------
l1: $ _wff $ by impR1 [#1]
l2: $ _wff $ by impR1 [#2]
l3: $ _wff $ by impR2 [#2]
l4: $ G ⊩ q ⋏ r: 𝔹 $ by andcT [l2, l3]
l5: $ _wff $ by UNDISCH [#1]
l6: $ G , p ⊩ q ⇒ r $ by weaken [#2]
l7: $ _wff $ by MP [l6, l5]
l8: $ G , p ⊩ q ⋏ r $ by CONJ [l5, l7]
l9: $ G ⊩ p ⇒ q ⋏ r $ by DISCH [l1, l4, l8]

EQF_INTRO
----------
l1: $ G ⊩ p: 𝔹 $ by notR [#1]
l2: $ G ⊩ p ⇒ F $ by NOT_ELIM [#1]
l3: $ G , F ⊩ p: 𝔹 $ by weaken [l1]
l4: $ G , F ⊩ F $ by ax
l5: $ G , F ⊩ p $ by CONTR [l3, l4]
l6: $ G ⊩ F: 𝔹 $ by FT
l7: $ G ⊩ F ⇒ p $ by DISCH [l6, l1, l5]
l8: $ G ⊩ p ⇔ F $ by IMP_ANTISYM [l2, l7]

EQF_ELIM
---------
l1: $ G ⊩ p ⇒ F $ by EQ_IMP1 [#1]
l2: $ _wff $ by eqTR1 [#1]
l3: $ G ⊩ ¬ p $ by NOT_INTRO [l2, l1]
