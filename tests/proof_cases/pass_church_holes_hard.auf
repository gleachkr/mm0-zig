l2: $ _wff $ by appT [l1, #1]
l3: $ _wff $ by appT [l2, #2]

andc_def
---------
l1: $ G ⊩ ≃[𝔹 → 𝔹 → 𝔹] and =
      (λ x: 𝔹. λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
        (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) =
        (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T)) $ by AND_DEF
l2: $ G ⊩ ≃[𝔹 → 𝔹] and · p =
      ((λ x: 𝔹. λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
          (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) =
          (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T)) · p) $ by aeq1 [l1, #1]
l3: $ G ⊩ λ x: 𝔹. λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
      (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) =
      (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T): 𝔹 → 𝔹 → 𝔹 $ by eqTR2 [l1]
l4: $ G , x: 𝔹 ⊩ λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
      (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) =
      (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T): 𝔹 → 𝔹 $ by lamTR [l3]
l5: $ G , y: 𝔹 , f: 𝔹 → 𝔹 → 𝔹 ⊩ f: 𝔹 → 𝔹 → 𝔹 $ by ax
l6: $ G , y: 𝔹 ⊩ y: 𝔹 $ by ax
