sym
----
l1: $ G ⊩ eq A: A → A → 𝔹 $ by eqT
l2: $ _wff $ by eqTR1 [#1]
l3: $ _wff $ by bineq1 [l1, #1, l2]
l4: $ _wff $ by reflt [l2]
l5: $ _wff $ by eqmp [l3, l4]

trans
------
