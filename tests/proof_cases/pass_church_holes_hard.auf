      ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
        (λ f: 𝔹 → 𝔹 → 𝔹. f · p · q) =
        (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T) $ by bineq1 [l49, l47, l48]
l51: $ G ⊩ ≃[𝔹]
      ((λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
          (λ f: 𝔹 → 𝔹 → 𝔹. f · p · y) =
          (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T)) · q) =
      ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
        (λ f: 𝔹 → 𝔹 → 𝔹. f · p · q) =
        (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T) $ by betacv [l19, #2, l41, l50]
l52: $ G ⊩ ≃[𝔹] and · p · q =
      ((λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
          (λ f: 𝔹 → 𝔹 → 𝔹. f · p · y) =
          (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T)) · q) $ by aeq1 [l34, #2]
l53: $ G ⊩ p ⋏ q ⇔ ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
      (λ f: 𝔹 → 𝔹 → 𝔹. f · p · q) =
      (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T) $ by trans [l52, l51]

CONJ
-----
l1: $ _wff $ by thmR [#1]
l2: $ _wff $ by thmR [#2]
l3: $ G , f: 𝔹 → 𝔹 → 𝔹 ⊩ f: 𝔹 → 𝔹 → 𝔹 $ by ax
