l14: $ G ⊩ p ⋏ q ⇔ ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
      (λ f: 𝔹 → 𝔹 → 𝔹. f · p · q) =
      (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T) $ by andc_def [l1, l2]
l15: $ _wff $ by eqmpr [l14, l13]

lemma proj1 (G: ctx) {x y: term}: $ G ⊩ λ x: 𝔹. λ y: 𝔹. x: 𝔹 → 𝔹 → 𝔹 $
--------------------------------------------------------------------------
l1: $ G , x: 𝔹 ⊩ x: 𝔹 $ by ax
l2: $ G , x: 𝔹 , y: 𝔹 ⊩ x: 𝔹 $ by weaken [l1]
l3: $ _wff $ by lamT [l2]
l4: $ _wff $ by lamT [l3]

lemma proj2 (G: ctx) {x y: term}: $ G ⊩ λ x: 𝔹. λ y: 𝔹. y: 𝔹 → 𝔹 → 𝔹 $
--------------------------------------------------------------------------
l1: $ G , x: 𝔹 , y: 𝔹 ⊩ y: 𝔹 $ by ax
l2: $ _wff $ by lamT [l1]
l3: $ _wff $ by lamT [l2]

lemma proj1_eval (G: ctx) (p q: term) {x y: term}: $ G ⊩ p: 𝔹 $ > $ G ⊩ q: 𝔹 $ > $ G ⊩ ≃[𝔹] (((λ x: 𝔹. λ y: 𝔹. x) · p) · q) = p $
--------------------------------------------------------
l1: $ G ⊩ λ x: 𝔹. λ y: 𝔹. x: 𝔹 → 𝔹 → 𝔹 $ by proj1 []
