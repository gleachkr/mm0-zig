        (λ f: 𝔹 → 𝔹 → 𝔹. f · p · y) =
        (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T) $ by bineq1 [l30, l29, l27]
l32: $ G , ≃[𝔹] x = p ⊩ ≃[𝔹 → 𝔹]
      (λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
        (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) =
        (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T)) =
      (λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
        (λ f: 𝔹 → 𝔹 → 𝔹. f · p · y) =
        (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T)) $ by leqt [l31]
l33: $ G ⊩ ≃[𝔹 → 𝔹]
      ((λ x: 𝔹. λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
          (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) =
          (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T)) · p) =
      (λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
        (λ f: 𝔹 → 𝔹 → 𝔹. f · p · y) =
        (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T)) $ by betacv [l4, #1, l20, l32]
l34: $ G ⊩ ≃[𝔹 → 𝔹] and · p =
      (λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
        (λ f: 𝔹 → 𝔹 → 𝔹. f · p · y) =
        (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T)) $ by trans [l2, l33]
l35: $ G , f: 𝔹 → 𝔹 → 𝔹 ⊩ f: 𝔹 → 𝔹 → 𝔹 $ by ax
l36: $ G , f: 𝔹 → 𝔹 → 𝔹 ⊩ p: 𝔹 $ by weaken [#1]
l37: $ G , f: 𝔹 → 𝔹 → 𝔹 ⊩ q: 𝔹 $ by weaken [#2]
l38: $ _wff $ by appT [l35, l36]
l39: $ _wff $ by appT [l38, l37]
l40: $ _wff $ by lamT [l39]
l41: $ G ⊩ ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
      (λ f: 𝔹 → 𝔹 → 𝔹. f · p · q) =
      (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T): 𝔹 $ by eqcT [l40, l16]
l42: $ G , ≃[𝔹] y = q ⊩ ≃[𝔹] y = q $ by ax
l43: $ G , ≃[𝔹] y = q , f: 𝔹 → 𝔹 → 𝔹 ⊩ ≃[𝔹] y = q $ by weaken [l42]
l44: $ G , ≃[𝔹] y = q , f: 𝔹 → 𝔹 → 𝔹 ⊩ f: 𝔹 → 𝔹 → 𝔹 $ by ax
l45: $ G , ≃[𝔹] y = q , f: 𝔹 → 𝔹 → 𝔹 ⊩ p: 𝔹 $ by weaken [#1]
l46: $ G , ≃[𝔹] y = q , f: 𝔹 → 𝔹 → 𝔹 ⊩
      ≃[𝔹] f · p · y = f · p · q $ by bineq2 [l44, l45, l43]
l47: $ G , ≃[𝔹] y = q ⊩ ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
      (λ f: 𝔹 → 𝔹 → 𝔹. f · p · y) =
      (λ f: 𝔹 → 𝔹 → 𝔹. f · p · q) $ by leqt [l46]
l48: $ G , ≃[𝔹] y = q ⊩ λ f: 𝔹 → 𝔹 → 𝔹. f · T · T:
      (𝔹 → 𝔹 → 𝔹) → 𝔹 $ by weaken [l16]
l49: $ G , ≃[𝔹] y = q ⊩ eq ((𝔹 → 𝔹 → 𝔹) → 𝔹):
      ((𝔹 → 𝔹 → 𝔹) → 𝔹) → ((𝔹 → 𝔹 → 𝔹) → 𝔹) → 𝔹 $ by eqT
l50: $ G , ≃[𝔹] y = q ⊩
      ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹]
        (λ f: 𝔹 → 𝔹 → 𝔹. f · p · y) =
