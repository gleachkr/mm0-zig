l4: $ _wff $ by appT [l3, l2]
l5: $ _wff $ by appT [l4, #3]
l6: $ G , ≃[A] x = t ⊩ λ x: A. u: A → B $ by weaken [l1]
l7: $ G , ≃[A] x = t ⊩ ≃[A] x = t $ by ax
l8: $ _wff $ by sym [l7]
