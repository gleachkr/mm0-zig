l11: $ _wff $ by trans [l10, l9]

lemma encoded_and_elim1 (G: ctx) (p q: term) {f: term}: $ G ⊩ p: 𝔹 $ > $ G ⊩ q: 𝔹 $ > $ G ⊩ ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹] (λ f: 𝔹 → 𝔹 → 𝔹. f · p · q) = (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T) $ > $ G ⊩ p $
