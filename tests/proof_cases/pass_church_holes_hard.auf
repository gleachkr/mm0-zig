l14: $ _wff $ by lamT [l13]
l15: $ _wff $ by reflt [l14]

andT
-----
l1: $ G ⊩ ≃[𝔹 → 𝔹 → 𝔹] and = (λ x: 𝔹. λ y: 𝔹. ≃[(𝔹 → 𝔹 → 𝔹) → 𝔹] (λ f: 𝔹 → 𝔹 → 𝔹. f · x · y) = (λ f: 𝔹 → 𝔹 → 𝔹. f · T · T)) $ by AND_DEF
l2: $ _wff $ by eqTR1 [l1]

andcT
------
