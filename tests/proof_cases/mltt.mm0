-- Small Martin-Lof style demo built on the minimal MLTT proof case.
--
-- This version keeps the dependent Π-fragment from mltt_min and adds
-- a simple Bool eliminator with computation rules, along with a few
-- user-facing conversion lemmas.
--
-- For readability, the user-facing theorem section below uses:
--   * `s ≈ t` for raw term convertibility
--   * `A ~ B` for raw type convertibility
--   * `A ≡ B` for judgemental type equality
--   * `≡[A] s = t` for indexed term equality

-- Split left and right delimiters so tokens like `≡[` stay intact while
-- bracketed substitution syntax like `[x/u]` still tokenizes correctly.
delimiter $ ( [ / $ $ / . : , ) ] ~ $;
strict provable sort jdg;
sort ctx;
sort ty;
--| @vars y z u v w k ih
sort tm;

-- This v1 demo omits an explicit context well-formedness judgment.
-- Context entries are just typing judgments, which keeps the core examples
-- small enough to read while still exercising dependent binders.
-- Under Curry-Howard, the `Π` and `→` examples below read like familiar
-- quantified intuitionistic logic formulas.

term jiff (J K: jdg): jdg;
infixr jiff: $<=>$ prec 20;

term ctx_eq (g h: ctx): jdg;
term emp: ctx;
--| @acui ctx_assoc _ emp _
term join (g h: ctx): ctx;
infixl join: $,$ prec 5;
term hyp (J: jdg): ctx;
coercion hyp: jdg > ctx;
term nd (g: ctx) (J: jdg): jdg;
infixl nd: $⊢$ prec 0;

-- `tm_raw_eq` and `ty_raw_eq` are the raw convertibility relations used
-- by substitution, rewriting, and normalization.
term tm_raw_eq (s t: tm): jdg;
infixl tm_raw_eq: $≈$ prec 15;
term ty_raw_eq (A B: ty): jdg;
infixl ty_raw_eq: $~$ prec 15;

-- `tm_eq` and `ty_eq` are the MLTT judgemental equalities. They only make
-- sense inside a typing context, and term equality is indexed by a type.
term ty_eq (A B: ty): jdg;
infixl ty_eq: $≡$ prec 15;
infixl ty_eq: $==$ prec 15;
term tm_eq (A: ty) (s t: tm): jdg;
notation tm_eq (A: ty) (s t: tm): jdg =
  ($≡[$:50) A ($]$:0) s ($=$:50) t;
notation tm_eq (A: ty) (s t: tm): jdg =
  ($==[$:50) A ($]$:0) s ($=$:50) t;

term Nat: ty;
term Bool: ty;
term is_ty (A: ty): jdg;
prefix is_ty: $Ty$ prec 60;

term has_ty (t: tm) (A: ty): jdg;
infixl has_ty: $:$ prec 40;

term Pi (A: ty) {x: tm} (B: ty x): ty;
notation Pi (A: ty) {x: tm} (B: ty x): ty =
  ($Π$:20) x ($:$:40) A ($.$:0) B;

def arr (A B: ty) {.x: tm}: ty = $ Π x : A. B $;
infixr arr: $→$ prec 25;

term lam (A: ty) {x: tm} (t: tm x): tm;
notation lam (A: ty) {x: tm} (t: tm x): tm =
  ($λ$:20) x ($:$:40) A ($.$:0) t;

term app (f u: tm): tm;
infixl app: $·$ prec 70;

term zero: tm;
term suc (t: tm): tm;
term true: tm;
term false: tm;
term bool_rec (A: ty) (t f b: tm): tm;
term nat_rec (A: ty) (z s n: tm): tm;
term nat_ind {k ih: tm} (C: ty k) (z: tm) (s: tm k ih) (n: tm): tm;
term bool_not_fn: tm;
term sel_ty (b: tm): ty;
term sel_tm (b: tm): tm;
term const_ty (k: tm) (A: ty): ty;
term stage_ty (n: tm): ty;
term stage_zero: tm;
term stage_suc (n ih: tm): tm;
term sb_ty {x: tm} (u: tm) (B: ty x): ty;
notation sb_ty {x: tm} (u: tm) (B: ty x): ty =
  ($[$:41) x ($/$:0) u ($]$:0) B;

term sb_tm {x: tm} (u: tm) (t: tm x): tm;
notation sb_tm {x: tm} (u: tm) (t: tm x): tm =
  ($⟦$:41) x ($/$:0) u ($⟧$:0) t;

def stage_fn (n: tm) {.k .ih: tm}: tm =
  $ nat_ind k ih (stage_ty k) stage_zero (stage_suc k ih) n $;

def nat_rec_dep (A: ty) (z s n: tm): tm =
  $ nat_rec A z s n $;

--| @relation jdg jiff jiff_refl jiff_trans jiff_sym jiff_mp
axiom jiff_refl (J: jdg): $ J <=> J $;
axiom jiff_trans (J K L: jdg):
  $ J <=> K $ > $ K <=> L $ > $ J <=> L $;
axiom jiff_sym (J K: jdg): $ J <=> K $ > $ K <=> J $;
axiom jiff_mp (J K: jdg): $ J <=> K $ > $ J $ > $ K $;

--| @relation ctx ctx_eq ctx_refl ctx_trans ctx_sym _
axiom ctx_refl (g: ctx): $ ctx_eq g g $;
axiom ctx_trans (g h i: ctx):
  $ ctx_eq g h $ > $ ctx_eq h i $ > $ ctx_eq g i $;
axiom ctx_sym (g h: ctx): $ ctx_eq g h $ > $ ctx_eq h g $;
axiom ctx_assoc (g h i: ctx):
  $ ctx_eq ((g , h) , i) (g , (h , i)) $;
axiom ctx_unit (g: ctx): $ ctx_eq (emp , g) g $;

--| @relation tm tm_raw_eq tm_refl tm_trans tm_sym _
axiom tm_refl (t: tm): $ tm_raw_eq t t $;
axiom tm_trans (s t u: tm):
  $ tm_raw_eq s t $ > $ tm_raw_eq t u $ > $ tm_raw_eq s u $;
axiom tm_sym (s t: tm): $ tm_raw_eq s t $ > $ tm_raw_eq t s $;

--| @relation ty ty_raw_eq ty_refl ty_trans ty_sym _
axiom ty_refl (A: ty): $ ty_raw_eq A A $;
axiom ty_trans (A B C: ty):
  $ ty_raw_eq A B $ > $ ty_raw_eq B C $ > $ ty_raw_eq A C $;
axiom ty_sym (A B: ty): $ ty_raw_eq A B $ > $ ty_raw_eq B A $;

--| @congr
axiom ctx_eq_congr (g1 g2 h1 h2: ctx):
  $ ctx_eq g1 g2 $ > $ ctx_eq h1 h2 $ > $ ctx_eq g1 h1 <=> ctx_eq g2 h2 $;

--| @congr
axiom tm_raw_eq_congr (s1 s2 t1 t2: tm):
  $ tm_raw_eq s1 s2 $ > $ tm_raw_eq t1 t2 $ > $ tm_raw_eq s1 t1 <=> tm_raw_eq s2 t2 $;

--| @congr
axiom ty_raw_eq_congr (A1 A2 B1 B2: ty):
  $ ty_raw_eq A1 A2 $ > $ ty_raw_eq B1 B2 $ > $ ty_raw_eq A1 B1 <=> ty_raw_eq A2 B2 $;

--| @congr
axiom hyp_congr (J K: jdg):
  $ J <=> K $ > $ ctx_eq (hyp J) (hyp K) $;

--| @congr
axiom join_congr (g1 g2 h1 h2: ctx):
  $ ctx_eq g1 g2 $ > $ ctx_eq h1 h2 $ > $ ctx_eq (g1 , h1) (g2 , h2) $;

--| @congr
axiom nd_congr (g h: ctx) (J K: jdg):
  $ ctx_eq g h $ > $ J <=> K $ > $ (g ⊢ J) <=> (h ⊢ K) $;

--| @congr
axiom is_ty_congr (A B: ty):
  $ ty_raw_eq A B $ > $ Ty A <=> Ty B $;

--| @congr
axiom has_ty_congr (t u: tm) (A B: ty):
  $ tm_raw_eq t u $ > $ ty_raw_eq A B $ > $ (t : A) <=> (u : B) $;

--| @congr
axiom tm_eq_congr (A B: ty) (s1 s2 t1 t2: tm):
  $ ty_raw_eq A B $
  > $ tm_raw_eq s1 s2 $
  > $ tm_raw_eq t1 t2 $
  > $ ≡[A] s1 = t1 <=> ≡[B] s2 = t2 $;

--| @congr
axiom pi_congr (A B: ty) {x: tm} (C D: ty x):
  $ ty_raw_eq A B $ > $ ty_raw_eq C D $ > $ ty_raw_eq (Π x : A. C) (Π x : B. D) $;

--| @congr
axiom lam_congr (A B: ty) {x: tm} (t u: tm x):
  $ ty_raw_eq A B $ > $ tm_raw_eq t u $ > $ tm_raw_eq (λ x : A. t) (λ x : B. u) $;

--| @congr
axiom app_congr (f g u v: tm):
  $ tm_raw_eq f g $ > $ tm_raw_eq u v $ > $ tm_raw_eq (f · u) (g · v) $;

--| @congr
axiom nat_rec_congr (A B: ty) (z1 z2 s1 s2 n1 n2: tm):
  $ ty_raw_eq A B $
  > $ tm_raw_eq z1 z2 $
  > $ tm_raw_eq s1 s2 $
  > $ tm_raw_eq n1 n2 $
  > $ tm_raw_eq (nat_rec A z1 s1 n1) (nat_rec B z2 s2 n2) $;

--| @congr
axiom nat_ind_congr {k ih: tm} (C D: ty k) (z1 z2: tm)
  (s1 s2: tm k ih) (n1 n2: tm):
  $ ty_raw_eq C D $
  > $ tm_raw_eq z1 z2 $
  > $ tm_raw_eq s1 s2 $
  > $ tm_raw_eq n1 n2 $
  > $ tm_raw_eq (nat_ind k ih C z1 s1 n1) (nat_ind k ih D z2 s2 n2) $;

--| @congr
axiom sel_ty_congr (b c: tm):
  $ tm_raw_eq b c $ > $ ty_raw_eq (sel_ty b) (sel_ty c) $;

--| @congr
axiom sel_tm_congr (b c: tm):
  $ tm_raw_eq b c $ > $ tm_raw_eq (sel_tm b) (sel_tm c) $;

--| @congr
axiom const_ty_congr (k: tm) (A B: ty):
  $ ty_raw_eq A B $ > $ ty_raw_eq (const_ty k A) (const_ty k B) $;

--| @congr
axiom stage_ty_congr (n m: tm):
  $ tm_raw_eq n m $ > $ ty_raw_eq (stage_ty n) (stage_ty m) $;

--| @congr
axiom stage_suc_congr (n m ih jh: tm):
  $ tm_raw_eq n m $
  > $ tm_raw_eq ih jh $
  > $ tm_raw_eq (stage_suc n ih) (stage_suc m jh) $;

--| @congr
axiom sb_ty_congr {x: tm} (u v: tm) (A B: ty x):
  $ tm_raw_eq u v $ > $ ty_raw_eq A B $ > $ ty_raw_eq ([x/u] A) ([x/v] B) $;

--| @rewrite
axiom sb_ty_nat {x: tm} (u: tm x): $ ty_raw_eq ([x/u] Nat) Nat $;

--| @rewrite
axiom sb_ty_bool {x: tm} (u: tm x): $ ty_raw_eq ([x/u] Bool) Bool $;

--| @rewrite
axiom sb_ty_arr {x: tm} (u: tm x) (A B: ty):
  $ ty_raw_eq ([x/u] (A → B)) (A → B) $;

--| @rewrite
axiom sb_ty_pi {x y: tm} (u: tm x) (A: ty) (B: ty x y):
  $ ty_raw_eq ([x/u] (Π y : A. B)) (Π y : A. [x/u] B) $;

--| @rewrite
axiom sb_ty_sel {x: tm} (u: tm x) (b: tm x):
  $ ty_raw_eq ([x/u] (sel_ty b)) (sel_ty (⟦ x / u ⟧ b)) $;

--| @rewrite
axiom sb_ty_const {k: tm} (u: tm k) (A: ty):
  $ ty_raw_eq ([k/u] (const_ty k A)) (const_ty k A) $;

--| @rewrite
axiom const_ty_eval (k: tm) (A: ty):
  $ ty_raw_eq (const_ty k A) A $;

--| @rewrite
axiom sb_ty_stage {x: tm} (u: tm x) (n: tm x):
  $ ty_raw_eq ([x/u] (stage_ty n)) (stage_ty (⟦ x / u ⟧ n)) $;

--| @rewrite
axiom sb_ty_id {x: tm} (A: ty x):
  $ ty_raw_eq ([x/x] A) A $;

--| @rewrite
axiom sb_ty_swap {x y: tm} (A: ty y):
  $ ty_raw_eq ([x/y] [y/x] A) A $;

--| @rewrite
axiom sb_ty_other {x y: tm} (u: tm x) (A: ty y):
  $ ty_raw_eq ([x/u] A) A $;

--| @rewrite
axiom sb_ty_free {x: tm} (u: tm x) (A: ty):
  $ ty_raw_eq ([x/u] A) A $;

--| @rewrite
axiom sb_tm_var {x: tm} (u: tm x): $ tm_raw_eq (⟦ x / u ⟧ x) u $;

--| @rewrite
axiom sb_tm_true {x: tm} (u: tm x): $ tm_raw_eq (⟦ x / u ⟧ true) true $;

--| @rewrite
axiom sb_tm_false {x: tm} (u: tm x):
  $ tm_raw_eq (⟦ x / u ⟧ false) false $;

--| @rewrite
axiom sb_tm_zero {x: tm} (u: tm x): $ tm_raw_eq (⟦ x / u ⟧ zero) zero $;

--| @rewrite
axiom sb_tm_stage_zero {x: tm} (u: tm x):
  $ tm_raw_eq (⟦ x / u ⟧ stage_zero) stage_zero $;

--| @rewrite
axiom sb_tm_bool_not_fn {x: tm} (u: tm x):
  $ tm_raw_eq (⟦ x / u ⟧ bool_not_fn) bool_not_fn $;

--| @rewrite
axiom sb_tm_other {x y: tm} (u: tm x): $ tm_raw_eq (⟦ x / u ⟧ y) y $;

--| @rewrite
axiom sb_tm_free {x: tm} (u: tm x) (t: tm):
  $ tm_raw_eq (⟦ x / u ⟧ t) t $;

--| @rewrite
axiom sb_tm_suc {x: tm} (u: tm x) (t: tm x):
  $ tm_raw_eq (⟦ x / u ⟧ (suc t)) (suc (⟦ x / u ⟧ t)) $;

--| @rewrite
axiom sb_tm_app {x: tm} (u: tm x) (f t: tm x):
  $ tm_raw_eq (⟦ x / u ⟧ (f · t)) ((⟦ x / u ⟧ f) · (⟦ x / u ⟧ t)) $;

-- β-reduction is a judgemental equality rule. The conclusion normalizes
-- the explicit substitution syntax away using the raw substitution rules.
--| @view (g: ctx) (A: ty) {x: tm} (B: ty x) (a b t u v: tm) (q: ty): $ g ⊢ (λ x : A. t) : (Π x : A. B) $ > $ g ⊢ u : A $ > $ g ⊢ ≡[q] a = b $
--| @normalize conc
axiom app_beta (g: ctx) (A: ty) {x: tm} (B: ty x) (t: tm x) (u: tm):
  $ g ⊢ (λ x : A. t) : (Π x : A. B) $
  > $ g ⊢ u : A $
  > $ g ⊢ ≡[[x/u] B] ((λ x : A. t) · u) = (⟦ x / u ⟧ t) $;

--| @rewrite
axiom sb_tm_lam {x y: tm} (u: tm x) (A: ty) (t: tm x y):
  $ tm_raw_eq (⟦ x / u ⟧ (λ y : A. t)) (λ y : A. ⟦ x / u ⟧ t) $;

--| @rewrite
axiom sb_tm_sel {x: tm} (u: tm x) (b: tm x):
  $ tm_raw_eq (⟦ x / u ⟧ (sel_tm b)) (sel_tm (⟦ x / u ⟧ b)) $;

--| @rewrite
axiom sb_tm_stage_suc {x: tm} (u: tm x) (n ih: tm x):
  $ tm_raw_eq (⟦ x / u ⟧ (stage_suc n ih))
      (stage_suc (⟦ x / u ⟧ n) (⟦ x / u ⟧ ih)) $;

--| @rewrite
axiom sb_tm_bool_rec {x: tm} (u: tm x) (A: ty x) (t f b: tm x):
  $ tm_raw_eq (⟦ x / u ⟧ (bool_rec A t f b))
      (bool_rec ([x/u] A) (⟦ x / u ⟧ t) (⟦ x / u ⟧ f) (⟦ x / u ⟧ b)) $;

--| @rewrite
axiom sb_tm_nat_rec {x: tm} (u: tm x) (A: ty x) (z s n: tm x):
  $ tm_raw_eq (⟦ x / u ⟧ (nat_rec A z s n))
      (nat_rec ([x/u] A) (⟦ x / u ⟧ z) (⟦ x / u ⟧ s)
          (⟦ x / u ⟧ n)) $;

--| @rewrite
axiom sb_tm_nat_rec_dep {x: tm} (u: tm x) (A: ty) (z s n: tm x):
  $ tm_raw_eq (⟦ x / u ⟧ (nat_rec_dep A z s n))
      (nat_rec A (⟦ x / u ⟧ z) (⟦ x / u ⟧ s) (⟦ x / u ⟧ n)) $;

--| @rewrite
axiom sb_tm_nat_ind {x k ih: tm} (u: tm x) (C: ty x k) (z: tm x)
  (s: tm x k ih) (n: tm x):
  $ tm_raw_eq (⟦ x / u ⟧ (nat_ind k ih C z s n))
      (nat_ind k ih ([x/u] C) (⟦ x / u ⟧ z) (⟦ x / u ⟧ s)
          (⟦ x / u ⟧ n)) $;

--| @congr
axiom sb_tm_congr {x: tm} (u1 u2 t1 t2: tm x):
  $ tm_raw_eq u1 u2 $
  > $ tm_raw_eq t1 t2 $
  > $ tm_raw_eq (⟦ x / u1 ⟧ t1) (⟦ x / u2 ⟧ t2) $;

axiom pi_const_alpha (A B: ty) {x y: tm}:
  $ ty_raw_eq (Π x : A. B) (Π y : A. B) $;

--| @alpha x y
axiom pi_alpha (A: ty) {x y: tm} (B: ty x):
  $ ty_raw_eq (Π x : A. B) (Π y : A. [x/y] B) $;

--| @alpha x y
axiom lam_alpha {x y: tm} (A: ty) (t: tm x y):
  $ tm_raw_eq (λ x : A. t) (λ y : A. ⟦ x / y ⟧ t) $;

axiom nat_form (g: ctx): $ g ⊢ Ty Nat $;
axiom bool_form (g: ctx): $ g ⊢ Ty Bool $;

axiom zero_ty (g: ctx): $ g ⊢ zero : Nat $;
axiom suc_ty (g: ctx) (t: tm): $ g ⊢ t : Nat $ > $ g ⊢ suc t : Nat $;
axiom true_ty (g: ctx): $ g ⊢ true : Bool $;
axiom false_ty (g: ctx): $ g ⊢ false : Bool $;
axiom bool_not_fn_ty (g: ctx): $ g ⊢ bool_not_fn : (Bool → Bool) $;

axiom sel_ty_form (g: ctx) (b: tm):
  $ g ⊢ b : Bool $ > $ g ⊢ Ty (sel_ty b) $;

axiom sel_tm_ty (g: ctx) (b: tm):
  $ g ⊢ b : Bool $ > $ g ⊢ sel_tm b : sel_ty b $;

axiom stage_ty_form (g: ctx) (n: tm):
  $ g ⊢ n : Nat $ > $ g ⊢ Ty (stage_ty n) $;

axiom stage_zero_ty (g: ctx): $ g ⊢ stage_zero : stage_ty zero $;

axiom stage_suc_ty (g: ctx) (n ih: tm):
  $ g ⊢ n : Nat $
  > $ g ⊢ ih : stage_ty n $
  > $ g ⊢ stage_suc n ih : stage_ty (suc n) $;

axiom var (g: ctx) {x: tm} (A: ty): $ g , x : A ⊢ x : A $;

axiom pi_form (g: ctx) (A: ty) {x: tm} (B: ty x):
  $ g ⊢ Ty A $
  > $ g , x : A ⊢ Ty B $
  > $ g ⊢ Ty (Π x : A. B) $;

axiom lam_intro (g: ctx) (A: ty) {x: tm} (B: ty x) (t: tm x):
  $ g ⊢ Ty A $
  > $ g , x : A ⊢ Ty B $
  > $ g , x : A ⊢ t : B $
  > $ g ⊢ (λ x : A. t) : (Π x : A. B) $;

axiom weaken (g: ctx) (J K: jdg):
  $ g ⊢ J $
  > $ g , K ⊢ J $;

--| @view (g: ctx) (A: ty) {x: tm} (B: ty x) (f u: tm) (q: ty): $ g ⊢ f : (Π x : A. B) $ > $ g ⊢ u : A $ > $ g ⊢ f · u : q $
--| @freshen f x
--| @normalize conc
axiom app_elim (g: ctx) (A: ty) {x: tm} (B: ty x) (f u: tm):
  $ g ⊢ f : (Π x : A. B) $
  > $ g ⊢ u : A $
  > $ g ⊢ f · u : [x/u] B $;


--| @congr
axiom suc_congr (s t: tm):
  $ tm_raw_eq s t $ > $ tm_raw_eq (suc s) (suc t) $;

--| @congr
axiom bool_rec_congr (A B: ty) (t1 t2 f1 f2 b1 b2: tm):
  $ ty_raw_eq A B $
  > $ tm_raw_eq t1 t2 $
  > $ tm_raw_eq f1 f2 $
  > $ tm_raw_eq b1 b2 $
  > $ tm_raw_eq (bool_rec A t1 f1 b1) (bool_rec B t2 f2 b2) $;

--| @normalize conc
axiom bool_rec_ty (g: ctx) (A: ty) (t f b: tm):
  $ g ⊢ Ty A $
  > $ g ⊢ t : A $
  > $ g ⊢ f : A $
  > $ g ⊢ b : Bool $
  > $ g ⊢ bool_rec A t f b : A $;

--| @normalize hyp0 hyp1 hyp2 conc
axiom nat_ind_ty (g: ctx) {k ih: tm} (C: ty k) (z: tm) (s: tm k ih)
  (n: tm):
  $ g , k : Nat ⊢ Ty C $
  > $ g ⊢ z : [k/zero] C $
  > $ g , k : Nat , ih : C ⊢ s : [k/suc k] C $
  > $ g ⊢ n : Nat $
  > $ g ⊢ nat_ind k ih C z s n : [k/n] C $;

--| @normalize conc
axiom nat_rec_ty (g: ctx) (A: ty) (z s n: tm):
  $ g ⊢ Ty A $
  > $ g ⊢ z : A $
  > $ g ⊢ s : (A → A) $
  > $ g ⊢ n : Nat $
  > $ g ⊢ nat_rec A z s n : A $;

--| @normalize conc
axiom bool_rec_true (g: ctx) (A: ty) (t f: tm):
  $ g ⊢ Ty A $
  > $ g ⊢ t : A $
  > $ g ⊢ f : A $
  > $ g ⊢ ≡[A] (bool_rec A t f true) = t $;

--| @normalize conc
axiom bool_rec_false (g: ctx) (A: ty) (t f: tm):
  $ g ⊢ Ty A $
  > $ g ⊢ t : A $
  > $ g ⊢ f : A $
  > $ g ⊢ ≡[A] (bool_rec A t f false) = f $;

--| @normalize conc
axiom nat_rec_zero (g: ctx) (A: ty) (z s: tm):
  $ g ⊢ Ty A $
  > $ g ⊢ z : A $
  > $ g ⊢ s : (A → A) $
  > $ g ⊢ ≡[A] (nat_rec A z s zero) = z $;

--| @normalize conc
axiom nat_rec_suc (g: ctx) (A: ty) (z s n: tm):
  $ g ⊢ Ty A $
  > $ g ⊢ z : A $
  > $ g ⊢ s : (A → A) $
  > $ g ⊢ n : Nat $
  > $ g ⊢ ≡[A] (nat_rec A z s (suc n)) = (s · (nat_rec A z s n)) $;

--| @normalize hyp0 hyp1 hyp2 conc
axiom nat_ind_zero (g: ctx) {k ih: tm} (C: ty k) (z: tm) (s: tm k ih):
  $ g , k : Nat ⊢ Ty C $
  > $ g ⊢ z : [k/zero] C $
  > $ g , k : Nat , ih : C ⊢ s : [k/suc k] C $
  > $ g ⊢ ≡[[k/zero] C] (nat_ind k ih C z s zero) = z $;

--| @normalize hyp0 hyp1 hyp2 conc
axiom nat_ind_suc (g: ctx) {k ih: tm} (C: ty k) (z: tm) (s: tm k ih)
  (n: tm):
  $ g , k : Nat ⊢ Ty C $
  > $ g ⊢ z : [k/zero] C $
  > $ g , k : Nat , ih : C ⊢ s : [k/suc k] C $
  > $ g ⊢ n : Nat $
  > $ g ⊢ ≡[[k/suc n] C] (nat_ind k ih C z s (suc n)) =
      (⟦ ih / nat_ind k ih C z s n ⟧ (⟦ k / n ⟧ s)) $;

axiom app_bool_not_true (g: ctx):
  $ g ⊢ ≡[Bool] (bool_not_fn · true) = false $;

axiom app_bool_not_false (g: ctx):
  $ g ⊢ ≡[Bool] (bool_not_fn · false) = true $;

--| @normalize hyp0 conc
axiom exchange (g: ctx) {x y: tm} (A: ty) (B: ty y) (d: ctx x y)
  (J: jdg x y):
  $ g , x : A , y : B , d ⊢ J $
  > $ g , y : B , x : A , d ⊢ J $;

axiom ty_eq_from_raw (g: ctx) (A B: ty):
  $ ty_raw_eq A B $
  > $ g ⊢ Ty A $
  > $ g ⊢ Ty B $
  > $ g ⊢ ty_eq A B $;

axiom tm_eq_from_raw (g: ctx) (A: ty) (s t: tm):
  $ tm_raw_eq s t $
  > $ g ⊢ s : A $
  > $ g ⊢ t : A $
  > $ g ⊢ ≡[A] s = t $;

axiom ty_eq_refl (g: ctx) (A: ty):
  $ g ⊢ Ty A $
  > $ g ⊢ ty_eq A A $;

axiom ty_eq_sym (g: ctx) (A B: ty):
  $ g ⊢ ty_eq A B $
  > $ g ⊢ ty_eq B A $;

axiom ty_eq_trans (g: ctx) (A B C: ty):
  $ g ⊢ ty_eq A B $
  > $ g ⊢ ty_eq B C $
  > $ g ⊢ ty_eq A C $;

axiom tm_eq_refl (g: ctx) (A: ty) (t: tm):
  $ g ⊢ t : A $
  > $ g ⊢ ≡[A] t = t $;

axiom tm_eq_sym (g: ctx) (A: ty) (s t: tm):
  $ g ⊢ ≡[A] s = t $
  > $ g ⊢ ≡[A] t = s $;

axiom tm_eq_trans (g: ctx) (A: ty) (s t u: tm):
  $ g ⊢ ≡[A] s = t $
  > $ g ⊢ ≡[A] t = u $
  > $ g ⊢ ≡[A] s = u $;

axiom ty_eq_left (g: ctx) (A B: ty):
  $ g ⊢ ty_eq A B $
  > $ g ⊢ Ty A $;

axiom ty_eq_right (g: ctx) (A B: ty):
  $ g ⊢ ty_eq A B $
  > $ g ⊢ Ty B $;

axiom tm_eq_left (g: ctx) (A: ty) (s t: tm):
  $ g ⊢ ≡[A] s = t $
  > $ g ⊢ s : A $;

axiom tm_eq_right (g: ctx) (A: ty) (s t: tm):
  $ g ⊢ ≡[A] s = t $
  > $ g ⊢ t : A $;

axiom app_eq_right (g: ctx) (A B: ty) (f s t: tm):
  $ g ⊢ f : (A → B) $
  > $ g ⊢ ≡[A] s = t $
  > $ g ⊢ ≡[B] (f · s) = (f · t) $;

axiom ty_conv (g: ctx) (t: tm) (A B: ty):
  $ g ⊢ ty_eq A B $
  > $ g ⊢ t : A $
  > $ g ⊢ t : B $;

theorem pi_dep_ty (g: ctx) (A: ty) {x: tm} (B: ty x):
  $ g ⊢ Ty A $
  > $ g , x : A ⊢ Ty B $
  > $ g ⊢ Ty (Π x : A. B) $;

theorem app_dep_raw (g: ctx) (A: ty) {x: tm} (B: ty x) (f u: tm):
  $ g ⊢ f : (Π x : A. B) $
  > $ g ⊢ u : A $
  > $ g ⊢ f · u : [x/u] B $;

theorem imp_form (g: ctx) (A B: ty):
  $ g ⊢ Ty A $
  > $ g ⊢ Ty B $
  > $ g ⊢ Ty (A → B) $;

theorem pi_imp_dist_ty (g: ctx) (A: ty) {x: tm} (p q: ty x):
  $ g ⊢ Ty A $
  > $ g , x : A ⊢ Ty p $
  > $ g , x : A ⊢ Ty q $
  > $ g ⊢ Ty ((Π x : A. (p → q)) → ((Π x : A. p) → (Π x : A. q))) $;

-- Core Π-fragment and transport helpers.

theorem ty_raw_conv (g: ctx) (t: tm) (A B: ty):
  $ A ~ B $
  > $ g ⊢ t : A $
  > $ g ⊢ t : B $;

theorem pi_const_alpha_has_ty (g: ctx) (A B: ty) (t: tm) {x y: tm}:
  $ g ⊢ t : (Π x : A. B) $
  > $ g ⊢ t : (Π y : A. B) $;

theorem pi_alpha_has_ty (g: ctx) (A: ty) (t: tm) {x y: tm} (B: ty x):
  $ g ⊢ t : (Π x : A. B) $
  > $ g ⊢ t : (Π y : A. [x/y] B) $;

theorem imp_dist_tm (g: ctx) (A: ty) (f h: tm) {y: tm} (p q: ty y):
  $ g ⊢ Ty A $
  > $ g , y : A ⊢ Ty p $
  > $ g , y : A ⊢ Ty q $
  > $ g ⊢ f : (Π y : A. (p → q)) $
  > $ g ⊢ h : (Π y : A. p) $
  > $ g ⊢ (λ y : A. (f · y) · (h · y)) : (Π y : A. q) $;

theorem imp_dist_bool_tm (g: ctx) (A: ty) (f h: tm) {y: tm}:
  $ g ⊢ Ty A $
  > $ g ⊢ f : (Π y : A. (Bool → Bool)) $
  > $ g ⊢ h : (Π y : A. Bool) $
  > $ g ⊢ (λ y : A. (f · y) · (h · y)) : (Π y : A. Bool) $;
theorem one_ty (g: ctx): $ g ⊢ suc zero : Nat $;

theorem pi_nat_nat_ty (g: ctx) {x: tm}: $ g ⊢ Ty (Π x : Nat. Nat) $;

theorem pi_nat_bool_ty (g: ctx) {x: tm}: $ g ⊢ Ty (Π x : Nat. Bool) $;

theorem second_var {x y: tm} (A B: ty): $ x : A , y : B ⊢ y : B $;

theorem exchange_demo {x y z: tm} (A B: ty):
  $ x : A , y : B , z : B ⊢ y : B $
  > $ y : B , x : A , z : B ⊢ y : B $;

theorem id_nat_ty (g: ctx) {x: tm}:
  $ g ⊢ (λ x : Nat. x) : (Π x : Nat. Nat) $;

theorem const_true_ty (g: ctx) {x: tm}:
  $ g ⊢ (λ x : Nat. true) : (Π x : Nat. Bool) $;

theorem app_id_nat (g: ctx) {x: tm} (n: tm):
  $ g ⊢ n : Nat $
  > $ g ⊢ (λ x : Nat. x) · n : Nat $;

theorem app_const_true (g: ctx) {x: tm} (n: tm):
  $ g ⊢ n : Nat $
  > $ g ⊢ (λ x : Nat. true) · n : Bool $;

theorem app_id_nat_beta (g: ctx) {x: tm} (n: tm):
  $ g ⊢ n : Nat $
  > $ g ⊢ ≡[Nat] ((λ x : Nat. x) · n) = n $;

theorem app_const_true_beta (g: ctx) {x: tm} (n: tm):
  $ g ⊢ n : Nat $
  > $ g ⊢ ≡[Bool] ((λ x : Nat. true) · n) = true $;

-- Small closed functions in the Π-fragment.

theorem first_var (g: ctx) {x y: tm} (A B: ty):
  $ g , x : A , y : B ⊢ x : A $;

-- Generic conversion helpers used by the rest of the demo.

theorem tm_raw_conv (g: ctx) (t u: tm) (A: ty):
  $ t ≈ u $
  > $ g ⊢ t : A $
  > $ g ⊢ u : A $;

theorem ctx_conv (g h: ctx) (J: jdg):
  $ ctx_eq g h $
  > $ g ⊢ J $
  > $ h ⊢ J $;

-- Bool elimination and direct computation examples.

theorem bool_not_ty (g: ctx) {y: tm}:
  $ g ⊢ (λ y : Bool. bool_rec Bool false true y) :
    (Π y : Bool. Bool) $;

theorem bool_not_true_ty (g: ctx) {y: tm}:
  $ g ⊢ (λ y : Bool. bool_rec Bool false true y) · true : Bool $;

theorem bool_not_false_ty (g: ctx) {y: tm}:
  $ g ⊢ (λ y : Bool. bool_rec Bool false true y) · false : Bool $;

theorem bool_not_true_eq (g: ctx) {y: tm}:
  $ g ⊢ ≡[Bool] ((λ y : Bool. bool_rec Bool false true y) · true) =
    false $;

theorem bool_not_false_eq (g: ctx) {y: tm}:
  $ g ⊢ ≡[Bool] ((λ y : Bool. bool_rec Bool false true y) · false) =
    true $;

theorem bool_rec_true_eq (g: ctx):
  $ g ⊢ ≡[Bool] (bool_rec Bool false true true) = false $;

theorem bool_rec_false_eq (g: ctx):
  $ g ⊢ ≡[Bool] (bool_rec Bool false true false) = true $;

theorem bool_to_nat_ty (g: ctx) {y: tm}:
  $ g ⊢ (λ y : Bool. bool_rec Nat zero (suc zero) y) :
    (Π y : Bool. Nat) $;

theorem bool_to_nat_true_ty (g: ctx) {y: tm}:
  $ g ⊢ (λ y : Bool. bool_rec Nat zero (suc zero) y) · true : Nat $;

theorem bool_to_nat_false_ty (g: ctx) {y: tm}:
  $ g ⊢ (λ y : Bool. bool_rec Nat zero (suc zero) y) · false : Nat $;

theorem bool_to_nat_true_eq (g: ctx) {y: tm}:
  $ g ⊢ ≡[Nat] ((λ y : Bool. bool_rec Nat zero (suc zero) y) · true) =
    zero $;

theorem bool_to_nat_false_eq (g: ctx) {y: tm}:
  $ g ⊢ ≡[Nat] ((λ y : Bool. bool_rec Nat zero (suc zero) y) · false) =
    (suc zero) $;

-- A dependent family indexed by Bool.

theorem sel_ty_true (g: ctx):
  $ g ⊢ Ty (sel_ty true) $;

theorem sel_ty_false (g: ctx):
  $ g ⊢ Ty (sel_ty false) $;

theorem sel_dep_ty (g: ctx) {y: tm}:
  $ g ⊢ (λ y : Bool. sel_tm y) : (Π y : Bool. sel_ty y) $;

theorem sel_dep_true_ty (g: ctx) {y: tm}:
  $ g ⊢ (λ y : Bool. sel_tm y) · true : sel_ty true $;

theorem sel_dep_false_ty (g: ctx) {y: tm}:
  $ g ⊢ (λ y : Bool. sel_tm y) · false : sel_ty false $;

-- A transparent alias for non-dependent nat recursion.

theorem nat_rec_dep_ty (g: ctx) (A: ty) (z s n: tm):
  $ g ⊢ Ty A $
  > $ g ⊢ z : A $
  > $ g ⊢ s : (A → A) $
  > $ g ⊢ n : Nat $
  > $ g ⊢ nat_rec_dep A z s n : A $;

theorem nat_rec_dep_zero (g: ctx) (A: ty) (z s: tm):
  $ g ⊢ Ty A $
  > $ g ⊢ z : A $
  > $ g ⊢ s : (A → A) $
  > $ g ⊢ ≡[A] (nat_rec_dep A z s zero) = z $;

theorem nat_rec_dep_suc (g: ctx) (A: ty) (z s n: tm):
  $ g ⊢ Ty A $
  > $ g ⊢ z : A $
  > $ g ⊢ s : (A → A) $
  > $ g ⊢ n : Nat $
  > $ g ⊢ ≡[A] (nat_rec_dep A z s (suc n)) =
    (s · (nat_rec_dep A z s n)) $;

-- The same alias, used for a different Nat program.

theorem double_step_ty (g: ctx) {k: tm}:
  $ g ⊢ (λ k : Nat. suc (suc k)) : (Nat → Nat) $;

theorem nat_double_ty (g: ctx) {n k: tm}:
  $ g ⊢ (λ n : Nat. nat_rec_dep Nat zero (λ k : Nat. suc (suc k)) n) :
    (Π n : Nat. Nat) $;

theorem nat_double_zero_beta (g: ctx) {k: tm}:
  $ g ⊢ ≡[Nat] (nat_rec_dep Nat zero (λ k : Nat. suc (suc k)) zero) =
    zero $;

theorem nat_double_one_beta (g: ctx) {k: tm}:
  $ g ⊢ ≡[Nat] (nat_rec_dep Nat zero (λ k : Nat. suc (suc k))
    (suc zero)) = (suc (suc zero)) $;

theorem nat_double_two_beta (g: ctx) {k: tm}:
  $ g ⊢ ≡[Nat] (nat_rec_dep Nat zero (λ k : Nat. suc (suc k))
    (suc (suc zero))) = (suc (suc (suc (suc zero)))) $;

-- A small program: parity computed by nat recursion.

theorem nat_even_ty (g: ctx) {n: tm}:
  $ g ⊢ (λ n : Nat. nat_rec Bool true bool_not_fn n) :
    (Π n : Nat. Bool) $;

theorem nat_even_zero_eq (g: ctx) {n: tm}:
  $ g ⊢ ≡[Bool] ((λ n : Nat. nat_rec Bool true bool_not_fn n) · zero) =
    true $;

theorem nat_even_one_eq (g: ctx) {n: tm}:
  $ g ⊢ ≡[Bool] ((λ n : Nat. nat_rec Bool true bool_not_fn n) ·
    suc zero) = false $;

theorem nat_even_two_eq (g: ctx) {n: tm}:
  $ g ⊢ ≡[Bool] ((λ n : Nat. nat_rec Bool true bool_not_fn n) ·
    suc (suc zero)) = true $;

theorem nat_even_zero_ty (g: ctx) {n: tm}:
  $ g ⊢ (λ n : Nat. nat_rec Bool true bool_not_fn n) · zero : Bool $;

theorem nat_even_one_ty (g: ctx) {n: tm}:
  $ g ⊢ (λ n : Nat. nat_rec Bool true bool_not_fn n) · suc zero : Bool $;

theorem nat_even_two_ty (g: ctx) {n: tm}:
  $ g ⊢ (λ n : Nat. nat_rec Bool true bool_not_fn n) ·
    suc (suc zero) : Bool $;

theorem nat_even_zero_beta (g: ctx):
  $ g ⊢ ≡[Bool] (nat_rec Bool true bool_not_fn zero) = true $;

theorem nat_even_one_beta (g: ctx):
  $ g ⊢ ≡[Bool] (nat_rec Bool true bool_not_fn (suc zero)) = false $;

theorem nat_even_two_beta (g: ctx):
  $ g ⊢ ≡[Bool] (nat_rec Bool true bool_not_fn (suc (suc zero))) =
    true $;

-- A genuinely dependent family over Nat, built by induction.

theorem stage_fn_term_ty (g: ctx) (n: tm):
  $ g ⊢ n : Nat $
  > $ g ⊢ stage_fn n : stage_ty n $;

theorem stage_fn_ty (g: ctx) {n: tm}:
  $ g ⊢ (λ n : Nat. stage_fn n) : (Π n : Nat. stage_ty n) $;

theorem stage_fn_zero_ty (g: ctx):
  $ g ⊢ stage_fn zero : stage_ty zero $;

theorem stage_fn_one_ty (g: ctx):
  $ g ⊢ stage_fn (suc zero) : stage_ty (suc zero) $;

theorem stage_fn_zero_beta (g: ctx):
  $ g ⊢ ≡[stage_ty zero] (stage_fn zero) = stage_zero $;

theorem stage_fn_suc_beta (g: ctx) (n: tm):
  $ g ⊢ n : Nat $
  > $ g ⊢ ≡[stage_ty (suc n)] (stage_fn (suc n)) =
    (stage_suc n (stage_fn n)) $;

-- One curried Bool combinator, then direct closed case splits.

theorem bool_and_ty (g: ctx) {y z: tm}:
  $ g ⊢ (λ y : Bool. λ z : Bool. bool_rec Bool z false y) :
    (Π y : Bool. (Π z : Bool. Bool)) $;

theorem bool_and_true_ty (g: ctx) {y z: tm}:
  $ g ⊢ (λ y : Bool. λ z : Bool. bool_rec Bool z false y) · true :
    (Π z : Bool. Bool) $;

theorem bool_and_false_ty (g: ctx) {y z: tm}:
  $ g ⊢ (λ y : Bool. λ z : Bool. bool_rec Bool z false y) · false :
    (Π z : Bool. Bool) $;

theorem bool_and_true_true_ty (g: ctx) {y z: tm}:
  $ g ⊢ ((λ y : Bool. λ z : Bool. bool_rec Bool z false y) · true)
    · true : Bool $;

theorem bool_and_true_false_ty (g: ctx) {y z: tm}:
  $ g ⊢ ((λ y : Bool. λ z : Bool. bool_rec Bool z false y) · true)
    · false : Bool $;

theorem bool_and_false_true_ty (g: ctx) {y z: tm}:
  $ g ⊢ ((λ y : Bool. λ z : Bool. bool_rec Bool z false y) · false)
    · true : Bool $;

theorem bool_and_false_false_ty (g: ctx) {y z: tm}:
  $ g ⊢ ((λ y : Bool. λ z : Bool. bool_rec Bool z false y) · false)
    · false : Bool $;

theorem nat_case_true_ty (g: ctx):
  $ g ⊢ bool_rec Nat zero (suc zero) true : Nat $;

theorem nat_case_false_ty (g: ctx):
  $ g ⊢ bool_rec Nat zero (suc zero) false : Nat $;

theorem nat_case_true_beta (g: ctx):
  $ g ⊢ ≡[Nat] (bool_rec Nat zero (suc zero) true) = zero $;

theorem nat_case_false_beta (g: ctx):
  $ g ⊢ ≡[Nat] (bool_rec Nat zero (suc zero) false) = (suc zero) $;

