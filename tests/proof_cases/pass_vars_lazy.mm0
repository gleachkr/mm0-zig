delimiter $ ( ) $;
provable sort wff;

--| @vars a1 a2 a3 a4 a5 a6 a7 a8 a9 a10
--| @vars b1 b2 b3 b4 b5 b6 b7 b8 b9 b10
--| @vars c1 c2 c3 c4 c5 c6 c7 c8 c9 c10
--| @vars d1 d2 d3 d4 d5 d6 d7 d8 d9 d10
--| @vars e1 e2 e3 e4 e5 e6 e7 e8 e9 e10
--| @vars f1 f2 f3 f4 f5 f6 f7 f8 f9 f10
sort nat;

term eq (a b: nat): wff;
infixl eq: $=$ prec 50;

axiom eq_refl (a: nat): $ a = a $;

-- 60 @vars tokens declared, but only `a1` is used in the proof.
-- Without lazy allocation, this would exhaust the 55-slot limit.
theorem vars_lazy (t: nat): $ t = t $;
