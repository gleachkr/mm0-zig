quant_functionality
------------------

l1: $ (F w (g x y) Ôłž F w (g x z)) ÔŐó (F w (g x y) Ôłž F w (g x z)) $
  by ax []
l2: $ _ ÔŐó ÔłÇ w ÔłÇ x ÔłÇ y ÔłÇ z
      ((F w (g x y) Ôłž F w (g x z)) Ôćĺ F w (g y z)) $
  by all_intro (x := $ w $)
  [all_intro (x := $ x $)
    [all_intro (x := $ y $)
      [all_intro (x := $ z $)
        [imp_intro
          [iff_elim_r
            [all_elim (t := $ z $)
              [all_elim (t := $ y $)
                [all_elim (t := $ w $) [#1]]],
             eq_transitivity
              [eq_symm
                [iff_elim_l
                  [all_elim (t := $ y $)
                    [all_elim (t := $ x $)
                      [all_elim (t := $ w $) [#1]]],
                   and_elim_l [l1]]],
               iff_elim_l
                [all_elim (t := $ z $)
                  [all_elim (t := $ x $)
                    [all_elim (t := $ w $) [#1]]],
                 and_elim_r [l1]]]]]]]]]
identity
--------

l1: $ a ÔŐó a $ by ax []
l2: $ _ ÔŐó a Ôćĺ a $ by imp_intro [l1]

explosion
---------

l1: $ ÔŐą ÔŐó ÔŐą $ by ax []
l2: $ _ ÔŐó ÔŐą Ôćĺ a $ by imp_intro [bot_elim [l1]]

double_neg_intro
----------------

l1: $ ┬Č a ÔŐó ┬Č a $ by ax []
l2: $ a ÔŐó a $ by ax []
l3: $ _ ÔŐó a Ôćĺ ┬Č ┬Č a $
  by imp_intro [not_intro (a := $ ┬Č a $) [not_elim [l1, l2]]]

modus_tollens
-------------

l1: $ (a Ôćĺ b) ÔŐó a Ôćĺ b $ by ax []
l2: $ a ÔŐó a $ by ax []
l3: $ ┬Č b ÔŐó ┬Č b $ by ax []
l4: $ _ ÔŐó (a Ôćĺ b) Ôćĺ ┬Č b Ôćĺ ┬Č a $
  by imp_intro
  [imp_intro
    [not_intro
      [not_elim [l3, imp_elim [l1, l2]]]]]
and_comm_iff
------------

-- Forward: (a /\ b) -> (b /\ a)
l1: $ (a Ôłž b) ÔŐó a Ôłž b $ by ax []
-- Backward: (b /\ a) -> (a /\ b)
l2: $ (b Ôłž a) ÔŐó b Ôłž a $ by ax []
-- Combine
l3: $ _ ÔŐó (a Ôłž b) Ôćö (b Ôłž a) $
  by iff_intro
  [imp_intro [and_intro [and_elim_r [l1], and_elim_l [l1]]],
   imp_intro [and_intro [and_elim_r [l2], and_elim_l [l2]]]]

or_comm
-------

l1: $ (a ÔłĘ b) ÔŐó a ÔłĘ b $ by ax []
l2: $ a ÔŐó a $ by ax []
l3: $ b ÔŐó b $ by ax []
l4: $ _ ÔŐó (a ÔłĘ b) Ôćĺ (b ÔłĘ a) $
  by imp_intro
  [or_elim
    [l1,
     or_intro_r (a := $ b $) [l2],
     or_intro_l (b := $ a $) [l3]]]

disjunctive_syllogism
---------------------

l1: $ (a ÔłĘ b) ÔŐó a ÔłĘ b $ by ax []
l2: $ ┬Č a ÔŐó ┬Č a $ by ax []
l3: $ a ÔŐó a $ by ax []
l4: $ b ÔŐó b $ by ax []
l5: $ _ ÔŐó (a ÔłĘ b) Ôćĺ ┬Č a Ôćĺ b $
  by imp_intro
  [imp_intro
    [or_elim [l1, bot_elim (a := $ b $) [not_elim [l2, l3]], l4]]]

de_morgan_or
------------

-- Forward: ~(a \/ b) -> (~a /\ ~b)
l1: $ ┬Č (a ÔłĘ b) ÔŐó ┬Č (a ÔłĘ b) $ by ax []
l2: $ a ÔŐó a $ by ax []
l3: $ b ÔŐó b $ by ax []
-- Backward: (~a /\ ~b) -> ~(a \/ b)
l4: $ (┬Č a Ôłž ┬Č b) ÔŐó ┬Č a Ôłž ┬Č b $ by ax []
l5: $ (a ÔłĘ b) ÔŐó a ÔłĘ b $ by ax []
-- Combine
l6: $ _ ÔŐó ┬Č (a ÔłĘ b) Ôćö (┬Č a Ôłž ┬Č b) $
  by iff_intro
  [imp_intro
    [and_intro
      [not_intro (a := $ a $)
        [not_elim [l1, or_intro_l (b := $ b $) [l2]]],
       not_intro (a := $ b $)
        [not_elim [l1, or_intro_r (a := $ a $) [l3]]]]],
   imp_intro
    [not_intro (a := $ a ÔłĘ b $)
      [or_elim
        [l5,
         not_elim [and_elim_l [l4], l2],
         not_elim [and_elim_r [l4], l3]]]]]
curry_iff
---------

-- Forward: ((a /\ b) -> c) -> (a -> b -> c)
l1: $ (a Ôłž b) Ôćĺ c ÔŐó (a Ôłž b) Ôćĺ c $ by ax []
l2: $ a , b ÔŐó a $ by ax []
l3: $ a , b ÔŐó b $ by ax []
-- Backward: (a -> b -> c) -> ((a /\ b) -> c)
l4: $ a Ôćĺ b Ôćĺ c ÔŐó a Ôćĺ b Ôćĺ c $ by ax []
l5: $ (a Ôłž b) ÔŐó a Ôłž b $ by ax []
-- Combine
l6: $ _ ÔŐó ((a Ôłž b) Ôćĺ c) Ôćö (a Ôćĺ b Ôćĺ c) $
  by iff_intro
    (b := $ a Ôćĺ b Ôćĺ c $)
  [imp_intro
    [imp_intro 
      [imp_intro (a := $ b $)
        [imp_elim [l1, and_intro [l2, l3]]]]],
   imp_intro
    [imp_intro (a := $ a Ôłž b $)
      [imp_elim [imp_elim [l4, and_elim_l [l5]],
                 and_elim_r [l5]]]]]

imp_trans
---------

l1: $ (a Ôćĺ b) ÔŐó a Ôćĺ b $ by ax []
l2: $ (b Ôćĺ c) ÔŐó b Ôćĺ c $ by ax []
l3: $ a ÔŐó a $ by ax []
l4: $ _ ÔŐó (a Ôćĺ b) Ôćĺ (b Ôćĺ c) Ôćĺ (a Ôćĺ c) $
  by imp_intro [imp_intro [imp_intro [imp_elim [l2, imp_elim [l1, l3]]]]]

not_not_lem
-----------

-- Proof that ~~(a \/ ~a) is intuitionistically valid
l1: $ ┬Č (a ÔłĘ ┬Č a) ÔŐó ┬Č (a ÔłĘ ┬Č a) $ by ax []
l2: $ a ÔŐó a $ by ax []
l3: $ _ ÔŐó ┬Č ┬Č (a ÔłĘ ┬Č a) $
  by not_intro 
  [not_elim
    [l1,
     or_intro_r (a := $ a $)
      [not_intro (a := $ a $)
        [not_elim
          [l1, or_intro_l (b := $ ┬Č a $) [l2]]]]]]

alpha_all_intro_demo
--------------------

l1: $ ÔłÇ a (F a b) , F b b ÔŐó F b b $ by ax []
l2: $ ÔłÇ a (F a b) , F b b ÔŐó ÔłÇ a (F b b) $ by all_intro [l1]

alpha_ex_intro_demo
-------------------

l1: $ ÔłÇ a (F a b) , F b b ÔŐó F b b $ by ax []
l2: $ ÔłÇ a (F a b) , F b b ÔŐó Ôłâ a (F a b) $ by ex_intro (t := $ b $) [l1]

alpha_ex_elim_demo
------------------

l1: $ ÔłÇ a (F a b) , Ôłâ a (F a b) ÔŐó Ôłâ a (F a b) $ by ax []
l2: $ ÔłÇ a (F a b) , F a b ÔŐó ÔłÇ a (F a b) $ by ax []
l3: $ ÔłÇ a (F a b) , Ôłâ a (F a b) ÔŐó ÔłÇ a (F a b) $ by ex_elim [l1, l2]

forall_swap
-----------

l1: $ _ ÔŐó ÔłÇ b ÔłÇ a (F a b) $
  by all_intro (x := $ b $)
  [all_intro (x := $ a $)
    [all_elim (t := $ b $) [all_elim (t := $ a $) [#1]]]]

forall_specialize
-----------------

l1: $ _ ÔŐó F c a $ by all_elim (t := $ a $)
  [all_elim (t := $ c $) [#1]]

forall_and_combine
------------------

l1: $ _ ÔŐó ÔłÇ a (F a b Ôłž F b a) $
  by all_intro (x := $ a $)
  [and_intro [all_elim (t := $ a $) [#1], all_elim (t := $ a $) [#2]]]

exists_from_forall
------------------

l1: $ _ ÔŐó Ôłâ a (F a b) $ by ex_intro
  [all_elim (t := $ a $) [#1]]

forall_imp_distribute
---------------------

l1: $ _ ÔŐó ÔłÇ a (F b a) $
  by all_intro (x := $ a $)
  [imp_elim [all_elim (t := $ a $) [#1], all_elim (t := $ a $) [#2]]]

forall_not_to_not_exists
------------------------

l1: $ (ÔłÇ a (┬Č (F a b))) ÔŐó ÔłÇ a (┬Č (F a b)) $ by ax []
l2: $ (F a b) ÔŐó F a b $ by ax []
l3: $ (Ôłâ a (F a b)) ÔŐó Ôłâ a (F a b) $ by ax []
l4: $ _ ÔŐó (ÔłÇ a (┬Č (F a b))) Ôćĺ ┬Č (Ôłâ a (F a b)) $
  by imp_intro
  [not_intro (a := $ Ôłâ a (F a b) $)
    [ex_elim
      [l3, not_elim [all_elim (t := $ a $) [l1], l2]]]]
