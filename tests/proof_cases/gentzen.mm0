delimiter $ ( ) , $;
provable sort wff;
sort ctx;
--| @vars z w
sort obj;

term imp (a b: wff): wff;
infixr imp: $â†’$ prec 25;
infixr imp: $->$ prec 25;
term and (a b: wff): wff;
infixr and: $âˆ§$ prec 30;
infixr and: $/\\$ prec 30;
term or (a b: wff): wff;
infixr or: $âˆ¨$ prec 30;
infixr or: $\\/$ prec 30;
term not (a: wff): wff;
prefix not: $Â¬$ prec 35;
prefix not: $~$ prec 35;
term all {x: obj} (p: wff x): wff;
prefix all: $âˆ€$ prec 41;
prefix all: $A.$ prec 41;
term ex {x: obj} (p: wff x): wff;
prefix ex: $âˆƒ$ prec 41;
prefix ex: $E.$ prec 41;
term P (t: obj): wff;
prefix P: $P$ prec 50;
term Q (t: obj): wff;
prefix Q: $Q$ prec 50;
term sb (t: obj) {x: obj} (p: wff x): wff;

term iff (a b: wff): wff;
infixr iff: $â†”$ prec 20;
infixr iff: $<->$ prec 20;
term ctx_eq (g h: ctx): wff;
term emp: ctx;
notation emp: ctx = ($_$:max);

--| @acui ctx_assoc ctx_comm emp ctx_idem
term join (g h: ctx): ctx;
infixl join: $,$ prec 5;
term hyp (a: wff): ctx;
coercion hyp: wff > ctx;
term seq (g d: ctx): wff;
infixl seq: $==>$ prec 0;

-- Contexts are ACUI collections of formulas. This bakes in exchange and
-- contraction, so the only explicit structural rules below are identity,
-- weakening, and cut.

--| @relation wff iff iff_refl iff_trans iff_sym iff_mp
axiom iff_refl (a: wff): $ a â†” a $;
axiom iff_trans (a b c: wff):
  $ a â†” b $ > $ b â†” c $ > $ a â†” c $;
axiom iff_sym (a b: wff): $ a â†” b $ > $ b â†” a $;
axiom iff_mp (a b: wff): $ a â†” b $ > $ a $ > $ b $;

--| @relation ctx ctx_eq ctx_refl ctx_trans ctx_sym _
axiom ctx_refl (g: ctx): $ ctx_eq g g $;
axiom ctx_trans (g h i: ctx):
  $ ctx_eq g h $ > $ ctx_eq h i $ > $ ctx_eq g i $;
axiom ctx_sym (g h: ctx): $ ctx_eq g h $ > $ ctx_eq h g $;
axiom ctx_assoc (g h i: ctx):
  $ ctx_eq ((g , h) , i) (g , (h , i)) $;
axiom ctx_comm (g h: ctx): $ ctx_eq (g , h) (h , g) $;
axiom ctx_idem (g: ctx): $ ctx_eq (g , g) g $;
axiom ctx_unit (g: ctx): $ ctx_eq (emp , g) g $;

--| @congr
axiom join_congr (g1 g2 h1 h2: ctx):
  $ ctx_eq g1 g2 $ > $ ctx_eq h1 h2 $ >
  $ ctx_eq (g1 , h1) (g2 , h2) $;

--| @congr
axiom hyp_congr (a b: wff): $ a â†” b $ > $ ctx_eq (hyp a) (hyp b) $;

--| @congr
axiom seq_congr (g1 g2 d1 d2: ctx):
  $ ctx_eq g1 g2 $ > $ ctx_eq d1 d2 $ > $ (g1 ==> d1) â†” (g2 ==> d2) $;

--| @congr
axiom imp_congr (a b c d: wff):
  $ a â†” b $ > $ c â†” d $ > $ (a â†’ c) â†” (b â†’ d) $;

--| @congr
axiom and_congr (a b c d: wff):
  $ a â†” b $ > $ c â†” d $ > $ (a âˆ§ c) â†” (b âˆ§ d) $;

--| @congr
axiom or_congr (a b c d: wff):
  $ a â†” b $ > $ c â†” d $ > $ (a âˆ¨ c) â†” (b âˆ¨ d) $;

--| @congr
axiom not_congr (a b: wff): $ a â†” b $ > $ Â¬ a â†” Â¬ b $;

--| @congr
axiom all_congr {x: obj} (p q: wff x): $ p â†” q $ > $ âˆ€ x p â†” âˆ€ x q $;

--| @congr
axiom ex_congr {x: obj} (p q: wff x): $ p â†” q $ > $ âˆƒ x p â†” âˆƒ x q $;

--| @rewrite
axiom sb_P (t: obj) {x: obj}: $ sb t x (P x) â†” P t $;

--| @rewrite
axiom sb_P_other {x y: obj} (t: obj x): $ sb t x (P y) â†” P y $;

--| @rewrite
axiom sb_Q (t: obj) {x: obj}: $ sb t x (Q x) â†” Q t $;

--| @rewrite
axiom sb_Q_other {x y: obj} (t: obj x): $ sb t x (Q y) â†” Q y $;

--| @rewrite
axiom sb_imp (t: obj) {x: obj} (p q: wff x):
  $ sb t x (p â†’ q) â†” (sb t x p â†’ sb t x q) $;

--| @rewrite
axiom sb_and (t: obj) {x: obj} (p q: wff x):
  $ sb t x (p âˆ§ q) â†” (sb t x p âˆ§ sb t x q) $;

--| @rewrite
axiom sb_or (t: obj) {x: obj} (p q: wff x):
  $ sb t x (p âˆ¨ q) â†” (sb t x p âˆ¨ sb t x q) $;

--| @rewrite
axiom sb_not (t: obj) {x: obj} (p: wff x):
  $ sb t x (Â¬ p) â†” Â¬ sb t x p $;

--| @rewrite
axiom sb_all {x y: obj} (t: obj x) (p: wff x y):
  $ sb t x (âˆ€ y p) â†” âˆ€ y (sb t x p) $;

--| @rewrite
axiom sb_ex {x y: obj} (t: obj x) (p: wff x y):
  $ sb t x (âˆƒ y p) â†” âˆƒ y (sb t x p) $;

--| @alpha x y
axiom all_alpha {x y: obj} (p: wff x y):
  $ âˆ€ x p â†” âˆ€ y (sb y x p) $;

--| @alpha x y
axiom ex_alpha {x y: obj} (p: wff x y):
  $ âˆƒ x p â†” âˆƒ y (sb y x p) $;

--| @normalize conc
axiom ax (a: wff): $ a ==> a $;

--| @normalize hyp0 conc
axiom weak_left (g d: ctx) (a: wff): $ g ==> d $ > $ g , a ==> d $;

--| @normalize hyp0 conc
axiom weak_right (g d: ctx) (a: wff): $ g ==> d $ > $ g ==> d , a $;

--| @normalize hyp0 hyp1 conc
axiom cut (g h d e: ctx) (a: wff):
  $ g ==> d , a $ > $ h , a ==> e $ > $ g , h ==> d , e $;

--| @normalize hyp0 hyp1 conc
axiom imp_left (g h d e: ctx) (a b: wff):
  $ g ==> d , a $ > $ h , b ==> e $ > $ g , h , (a â†’ b) ==> d , e $;

--| @normalize hyp0 conc
axiom imp_right (g d: ctx) (a b: wff):
  $ g , a ==> d , b $ > $ g ==> d , (a â†’ b) $;

--| @normalize hyp0 conc
axiom and_left (g d: ctx) (a b: wff):
  $ g , a , b ==> d $ > $ g , (a âˆ§ b) ==> d $;

--| @normalize hyp0 hyp1 conc
axiom and_right (g d: ctx) (a b: wff):
  $ g ==> d , a $ > $ g ==> d , b $ > $ g ==> d , (a âˆ§ b) $;

--| @normalize hyp0 hyp1 conc
axiom or_left (g h d e: ctx) (a b: wff):
  $ g , a ==> d $ > $ h , b ==> e $ > $ g , h , (a âˆ¨ b) ==> d , e $;

--| @normalize hyp0 conc
axiom or_right (g d: ctx) (a b: wff):
  $ g ==> d , a , b $ > $ g ==> d , (a âˆ¨ b) $;

--| @normalize hyp0 conc
axiom not_left (g d: ctx) (a: wff):
  $ g ==> d , a $ > $ g , Â¬ a ==> d $;

--| @normalize hyp0 conc
axiom not_right (g d: ctx) (a: wff):
  $ g , a ==> d $ > $ g ==> d , Â¬ a $;

-- all_left and ex_right are the witness-carrying rules. @view/@recover let
-- the demo infer the witness term from normalized sequents.
--| @view (g d: ctx) {x: obj} (t: obj x) (p: wff x) (q: wff): $ g , q ==> d $ > $ g , âˆ€ x p ==> d $
--| @recover t q p x
--| @freshen g x
--| @freshen d x
--| @normalize hyp0 conc
axiom all_left (g d: ctx) {x: obj} (t: obj x) (p: wff x):
  $ g , sb t x p ==> d $ > $ g , âˆ€ x p ==> d $;

--| @freshen g x
--| @freshen d x
--| @normalize hyp0 conc
axiom all_right (g d: ctx) {x: obj} (p: wff x):
  $ g ==> d , p $ > $ g ==> d , âˆ€ x p $;

--| @freshen g x
--| @freshen d x
--| @normalize hyp0 conc
axiom ex_left (g d: ctx) {x: obj} (p: wff x):
  $ g , p ==> d $ > $ g , âˆƒ x p ==> d $;

--| @view (g d: ctx) {x: obj} (t: obj x) (p: wff x) (q: wff): $ g ==> d , q $ > $ g ==> d , âˆƒ x p $
--| @recover t q p x
--| @freshen g x
--| @freshen d x
--| @normalize hyp0 conc
axiom ex_right (g d: ctx) {x: obj} (t: obj x) (p: wff x):
  $ g ==> d , sb t x p $ > $ g ==> d , âˆƒ x p $;

theorem exists_mono {x y z: obj}:
  $ âˆ€ y (P y â†’ Q y) , âˆƒ x P x ==> âˆƒ z Q z $;

theorem forall_mono {x y z: obj}:
  $ âˆ€ x (P x â†’ Q x) , âˆ€ y P y ==> âˆ€ z Q z $;

theorem forall_to_exists {x y: obj}:
  $ âˆ€ x P x ==> âˆƒ y P y $;

theorem forall_not_to_not_exists {x y: obj}:
  $ âˆ€ x (Â¬ P x) ==> Â¬ (âˆƒ y P y) $;

theorem not_exists_to_forall_not {x y: obj}:
  $ Â¬ (âˆƒ x P x) ==> âˆ€ y (Â¬ P y) $;

theorem forall_exists_permute_mono {u v x y: obj}:
  $ âˆ€ u âˆƒ v (P u âˆ§ Q v) ==> âˆƒ y âˆ€ x (P x âˆ§ Q y) $;

theorem exists_or_distrib {x y z: obj}:
  $ âˆƒ x (P x âˆ¨ Q x) ==> (âˆƒ y P y âˆ¨ âˆƒ z Q z) $;

theorem forall_excluded_middle {x: obj}:
  $ emp ==> âˆ€ x (P x âˆ¨ Â¬ P x) $;
