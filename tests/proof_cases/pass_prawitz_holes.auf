quant_functionality
------------------

l1: $ _wff $ by all_elim (t := $ w $) [#1]
l2: $ _ctx вКҐ вИА z (F w (g x z) вЖФ h w x = h w z) $ by all_elim [l1]
l3: $ _ctx вКҐ F w (g x y) вЖФ h w x = h w y $ by all_elim [l2]
l4: $ _ctx вКҐ F w (g x z) вЖФ h w x = h w z $ by all_elim [l2]
l5: $ _ctx вКҐ вИА z (F w (g y z) вЖФ h w y = h w z) $ by all_elim [l1]
l6: $ _ctx вКҐ F w (g y z) вЖФ h w y = h w z $ by all_elim [l5]
l7: $ (F w (g x y) вИІ F w (g x z)) вКҐ (F w (g x y) вИІ F w (g x z)) $ by ax []
l8: $ _ctx вКҐ F w (g x y) $ by and_elim_l [l7]
l9: $ _ctx вКҐ F w (g x z) $ by and_elim_r [l7]
l10: $ _ctx вКҐ h w x = h w y $ by iff_elim_l [l3, l8]
l11: $ _ctx вКҐ h w x = h w z $ by iff_elim_l [l4, l9]
l12: $ _ctx вКҐ h w y = h w x $ by eq_symm [l10]
l13: $ _ctx вКҐ h w y = h w z $ by eq_transitivity [l12, l11]
l14: $ _ctx вКҐ F w (g y z) $ by iff_elim_r [l6, l13]
l15: $ _ctx вКҐ (F w (g x y) вИІ F w (g x z)) вЖТ F w (g y z) $ by imp_intro [l14]
l16: $ _ctx вКҐ вИА z ((F w (g x y) вИІ F w (g x z)) вЖТ F w (g y z)) $ by all_intro [l15]
l17: $ _ctx вКҐ вИА y вИА z ((F w (g x y) вИІ F w (g x z)) вЖТ F w (g y z)) $ by all_intro [l16]
l18: $ _ctx вКҐ вИА x вИА y вИА z ((F w (g x y) вИІ F w (g x z)) вЖТ F w (g y z)) $ by all_intro [l17]
l19: $ _ctx вКҐ вИА w вИА x вИА y вИА z ((F w (g x y) вИІ F w (g x z)) вЖТ F w (g y z)) $ by all_intro [l18]

identity
--------

l1: $ a вКҐ a $ by ax []
l2: $ _ctx вКҐ a вЖТ a $ by imp_intro [l1]

explosion
---------

l1: $ вК• вКҐ вК• $ by ax []
l2: $ _ctx вКҐ a $ by bot_elim [l1]
l3: $ _ctx вКҐ вК• вЖТ a $ by imp_intro [l2]

double_neg_intro
----------------

l1: $ ¬ђ a вКҐ ¬ђ a $ by ax []
l2: $ a вКҐ a $ by ax []
l3: $ _ctx вКҐ вК• $ by not_elim [l1, l2]
l4: $ _ctx вКҐ ¬ђ ¬ђ a $ by not_intro [l3]
l5: $ _ctx вКҐ a вЖТ ¬ђ ¬ђ a $ by imp_intro [l4]

modus_tollens
-------------

l1: $ (a вЖТ b) вКҐ a вЖТ b $ by ax []
l2: $ a вКҐ a $ by ax []
l3: $ _ctx вКҐ b $ by imp_elim [l1, l2]
l4: $ ¬ђ b вКҐ ¬ђ b $ by ax []
l5: $ _ctx вКҐ вК• $ by not_elim [l4, l3]
l6: $ _ctx вКҐ ¬ђ a $ by not_intro [l5]
l7: $ _ctx вКҐ ¬ђ b вЖТ ¬ђ a $ by imp_intro [l6]
l8: $ _ctx вКҐ (a вЖТ b) вЖТ ¬ђ b вЖТ ¬ђ a $ by imp_intro [l7]

and_comm_iff
------------

-- Forward: (a /\ b) -> (b /\ a)
l1: $ (a вИІ b) вКҐ a вИІ b $ by ax []
l2: $ _ctx вКҐ a $ by and_elim_l [l1]
l3: $ _ctx вКҐ b $ by and_elim_r [l1]
l4: $ _ctx вКҐ b вИІ a $ by and_intro [l3, l2]
l5: $ _ctx вКҐ (a вИІ b) вЖТ (b вИІ a) $ by imp_intro [l4]
-- Backward: (b /\ a) -> (a /\ b)
l6: $ (b вИІ a) вКҐ b вИІ a $ by ax []
l7: $ _ctx вКҐ b $ by and_elim_l [l6]
l8: $ _ctx вКҐ a $ by and_elim_r [l6]
l9: $ _ctx вКҐ a вИІ b $ by and_intro [l8, l7]
l10: $ _ctx вКҐ (b вИІ a) вЖТ (a вИІ b) $ by imp_intro [l9]
-- Combine
l11: $ _ctx вКҐ (a вИІ b) вЖФ (b вИІ a) $ by iff_intro [l5, l10]

or_comm
-------

l1: $ (a вИ® b) вКҐ a вИ® b $ by ax []
l2: $ a вКҐ a $ by ax []
l3: $ _ctx вКҐ b вИ® a $ by or_intro_r [l2]
l4: $ b вКҐ b $ by ax []
l5: $ _ctx вКҐ b вИ® a $ by or_intro_l [l4]
l6: $ _ctx вКҐ b вИ® a $ by or_elim [l1, l3, l5]
l7: $ _ вКҐ (a вИ® b) вЖТ (b вИ® a) $ by imp_intro [l6]

disjunctive_syllogism
---------------------

l1: $ (a вИ® b) вКҐ a вИ® b $ by ax []
l2: $ ¬ђ a вКҐ ¬ђ a $ by ax []
l3: $ a вКҐ a $ by ax []
l4: $ _ctx вКҐ вК• $ by not_elim [l2, l3]
l5: $ _ctx вКҐ b $ by bot_elim [l4]
l6: $ b вКҐ b $ by ax []
l7: $ _ctx вКҐ b $ by or_elim [l1, l5, l6]
l8: $ _ctx вКҐ ¬ђ a вЖТ b $ by imp_intro [l7]
l9: $ _ вКҐ (a вИ® b) вЖТ ¬ђ a вЖТ b $ by imp_intro [l8]

de_morgan_or
------------

-- Forward: ~(a \/ b) -> (~a /\ ~b)
l1: $ ¬ђ (a вИ® b) вКҐ ¬ђ (a вИ® b) $ by ax []
l2: $ a вКҐ a $ by ax []
l3: $ _ctx вКҐ a вИ® b $ by or_intro_l [l2]
l4: $ _ctx вКҐ вК• $ by not_elim [l1, l3]
l5: $ _ctx вКҐ ¬ђ a $ by not_intro [l4]
l6: $ b вКҐ b $ by ax []
l7: $ _ctx вКҐ a вИ® b $ by or_intro_r [l6]
l8: $ _ctx вКҐ вК• $ by not_elim [l1, l7]
l9: $ _ctx вКҐ ¬ђ b $ by not_intro [l8]
l10: $ _ctx вКҐ ¬ђ a вИІ ¬ђ b $ by and_intro [l5, l9]
l11: $ _ctx вКҐ ¬ђ (a вИ® b) вЖТ (¬ђ a вИІ ¬ђ b) $ by imp_intro [l10]
-- Backward: (~a /\ ~b) -> ~(a \/ b)
l12: $ (¬ђ a вИІ ¬ђ b) вКҐ ¬ђ a вИІ ¬ђ b $ by ax []
l13: $ _ctx вКҐ ¬ђ a $ by and_elim_l [l12]
l14: $ _ctx вКҐ ¬ђ b $ by and_elim_r [l12]
l15: $ (a вИ® b) вКҐ a вИ® b $ by ax []
l16: $ a вКҐ a $ by ax []
l17: $ _ctx вКҐ вК• $ by not_elim [l13, l16]
l18: $ b вКҐ b $ by ax []
l19: $ _ctx вКҐ вК• $ by not_elim [l14, l18]
l20: $ _ctx вКҐ вК• $ by or_elim [l15, l17, l19]
l21: $ _ctx вКҐ ¬ђ (a вИ® b) $ by not_intro [l20]
l22: $ _ctx вКҐ (¬ђ a вИІ ¬ђ b) вЖТ ¬ђ (a вИ® b) $ by imp_intro [l21]
-- Combine
l23: $ _ctx вКҐ ¬ђ (a вИ® b) вЖФ (¬ђ a вИІ ¬ђ b) $ by iff_intro [l11, l22]

curry_iff
---------

-- Forward: ((a /\ b) -> c) -> (a -> b -> c)
l1: $ (a вИІ b) вЖТ c вКҐ (a вИІ b) вЖТ c $ by ax []
l2: $ a , b вКҐ a $ by ax []
l3: $ a , b вКҐ b $ by ax []
l4: $ _ctx вКҐ a вИІ b $ by and_intro [l2, l3]
l5: $ _ctx  вКҐ c $ by imp_elim [l1, l4]
l6: $ _ctx вКҐ b вЖТ c $ by imp_intro [l5]
l7: $ _ctx вКҐ a вЖТ b вЖТ c $ by imp_intro [l6]
l8: $ _ctx вКҐ ((a вИІ b) вЖТ c) вЖТ (a вЖТ b вЖТ c) $ by imp_intro [l7]
-- Backward: (a -> b -> c) -> ((a /\ b) -> c)
l9: $ a вЖТ b вЖТ c вКҐ a вЖТ b вЖТ c $ by ax []
l10: $ (a вИІ b) вКҐ a вИІ b $ by ax []
l11: $ _ctx вКҐ a $ by and_elim_l [l10]
l12: $ _ctx вКҐ b $ by and_elim_r [l10]
l13: $ _ctx вКҐ b вЖТ c $ by imp_elim [l9, l11]
l14: $ _ctx вКҐ c $ by imp_elim [l13, l12]
l15: $ _ctx вКҐ (a вИІ b) вЖТ c $ by imp_intro [l14]
l16: $ _ctx вКҐ (a вЖТ b вЖТ c) вЖТ ((a вИІ b) вЖТ c) $ by imp_intro [l15]
-- Combine
l17: $ _ вКҐ ((a вИІ b) вЖТ c) вЖФ (a вЖТ b вЖТ c) $ by iff_intro [l8, l16]

imp_trans
---------

l1: $ (a вЖТ b) вКҐ a вЖТ b $ by ax []
l2: $ (b вЖТ c) вКҐ b вЖТ c $ by ax []
l3: $ a вКҐ a $ by ax []
l4: $ _ctx вКҐ b $ by imp_elim [l1, l3]
l5: $ _ctx вКҐ c $ by imp_elim [l2, l4]
l6: $ _ctx вКҐ a вЖТ c $ by imp_intro [l5]
l7: $ _ctx вКҐ (b вЖТ c) вЖТ (a вЖТ c) $ by imp_intro [l6]
l8: $ _ вКҐ (a вЖТ b) вЖТ (b вЖТ c) вЖТ (a вЖТ c) $ by imp_intro [l7]

not_not_lem
-----------

-- Proof that ~~(a \/ ~a) is intuitionistically valid
l1: $ ¬ђ (a вИ® ¬ђ a) вКҐ ¬ђ (a вИ® ¬ђ a) $ by ax []
-- Derive ~a from ~(a \/ ~a)
l2: $ a вКҐ a $ by ax []
l3: $ _ctx вКҐ a вИ® ¬ђ a $ by or_intro_l [l2]
l4: $ _ctx вКҐ вК• $ by not_elim [l1, l3]
l5: $ _ctx вКҐ ¬ђ a $ by not_intro [l4]
-- Now a \/ ~a from ~a
l6: $ _ctx вКҐ a вИ® ¬ђ a $ by or_intro_r [l5]
-- Contradiction
l7: $ _ctx вКҐ вК• $ by not_elim [l1, l6]
-- Conclude ~~(a \/ ~a)
l8: $ _ вКҐ ¬ђ ¬ђ (a вИ® ¬ђ a) $ by not_intro [l7]

alpha_all_intro_demo
--------------------

l1: $ вИА a (F a b) , F b b вКҐ F b b $ by ax []
l2: $ _ctx вКҐ вИА a (F b b) $ by all_intro [l1]

alpha_ex_intro_demo
-------------------

l1: $ вИА a (F a b) , F b b вКҐ F b b $ by ax []
l2: $ _ctx вКҐ вИГ a (F a b) $ by ex_intro (t := $ b $) [l1]

alpha_ex_elim_demo
------------------

l1: $ вИА a (F a b) , вИГ a (F a b) вКҐ вИГ a (F a b) $ by ax []
l2: $ вИА a (F a b) , F a b вКҐ вИА a (F a b) $ by ax []
l3: $ _ctx вКҐ вИА a (F a b) $ by ex_elim [l1, l2]

forall_swap
-----------

l1: $ _ вКҐ вИА b (F a b) $ by all_elim [#1]
l2: $ _ вКҐ F a b $ by all_elim [l1]
l3: $ _ вКҐ вИА a (F a b) $ by all_intro [l2]
l4: $ _ вКҐ вИА b вИА a (F a b) $ by all_intro [l3]

forall_specialize
-----------------

l1: $ _ вКҐ вИА b (F c b) $ by all_elim [#1]
l2: $ _ вКҐ F c a $ by all_elim [l1]

forall_and_combine
------------------

l1: $ _ вКҐ F a b $ by all_elim [#1]
l2: $ _ вКҐ F b a $ by all_elim [#2]
l3: $ _ вКҐ F a b вИІ F b a $ by and_intro [l1, l2]
l4: $ _ вКҐ вИА a (F a b вИІ F b a) $ by all_intro [l3]

exists_from_forall
------------------

l1: $ _ вКҐ F a b $ by all_elim [#1]
l2: $ _ вКҐ вИГ a (F a b) $ by ex_intro [l1]

forall_imp_distribute
---------------------

l1: $ _ вКҐ (F a b) вЖТ (F b a) $ by all_elim [#1]
l2: $ _ вКҐ F a b $ by all_elim [#2]
l3: $ _ вКҐ F b a $ by imp_elim [l1, l2]
l4: $ _ вКҐ вИА a (F b a) $ by all_intro [l3]

forall_not_to_not_exists
------------------------

l1: $ (вИА a (¬ђ (F a b))) вКҐ вИА a (¬ђ (F a b)) $ by ax []
l2: $ _ctx вКҐ ¬ђ (F a b) $ by all_elim [l1]
l3: $ (F a b) вКҐ F a b $ by ax []
l4: $ _ctx вКҐ вК• $ by not_elim [l2, l3]
l5: $ (вИГ a (F a b)) вКҐ вИГ a (F a b) $ by ax []
l6: $ _ctx вКҐ вК• $ by ex_elim [l5, l4]
l7: $ _ctx вКҐ ¬ђ (вИГ a (F a b)) $ by not_intro [l6]
l8: $ _ вКҐ (вИА a (¬ђ (F a b))) вЖТ ¬ђ (вИГ a (F a b)) $ by imp_intro [l7]
