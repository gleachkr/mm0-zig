injective_elim_imp
------------------
l1: $ ∀ w ∀ u ∀ v (((w ∈ A ∧ u ∈ A) ∧ (maps f w v ∧ maps f u v)) → w = u) $ by and_elim_r [#1]
l2: $ ∀ w ∀ u ∀ v (((w ∈ A ∧ u ∈ A) ∧ (maps f w v ∧ maps f u v)) → w = u) → ∀ u ∀ v (((x ∈ A ∧ u ∈ A) ∧ (maps f x v ∧ maps f u v)) → x = u) $ by all_elim_imp
l3: $ ∀ u ∀ v (((x ∈ A ∧ u ∈ A) ∧ (maps f x v ∧ maps f u v)) → x = u) $ by mp [l2, l1]
l4: $ ∀ u ∀ v (((x ∈ A ∧ u ∈ A) ∧ (maps f x v ∧ maps f u v)) → x = u) → ∀ v (((x ∈ A ∧ y ∈ A) ∧ (maps f x v ∧ maps f y v)) → x = y) $ by all_elim_imp
l5: $ ∀ v (((x ∈ A ∧ y ∈ A) ∧ (maps f x v ∧ maps f y v)) → x = y) $ by mp [l4, l3]
l6: $ ∀ v (((x ∈ A ∧ y ∈ A) ∧ (maps f x v ∧ maps f y v)) → x = y) → (((x ∈ A ∧ y ∈ A) ∧ (maps f x z ∧ maps f y z)) → x = y) $ by all_elim_imp
l7: $ (((x ∈ A ∧ y ∈ A) ∧ (maps f x z ∧ maps f y z)) → x = y) $ by mp [l6, l5]
l8: $ x ∈ A ∧ y ∈ A $ by and_intro [#2, #3]
l9: $ maps f x z → (maps f y z → maps f x z) $ by h1
l10: $ maps f y z → maps f x z $ by mp [l9, #4]
l11: $ maps f y z → maps f y z $ by imp_id
l12: $ maps f y z → maps f x z ∧ maps f y z $ by and_intro_imp [l10, l11]
l13: $ (x ∈ A ∧ y ∈ A) → (maps f y z → (x ∈ A ∧ y ∈ A)) $ by h1
