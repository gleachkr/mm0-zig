cb_core_not_mem_image
---------------------
l1: $ cb_core A B f g = cb_step A B f g (cb_core A B f g) $ by cb_core_fixed
l2: $ x ∉ cb_core A B f g → x ∉ cb_step A B f g (cb_core A B f g) $ by not_mem_eq_imp [l1]
l3: $ x ∈ A → (x ∉ cb_step A B f g (cb_core A B f g) → x ∈ image g (B ∖ image f (cb_core A B f g) B) A) $ by setdiff_missing_imp
l4: $ x ∉ cb_step A B f g (cb_core A B f g) → x ∈ image g (B ∖ image f (cb_core A B f g) B) A $ by mp [l3, #1]
l5: $ x ∉ cb_core A B f g → x ∈ image g (B ∖ image f (cb_core A B f g) B) A $ by imp_trans [l2, l4]

cb_core_not_mem_image_imp
-------------------------
l1: $ cb_core A B f g = cb_step A B f g (cb_core A B f g) $ by cb_core_fixed
l2: $ x ∉ cb_core A B f g → x ∉ cb_step A B f g (cb_core A B f g) $ by not_mem_eq_imp [l1]
l3: $ x ∈ A → (x ∉ cb_step A B f g (cb_core A B f g) → x ∈ image g (B ∖ image f (cb_core A B f g) B) A) $ by setdiff_missing_imp
l4: $ x ∈ A → (x ∉ cb_core A B f g → x ∉ cb_step A B f g (cb_core A B f g)) $ by imp_const [l2]
l5: $ x ∈ A → (x ∉ cb_core A B f g → x ∈ image g (B ∖ image f (cb_core A B f g) B) A) $ by imp_trans_under [l4, l3]

cb_f_image_g_maps_core_imp
--------------------------
l1: $ t ∈ image f (cb_core A B f g) B → t ∈ B $ by image_elim_mem
l2: $ t ∈ image f (cb_core A B f g) B →
      (w ∈ A → t ∈ B) $ by imp_lift [l1]
l3: $ t ∈ image f (cb_core A B f g) B →
      (w ∈ A → (maps g t w → t ∈ B)) $ by imp_lift_under2 [l2]
l4: $ w ∈ A → (w ∉ cb_core A B f g →
      w ∈ image g (B ∖ image f (cb_core A B f g) B) A) $
  by cb_core_not_mem_image_imp
l5: $ t ∈ image f (cb_core A B f g) B →
      (w ∈ A → (w ∉ cb_core A B f g →
      w ∈ image g (B ∖ image f (cb_core A B f g) B) A)) $
  by imp_const [l4]
l6: $ t ∈ image f (cb_core A B f g) B →
      (w ∈ A → (maps g t w → (w ∉ cb_core A B f g →
      w ∈ image g (B ∖ image f (cb_core A B f g) B) A))) $
  by imp_lift_under2 [l5]
l7a: $ maps g t w → maps g t w $ by imp_id
l7b: $ t ∈ image f (cb_core A B f g) B →
      (w ∈ A → (maps g t w → maps g t w)) $ by imp_const2 [l7a]
l9: $ t ∈ image f (cb_core A B f g) B →
      (w ∈ A → (maps g t w →
      (w ∈ image g (B ∖ image f (cb_core A B f g) B) A →
      t ∉ image f (cb_core A B f g) B))) $
  by image_preimage_not_mem_imp_under3 [#1, l3, l7b]
l10: $ t ∈ image f (cb_core A B f g) B →
       (w ∈ A → (maps g t w → (w ∉ cb_core A B f g →
       t ∉ image f (cb_core A B f g) B))) $
  by imp_trans_under3 [l6, l9]
l11a: $ t ∈ image f (cb_core A B f g) B →
        t ∈ image f (cb_core A B f g) B $ by imp_id
l11b: $ t ∈ image f (cb_core A B f g) B →
       (w ∈ A → t ∈ image f (cb_core A B f g) B) $ by imp_lift [l11a]
l11c: $ t ∈ image f (cb_core A B f g) B →
       (w ∈ A → (maps g t w →
       t ∈ image f (cb_core A B f g) B)) $ by imp_lift_under2 [l11b]
l11: $ t ∈ image f (cb_core A B f g) B →
