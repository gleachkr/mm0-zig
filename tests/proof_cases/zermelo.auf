imp_trans
---------
l1: $ (q тЖТ r) тЖТ (p тЖТ (q тЖТ r)) $ by h1
l2: $ p тЖТ (q тЖТ r) $ by mp [l1, #2]
l3: $ (p тЖТ (q тЖТ r)) тЖТ ((p тЖТ q) тЖТ (p тЖТ r)) $ by h2
l4: $ (p тЖТ q) тЖТ (p тЖТ r) $ by mp [l3, l2]
l5: $ p тЖТ r $ by mp [l4, #1]

imp_mp_right
------------
l1: $ q тЖТ (p тЖТ q) $ by h1
l2: $ p тЖТ q $ by mp [l1, #1]
l3: $ (p тЖТ (q тЖТ r)) тЖТ ((p тЖТ q) тЖТ (p тЖТ r)) $ by h2
l4: $ (p тЖТ q) тЖТ (p тЖТ r) $ by mp [l3, #2]
l5: $ p тЖТ r $ by mp [l4, l2]

and_intro
---------
l1: $ p тЖТ (q тЖТ p тИз q) $ by and1
l2: $ q тЖТ p тИз q $ by mp [l1, #1]
l3: $ p тИз q $ by mp [l2, #2]

and_mp_right
------------
l1: $ r тЖТ (q тЖТ r) $ by h1
l2: $ q тЖТ r $ by mp [l1, #1]
l3: $ q тЖТ (r тЖТ q тИз r) $ by and1
l4: $ (q тЖТ (r тЖТ q тИз r)) тЖТ ((q тЖТ r) тЖТ (q тЖТ q тИз r)) $ by h2
l5: $ (q тЖТ r) тЖТ (q тЖТ q тИз r) $ by mp [l4, l3]
l6: $ q тЖТ q тИз r $ by mp [l5, l2]
l7: $ ((q тИз r) тЖТ s) тЖТ (q тЖТ ((q тИз r) тЖТ s)) $ by h1
l8: $ q тЖТ ((q тИз r) тЖТ s) $ by mp [l7, #2]
l9: $ (q тЖТ ((q тИз r) тЖТ s)) тЖТ ((q тЖТ q тИз r) тЖТ (q тЖТ s)) $ by h2
l10: $ (q тЖТ q тИз r) тЖТ (q тЖТ s) $ by mp [l9, l8]
l11: $ q тЖТ s $ by mp [l10, l6]

bi_imp
------
l1: $ (p тЖФ q) тЖТ (p тЖТ q) $ by bi1
l2: $ p тЖТ q $ by mp [l1, #1]

bi_imp_imp
----------
l1: $ (q тЖФ r) тЖТ (q тЖТ r) $ by bi1
l2: $ ((q тЖФ r) тЖТ (q тЖТ r)) тЖТ (p тЖТ ((q тЖФ r) тЖТ (q тЖТ r))) $ by h1
l3: $ p тЖТ ((q тЖФ r) тЖТ (q тЖТ r)) $ by mp [l2, l1]
l4: $ (p тЖТ ((q тЖФ r) тЖТ (q тЖТ r))) тЖТ ((p тЖТ (q тЖФ r)) тЖТ (p тЖТ (q тЖТ r))) $ by h2
l5: $ (p тЖТ (q тЖФ r)) тЖТ (p тЖТ (q тЖТ r)) $ by mp [l4, l3]
l6: $ p тЖТ (q тЖТ r) $ by mp [l5, #1]

functional_elim_imp
-------------------
l1: $ тИА w тИА u тИА v ((maps f w u тИз maps f w v) тЖТ u = v) тЖТ тИА u тИА v ((maps f x u тИз maps f x v) тЖТ u = v) $ by all_elim_imp
l2: $ тИА u тИА v ((maps f x u тИз maps f x v) тЖТ u = v) $ by mp [l1, #1]
l3: $ тИА u тИА v ((maps f x u тИз maps f x v) тЖТ u = v) тЖТ тИА v ((maps f x y тИз maps f x v) тЖТ y = v) $ by all_elim_imp
l4: $ тИА v ((maps f x y тИз maps f x v) тЖТ y = v) $ by mp [l3, l2]
l5: $ тИА v ((maps f x y тИз maps f x v) тЖТ y = v) тЖТ ((maps f x y тИз maps f x z) тЖТ y = z) $ by all_elim_imp
l6: $ (maps f x y тИз maps f x z) тЖТ y = z $ by mp [l5, l4]
l7: $ maps f x y тЖТ y = z $ by and_mp_right [#2, l6]

functional_elim
---------------
l1: $ maps f x y тЖТ y = z $ by functional_elim_imp [#1, #3]
l2: $ y = z $ by mp [l1, #2]

surj_has_preimage
-----------------
l1: $ тИА u (u тИИ B тЖТ тИГ x (x тИИ A тИз maps f x u)) $ by and_elim_r [#1]
l2: $ тИА u (u тИИ B тЖТ тИГ x (x тИИ A тИз maps f x u)) тЖТ (y тИИ B тЖТ тИГ x (x тИИ A тИз maps f x y)) $ by all_elim_imp
l3: $ y тИИ B тЖТ тИГ x (x тИИ A тИз maps f x y) $ by mp [l2, l1]
l4: $ тИГ x (x тИИ A тИз maps f x y) $ by mp [l3, #2]

mem_eq_imp
----------
l1: $ x = x $ by setid
l2: $ (x тИИ A) тЖФ (x тИИ B) $ by mem_congr [l1, #1]
l3: $ x тИИ A тЖТ x тИИ B $ by bi_imp [l2]

mem_eq_imp_imp
--------------
l1: $ A = B тЖТ (x тИИ A тЖТ x тИИ B) $ by eq_replace_imp

function_unique
---------------
l1: $ functional f $ by and_elim_l [#1]
l2: $ y = z $ by functional_elim [l1, #2, #3]

function_unique_imp
-------------------
l1: $ functional f $ by and_elim_l [#1]
l2: $ maps f x y тЖТ y = z $ by functional_elim_imp [l1, #2]

image_not_mem_imp
-----------------
l1: $ maps f a y тЖТ y = diag A f $ by function_unique_imp [#1, #2]
l2: $ y = diag A f тЖТ (a тИИ y тЖТ a тИИ diag A f) $ by mem_eq_imp_imp
l3: $ maps f a y тЖТ (a тИИ y тЖТ a тИИ diag A f) $ by imp_trans [l1, l2]

misses_elim_imp
---------------
l1: $ тИА u (maps f x u тЖТ x тИЙ u) тЖТ (maps f x y тЖТ x тИЙ y) $ by all_elim_imp
l2: $ тИА u (maps f x u тЖТ x тИЙ u) тЖТ x тИЙ y $ by imp_mp_right [#1, l1]

misses_if_not_in_diag_imp
-------------------------
l1: $ maps f a y тЖТ (a тИИ y тЖТ a тИИ diag A f) $ by image_not_mem_imp [#1, #2]
l2: $ ┬м (a тИИ diag A f) тЖТ (maps f a y тЖТ a тИЙ y) $ by contra_imp [l1]
l3: $ ┬м (a тИИ diag A f) тЖТ misses f a $ by all_intro_imp [l2]

diag_subset
-----------
l1: $ diag A f тКЖ A $ by sep_subset

diag_misses_imp
---------------
l1: $ a тИИ diag A f тЖТ misses f a $ by sep_elim_right_imp

diag_intro_from_misses
----------------------
l1: $ misses f a тЖТ a тИИ diag A f $ by sep_intro_imp [#1]

diagonal_intro_out_imp
----------------------
l1: $ ┬м (a тИИ diag A f) тЖТ misses f a $ by misses_if_not_in_diag_imp [#1, #3]
l2: $ misses f a тЖТ a тИИ diag A f $ by diag_intro_from_misses [#2]
l3: $ ┬м (a тИИ diag A f) тЖТ a тИИ diag A f $ by imp_trans [l1, l2]

diagonal_in_case
----------------
l1: $ a тИИ diag A f тЖТ misses f a $ by diag_misses_imp
l2: $ misses f a тЖТ a тИЙ diag A f $ by misses_elim_imp [#2]
l3: $ a тИИ diag A f тЖТ a тИЙ diag A f $ by imp_trans [l1, l2]
l4: $ a тИИ diag A f тЖТ тКе $ by imp_not_self [l3]

diagonal_out_case
-----------------
l1: $ ┬м (a тИИ diag A f) тЖТ a тИИ diag A f $ by diagonal_intro_out_imp [#1, #2, #3]
l2: $ ┬м (a тИИ diag A f) тЖТ тКе $ by imp_not_to_self [l1]

surj_wit_mem
------------
l1: $ тИГ x (x тИИ A тИз maps f x y) $ by surj_has_preimage [#1, #2]
l2: $ surj_wit f A y тИИ A тИз maps f (surj_wit f A y) y $ by preimage_wit_pair [l1]
l3: $ surj_wit f A y тИИ A $ by and_elim_l [l2]

surj_wit_maps
-------------
l1: $ тИГ x (x тИИ A тИз maps f x y) $ by surj_has_preimage [#1, #2]
l2: $ surj_wit f A y тИИ A тИз maps f (surj_wit f A y) y $ by preimage_wit_pair [l1]
l3: $ maps f (surj_wit f A y) y $ by and_elim_r [l2]

cantor_witness
--------------
l1: $ a тИИ diag A f тЖТ тКе $ by diagonal_in_case [#1, #3]
l2: $ ┬м (a тИИ diag A f) тЖТ тКе $ by diagonal_out_case [#1, #2, #3]
l3: $ тКе $ by cases_bot [l1, l2]

cantor
------
l1: $ diag A f тКЖ A $ by diag_subset
l2: $ diag A f тИИ power A $ by power_intro [l1]
l3: $ surj_wit f A (diag A f) тИИ A $ by surj_wit_mem [#2, l2]
l4: $ maps f (surj_wit f A (diag A f)) (diag A f) $ by surj_wit_maps [#2, l2]
l5: $ тКе $ by cantor_witness [#1, l3, l4]
