      (u ∉ cb_core A B f g ∧ maps g v u)) →
      (((w ∈ cb_core A B f g ∧ maps f w t) ∨
      (w ∉ cb_core A B f g ∧ maps g t w)) → x = y))) $
  by imp_trans_under [l7, l6]
l9: $ (opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) →
      ((opair y z = opair w t ∧
      ((w ∈ cb_core A B f g ∧ maps f w t) ∨
      (w ∉ cb_core A B f g ∧ maps g t w))) →
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) $ by imp_lift [l2]
l10: $ (opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) →
      ((opair y z = opair w t ∧
      ((w ∈ cb_core A B f g ∧ maps f w t) ∨
      (w ∉ cb_core A B f g ∧ maps g t w))) →
      (((w ∈ cb_core A B f g ∧ maps f w t) ∨
      (w ∉ cb_core A B f g ∧ maps g t w)) → x = y)) $
  by imp_apply_under2 [l8, l9]
l11: $ (opair x z = opair u v ∧
