cb_bijection_intro_imp
-------------------------
l1: $ p ∈ pair_carrier A B → ((∃ u ∃ v (p = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u)))) → p ∈ cb_bijection A B f g) $ by sep_intro_imp_imp

cb_bijection_f_branch_maps_imp
------------------------------
l1: $ cb_core A B f g ⊆ A $ by cb_core_subset
l2: $ x ∈ cb_core A B f g → x ∈ A $ by subset_elim_imp [l1]
l3: $ x ∈ cb_core A B f g ∧ maps f x y → x ∈ cb_core A B f g $ by and_elim_l_imp
l4: $ x ∈ cb_core A B f g ∧ maps f x y → maps f x y $ by and_elim_r_imp
l5: $ x ∈ cb_core A B f g ∧ maps f x y → x ∈ A $ by imp_trans [l3, l2]
l6: $ maps f x y → y ∈ B $ by injective_maps_range_imp [#1]
l7: $ x ∈ cb_core A B f g ∧ maps f x y → y ∈ B $ by imp_trans [l4, l6]
l8: $ x ∈ A → (y ∈ B → opair x y ∈ pair_carrier A B) $ by opair_mem_pair_carrier_imp
l9: $ x ∈ cb_core A B f g ∧ maps f x y → (x ∈ A → (y ∈ B → opair x y ∈ pair_carrier A B)) $ by imp_const [l8]
l10: $ x ∈ cb_core A B f g ∧ maps f x y → (y ∈ B → opair x y ∈ pair_carrier A B) $ by imp_apply_under [l9, l5]
l11: $ x ∈ cb_core A B f g ∧ maps f x y → opair x y ∈ pair_carrier A B $ by imp_apply_under [l10, l7]
l12: $ opair x y = opair x y $ by setid
l13: $ x ∈ cb_core A B f g ∧ maps f x y → opair x y = opair x y $ by imp_const [l12]
l14: $ (x ∈ cb_core A B f g ∧ maps f x y) → ((x ∈ cb_core A B f g ∧ maps f x y) ∨ (x ∉ cb_core A B f g ∧ maps g y x)) $ by or_intro_l_imp
l15: $ x ∈ cb_core A B f g ∧ maps f x y → (opair x y = opair x y ∧ ((x ∈ cb_core A B f g ∧ maps f x y) ∨ (x ∉ cb_core A B f g ∧ maps g y x))) $ by and_intro_imp [l13, l14]
l16: $ x ∈ cb_core A B f g ∧ maps f x y → ∃ v (opair x y = opair x v ∧ ((x ∈ cb_core A B f g ∧ maps f x v) ∨ (x ∉ cb_core A B f g ∧ maps g v x))) $ by ex_intro_imp [l15]
l17: $ x ∈ cb_core A B f g ∧ maps f x y → ∃ u ∃ v (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u))) $ by ex_intro_imp [l16]
l18a: $ opair x y ∈ pair_carrier A B → ((∃ u ∃ v (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u)))) → maps (cb_bijection A B f g) x y) $ by cb_bijection_intro_imp
l18b: $ x ∈ cb_core A B f g ∧ maps f x y → (opair x y ∈ pair_carrier A B → ((∃ u ∃ v (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u)))) → maps (cb_bijection A B f g) x y)) $ by imp_const [l18a]
l18c: $ x ∈ cb_core A B f g ∧ maps f x y → ((∃ u ∃ v (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u)))) → maps (cb_bijection A B f g) x y) $ by imp_apply_under [l18b, l11]
l18: $ x ∈ cb_core A B f g ∧ maps f x y → maps (cb_bijection A B f g) x y $ by imp_apply_under [l18c, l17]
l19: $ x ∈ cb_core A B f g → (maps f x y → x ∈ cb_core A B f g ∧ maps f x y) $ by and1
l20: $ x ∈ cb_core A B f g → ((x ∈ cb_core A B f g ∧ maps f x y) → maps (cb_bijection A B f g) x y) $ by imp_const [l18]
l21: $ x ∈ cb_core A B f g → (maps f x y → maps (cb_bijection A B f g) x y) $ by imp_trans_under [l19, l20]

cb_bijection_g_branch_maps_imp
------------------------------
l1: $ x ∈ A ∧ (x ∉ cb_core A B f g ∧ maps g y x) → x ∈ A $ by and_elim_l_imp
l2: $ x ∈ A ∧ (x ∉ cb_core A B f g ∧ maps g y x) → x ∉ cb_core A B f g ∧ maps g y x $ by and_elim_r_imp
l3: $ x ∉ cb_core A B f g ∧ maps g y x → maps g y x $ by and_elim_r_imp
l4: $ x ∈ A ∧ (x ∉ cb_core A B f g ∧ maps g y x) → maps g y x $ by imp_trans [l2, l3]
l5: $ maps g y x → y ∈ B $ by injective_maps_domain_imp [#1]
l6: $ x ∈ A ∧ (x ∉ cb_core A B f g ∧ maps g y x) → y ∈ B $ by imp_trans [l4, l5]
l7: $ x ∈ A → (y ∈ B → opair x y ∈ pair_carrier A B) $ by opair_mem_pair_carrier_imp
l8: $ x ∈ A ∧ (x ∉ cb_core A B f g ∧ maps g y x) → (x ∈ A → (y ∈ B → opair x y ∈ pair_carrier A B)) $ by imp_const [l7]
l9: $ x ∈ A ∧ (x ∉ cb_core A B f g ∧ maps g y x) → (y ∈ B → opair x y ∈ pair_carrier A B) $ by imp_apply_under [l8, l1]
l10: $ x ∈ A ∧ (x ∉ cb_core A B f g ∧ maps g y x) → opair x y ∈ pair_carrier A B $ by imp_apply_under [l9, l6]
l11: $ opair x y = opair x y $ by setid
l12: $ x ∈ A ∧ (x ∉ cb_core A B f g ∧ maps g y x) → opair x y = opair x y $ by imp_const [l11]
l13: $ (x ∉ cb_core A B f g ∧ maps g y x) → ((x ∈ cb_core A B f g ∧ maps f x y) ∨ (x ∉ cb_core A B f g ∧ maps g y x)) $ by or_intro_r_imp
l14: $ x ∈ A ∧ (x ∉ cb_core A B f g ∧ maps g y x) → ((x ∈ cb_core A B f g ∧ maps f x y) ∨ (x ∉ cb_core A B f g ∧ maps g y x)) $ by imp_trans [l2, l13]
l15: $ x ∈ A ∧ (x ∉ cb_core A B f g ∧ maps g y x) → (opair x y = opair x y ∧ ((x ∈ cb_core A B f g ∧ maps f x y) ∨ (x ∉ cb_core A B f g ∧ maps g y x))) $ by and_intro_imp [l12, l14]
l16: $ x ∈ A ∧ (x ∉ cb_core A B f g ∧ maps g y x) → ∃ v (opair x y = opair x v ∧ ((x ∈ cb_core A B f g ∧ maps f x v) ∨ (x ∉ cb_core A B f g ∧ maps g v x))) $ by ex_intro_imp [l15]
l17: $ x ∈ A ∧ (x ∉ cb_core A B f g ∧ maps g y x) → ∃ u ∃ v (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u))) $ by ex_intro_imp [l16]
l18a: $ opair x y ∈ pair_carrier A B → ((∃ u ∃ v (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u)))) → maps (cb_bijection A B f g) x y) $ by cb_bijection_intro_imp
l18b: $ x ∈ A ∧ (x ∉ cb_core A B f g ∧ maps g y x) → (opair x y ∈ pair_carrier A B → ((∃ u ∃ v (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u)))) → maps (cb_bijection A B f g) x y)) $ by imp_const [l18a]
l18c: $ x ∈ A ∧ (x ∉ cb_core A B f g ∧ maps g y x) → ((∃ u ∃ v (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u)))) → maps (cb_bijection A B f g) x y) $ by imp_apply_under [l18b, l10]
l18: $ x ∈ A ∧ (x ∉ cb_core A B f g ∧ maps g y x) → maps (cb_bijection A B f g) x y $ by imp_apply_under [l18c, l17]
l19: $ x ∈ A → (x ∉ cb_core A B f g → x ∈ A) $ by h1
l20: $ x ∈ A → (x ∉ cb_core A B f g → (maps g y x → x ∈ A)) $ by imp_lift_under2 [l19]
l21: $ x ∉ cb_core A B f g → (maps g y x → x ∉ cb_core A B f g ∧ maps g y x) $ by and1
l22: $ x ∈ A → (x ∉ cb_core A B f g → (maps g y x → x ∉ cb_core A B f g ∧ maps g y x)) $ by imp_const [l21]
l23: $ x ∈ A → (x ∉ cb_core A B f g → (maps g y x → x ∈ A ∧ (x ∉ cb_core A B f g ∧ maps g y x))) $ by and_intro_imp_under2 [l20, l22]
l24: $ x ∈ A → (x ∉ cb_core A B f g → ((x ∈ A ∧ (x ∉ cb_core A B f g ∧ maps g y x)) → maps (cb_bijection A B f g) x y)) $ by imp_const2 [l18]
l25: $ x ∈ A → (x ∉ cb_core A B f g → (maps g y x → maps (cb_bijection A B f g) x y)) $ by imp_trans_under2 [l23, l24]

cb_bijection_maps_domain_from_injections
----------------------------------------
l1: $ maps (cb_bijection A B f g) x y → ∃ u ∃ v (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u))) $ by cb_bijection_maps_cases_imp
l2: $ (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u))) → opair x y = opair u v $ by and_elim_l_imp
l3: $ (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u))) → ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u)) $ by and_elim_r_imp
l4: $ u ∈ cb_core A B f g ∧ maps f u v → u ∈ cb_core A B f g $ by and_elim_l_imp
l5: $ cb_core A B f g ⊆ A $ by cb_core_subset
l6: $ u ∈ cb_core A B f g → u ∈ A $ by subset_elim_imp [l5]
l7: $ u ∈ cb_core A B f g ∧ maps f u v → u ∈ A $ by imp_trans [l4, l6]
l8: $ u ∉ cb_core A B f g ∧ maps g v u → maps g v u $ by and_elim_r_imp
l9: $ maps g v u → u ∈ A $ by injective_maps_range_imp [#2]
l10: $ u ∉ cb_core A B f g ∧ maps g v u → u ∈ A $ by imp_trans [l8, l9]
l11: $ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u)) → u ∈ A $ by or_elim_imp [l7, l10]
l12: $ opair x y = opair u v → x = u $ by opair_eq_left_imp
l13: $ x = u → (u ∈ A → x ∈ A) $ by mem_arg_eq_left_imp_imp
l14: $ opair x y = opair u v → (u ∈ A → x ∈ A) $ by imp_trans [l12, l13]
l15: $ (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u))) → (u ∈ A → x ∈ A) $ by imp_trans [l2, l14]
l16: $ (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u))) → u ∈ A $ by imp_trans [l3, l11]
l17: $ (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u))) → x ∈ A $ by imp_apply_under [l15, l16]
l18: $ ∀ v ((opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u))) → x ∈ A) $ by all_intro [l17]
l19: $ ∃ v (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u))) → x ∈ A $ by ex_elim_imp [l18]
l20: $ ∀ u ((∃ v (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u)))) → x ∈ A) $ by all_intro [l19]
l21: $ ∃ u ∃ v (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u))) → x ∈ A $ by ex_elim_imp [l20]
l22: $ maps (cb_bijection A B f g) x y → x ∈ A $ by imp_trans [l1, l21]

cb_bijection_has_value_from_injections
--------------------------------------
l1: $ domain_on f A $ by injective_domain_on [#1]
l2: $ x ∈ A → ∃ a maps f x a $ by domain_on_has_maps_imp [l1]
l3: $ x ∈ cb_core A B f g → (maps f x a → maps (cb_bijection A B f g) x a) $ by cb_bijection_f_branch_maps_imp [#1]
l4a: $ maps (cb_bijection A B f g) x a → maps (cb_bijection A B f g) x a $ by imp_id
l4: $ maps (cb_bijection A B f g) x a → ∃ y maps (cb_bijection A B f g) x y $ by ex_intro_imp [l4a]
l4b: $ x ∈ cb_core A B f g → (maps (cb_bijection A B f g) x a → ∃ y maps (cb_bijection A B f g) x y) $ by imp_const [l4]
l5: $ x ∈ cb_core A B f g → (maps f x a → ∃ y maps (cb_bijection A B f g) x y) $ by imp_trans_under [l3, l4b]
l6: $ maps f x a → (x ∈ cb_core A B f g → ∃ y maps (cb_bijection A B f g) x y) $ by imp_swap [l5]
l7: $ ∀ a (maps f x a → (x ∈ cb_core A B f g → ∃ y maps (cb_bijection A B f g) x y)) $ by all_intro [l6]
l8: $ (∃ a maps f x a) → (x ∈ cb_core A B f g → ∃ y maps (cb_bijection A B f g) x y) $ by ex_elim_imp [l7]
l9: $ x ∈ A → (x ∈ cb_core A B f g → ∃ y maps (cb_bijection A B f g) x y) $ by imp_trans [l2, l8]
l10: $ x ∈ cb_core A B f g → (x ∈ A → ∃ y maps (cb_bijection A B f g) x y) $ by imp_swap [l9]
l11: $ x ∈ A → (x ∉ cb_core A B f g → x ∈ image g (B ∖ image f (cb_core A B f g) B) A) $ by cb_core_not_mem_image_imp
l12: $ x ∈ image g (B ∖ image f (cb_core A B f g) B) A → ∃ a (a ∈ B ∖ image f (cb_core A B f g) B ∧ maps g a x) $ by image_has_preimage
l12b: $ x ∈ A → (x ∈ image g (B ∖ image f (cb_core A B f g) B) A → ∃ a (a ∈ B ∖ image f (cb_core A B f g) B ∧ maps g a x)) $ by imp_const [l12]
l13: $ x ∈ A → (x ∉ cb_core A B f g → ∃ a (a ∈ B ∖ image f (cb_core A B f g) B ∧ maps g a x)) $ by imp_trans_under [l11, l12b]
l14: $ x ∈ A → (x ∉ cb_core A B f g → (maps g a x → maps (cb_bijection A B f g) x a)) $ by cb_bijection_g_branch_maps_imp [#2]
l15: $ a ∈ B ∖ image f (cb_core A B f g) B ∧ maps g a x → maps g a x $ by and_elim_r_imp
l16: $ x ∈ A → (x ∉ cb_core A B f g → (a ∈ B ∖ image f (cb_core A B f g) B ∧ maps g a x → maps g a x)) $ by imp_const2 [l15]
l17: $ x ∈ A → (x ∉ cb_core A B f g → (a ∈ B ∖ image f (cb_core A B f g) B ∧ maps g a x → maps (cb_bijection A B f g) x a)) $ by imp_trans_under2 [l16, l14]
l18a: $ maps (cb_bijection A B f g) x a → maps (cb_bijection A B f g) x a $ by imp_id
l18: $ maps (cb_bijection A B f g) x a → ∃ y maps (cb_bijection A B f g) x y $ by ex_intro_imp [l18a]
l19: $ x ∈ A → (x ∉ cb_core A B f g → (maps (cb_bijection A B f g) x a → ∃ y maps (cb_bijection A B f g) x y)) $ by imp_const2 [l18]
l20: $ x ∈ A → (x ∉ cb_core A B f g → (a ∈ B ∖ image f (cb_core A B f g) B ∧ maps g a x → ∃ y maps (cb_bijection A B f g) x y)) $ by imp_trans_under2 [l17, l19]
l21: $ x ∈ A → (x ∉ cb_core A B f g → ((∃ a (a ∈ B ∖ image f (cb_core A B f g) B ∧ maps g a x)) → ∃ y maps (cb_bijection A B f g) x y)) $ by ex_elim_imp_under2 [l20]
l22: $ x ∈ A → (x ∉ cb_core A B f g → ∃ y maps (cb_bijection A B f g) x y) $ by imp_apply_under2 [l21, l13]
l26: $ x ∉ cb_core A B f g → (x ∈ A → ∃ y maps (cb_bijection A B f g) x y) $ by imp_swap [l22]
l27: $ (x ∈ cb_core A B f g ∨ x ∉ cb_core A B f g) → (x ∈ A → ∃ y maps (cb_bijection A B f g) x y) $ by or_elim_imp [l10, l26]
l28: $ x ∈ cb_core A B f g ∨ x ∉ cb_core A B f g $ by excluded_middle
l29: $ x ∈ A → ∃ y maps (cb_bijection A B f g) x y $ by mp [l27, l28]

cb_bijection_has_value_domain_imp
---------------------------------
l1: $ maps (cb_bijection A B f g) x y → x ∈ A $ by cb_bijection_maps_domain_from_injections [#1, #2]
l2: $ ∀ y (maps (cb_bijection A B f g) x y → x ∈ A) $ by all_intro [l1]
l3: $ (∃ y maps (cb_bijection A B f g) x y) → x ∈ A $ by ex_elim_imp [l2]

cb_g_setdiff_maps_not_core_imp
------------------------------
l1: $ maps g y x → x ∈ A $ by injective_maps_range_imp [#1]
l2: $ y ∈ B ∖ image f (cb_core A B f g) B → (maps g y x → x ∈ A) $
  by imp_const [l1]
l3: $ y ∈ B ∖ image f (cb_core A B f g) B →
      (maps g y x → y ∈ B ∖ image f (cb_core A B f g) B) $ by h1
l4: $ maps g y x → maps g y x $ by imp_id
l5: $ y ∈ B ∖ image f (cb_core A B f g) B →
      (maps g y x → maps g y x) $ by imp_const [l4]
l6: $ y ∈ B ∖ image f (cb_core A B f g) B →
      (maps g y x →
      x ∈ image g (B ∖ image f (cb_core A B f g) B) A) $
  by image_intro_imp_under2 [l2, l3, l5]
l7: $ cb_core A B f g = cb_step A B f g (cb_core A B f g) $
  by cb_core_fixed
l8: $ cb_core A B f g = cb_step A B f g (cb_core A B f g) →
      (x ∈ cb_core A B f g →
      x ∈ cb_step A B f g (cb_core A B f g)) $ by eq_replace_imp
l9: $ x ∈ cb_core A B f g →
      x ∈ cb_step A B f g (cb_core A B f g) $ by mp [l8, l7]
l10: $ x ∈ cb_step A B f g (cb_core A B f g) →
       x ∉ image g (B ∖ image f (cb_core A B f g) B) A $
  by cb_step_elim_right
l11: $ x ∈ cb_core A B f g →
       x ∉ image g (B ∖ image f (cb_core A B f g) B) A $
  by imp_trans [l9, l10]
l12: $ y ∈ B ∖ image f (cb_core A B f g) B →
       (maps g y x → (x ∈ cb_core A B f g →
       x ∈ image g (B ∖ image f (cb_core A B f g) B) A)) $
  by imp_lift_under2 [l6]
l13: $ y ∈ B ∖ image f (cb_core A B f g) B →
       (maps g y x → (x ∈ cb_core A B f g →
       x ∉ image g (B ∖ image f (cb_core A B f g) B) A)) $
  by imp_const2 [l11]
l14: $ y ∈ B ∖ image f (cb_core A B f g) B →
       (maps g y x → x ∉ cb_core A B f g) $
  by not_intro_under2 [l12, l13]

cb_bijection_has_preimage_image_imp
-----------------------------------
l1: $ y ∈ image f (cb_core A B f g) B →
      ∃ x (x ∈ cb_core A B f g ∧ maps f x y) $ by image_has_preimage
l2: $ x ∈ cb_core A B f g ∧ maps f x y → x ∈ cb_core A B f g $
  by and_elim_l_imp
l3: $ x ∈ cb_core A B f g ∧ maps f x y → maps f x y $
  by and_elim_r_imp
l4: $ cb_core A B f g ⊆ A $ by cb_core_subset
l5: $ x ∈ cb_core A B f g → x ∈ A $ by subset_elim_imp [l4]
l6: $ x ∈ cb_core A B f g ∧ maps f x y → x ∈ A $
  by imp_trans [l2, l5]
l7: $ x ∈ cb_core A B f g →
      (maps f x y → maps (cb_bijection A B f g) x y) $
  by cb_bijection_f_branch_maps_imp [#1]
l8: $ x ∈ cb_core A B f g ∧ maps f x y →
      (maps f x y → maps (cb_bijection A B f g) x y) $
  by imp_trans [l2, l7]
l9: $ x ∈ cb_core A B f g ∧ maps f x y →
      maps (cb_bijection A B f g) x y $ by imp_apply_under [l8, l3]
l10: $ x ∈ cb_core A B f g ∧ maps f x y →
       x ∈ A ∧ maps (cb_bijection A B f g) x y $
  by and_intro_imp [l6, l9]
l11: $ x ∈ cb_core A B f g ∧ maps f x y →
       has_preimage (cb_bijection A B f g) A y $ by ex_intro_imp [l10]
l12: $ ∀ x ((x ∈ cb_core A B f g ∧ maps f x y) →
       has_preimage (cb_bijection A B f g) A y) $ by all_intro [l11]
l13: $ (∃ x (x ∈ cb_core A B f g ∧ maps f x y)) →
       has_preimage (cb_bijection A B f g) A y $ by ex_elim_imp [l12]
l14: $ y ∈ image f (cb_core A B f g) B →
       has_preimage (cb_bijection A B f g) A y $ by imp_trans [l1, l13]

cb_bijection_has_preimage_setdiff_imp
-------------------------------------
l1: $ domain_on g B $ by injective_domain_on [#1]
l2: $ y ∈ B ∖ image f (cb_core A B f g) B → y ∈ B $
  by setdiff_elim_left
l3: $ y ∈ B → ∃ x maps g y x $ by domain_on_has_maps_imp [l1]
l4: $ y ∈ B ∖ image f (cb_core A B f g) B → ∃ x maps g y x $
  by imp_trans [l2, l3]
l5a: $ maps g y x → x ∈ A $ by injective_maps_range_imp [#1]
l5: $ y ∈ B ∖ image f (cb_core A B f g) B → (maps g y x → x ∈ A) $
  by imp_const [l5a]
l6: $ y ∈ B ∖ image f (cb_core A B f g) B →
      (maps g y x → x ∉ cb_core A B f g) $
  by cb_g_setdiff_maps_not_core_imp [#1]
l7: $ x ∈ A → (x ∉ cb_core A B f g →
      (maps g y x → maps (cb_bijection A B f g) x y)) $
  by cb_bijection_g_branch_maps_imp [#1]
l8: $ x ∈ A → (maps g y x →
      (x ∉ cb_core A B f g → maps (cb_bijection A B f g) x y)) $
  by imp_swap_under [l7]
l9: $ maps g y x → (x ∈ A →
      (x ∉ cb_core A B f g → maps (cb_bijection A B f g) x y)) $
  by imp_swap [l8]
l10: $ y ∈ B ∖ image f (cb_core A B f g) B →
       (maps g y x → (x ∈ A →
       (x ∉ cb_core A B f g → maps (cb_bijection A B f g) x y))) $
  by imp_const [l9]
l11: $ y ∈ B ∖ image f (cb_core A B f g) B →
       (maps g y x →
       (x ∉ cb_core A B f g → maps (cb_bijection A B f g) x y)) $
  by imp_apply_under2 [l10, l5]
l12: $ y ∈ B ∖ image f (cb_core A B f g) B →
       (maps g y x → maps (cb_bijection A B f g) x y) $
  by imp_apply_under2 [l11, l6]
l13: $ y ∈ B ∖ image f (cb_core A B f g) B →
       (maps g y x → x ∈ A ∧ maps (cb_bijection A B f g) x y) $
  by and_intro_imp_under [l5, l12]
l14a: $ x ∈ A ∧ maps (cb_bijection A B f g) x y →
        x ∈ A ∧ maps (cb_bijection A B f g) x y $ by imp_id
l14: $ x ∈ A ∧ maps (cb_bijection A B f g) x y →
       has_preimage (cb_bijection A B f g) A y $ by ex_intro_imp [l14a]
l15: $ y ∈ B ∖ image f (cb_core A B f g) B →
       (maps g y x → ((x ∈ A ∧ maps (cb_bijection A B f g) x y) →
       has_preimage (cb_bijection A B f g) A y)) $ by imp_const2 [l14]
l16: $ y ∈ B ∖ image f (cb_core A B f g) B →
       (maps g y x → has_preimage (cb_bijection A B f g) A y) $
  by imp_apply_under2 [l15, l13]
l17: $ maps g y x →
       (y ∈ B ∖ image f (cb_core A B f g) B →
       has_preimage (cb_bijection A B f g) A y) $ by imp_swap [l16]
l18: $ ∀ x (maps g y x →
       (y ∈ B ∖ image f (cb_core A B f g) B →
       has_preimage (cb_bijection A B f g) A y)) $ by all_intro [l17]
l19: $ (∃ x maps g y x) →
       (y ∈ B ∖ image f (cb_core A B f g) B →
       has_preimage (cb_bijection A B f g) A y) $ by ex_elim_imp [l18]
l20: $ y ∈ B ∖ image f (cb_core A B f g) B →
       ((∃ x maps g y x) →
       has_preimage (cb_bijection A B f g) A y) $ by imp_swap [l19]
l21: $ y ∈ B ∖ image f (cb_core A B f g) B →
       has_preimage (cb_bijection A B f g) A y $
  by imp_apply_under [l20, l4]

cb_bijection_domain_on_from_injections
--------------------------------------
l1: $ x ∈ A → ∃ y maps (cb_bijection A B f g) x y $ by cb_bijection_has_value_from_injections [#1, #2]
l2: $ (∃ y maps (cb_bijection A B f g) x y) → x ∈ A $ by cb_bijection_has_value_domain_imp [#1, #2]
l3: $ x ∈ A ↔ ∃ y maps (cb_bijection A B f g) x y $ by bi_intro [l1, l2]
l4: $ ∀ x (x ∈ A ↔ ∃ y maps (cb_bijection A B f g) x y) $ by all_intro [l3]

cb_bijection_functional_from_injections
---------------------------------------
l1: $ maps (cb_bijection A B f g) x y →
      (maps (cb_bijection A B f g) x z → y = z) $
  by cb_bijection_maps_functional_imp [#1, #2]
l2: $ (maps (cb_bijection A B f g) x y ∧
      maps (cb_bijection A B f g) x z) →
      maps (cb_bijection A B f g) x y $ by and_elim_l_imp
l3: $ (maps (cb_bijection A B f g) x y ∧
      maps (cb_bijection A B f g) x z) →
      maps (cb_bijection A B f g) x z $ by and_elim_r_imp
l4: $ (maps (cb_bijection A B f g) x y ∧
      maps (cb_bijection A B f g) x z) →
      (maps (cb_bijection A B f g) x z → y = z) $
  by imp_trans [l2, l1]
l5: $ (maps (cb_bijection A B f g) x y ∧
      maps (cb_bijection A B f g) x z) → y = z $
  by imp_apply_under [l4, l3]
l6: $ ∀ z ((maps (cb_bijection A B f g) x y ∧
      maps (cb_bijection A B f g) x z) → y = z) $ by all_intro [l5]
l7: $ ∀ y ∀ z ((maps (cb_bijection A B f g) x y ∧
      maps (cb_bijection A B f g) x z) → y = z) $ by all_intro [l6]
l8: $ ∀ x ∀ y ∀ z ((maps (cb_bijection A B f g) x y ∧
      maps (cb_bijection A B f g) x z) → y = z) $ by all_intro [l7]

cb_bijection_range_sub_from_injections
--------------------------------------
l1: $ maps (cb_bijection A B f g) x y → y ∈ B $ by cb_bijection_maps_range_from_injections [#1, #2]
l2: $ ∀ x (maps (cb_bijection A B f g) x y → y ∈ B) $ by all_intro [l1]
l3: $ ∀ y ∀ x (maps (cb_bijection A B f g) x y → y ∈ B) $ by all_intro [l2]
l4: $ range_sub (cb_bijection A B f g) B $ by range_sub_intro [l3]

cb_bijection_function_from_injections
-------------------------------------
l1: $ functional (cb_bijection A B f g) $ by cb_bijection_functional_from_injections [#1, #2]
l2: $ domain_on (cb_bijection A B f g) A $ by cb_bijection_domain_on_from_injections [#1, #2]
l3: $ range_sub (cb_bijection A B f g) B $ by cb_bijection_range_sub_from_injections [#1, #2]
l4: $ function (cb_bijection A B f g) A B $ by function_intro [l1, l2, l3]


cb_bijection_injective_body
---------------------------
l1: $ maps (cb_bijection A B f g) x z →
      (maps (cb_bijection A B f g) y z → x = y) $
  by cb_bijection_maps_injective_imp [#1, #2]
l2: $ ((x ∈ A ∧ y ∈ A) ∧
      (maps (cb_bijection A B f g) x z ∧
       maps (cb_bijection A B f g) y z)) →
      (maps (cb_bijection A B f g) x z ∧
       maps (cb_bijection A B f g) y z) $ by and_elim_r_imp
l3: $ (maps (cb_bijection A B f g) x z ∧
       maps (cb_bijection A B f g) y z) →
      maps (cb_bijection A B f g) x z $ by and_elim_l_imp
l4: $ ((x ∈ A ∧ y ∈ A) ∧
      (maps (cb_bijection A B f g) x z ∧
       maps (cb_bijection A B f g) y z)) →
      maps (cb_bijection A B f g) x z $ by imp_trans [l2, l3]
l5: $ ((x ∈ A ∧ y ∈ A) ∧
      (maps (cb_bijection A B f g) x z ∧
       maps (cb_bijection A B f g) y z)) →
      (maps (cb_bijection A B f g) y z → x = y) $
  by imp_trans [l4, l1]
l6: $ (maps (cb_bijection A B f g) x z ∧
       maps (cb_bijection A B f g) y z) →
      maps (cb_bijection A B f g) y z $ by and_elim_r_imp
l7: $ ((x ∈ A ∧ y ∈ A) ∧
      (maps (cb_bijection A B f g) x z ∧
       maps (cb_bijection A B f g) y z)) →
      maps (cb_bijection A B f g) y z $ by imp_trans [l2, l6]
l8: $ ((x ∈ A ∧ y ∈ A) ∧
      (maps (cb_bijection A B f g) x z ∧
       maps (cb_bijection A B f g) y z)) → x = y $
  by imp_apply_under [l5, l7]
l9: $ ∀ z (((x ∈ A ∧ y ∈ A) ∧
      (maps (cb_bijection A B f g) x z ∧
       maps (cb_bijection A B f g) y z)) → x = y) $ by all_intro [l8]
l10: $ ∀ y ∀ z (((x ∈ A ∧ y ∈ A) ∧
       (maps (cb_bijection A B f g) x z ∧
        maps (cb_bijection A B f g) y z)) → x = y) $ by all_intro [l9]
l11: $ ∀ x ∀ y ∀ z (((x ∈ A ∧ y ∈ A) ∧
       (maps (cb_bijection A B f g) x z ∧
        maps (cb_bijection A B f g) y z)) → x = y) $ by all_intro [l10]

cb_bijection_surj_body
----------------------
l1: $ y ∈ image f (cb_core A B f g) B →
      has_preimage (cb_bijection A B f g) A y $
  by cb_bijection_has_preimage_image_imp [#1, #2]
l2: $ y ∈ B → (y ∉ image f (cb_core A B f g) B → y ∈ B) $ by h1
l3a: $ y ∉ image f (cb_core A B f g) B →
       y ∉ image f (cb_core A B f g) B $ by imp_id
l3: $ y ∈ B → (y ∉ image f (cb_core A B f g) B →
      y ∉ image f (cb_core A B f g) B) $ by imp_const [l3a]
l4: $ y ∈ B → (y ∉ image f (cb_core A B f g) B →
      y ∈ B ∖ image f (cb_core A B f g) B) $
  by setdiff_intro_imp2_under [l2, l3]
l5: $ y ∈ B ∖ image f (cb_core A B f g) B →
      has_preimage (cb_bijection A B f g) A y $
  by cb_bijection_has_preimage_setdiff_imp [#2]
l6: $ y ∈ B → (y ∈ B ∖ image f (cb_core A B f g) B →
      has_preimage (cb_bijection A B f g) A y) $ by imp_const [l5]
l7: $ y ∈ B → (y ∉ image f (cb_core A B f g) B →
      has_preimage (cb_bijection A B f g) A y) $
  by imp_trans_under [l4, l6]
l8: $ y ∈ B → (y ∈ image f (cb_core A B f g) B →
      has_preimage (cb_bijection A B f g) A y) $ by imp_const [l1]
l9: $ y ∈ B → ((y ∈ image f (cb_core A B f g) B ∨
      y ∉ image f (cb_core A B f g) B) →
      has_preimage (cb_bijection A B f g) A y) $
  by or_elim_imp_under [l8, l7]
l10: $ y ∈ image f (cb_core A B f g) B ∨
       y ∉ image f (cb_core A B f g) B $ by excluded_middle
l11: $ y ∈ B → (y ∈ image f (cb_core A B f g) B ∨
       y ∉ image f (cb_core A B f g) B) $ by imp_const [l10]
l12: $ y ∈ B → has_preimage (cb_bijection A B f g) A y $
  by imp_apply_under [l9, l11]
l13: $ ∀ y (y ∈ B → has_preimage (cb_bijection A B f g) A y) $
  by all_intro [l12]

cb_bijection_injective
----------------------
l1: $ function (cb_bijection A B f g) A B $ by cb_bijection_function_from_injections [#1, #2]
l2: $ ∀ x ∀ y ∀ z (((x ∈ A ∧ y ∈ A) ∧ (maps (cb_bijection A B f g) x z ∧ maps (cb_bijection A B f g) y z)) → x = y) $ by cb_bijection_injective_body [#1, #2]
l3: $ injective (cb_bijection A B f g) A B $ by injective_intro [l1, l2]

cb_bijection_surj
-----------------
l1: $ function (cb_bijection A B f g) A B $ by cb_bijection_function_from_injections [#1, #2]
l2: $ ∀ y (y ∈ B → has_preimage (cb_bijection A B f g) A y) $ by cb_bijection_surj_body [#1, #2]
l3: $ surj (cb_bijection A B f g) A B $ by surj_intro [l1, l2]

cantor_bernstein
----------------
l1: $ injective (cb_bijection A B f g) A B $ by cb_bijection_injective [#1, #2]
l2: $ surj (cb_bijection A B f g) A B $ by cb_bijection_surj [#1, #2]
l3: $ bijective (cb_bijection A B f g) A B $ by bijective_intro [l1, l2]

surj_has_preimage
-----------------
l1: $ ∀ u (u ∈ B → ∃ x (x ∈ A ∧ maps f x u)) $ by and_elim_r [#1]
l2: $ ∀ u (u ∈ B → ∃ x (x ∈ A ∧ maps f x u)) → (y ∈ B → ∃ x (x ∈ A ∧ maps f x y)) $ by all_elim_imp
l3: $ y ∈ B → ∃ x (x ∈ A ∧ maps f x y) $ by mp [l2, l1]
l4: $ ∃ x (x ∈ A ∧ maps f x y) $ by mp [l3, #2]

mem_eq_imp
----------
l1: $ x = x $ by setid
l2: $ (x ∈ A) ↔ (x ∈ B) $ by mem_congr [l1, #1]
l3: $ x ∈ A → x ∈ B $ by bi_imp [l2]

mem_eq_imp_imp
--------------
l1: $ A = B → (x ∈ A → x ∈ B) $ by eq_replace_imp

function_unique
---------------
l1: $ functional f $ by and_elim_l [#1]
l2: $ y = z $ by functional_elim [l1, #2, #3]

function_unique_imp
-------------------
l1: $ functional f $ by and_elim_l [#1]
l2: $ maps f x y → y = z $ by functional_elim_imp [l1, #2]

image_not_mem_imp
-----------------
l1: $ maps f a y → y = diag A f $ by function_unique_imp [#1, #2]
l2: $ y = diag A f → (a ∈ y → a ∈ diag A f) $ by mem_eq_imp_imp
l3: $ maps f a y → (a ∈ y → a ∈ diag A f) $ by imp_trans [l1, l2]

misses_elim_imp
---------------
l1: $ ∀ u (maps f x u → x ∉ u) → (maps f x y → x ∉ y) $ by all_elim_imp
l2: $ ∀ u (maps f x u → x ∉ u) → x ∉ y $ by imp_mp_right [#1, l1]

misses_if_not_in_diag_imp
-------------------------
l1: $ maps f a y → (a ∈ y → a ∈ diag A f) $ by image_not_mem_imp [#1, #2]
l2: $ ¬ (a ∈ diag A f) → (maps f a y → a ∉ y) $ by contra_imp [l1]
l3: $ ¬ (a ∈ diag A f) → misses f a $ by all_intro_imp [l2]

diag_subset
-----------
l1: $ diag A f ⊆ A $ by sep_subset

diag_misses_imp
---------------
l1: $ a ∈ diag A f → misses f a $ by sep_elim_right_imp

diag_intro_from_misses
----------------------
l1: $ misses f a → a ∈ diag A f $ by sep_intro_imp [#1]

diagonal_intro_out_imp
----------------------
l1: $ ¬ (a ∈ diag A f) → misses f a $ by misses_if_not_in_diag_imp [#1, #3]
l2: $ misses f a → a ∈ diag A f $ by diag_intro_from_misses [#2]
l3: $ ¬ (a ∈ diag A f) → a ∈ diag A f $ by imp_trans [l1, l2]

diagonal_in_case
----------------
l1: $ a ∈ diag A f → misses f a $ by diag_misses_imp
l2: $ misses f a → a ∉ diag A f $ by misses_elim_imp [#2]
l3: $ a ∈ diag A f → a ∉ diag A f $ by imp_trans [l1, l2]
l4: $ a ∈ diag A f → ⊥ $ by imp_not_self [l3]

diagonal_out_case
-----------------
l1: $ ¬ (a ∈ diag A f) → a ∈ diag A f $ by diagonal_intro_out_imp [#1, #2, #3]
l2: $ ¬ (a ∈ diag A f) → ⊥ $ by imp_not_to_self [l1]

surj_wit_mem
------------
l1: $ ∃ x (x ∈ A ∧ maps f x y) $ by surj_has_preimage [#1, #2]
l2: $ surj_wit f A y ∈ A ∧ maps f (surj_wit f A y) y $ by preimage_wit_pair [l1]
l3: $ surj_wit f A y ∈ A $ by and_elim_l [l2]

surj_wit_maps
-------------
l1: $ ∃ x (x ∈ A ∧ maps f x y) $ by surj_has_preimage [#1, #2]
l2: $ surj_wit f A y ∈ A ∧ maps f (surj_wit f A y) y $ by preimage_wit_pair [l1]
l3: $ maps f (surj_wit f A y) y $ by and_elim_r [l2]

cantor_witness
--------------
l1: $ a ∈ diag A f → ⊥ $ by diagonal_in_case [#1, #3]
l2: $ ¬ (a ∈ diag A f) → ⊥ $ by diagonal_out_case [#1, #2, #3]
l3: $ ⊥ $ by cases_bot [l1, l2]

cantor
------
l1: $ diag A f ⊆ A $ by diag_subset
l2: $ diag A f ∈ power A $ by power_intro [l1]
l3: $ surj_wit f A (diag A f) ∈ A $ by surj_wit_mem [#2, l2]
l4: $ maps f (surj_wit f A (diag A f)) (diag A f) $ by surj_wit_maps [#2, l2]
l5: $ ⊥ $ by cantor_witness [#1, l3, l4]
