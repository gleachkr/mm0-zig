      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) → x = y)) $
  by all_intro [l6]
l8: $ ∃ w ∃ a (opair y z = opair w a ∧
      ((w ∈ cb_core A B f g ∧ maps f w a) ∨
      (w ∉ cb_core A B f g ∧ maps g a w))) →
      ((opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) → x = y) $
  by ex_elim_imp [l7]
l9: $ (opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) →
      ((∃ w ∃ a (opair y z = opair w a ∧
      ((w ∈ cb_core A B f g ∧ maps f w a) ∨
      (w ∉ cb_core A B f g ∧ maps g a w)))) → x = y) $
  by imp_swap [l8]
l10: $ (opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) →
      (maps (cb_bijection A B f g) y z →
      ∃ w ∃ a (opair y z = opair w a ∧
      ((w ∈ cb_core A B f g ∧ maps f w a) ∨
      (w ∉ cb_core A B f g ∧ maps g a w)))) $ by imp_const [l2]
l11: $ (opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) →
      (maps (cb_bijection A B f g) y z → x = y) $
  by imp_trans_under [l10, l9]
l12: $ ∀ v ((opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) →
      (maps (cb_bijection A B f g) y z → x = y)) $
  by all_intro [l11]
l13: $ ∃ v (opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
