  by imp_apply_under2 [l10, l11]

cb_bijection_f_branch_range_imp
-------------------------------
l1: $ u ∈ cb_core A B f g ∧ maps f u v → maps f u v $ by and_elim_r_imp
l2: $ maps f u v → v ∈ B $ by injective_maps_range_imp [#1]
l3: $ u ∈ cb_core A B f g ∧ maps f u v → v ∈ B $ by imp_trans [l1, l2]
l4: $ (u ∈ cb_core A B f g ∧ maps f u v → v ∈ B) → (opair x y = opair u v → (u ∈ cb_core A B f g ∧ maps f u v → v ∈ B)) $ by h1
l5: $ opair x y = opair u v → (u ∈ cb_core A B f g ∧ maps f u v → v ∈ B) $ by mp [l4, l3]
l6: $ opair x y = opair u v → y = v $ by opair_eq_right_imp
l7: $ y = v → (v ∈ B → y ∈ B) $ by mem_arg_eq_left_imp_imp
l8: $ opair x y = opair u v → (v ∈ B → y ∈ B) $ by imp_trans [l6, l7]
l9: $ opair x y = opair u v → ((u ∈ cb_core A B f g ∧ maps f u v) → y ∈ B) $ by imp_trans_under [l5, l8]

cb_bijection_g_branch_range_imp
-------------------------------
l1: $ u ∉ cb_core A B f g ∧ maps g v u → maps g v u $ by and_elim_r_imp
l2: $ maps g v u → v ∈ B $ by injective_maps_domain_imp [#1]
l3: $ u ∉ cb_core A B f g ∧ maps g v u → v ∈ B $ by imp_trans [l1, l2]
l4: $ (u ∉ cb_core A B f g ∧ maps g v u → v ∈ B) → (opair x y = opair u v → (u ∉ cb_core A B f g ∧ maps g v u → v ∈ B)) $ by h1
l5: $ opair x y = opair u v → (u ∉ cb_core A B f g ∧ maps g v u → v ∈ B) $ by mp [l4, l3]
l6: $ opair x y = opair u v → y = v $ by opair_eq_right_imp
l7: $ y = v → (v ∈ B → y ∈ B) $ by mem_arg_eq_left_imp_imp
l8: $ opair x y = opair u v → (v ∈ B → y ∈ B) $ by imp_trans [l6, l7]
l9: $ opair x y = opair u v → ((u ∉ cb_core A B f g ∧ maps g v u) → y ∈ B) $ by imp_trans_under [l5, l8]

cb_bijection_branch_range_imp
-----------------------------
l1: $ opair x y = opair u v → ((u ∈ cb_core A B f g ∧ maps f u v) → y ∈ B) $ by cb_bijection_f_branch_range_imp [#1]
l2: $ opair x y = opair u v → ((u ∉ cb_core A B f g ∧ maps g v u) → y ∈ B) $ by cb_bijection_g_branch_range_imp [#2]
l3: $ opair x y = opair u v → (((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u)) → y ∈ B) $ by or_elim_imp_under [l1, l2]

cb_bijection_pair_range_imp
---------------------------
l1: $ (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u))) → opair x y = opair u v $ by and_elim_l_imp
l2: $ (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u))) → ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u)) $ by and_elim_r_imp
l3: $ opair x y = opair u v → (((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u)) → y ∈ B) $ by cb_bijection_branch_range_imp [#1, #2]
l4: $ (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u))) → (((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u)) → y ∈ B) $ by imp_trans [l1, l3]
l5: $ (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u))) → y ∈ B $ by imp_apply_under [l4, l2]

cb_bijection_maps_cases_imp
---------------------------
l1: $ maps (cb_bijection A B f g) x y → ∃ u ∃ v (opair x y = opair u v ∧ ((u ∈ cb_core A B f g ∧ maps f u v) ∨ (u ∉ cb_core A B f g ∧ maps g v u))) $ by sep_elim_right_imp


