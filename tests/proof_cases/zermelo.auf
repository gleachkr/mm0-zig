-------------------------------
l1: $ maps (cb_bijection A B f g) x z →
      ∃ u ∃ v (opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) $
  by cb_bijection_maps_cases_imp
l2: $ maps (cb_bijection A B f g) y z →
      ∃ w ∃ a (opair y z = opair w a ∧
      ((w ∈ cb_core A B f g ∧ maps f w a) ∨
      (w ∉ cb_core A B f g ∧ maps g a w))) $
  by cb_bijection_maps_cases_imp
l3: $ (opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) →
      ((opair y z = opair w a ∧
      ((w ∈ cb_core A B f g ∧ maps f w a) ∨
      (w ∉ cb_core A B f g ∧ maps g a w))) → x = y) $
  by cb_bijection_pair_injective_imp [#1, #2]
l4: $ (opair y z = opair w a ∧
      ((w ∈ cb_core A B f g ∧ maps f w a) ∨
      (w ∉ cb_core A B f g ∧ maps g a w))) →
      ((opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) → x = y) $
  by imp_swap [l3]
l5: $ ∀ a ((opair y z = opair w a ∧
      ((w ∈ cb_core A B f g ∧ maps f w a) ∨
      (w ∉ cb_core A B f g ∧ maps g a w))) →
      ((opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) → x = y)) $
  by all_intro [l4]
l6: $ ∃ a (opair y z = opair w a ∧
      ((w ∈ cb_core A B f g ∧ maps f w a) ∨
      (w ∉ cb_core A B f g ∧ maps g a w))) →
      ((opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) → x = y) $
  by ex_elim_imp [l5]
l7: $ ∀ w ((∃ a (opair y z = opair w a ∧
      ((w ∈ cb_core A B f g ∧ maps f w a) ∨
      (w ∉ cb_core A B f g ∧ maps g a w)))) →
