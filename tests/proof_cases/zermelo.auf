not_to_imp
----------
l1: $ ¬ p → (p → ¬ p) $ by h1
l2: $ p → ¬ p $ by mp [l1, #1]
l3: $ p → ⊥ $ by imp_not_self [l2]

imp_id
------
l1: $ p → ((p → p) → p) $ by h1
l2: $ p → (p → p) $ by h1
l3: $ (p → ((p → p) → p)) → ((p → (p → p)) → (p → p)) $ by h2
l4: $ (p → (p → p)) → (p → p) $ by mp [l3, l1]
l5: $ p → p $ by mp [l4, l2]

imp_trans
---------
l1: $ (q → r) → (p → (q → r)) $ by h1
l2: $ p → (q → r) $ by mp [l1, #2]
l3: $ (p → (q → r)) → ((p → q) → (p → r)) $ by h2
l4: $ (p → q) → (p → r) $ by mp [l3, l2]
l5: $ p → r $ by mp [l4, #1]

imp_const
---------
l1: $ q → (p → q) $ by h1
l2: $ p → q $ by mp [l1, #1]

imp_const2
----------
l1: $ q → r $ by imp_const [#1]
l2: $ p → (q → r) $ by imp_const [l1]

imp_const3
----------
l1: $ q → (r → s) $ by imp_const2 [#1]
l2: $ p → (q → (r → s)) $ by imp_const [l1]

imp_lift
--------
l1: $ r → (q → r) $ by h1
l2: $ p → (q → r) $ by imp_trans [#1, l1]

imp_mp_right
------------
l1: $ q → (p → q) $ by h1
l2: $ p → q $ by mp [l1, #1]
l3: $ (p → (q → r)) → ((p → q) → (p → r)) $ by h2
l4: $ (p → q) → (p → r) $ by mp [l3, #2]
l5: $ p → r $ by mp [l4, l2]

imp_swap
--------
l1: $ (p → (q → r)) → ((p → q) → (p → r)) $ by h2
l2: $ ((p → (q → r)) → ((p → q) → (p → r))) → (q → ((p → (q → r)) → ((p → q) → (p → r)))) $ by h1
l3: $ q → ((p → (q → r)) → ((p → q) → (p → r))) $ by mp [l2, l1]
l4: $ (p → (q → r)) → (q → (p → (q → r))) $ by h1
l5: $ q → (p → (q → r)) $ by mp [l4, #1]
l6: $ (q → ((p → (q → r)) → ((p → q) → (p → r)))) → ((q → (p → (q → r))) → (q → ((p → q) → (p → r)))) $ by h2
l7: $ (q → (p → (q → r))) → (q → ((p → q) → (p → r))) $ by mp [l6, l3]
l8: $ q → ((p → q) → (p → r)) $ by mp [l7, l5]
l9: $ q → (p → q) $ by h1
l10: $ (q → ((p → q) → (p → r))) → ((q → (p → q)) → (q → (p → r))) $ by h2
l11: $ (q → (p → q)) → (q → (p → r)) $ by mp [l10, l8]
l12: $ q → (p → r) $ by mp [l11, l9]

imp_apply_under
---------------
l1: $ (p → (q → r)) → ((p → q) → (p → r)) $ by h2
l2: $ (p → q) → (p → r) $ by mp [l1, #1]
l3: $ p → r $ by mp [l2, #2]

imp_apply_under2
----------------
l1: $ (q → (r → s)) → ((q → r) → (q → s)) $ by h2
l2: $ p → ((q → r) → (q → s)) $ by imp_trans [#1, l1]
l3: $ p → (q → s) $ by imp_apply_under [l2, #2]

imp_apply_under3
----------------
l1: $ (r → (s → t)) → ((r → s) → (r → t)) $ by h2
l2: $ p → (q → ((r → (s → t)) →
      ((r → s) → (r → t)))) $ by imp_const2 [l1]
l3: $ p → (q → ((r → s) → (r → t))) $
  by imp_apply_under2 [l2, #1]
l4: $ p → (q → (r → t)) $ by imp_apply_under2 [l3, #2]

imp_apply_under4
----------------
l1: $ (s → (t → u)) → ((s → t) → (s → u)) $ by h2
l2: $ p → (q → (r → ((s → (t → u)) →
      ((s → t) → (s → u))))) $ by imp_const3 [l1]
l3: $ p → (q → (r → ((s → t) → (s → u)))) $
  by imp_apply_under3 [l2, #1]
l4: $ p → (q → (r → (s → u))) $ by imp_apply_under3 [l3, #2]

imp_lift_under2
---------------
l1: $ s → (r → s) $ by h1
l2: $ p → (q → (s → (r → s))) $ by imp_const2 [l1]
l3: $ p → (q → (r → s)) $ by imp_apply_under2 [l2, #1]

imp_lift_under3
---------------
l1: $ t → (s → t) $ by h1
l2: $ p → (q → (r → (t → (s → t)))) $ by imp_const3 [l1]
l3: $ p → (q → (r → (s → t))) $ by imp_apply_under3 [l2, #1]

imp_trans_under
---------------
l1: $ (q → (r → s)) → ((q → r) → (q → s)) $ by h2
l2: $ ((q → (r → s)) → ((q → r) → (q → s))) → (p → ((q → (r → s)) → ((q → r) → (q → s)))) $ by h1
l3: $ p → ((q → (r → s)) → ((q → r) → (q → s))) $ by mp [l2, l1]
l4: $ (r → s) → (q → (r → s)) $ by h1
l5: $ p → (q → (r → s)) $ by imp_trans [#2, l4]
l6: $ (p → ((q → (r → s)) → ((q → r) → (q → s)))) → ((p → (q → (r → s))) → (p → ((q → r) → (q → s)))) $ by h2
l7: $ (p → (q → (r → s))) → (p → ((q → r) → (q → s))) $ by mp [l6, l3]
l8: $ p → ((q → r) → (q → s)) $ by mp [l7, l5]
l9: $ (p → ((q → r) → (q → s))) → ((p → (q → r)) → (p → (q → s))) $ by h2
l10: $ (p → (q → r)) → (p → (q → s)) $ by mp [l9, l8]
l11: $ p → (q → s) $ by mp [l10, #1]

imp_trans_under2
----------------
l1: $ p → (q → (r → (s → t))) $ by imp_lift_under2 [#2]
l2: $ p → (q → (r → t)) $ by imp_apply_under3 [l1, #1]

imp_swap_imp
------------
l1: $ (p → (q → r)) → (p → (q → r)) $ by imp_id
l2: $ (p → (q → r)) → (q → (p → (q → r))) $ by imp_lift [l1]
l3: $ q → (p → q) $ by h1
l4: $ (p → (q → r)) → (q → (p → q)) $ by imp_const [l3]
l5: $ (p → (q → r)) → (q → (p → r)) $
  by imp_apply_under3 [l2, l4]

imp_swap_under
--------------
l1: $ (q → (r → s)) → (r → (q → s)) $ by imp_swap_imp
l2: $ p → ((q → (r → s)) → (r → (q → s))) $ by imp_const [l1]
l3: $ p → (r → (q → s)) $ by imp_apply_under [l2, #1]

imp_swap_under2
---------------
l1: $ (r → (s → t)) → (s → (r → t)) $ by imp_swap_imp
l2: $ p → (q → ((r → (s → t)) → (s → (r → t)))) $
  by imp_const2 [l1]
l3: $ p → (q → (s → (r → t))) $ by imp_apply_under2 [l2, #1]

and_intro
---------
l1: $ p → (q → p ∧ q) $ by and1
l2: $ q → p ∧ q $ by mp [l1, #1]
l3: $ p ∧ q $ by mp [l2, #2]

and_intro_imp
-------------
l1: $ q → (r → q ∧ r) $ by and1
l2: $ (q → (r → q ∧ r)) → (p → (q → (r → q ∧ r))) $ by h1
l3: $ p → (q → (r → q ∧ r)) $ by mp [l2, l1]
l4: $ (p → (q → (r → q ∧ r))) → ((p → q) → (p → (r → q ∧ r))) $ by h2
l5: $ (p → q) → (p → (r → q ∧ r)) $ by mp [l4, l3]
l6: $ p → (r → q ∧ r) $ by mp [l5, #1]
l7: $ (p → (r → q ∧ r)) → ((p → r) → (p → q ∧ r)) $ by h2
l8: $ (p → r) → (p → q ∧ r) $ by mp [l7, l6]
l9: $ p → q ∧ r $ by mp [l8, #2]

and_intro_imp_imp
-----------------
l1: $ q → (r → q ∧ r) $ by and1
l2: $ (q → (r → q ∧ r)) →
      (p → (q → (r → q ∧ r))) $ by h1
l3: $ p → (q → (r → q ∧ r)) $ by mp [l2, l1]
l4: $ (p → (q → (r → q ∧ r))) →
      ((p → q) → (p → (r → q ∧ r))) $ by h2
l5: $ (p → q) → (p → (r → q ∧ r)) $ by mp [l4, l3]
l6: $ (p → (r → q ∧ r)) → ((p → r) → (p → q ∧ r)) $ by h2
l7: $ (p → q) → ((p → r) → (p → q ∧ r)) $
  by imp_trans [l5, l6]

and_intro_imp_under
-------------------
l1: $ (q → r) → ((q → s) → (q → r ∧ s)) $ by and_intro_imp_imp
l2: $ ((q → r) → ((q → s) → (q → r ∧ s))) →
      (p → ((q → r) → ((q → s) → (q → r ∧ s)))) $ by h1
l3: $ p → ((q → r) → ((q → s) → (q → r ∧ s))) $ by mp [l2, l1]
l4: $ p → ((q → s) → (q → r ∧ s)) $ by imp_apply_under [l3, #1]
l5: $ p → (q → r ∧ s) $ by imp_apply_under [l4, #2]

and_intro_imp_under2
--------------------
l1: $ (r → s) → ((r → t) → (r → s ∧ t)) $
  by and_intro_imp_imp
l2: $ p → (q → ((r → s) → ((r → t) → (r → s ∧ t)))) $
  by imp_const2 [l1]
l3: $ p → (q → ((r → t) → (r → s ∧ t))) $
  by imp_apply_under2 [l2, #1]
l4: $ p → (q → (r → s ∧ t)) $ by imp_apply_under2 [l3, #2]

and_intro_imp_under3
--------------------
l1: $ (s → t) → ((s → u) → (s → t ∧ u)) $
  by and_intro_imp_imp
l2: $ p → (q → (r → ((s → t) →
      ((s → u) → (s → t ∧ u))))) $ by imp_const3 [l1]
l3: $ p → (q → (r → ((s → u) → (s → t ∧ u)))) $
  by imp_apply_under3 [l2, #1]
l4: $ p → (q → (r → (s → t ∧ u))) $
  by imp_apply_under3 [l3, #2]

and_elim_l
----------
l1: $ p ∧ q → p $ by and_elim_l_imp
l2: $ p $ by mp [l1, #1]

and_elim_r
----------
l1: $ p ∧ q → q $ by and_elim_r_imp
l2: $ q $ by mp [l1, #1]

and_mp_right
------------
l1: $ r → (q → r) $ by h1
l2: $ q → r $ by mp [l1, #1]
l3: $ q → (r → q ∧ r) $ by and1
l4: $ (q → (r → q ∧ r)) → ((q → r) → (q → q ∧ r)) $ by h2
l5: $ (q → r) → (q → q ∧ r) $ by mp [l4, l3]
l6: $ q → q ∧ r $ by mp [l5, l2]
l7: $ ((q ∧ r) → s) → (q → ((q ∧ r) → s)) $ by h1
l8: $ q → ((q ∧ r) → s) $ by mp [l7, #2]
l9: $ (q → ((q ∧ r) → s)) → ((q → q ∧ r) → (q → s)) $ by h2
l10: $ (q → q ∧ r) → (q → s) $ by mp [l9, l8]
l11: $ q → s $ by mp [l10, l6]

and_mp_right_imp
----------------
l1: $ q → (r → q ∧ r) $ by and1
l2: $ r → (q → q ∧ r) $ by imp_swap [l1]
l3: $ ((q ∧ r) → s) → (r → ((q ∧ r) → s)) $ by h1
l4: $ r → ((q ∧ r) → s) $ by mp [l3, #1]
l5: $ r → (q → s) $ by imp_trans_under [l2, l4]

bi_imp
------
l1: $ (p ↔ q) → (p → q) $ by bi1
l2: $ p → q $ by mp [l1, #1]

bi_imp_rev
----------
l1: $ q ↔ p $ by bisym [#1]
l2: $ q → p $ by bi_imp [l1]

bi_imp_imp
----------
l1: $ (q ↔ r) → (q → r) $ by bi1
l2: $ ((q ↔ r) → (q → r)) → (p → ((q ↔ r) → (q → r))) $ by h1
l3: $ p → ((q ↔ r) → (q → r)) $ by mp [l2, l1]
l4: $ (p → ((q ↔ r) → (q → r))) → ((p → (q ↔ r)) → (p → (q → r))) $ by h2
l5: $ (p → (q ↔ r)) → (p → (q → r)) $ by mp [l4, l3]
l6: $ p → (q → r) $ by mp [l5, #1]

subset_intro_imp
----------------
l1: $ ∀ x (x ∈ A → x ∈ B) $ by all_intro [#1]

subset_intro_imp_imp
--------------------
l1: $ p → ∀ x (x ∈ A → x ∈ B) $ by all_intro_imp [#1]

opair_eq_left
-------------
l1: $ opair a b = opair c d → a = c $ by opair_eq_left_imp
l2: $ a = c $ by mp [l1, #1]

opair_eq_right
--------------
l1: $ opair a b = opair c d → b = d $ by opair_eq_right_imp
l2: $ b = d $ by mp [l1, #1]

inter_subsets_intro_imp2
------------------------
l1: $ p → x ∈ inter_subsets A S $ by sep_intro_imp2 [#1, #2]

subset_elim_imp
---------------
l1: $ ∀ u (u ∈ A → u ∈ B) → (x ∈ A → x ∈ B) $ by all_elim_imp
l2: $ x ∈ A → x ∈ B $ by mp [l1, #1]

subset_elim_imp_imp
-------------------
l1: $ ∀ u (u ∈ A → u ∈ B) → (x ∈ A → x ∈ B) $ by all_elim_imp

subset_not_mem_imp
------------------
l1: $ x ∈ A → x ∈ B $ by subset_elim_imp [#1]
l2: $ (x ∈ A → x ∈ B) → (x ∉ B → (x ∈ A → x ∈ B)) $ by h1
l3: $ x ∉ B → (x ∈ A → x ∈ B) $ by mp [l2, l1]
l4: $ x ∉ B → (x ∉ B → x ∉ A) $ by contra_imp [l3]
l5: $ x ∉ B → x ∉ B $ by imp_id
l6: $ x ∉ B → x ∉ A $ by imp_apply_under [l4, l5]

subset_not_mem_imp_imp
----------------------
l1: $ (A ⊆ B) → (x ∈ A → x ∈ B) $ by subset_elim_imp_imp
l2: $ x ∉ B → ((A ⊆ B) → x ∉ A) $ by contra_imp [l1]
l3: $ (A ⊆ B) → (x ∉ B → x ∉ A) $ by imp_swap [l2]

setdiff_subset
--------------
l1: $ A ∖ B ⊆ A $ by sep_subset

setdiff_elim_left
-----------------
l1: $ A ∖ B ⊆ A $ by setdiff_subset
l2: $ x ∈ A ∖ B → x ∈ A $ by subset_elim_imp [l1]

setdiff_elim_right
------------------
l1: $ x ∈ A ∖ B → x ∉ B $ by sep_elim_right_imp

setdiff_intro
-------------
l1: $ x ∉ B → x ∈ A ∖ B $ by sep_intro_imp [#1]

setdiff_intro_imp2
------------------
l1: $ p → x ∈ A ∖ B $ by sep_intro_imp2 [#1, #2]

setdiff_antitone_right
----------------------
l1: $ x ∈ A ∖ C → x ∈ A $ by setdiff_elim_left
l2: $ x ∈ A ∖ C → x ∉ C $ by setdiff_elim_right
l3: $ x ∉ C → x ∉ B $ by subset_not_mem_imp [#1]
l4: $ x ∈ A ∖ C → x ∉ B $ by imp_trans [l2, l3]
l5: $ x ∈ A ∖ C → x ∈ A ∖ B $ by setdiff_intro_imp2 [l1, l4]
l6: $ A ∖ C ⊆ A ∖ B $ by subset_intro_imp [l5]

setdiff_antitone_right_imp_imp
------------------------------
l1: $ x ∈ A ∖ C → x ∈ A $ by setdiff_elim_left
l2: $ (x ∈ A ∖ C → x ∈ A) →
      ((B ⊆ C) → (x ∈ A ∖ C → x ∈ A)) $ by h1
l3: $ (B ⊆ C) → (x ∈ A ∖ C → x ∈ A) $ by mp [l2, l1]
l4: $ x ∈ A ∖ C → x ∉ C $ by setdiff_elim_right
l5: $ (x ∈ A ∖ C → x ∉ C) →
      ((B ⊆ C) → (x ∈ A ∖ C → x ∉ C)) $ by h1
l6: $ (B ⊆ C) → (x ∈ A ∖ C → x ∉ C) $ by mp [l5, l4]
l7: $ (B ⊆ C) → (x ∉ C → x ∉ B) $ by subset_not_mem_imp_imp
l8: $ (B ⊆ C) → (x ∈ A ∖ C → x ∉ B) $ by imp_trans_under [l6, l7]
l9: $ (B ⊆ C) → (x ∈ A ∖ C → x ∈ A ∖ B) $
  by setdiff_intro_imp2_under [l3, l8]
l10: $ (B ⊆ C) → (A ∖ C ⊆ A ∖ B) $ by subset_intro_imp_imp [l9]

image_subset
------------
l1: $ image f X B ⊆ B $ by sep_subset

image_elim_mem
--------------
l1: $ image f X B ⊆ B $ by image_subset
l2: $ y ∈ image f X B → y ∈ B $ by subset_elim_imp [l1]

image_has_preimage
------------------
l1: $ y ∈ image f X B → ∃ x (x ∈ X ∧ maps f x y) $ by sep_elim_right_imp

image_intro
-----------
l1: $ x ∈ X ∧ maps f x y $ by and_intro [#2, #3]
l2: $ has_preimage f X y $ by ex_intro [l1]
l3: $ has_preimage f X y → y ∈ image f X B $ by sep_intro_imp [#1]
l4: $ y ∈ image f X B $ by mp [l3, l2]

image_intro_imp_under2
----------------------
l1: $ p → (q → x ∈ X ∧ maps f x y) $
  by and_intro_imp_under [#2, #3]
l2a: $ x ∈ X ∧ maps f x y → x ∈ X ∧ maps f x y $ by imp_id
l2: $ x ∈ X ∧ maps f x y → has_preimage f X y $
  by ex_intro_imp [l2a]
l3: $ p → (q → ((x ∈ X ∧ maps f x y) → has_preimage f X y)) $
  by imp_const2 [l2]
l4: $ p → (q → has_preimage f X y) $ by imp_apply_under2 [l3, l1]
l5: $ y ∈ B → (has_preimage f X y → y ∈ image f X B) $
  by sep_intro_imp_imp
l6: $ p → (q → (y ∈ B → (has_preimage f X y → y ∈ image f X B))) $
  by imp_const2 [l5]
l7: $ p → (q → (has_preimage f X y → y ∈ image f X B)) $
  by imp_apply_under2 [l6, #1]
l8: $ p → (q → y ∈ image f X B) $ by imp_apply_under2 [l7, l4]

has_preimage_mono_imp
---------------------
l1: $ x ∈ X ∧ maps f x y → x ∈ X $ by and_elim_l_imp
l2: $ x ∈ X → x ∈ Y $ by subset_elim_imp [#1]
l3: $ x ∈ X ∧ maps f x y → x ∈ Y $ by imp_trans [l1, l2]
l4: $ x ∈ X ∧ maps f x y → maps f x y $ by and_elim_r_imp
l5: $ x ∈ X ∧ maps f x y → x ∈ Y ∧ maps f x y $ by and_intro_imp [l3, l4]
l6: $ x ∈ X ∧ maps f x y → has_preimage f Y y $ by ex_intro_imp [l5]
l7: $ ∀ x ((x ∈ X ∧ maps f x y) → has_preimage f Y y) $ by all_intro [l6]
l8: $ has_preimage f X y → has_preimage f Y y $ by ex_elim_imp [l7]

image_mono
----------
l1: $ y ∈ image f X B → y ∈ B $ by image_elim_mem
l2: $ y ∈ image f X B → has_preimage f X y $ by sep_elim_right_imp
l3: $ has_preimage f X y → has_preimage f Y y $ by has_preimage_mono_imp [#1]
l4: $ y ∈ image f X B → has_preimage f Y y $ by imp_trans [l2, l3]
l5: $ y ∈ image f X B → y ∈ image f Y B $ by sep_intro_imp2 [l1, l4]
l6: $ image f X B ⊆ image f Y B $ by subset_intro_imp [l5]

inter_subsets_subset
--------------------
l1: $ {x ∈ A | in_all_subsets S x} ⊆ A $ by sep_subset

inter_subsets_elim
------------------
l1: $ x ∈ {u ∈ A | in_all_subsets S u} → in_all_subsets S x $ by sep_elim_right_imp
l2: $ ∀ u (u ∈ S → x ∈ u) $ by mp [l1, #1]
l3: $ ∀ u (u ∈ S → x ∈ u) → (X ∈ S → x ∈ X) $ by all_elim_imp
l4: $ X ∈ S → x ∈ X $ by mp [l3, l2]
l5: $ x ∈ X $ by mp [l4, #2]

inter_subsets_elim_imp
----------------------
l1: $ x ∈ {u ∈ A | in_all_subsets S u} → in_all_subsets S x $ by sep_elim_right_imp
l2: $ ∀ u (u ∈ S → x ∈ u) → (X ∈ S → x ∈ X) $ by all_elim_imp
l3: $ x ∈ inter_subsets A S → (X ∈ S → x ∈ X) $ by imp_trans [l1, l2]
l4: $ x ∈ inter_subsets A S → x ∈ X $ by imp_mp_right [#1, l3]

inter_subsets_elim_imp_imp
--------------------------
l1: $ x ∈ {u ∈ A | in_all_subsets S u} → in_all_subsets S x $ by sep_elim_right_imp
l2: $ ∀ u (u ∈ S → x ∈ u) → (X ∈ S → x ∈ X) $ by all_elim_imp
l3: $ x ∈ inter_subsets A S → (X ∈ S → x ∈ X) $ by imp_trans [l1, l2]
l4: $ X ∈ S → (x ∈ inter_subsets A S → x ∈ X) $ by imp_swap [l3]

inter_subsets_intro
-------------------
l1: $ in_all_subsets S x → x ∈ {u ∈ A | in_all_subsets S u} $ by sep_intro_imp [#1]

cb_core_subset
--------------
l1: $ cb_core A B f g ⊆ A $ by inter_subsets_subset

cb_core_elim_prefixed
---------------------
l1: $ x ∈ X $ by inter_subsets_elim [#1, #2]

cb_step_subset
--------------
l1: $ cb_step A B f g X ⊆ A $ by setdiff_subset

cb_step_elim_left
-----------------
l1: $ x ∈ cb_step A B f g X → x ∈ A $ by setdiff_elim_left

cb_step_elim_right
------------------
l1: $ x ∈ cb_step A B f g X → x ∉ image g (B ∖ image f X B) A $ by setdiff_elim_right

cb_step_intro
-------------
l1: $ x ∉ image g (B ∖ image f X B) A → x ∈ cb_step A B f g X $ by setdiff_intro [#1]

cb_step_in_power
----------------
l1: $ cb_step A B f g X ⊆ A $ by cb_step_subset
l2: $ cb_step A B f g X ∈ 𝒫 A $ by power_intro [l1]

cb_prefixeds_elim_power
-----------------------
l1: $ X ∈ cb_prefixeds A B f g → X ∈ 𝒫 A $ by sep_elim_left_imp
l2: $ X ∈ 𝒫 A $ by mp [l1, #1]

cb_prefixeds_elim_subset
------------------------
l1: $ X ∈ 𝒫 A $ by cb_prefixeds_elim_power [#1]
l2: $ X ⊆ A $ by power_elim [l1]

cb_prefixeds_elim_prefixed
--------------------------
l1: $ X ∈ {x ∈ 𝒫 A | cb_prefixed A B f g x} → cb_prefixed A B f g X $ by sep_elim_right_imp
l2: $ cb_prefixed A B f g X $ by mp [l1, #1]

cb_prefixeds_elim_prefixed_imp
------------------------------
l1: $ X ∈ {x ∈ 𝒫 A | cb_prefixed A B f g x} → cb_prefixed A B f g X $ by sep_elim_right_imp

cb_prefixeds_intro
------------------
l1: $ X ∈ 𝒫 A $ by power_intro [#1]
l2: $ cb_prefixed A B f g X → X ∈ cb_prefixeds A B f g $ by sep_intro_imp [l1]
l3: $ X ∈ cb_prefixeds A B f g $ by mp [l2, #2]

cb_prefixed_elim
----------------
l1: $ cb_step A B f g X ⊆ X $ by cb_prefixeds_elim_prefixed [#1]
l2: $ x ∈ cb_step A B f g X → x ∈ X $ by subset_elim_imp [l1]
l3: $ x ∈ X $ by mp [l2, #2]

cb_prefixed_elim_imp
--------------------
l1: $ cb_step A B f g X ⊆ X $ by cb_prefixeds_elim_prefixed [#1]
l2: $ x ∈ cb_step A B f g X → x ∈ X $ by subset_elim_imp [l1]

cb_prefixed_elim_imp_imp
------------------------
l1: $ X ∈ cb_prefixeds A B f g → cb_prefixed A B f g X $ by cb_prefixeds_elim_prefixed_imp
l2: $ (cb_step A B f g X ⊆ X) → (x ∈ cb_step A B f g X → x ∈ X) $ by subset_elim_imp_imp
l3: $ X ∈ cb_prefixeds A B f g → (x ∈ cb_step A B f g X → x ∈ X) $ by imp_trans [l1, l2]

cb_core_in_power
----------------
l1: $ cb_core A B f g ⊆ A $ by cb_core_subset
l2: $ cb_core A B f g ∈ 𝒫 A $ by power_intro [l1]

cb_core_subset_prefixed
-----------------------
l1: $ x ∈ cb_core A B f g → x ∈ X $ by inter_subsets_elim_imp [#1]
l2: $ cb_core A B f g ⊆ X $ by subset_intro_imp [l1]

cb_core_subset_prefixed_imp
---------------------------
l1: $ X ∈ cb_prefixeds A B f g → (x ∈ cb_core A B f g → x ∈ X) $ by inter_subsets_elim_imp_imp
l2: $ X ∈ cb_prefixeds A B f g → cb_core A B f g ⊆ X $ by subset_intro_imp_imp [l1]

cb_step_mono_imp
----------------
l1: $ image f X B ⊆ image f Y B $ by image_mono [#1]
l2: $ B ∖ image f Y B ⊆ B ∖ image f X B $ by setdiff_antitone_right [l1]
l3: $ image g (B ∖ image f Y B) A ⊆ image g (B ∖ image f X B) A $ by image_mono [l2]
l4: $ x ∈ cb_step A B f g X → x ∈ A $ by cb_step_elim_left
l5: $ x ∈ cb_step A B f g X → x ∉ image g (B ∖ image f X B) A $ by cb_step_elim_right
l6: $ x ∉ image g (B ∖ image f X B) A → x ∉ image g (B ∖ image f Y B) A $ by subset_not_mem_imp [l3]
l7: $ x ∈ cb_step A B f g X → x ∉ image g (B ∖ image f Y B) A $ by imp_trans [l5, l6]
l8: $ x ∈ cb_step A B f g X → x ∈ cb_step A B f g Y $ by setdiff_intro_imp2 [l4, l7]

cb_step_mono_imp_imp
--------------------
l1: $ (X ⊆ Y) → image f X B ⊆ image f Y B $ by image_mono_imp_imp
l2: $ (image f X B ⊆ image f Y B) →
        B ∖ image f Y B ⊆ B ∖ image f X B $
  by setdiff_antitone_right_imp_imp
l3: $ (X ⊆ Y) → B ∖ image f Y B ⊆ B ∖ image f X B $
  by imp_trans [l1, l2]
l4: $ (B ∖ image f Y B ⊆ B ∖ image f X B) →
        image g (B ∖ image f Y B) A ⊆
          image g (B ∖ image f X B) A $
  by image_mono_imp_imp
l5: $ (X ⊆ Y) →
        image g (B ∖ image f Y B) A ⊆
          image g (B ∖ image f X B) A $
  by imp_trans [l3, l4]
l6: $ x ∈ cb_step A B f g X → x ∈ A $ by cb_step_elim_left
l7: $ (x ∈ cb_step A B f g X → x ∈ A) →
        ((X ⊆ Y) → (x ∈ cb_step A B f g X → x ∈ A)) $ by h1
l8: $ (X ⊆ Y) → (x ∈ cb_step A B f g X → x ∈ A) $ by mp [l7, l6]
l9: $ x ∈ cb_step A B f g X →
        x ∉ image g (B ∖ image f X B) A $ by cb_step_elim_right
l10: $ (x ∈ cb_step A B f g X →
        x ∉ image g (B ∖ image f X B) A) →
        ((X ⊆ Y) → (x ∈ cb_step A B f g X →
          x ∉ image g (B ∖ image f X B) A)) $ by h1
l11: $ (X ⊆ Y) → (x ∈ cb_step A B f g X →
        x ∉ image g (B ∖ image f X B) A) $ by mp [l10, l9]
l12: $ (image g (B ∖ image f Y B) A ⊆
          image g (B ∖ image f X B) A) →
        (x ∉ image g (B ∖ image f X B) A →
          x ∉ image g (B ∖ image f Y B) A) $
  by subset_not_mem_imp_imp
l13: $ (X ⊆ Y) →
        (x ∉ image g (B ∖ image f X B) A →
          x ∉ image g (B ∖ image f Y B) A) $
  by imp_trans [l5, l12]
l14: $ (X ⊆ Y) → (x ∈ cb_step A B f g X →
        x ∉ image g (B ∖ image f Y B) A) $
  by imp_trans_under [l11, l13]
l15: $ (X ⊆ Y) → (x ∈ cb_step A B f g X →
        x ∈ cb_step A B f g Y) $ by setdiff_intro_imp2_under [l8, l14]

cb_core_step_prefixed_imp
-------------------------
l1: $ X ∈ cb_prefixeds A B f g → (cb_core A B f g ⊆ X) $ by cb_core_subset_prefixed_imp
l2: $ (cb_core A B f g ⊆ X) → (x ∈ cb_step A B f g (cb_core A B f g) → x ∈ cb_step A B f g X) $ by cb_step_mono_imp_imp
l3: $ X ∈ cb_prefixeds A B f g → (x ∈ cb_step A B f g (cb_core A B f g) → x ∈ cb_step A B f g X) $ by imp_trans [l1, l2]
l4: $ X ∈ cb_prefixeds A B f g → (x ∈ cb_step A B f g X → x ∈ X) $ by cb_prefixed_elim_imp_imp
l5: $ X ∈ cb_prefixeds A B f g → (x ∈ cb_step A B f g (cb_core A B f g) → x ∈ X) $ by imp_trans_under [l3, l4]

cb_core_prefixed
----------------
l1: $ x ∈ cb_step A B f g (cb_core A B f g) → x ∈ A $ by cb_step_elim_left
l2: $ X ∈ cb_prefixeds A B f g → (x ∈ cb_step A B f g (cb_core A B f g) → x ∈ X) $ by cb_core_step_prefixed_imp
l3: $ x ∈ cb_step A B f g (cb_core A B f g) → (X ∈ cb_prefixeds A B f g → x ∈ X) $ by imp_swap [l2]
l4: $ x ∈ cb_step A B f g (cb_core A B f g) → ∀ X (X ∈ cb_prefixeds A B f g → x ∈ X) $ by all_intro_imp [l3]
l5: $ x ∈ cb_step A B f g (cb_core A B f g) → x ∈ cb_core A B f g $ by inter_subsets_intro_imp2 [l1, l4]
l6: $ cb_step A B f g (cb_core A B f g) ⊆ cb_core A B f g $ by subset_intro_imp [l5]

cb_step_core_prefixed
---------------------
l1: $ cb_step A B f g (cb_core A B f g) ⊆ cb_core A B f g $ by cb_core_prefixed
l2: $ x ∈ cb_step A B f g (cb_step A B f g (cb_core A B f g)) → x ∈ cb_step A B f g (cb_core A B f g) $ by cb_step_mono_imp [l1]
l3: $ cb_step A B f g (cb_step A B f g (cb_core A B f g)) ⊆ cb_step A B f g (cb_core A B f g) $ by subset_intro_imp [l2]

cb_step_core_in_prefixeds
-------------------------
l1: $ cb_step A B f g (cb_core A B f g) ⊆ A $ by cb_step_subset
l2: $ cb_prefixed A B f g (cb_step A B f g (cb_core A B f g)) $ by cb_step_core_prefixed
l3: $ cb_step A B f g (cb_core A B f g) ∈ cb_prefixeds A B f g $ by cb_prefixeds_intro [l1, l2]

cb_core_subset_step_core
------------------------
l1: $ cb_step A B f g (cb_core A B f g) ∈ cb_prefixeds A B f g $ by cb_step_core_in_prefixeds
l2: $ cb_core A B f g ⊆ cb_step A B f g (cb_core A B f g) $ by cb_core_subset_prefixed [l1]

cb_step_core_subset_core
------------------------
l1: $ cb_step A B f g (cb_core A B f g) ⊆ cb_core A B f g $ by cb_core_prefixed

cb_core_fixed
-------------
l1: $ cb_core A B f g ⊆ cb_step A B f g (cb_core A B f g) $ by cb_core_subset_step_core
l2: $ cb_step A B f g (cb_core A B f g) ⊆ cb_core A B f g $ by cb_step_core_subset_core
l3: $ cb_core A B f g = cb_step A B f g (cb_core A B f g) $ by ext [l1, l2]

mem_arg_eq_left_imp_imp
-----------------------
l1: $ x = x $ by setid
l2: $ x = y → (x = x → y = x) $ by eq_replace_imp
l3: $ x = y → y = x $ by imp_mp_right [l1, l2]
l4: $ y = x → (y ∈ A → x ∈ A) $ by eq_replace_imp
l5: $ x = y → (y ∈ A → x ∈ A) $ by imp_trans [l3, l4]

mem_arg_eq_left_imp
-------------------
l1: $ y = x $ by setsym [#1]
l2: $ A = A $ by setid
l3: $ (y ∈ A) ↔ (x ∈ A) $ by mem_congr [l1, l2]
l4: $ y ∈ A → x ∈ A $ by bi_imp [l3]

mem_arg_eq_left
---------------
l1: $ y ∈ A → x ∈ A $ by mem_arg_eq_left_imp [#1]
l2: $ x ∈ A $ by mp [l1, #2]

not_mem_eq_imp
--------------
l1: $ x = x $ by setid
l2: $ (x ∉ A) ↔ (x ∉ B) $ by not_mem_congr [l1, #1]
l3: $ x ∉ A → x ∉ B $ by bi_imp [l2]

set_sym_imp
-----------
l1: $ a = a $ by setid
l2: $ a = b → (a = a → b = a) $ by eq_replace_imp
l3: $ a = b → b = a $ by imp_mp_right [l1, l2]

set_eq_from_common_left
-----------------------
l1: $ b = a $ by setsym [#1]
l2: $ b = c $ by settr [l1, #2]

set_eq_from_common_left_imp_imp
-------------------------------
l1: $ a = b → (a = c → b = c) $ by eq_replace_imp

settr_imp_left
--------------
l1: $ b = c → (a = b → a = c) $ by eq_replace_imp
l2: $ a = b → (b = c → a = b) $ by h1
l3: $ b = c → a = b $ by mp [l2, #1]
l4: $ b = c → a = c $ by imp_apply_under [l1, l3]

settr_imp_left_imp
------------------
l1: $ a = b → b = a $ by set_sym_imp
l2: $ b = a → (b = c → a = c) $ by eq_replace_imp
l3: $ a = b → (b = c → a = c) $ by imp_trans [l1, l2]

settr_imp_right
---------------
l1: $ b = c → (a = b → a = c) $ by eq_replace_imp
l2: $ a = b → a = c $ by mp [l1, #1]

settr_imp_right_imp
-------------------
l1: $ b = c → (a = b → a = c) $ by eq_replace_imp

opair_rights_eq_imp
-------------------
l1: $ opair x z = opair u v → z = v $ by opair_eq_right_imp
l2: $ opair y z = opair w t → z = t $ by opair_eq_right_imp
l3: $ z = v → (z = t → v = t) $ by set_eq_from_common_left_imp_imp
l4: $ opair x z = opair u v → (z = t → v = t) $
  by imp_trans [l1, l3]
l4a: $ opair x z = opair u v →
      (opair y z = opair w t → (z = t → v = t)) $ by imp_lift [l4]
l5: $ opair x z = opair u v →
      (opair y z = opair w t → z = t) $ by imp_const [l2]
l6: $ opair x z = opair u v →
      (opair y z = opair w t → v = t) $ by imp_apply_under2 [l4a, l5]

opair_lefts_eq_imp
------------------
l1: $ opair x z = opair u v → x = u $ by opair_eq_left_imp
l2: $ opair y z = opair w t → y = w $ by opair_eq_left_imp
l3: $ u = w → (x = u → x = w) $ by settr_imp_right_imp
l3a: $ opair x z = opair u v → (u = w → (x = u → x = w)) $
  by imp_const [l3]
l3b: $ opair x z = opair u v → (u = w → x = u) $ by imp_lift [l1]
l4: $ opair x z = opair u v → (u = w → x = w) $
  by imp_apply_under2 [l3a, l3b]
l5: $ y = w → w = y $ by set_sym_imp
l6: $ opair y z = opair w t → w = y $ by imp_trans [l2, l5]
l7: $ w = y → (x = w → x = y) $ by settr_imp_right_imp
l8: $ opair y z = opair w t → (x = w → x = y) $
  by imp_trans [l6, l7]
l9: $ opair x z = opair u v →
      (opair y z = opair w t → (u = w → x = w)) $
  by imp_lift [l4]
l10: $ opair x z = opair u v →
       (opair y z = opair w t → (x = w → x = y)) $
  by imp_const [l8]
l11: $ opair x z = opair u v →
       (opair y z = opair w t → (u = w → x = y)) $
  by imp_trans_under2 [l9, l10]

maps_arg_eq_left_imp
--------------------
l1: $ x = x $ by setid
l2: $ x = y → (x = x → y = x) $ by eq_replace_imp
l3: $ x = y → y = x $ by imp_mp_right [l1, l2]
l4: $ y = x → (maps f y z → maps f x z) $ by eq_replace_imp
l5: $ x = y → (maps f y z → maps f x z) $ by imp_trans [l3, l4]

maps_arg_eq_right_imp
---------------------
l1: $ y = z → (maps f x y → maps f x z) $ by eq_replace_imp

functional_elim_imp
-------------------
l1: $ ∀ w ∀ u ∀ v ((maps f w u ∧ maps f w v) → u = v) → ∀ u ∀ v ((maps f x u ∧ maps f x v) → u = v) $ by all_elim_imp
l2: $ ∀ u ∀ v ((maps f x u ∧ maps f x v) → u = v) $ by mp [l1, #1]
l3: $ ∀ u ∀ v ((maps f x u ∧ maps f x v) → u = v) → ∀ v ((maps f x y ∧ maps f x v) → y = v) $ by all_elim_imp
l4: $ ∀ v ((maps f x y ∧ maps f x v) → y = v) $ by mp [l3, l2]
l5: $ ∀ v ((maps f x y ∧ maps f x v) → y = v) → ((maps f x y ∧ maps f x z) → y = z) $ by all_elim_imp
l6: $ (maps f x y ∧ maps f x z) → y = z $ by mp [l5, l4]
l7: $ maps f x y → y = z $ by and_mp_right [#2, l6]

functional_elim_imp_imp
-----------------------
l1: $ ∀ w ∀ u ∀ v ((maps f w u ∧ maps f w v) → u = v) → ∀ u ∀ v ((maps f x u ∧ maps f x v) → u = v) $ by all_elim_imp
l2: $ ∀ u ∀ v ((maps f x u ∧ maps f x v) → u = v) $ by mp [l1, #1]
l3: $ ∀ u ∀ v ((maps f x u ∧ maps f x v) → u = v) → ∀ v ((maps f x y ∧ maps f x v) → y = v) $ by all_elim_imp
l4: $ ∀ v ((maps f x y ∧ maps f x v) → y = v) $ by mp [l3, l2]
l5: $ ∀ v ((maps f x y ∧ maps f x v) → y = v) → ((maps f x y ∧ maps f x z) → y = z) $ by all_elim_imp
l6: $ (maps f x y ∧ maps f x z) → y = z $ by mp [l5, l4]
l7: $ maps f x z → (maps f x y → y = z) $ by and_mp_right_imp [l6]

functional_elim
---------------
l1: $ maps f x y → y = z $ by functional_elim_imp [#1, #3]
l2: $ y = z $ by mp [l1, #2]

domain_on_maps_mem_imp
----------------------
l0: $ maps f x y → maps f x y $ by imp_id
l1: $ maps f x y → ∃ v (maps f x v) $ by ex_intro_imp [l0]
l2: $ ∀ u (u ∈ A ↔ ∃ v (maps f u v)) → (x ∈ A ↔ ∃ v (maps f x v)) $ by all_elim_imp
l3: $ x ∈ A ↔ ∃ v (maps f x v) $ by mp [l2, #1]
l4: $ (∃ v (maps f x v)) → x ∈ A $ by bi_imp_rev [l3]
l5: $ maps f x y → x ∈ A $ by imp_trans [l1, l4]

domain_on_maps_mem
------------------
l1: $ maps f x y → x ∈ A $ by domain_on_maps_mem_imp [#1]
l2: $ x ∈ A $ by mp [l1, #2]

domain_on_has_maps_imp
----------------------
l1: $ ∀ u (u ∈ A ↔ ∃ a (maps f u a)) → (x ∈ A ↔ ∃ a (maps f x a)) $ by all_elim_imp
l2: $ x ∈ A ↔ ∃ a (maps f x a) $ by mp [l1, #1]
l3: $ x ∈ A → ∃ a (maps f x a) $ by bi_imp [l2]

range_sub_elim_imp
------------------
l0: $ maps f x y → maps f x y $ by imp_id
l1: $ maps f x y → ∃ v (maps f v y) $ by ex_intro_imp [l0]
l2: $ ∀ u ((∃ v (maps f v u)) → u ∈ B) → ((∃ v (maps f v y)) → y ∈ B) $ by all_elim_imp
l3: $ (∃ v (maps f v y)) → y ∈ B $ by mp [l2, #1]
l4: $ maps f x y → y ∈ B $ by imp_trans [l1, l3]

range_sub_elim
--------------
l1: $ maps f x y → y ∈ B $ by range_sub_elim_imp [#1]
l2: $ y ∈ B $ by mp [l1, #2]

range_sub_intro
---------------
l1: $ ∀ y ∀ x (maps f x y → y ∈ B) →
      ∀ x (maps f x y → y ∈ B) $ by all_elim_self_imp
l2: $ ∀ x (maps f x y → y ∈ B) $ by mp [l1, #1]
l3: $ (∃ x (maps f x y)) → y ∈ B $ by ex_elim_imp [l2]
l4: $ ∀ y ((∃ x (maps f x y)) → y ∈ B) $ by all_intro [l3]

function_intro
--------------
l1: $ domain_on f A ∧ range_sub f B $ by and_intro [#2, #3]
l2: $ function f A B $ by and_intro [#1, l1]

function_functional
-------------------
l1: $ functional f $ by and_elim_l [#1]

function_domain_on
------------------
l1: $ domain_on f A ∧ range_sub f B $ by and_elim_r [#1]
l2: $ domain_on f A $ by and_elim_l [l1]

function_range_sub
------------------
l1: $ domain_on f A ∧ range_sub f B $ by and_elim_r [#1]
l2: $ range_sub f B $ by and_elim_r [l1]

function_maps_range
-------------------
l1: $ range_sub f B $ by function_range_sub [#1]
l2: $ y ∈ B $ by range_sub_elim [l1, #2]

function_maps_range_imp
-----------------------
l1: $ range_sub f B $ by function_range_sub [#1]
l2: $ maps f x y → y ∈ B $ by range_sub_elim_imp [l1]

function_maps_domain_imp
------------------------
l1: $ domain_on f A $ by function_domain_on [#1]
l2: $ maps f x y → x ∈ A $ by domain_on_maps_mem_imp [l1]

function_maps_domain
--------------------
l1: $ maps f x y → x ∈ A $ by function_maps_domain_imp [#1]
l2: $ x ∈ A $ by mp [l1, #2]

injective_intro
----------------
l1: $ injective f A B $ by and_intro [#1, #2]

injective_function
------------------
l1: $ function f A B $ by and_elim_l [#1]

injective_functional
--------------------
l1: $ function f A B $ by injective_function [#1]
l2: $ functional f $ by function_functional [l1]

injective_domain_on
-------------------
l1: $ function f A B $ by injective_function [#1]
l2: $ domain_on f A $ by function_domain_on [l1]

injective_range_sub
-------------------
l1: $ function f A B $ by injective_function [#1]
l2: $ range_sub f B $ by function_range_sub [l1]

injective_maps_range
--------------------
l1: $ function f A B $ by injective_function [#1]
l2: $ y ∈ B $ by function_maps_range [l1, #2]

injective_maps_range_imp
------------------------
l1: $ function f A B $ by injective_function [#1]
l2: $ maps f x y → y ∈ B $ by function_maps_range_imp [l1]

injective_maps_domain_imp
-------------------------
l1: $ function f A B $ by injective_function [#1]
l2: $ maps f x y → x ∈ A $ by function_maps_domain_imp [l1]

injective_maps_domain
---------------------
l1: $ maps f x y → x ∈ A $ by injective_maps_domain_imp [#1]
l2: $ x ∈ A $ by mp [l1, #2]

injective_elim
---------------
l1: $ ∀ w ∀ u ∀ v (((w ∈ A ∧ u ∈ A) ∧ (maps f w v ∧ maps f u v)) → w = u) $ by and_elim_r [#1]
l2: $ ∀ w ∀ u ∀ v (((w ∈ A ∧ u ∈ A) ∧ (maps f w v ∧ maps f u v)) → w = u) → ∀ u ∀ v (((x ∈ A ∧ u ∈ A) ∧ (maps f x v ∧ maps f u v)) → x = u) $ by all_elim_imp
l3: $ ∀ u ∀ v (((x ∈ A ∧ u ∈ A) ∧ (maps f x v ∧ maps f u v)) → x = u) $ by mp [l2, l1]
l4: $ ∀ u ∀ v (((x ∈ A ∧ u ∈ A) ∧ (maps f x v ∧ maps f u v)) → x = u) → ∀ v (((x ∈ A ∧ y ∈ A) ∧ (maps f x v ∧ maps f y v)) → x = y) $ by all_elim_imp
l5: $ ∀ v (((x ∈ A ∧ y ∈ A) ∧ (maps f x v ∧ maps f y v)) → x = y) $ by mp [l4, l3]
l6: $ ∀ v (((x ∈ A ∧ y ∈ A) ∧ (maps f x v ∧ maps f y v)) → x = y) → (((x ∈ A ∧ y ∈ A) ∧ (maps f x z ∧ maps f y z)) → x = y) $ by all_elim_imp
l7: $ (((x ∈ A ∧ y ∈ A) ∧ (maps f x z ∧ maps f y z)) → x = y) $ by mp [l6, l5]
l8: $ x ∈ A ∧ y ∈ A $ by and_intro [#2, #3]
