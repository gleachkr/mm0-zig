  by or_elim_imp_under2 [l3, l6]

cb_bijection_pair_injective_imp
-------------------------------
l1: $ (opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) →
      opair x z = opair u v $ by and_elim_l_imp
l2: $ (opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) →
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u)) $ by and_elim_r_imp
l3: $ (opair y z = opair w t ∧
      ((w ∈ cb_core A B f g ∧ maps f w t) ∨
      (w ∉ cb_core A B f g ∧ maps g t w))) →
      opair y z = opair w t $ by and_elim_l_imp
l4: $ (opair y z = opair w t ∧
      ((w ∈ cb_core A B f g ∧ maps f w t) ∨
      (w ∉ cb_core A B f g ∧ maps g t w))) →
      ((w ∈ cb_core A B f g ∧ maps f w t) ∨
      (w ∉ cb_core A B f g ∧ maps g t w)) $ by and_elim_r_imp
l5: $ opair x z = opair u v → (opair y z = opair w t →
      (((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u)) →
      (((w ∈ cb_core A B f g ∧ maps f w t) ∨
      (w ∉ cb_core A B f g ∧ maps g t w)) → x = y))) $
  by cb_bijection_branch_injective_imp_imp [#1, #2]
l6: $ (opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) →
      (opair y z = opair w t →
      (((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u)) →
      (((w ∈ cb_core A B f g ∧ maps f w t) ∨
      (w ∉ cb_core A B f g ∧ maps g t w)) → x = y))) $
  by imp_trans [l1, l5]
l7: $ (opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) →
      ((opair y z = opair w t ∧
      ((w ∈ cb_core A B f g ∧ maps f w t) ∨
      (w ∉ cb_core A B f g ∧ maps g t w))) → opair y z = opair w t) $
  by imp_const [l3]
l8: $ (opair x z = opair u v ∧
      ((u ∈ cb_core A B f g ∧ maps f u v) ∨
      (u ∉ cb_core A B f g ∧ maps g v u))) →
      ((opair y z = opair w t ∧
      ((w ∈ cb_core A B f g ∧ maps f w t) ∨
      (w ∉ cb_core A B f g ∧ maps g t w))) →
