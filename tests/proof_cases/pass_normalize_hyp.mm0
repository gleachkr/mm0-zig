delimiter $ ( ) $;

-- Sorts
provable sort wff;

-- Terms
term im (a b: wff): wff; infixr im: $->$ prec 25;
term bi (a b: wff): wff; infixr bi: $<->$ prec 20;
term P: wff;
term Q: wff;
term R: wff;
term sb (a b: wff): wff;

-- Relation bundle
--| @relation wff bi biid bitr bisym mpbi

-- Relation axioms
axiom biid (a: wff): $ a <-> a $;
axiom bitr (a b c: wff): $ a <-> b $ > $ b <-> c $ > $ a <-> c $;
axiom bisym (a b: wff): $ a <-> b $ > $ b <-> a $;
axiom mpbi (a b: wff): $ a <-> b $ > $ a $ > $ b $;

-- Rewrite rules
--| @rewrite
axiom sb_im (a b c: wff): $ sb a (b -> c) <-> (sb a b -> sb a c) $;

--| @rewrite
axiom sb_P (a: wff): $ sb a P <-> a $;

-- Congruence for implication
--| @congr
axiom im_congr (a b c d: wff): $ a <-> b $ > $ c <-> d $ > $ (a -> c) <-> (b -> d) $;

-- A rule whose conclusion needs normalization
axiom all_elim (a b: wff): $ sb a b $;

-- A rule with hypothesis normalization:
-- hyp0 expects sb(a, b) but user provides an already-normalized form
axiom use_sub (a b: wff): $ sb a b $ > $ a $;

-- The proof:
-- 1. all_elim [Q, P -> P] produces sb(Q, P->P), normalized to Q -> Q
-- 2. use_sub [Q, P -> P] expects hyp0 = sb(Q, P->P). We provide Q -> Q from step 1.
--    With automatic hypothesis normalization, both sb(Q, P->P) and Q -> Q normalize to Q -> Q, so they match.
-- 3. Conclusion of use_sub is Q.
theorem test_hyp_norm (a: wff): $ Q $;
