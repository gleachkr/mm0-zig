a1i
---
-- Given h: b.  Apply ax_1 at (b, a) to obtain b -> a -> b, then ax_mp.
l1: $ b -> a -> b $ by ax_1
l2: $ a -> b $ by ax_mp [l1, #1]

a2i
---
-- Given h: a -> b -> c.  ax_2 is (a -> b -> c) -> (a -> b) -> a -> c.
l1: $ (a -> b -> c) -> (a -> b) -> a -> c $ by ax_2
l2: $ (a -> b) -> a -> c $ by ax_mp [l1, #1]

mpd
---
-- h1: a -> b, h2: a -> b -> c.  Conclude a -> c.
l1: $ (a -> b) -> a -> c $ by a2i [#2]
l2: $ a -> c $ by ax_mp [l1, #1]

mpi
---
-- h1: b, h2: a -> b -> c.  Weaken h1 to a -> b and feed mpd.
l1: $ a -> b $ by a1i [#1]
l2: $ a -> c $ by mpd [l1, #2]

id
--
-- a -> a by the standard Lukasiewicz trick: ax_1 twice at different b's
-- and ax_2 to glue them together.
l1: $ a -> (a -> a) -> a $ by ax_1
l2: $ a -> a -> a $ by ax_1
l3: $ (a -> (a -> a) -> a) -> (a -> a -> a) -> a -> a $ by ax_2
l4: $ (a -> a -> a) -> a -> a $ by ax_mp [l3, l1]
l5: $ a -> a $ by ax_mp [l4, l2]

idd
---
-- a -> b -> b: take id at b, weaken with a1i.
l1: $ b -> b $ by id
l2: $ a -> b -> b $ by a1i [l1]

syl
---
-- h1: b -> c, h2: a -> b.  Conclude a -> c.
l1: $ a -> b -> c $ by a1i [#1]
l2: $ a -> c $ by mpd [#2, l1]

rsyl
----
-- Reverse-argument version of syl.
l1: $ a -> c $ by syl [#2, #1]

a1d
---
-- h: a -> b.  Conclude a -> c -> b.
l1: $ b -> c -> b $ by ax_1
l2: $ a -> c -> b $ by syl [l1, #1]

a2d
---
-- h: a -> b -> c -> d.  Conclude a -> (b -> c) -> b -> d.
l1: $ (b -> c -> d) -> (b -> c) -> b -> d $ by ax_2
l2: $ a -> (b -> c) -> b -> d $ by syl [l1, #1]

a3d
---
-- h: a -> ~ b -> ~ c.  Conclude a -> c -> b.
l1: $ (~ b -> ~ c) -> c -> b $ by ax_3
l2: $ a -> c -> b $ by syl [l1, #1]

imim2
-----
-- (b -> c) -> (a -> b) -> a -> c.  MM1 recipe: a2d ax_1.
l1: $ (b -> c) -> a -> b -> c $ by ax_1
l2: $ (b -> c) -> (a -> b) -> a -> c $ by a2d [l1]

imim2i
------
-- h: b -> c.  Feed imim2.
l1: $ (b -> c) -> (a -> b) -> a -> c $ by imim2
l2: $ (a -> b) -> a -> c $ by ax_mp [l1, #1]

com12
-----
-- h: a -> b -> c.  Conclude b -> a -> c.
l1: $ (a -> b) -> a -> c $ by a2i [#1]
l2: $ b -> a -> b $ by ax_1
l3: $ b -> a -> c $ by syl [l1, l2]

mpcom
-----
-- a -> (a -> b) -> b.  Flip the id on (a -> b).
l1: $ (a -> b) -> a -> b $ by id
l2: $ a -> (a -> b) -> b $ by com12 [l1]

absurd
------
-- ~ a -> a -> b.  MM1 recipe: a3d ax_1.
l1: $ ~ a -> ~ b -> ~ a $ by ax_1
l2: $ ~ a -> a -> b $ by a3d [l1]

imidm
-----
-- (a -> a -> b) -> a -> b.  MM1 recipe: a2i mpcom.
l1: $ a -> (a -> b) -> b $ by mpcom
l2: $ (a -> a -> b) -> a -> b $ by a2i [l1]

contra
------
-- (~ a -> a) -> a.  Instantiate absurd with its "b" slot := ~ (~ a -> a)
-- so that imidm collapses a double (~ a -> a) implication into a.
l1: $ ~ a -> a -> ~ (~ a -> a) $ by absurd
l2: $ (~ a -> a) -> ~ a -> ~ (~ a -> a) $ by a2i [l1]
l3: $ (~ a -> a) -> (~ a -> a) -> a $ by a3d [l2]
l4: $ ((~ a -> a) -> (~ a -> a) -> a) -> (~ a -> a) -> a $ by imidm
l5: $ (~ a -> a) -> a $ by ax_mp [l4, l3]

syld
----
-- h1: a -> b -> c, h2: a -> c -> d.  Conclude a -> b -> d.
-- MM1 recipe: mpd h1 (a2d (a1d h2)).
l1: $ a -> b -> c -> d $ by a1d [#2]
l2: $ a -> (b -> c) -> b -> d $ by a2d [l1]
l3: $ a -> b -> d $ by mpd [#1, l2]

syl5
----
-- h1: b -> c, h2: a -> c -> d.  Conclude a -> b -> d.
l1: $ a -> b -> c $ by a1i [#1]
l2: $ a -> b -> d $ by syld [l1, #2]

dne
---
-- ~ ~ a -> a.  MM1 recipe: syl contra absurd.
l1: $ (~ a -> a) -> a $ by contra
l2: $ ~ ~ a -> ~ a -> a $ by absurd
l3: $ ~ ~ a -> a $ by syl [l1, l2]

con2
----
-- (a -> ~ b) -> b -> ~ a.  MM1 recipe: a3d (syl5 dne id).
l1: $ ~ ~ a -> a $ by dne
l2: $ (a -> ~ b) -> a -> ~ b $ by id
l3: $ (a -> ~ b) -> ~ ~ a -> ~ b $ by syl5 [l1, l2]
l4: $ (a -> ~ b) -> b -> ~ a $ by a3d [l3]

notnot1
-------
-- a -> ~ ~ a.  MM1 recipe: con2 id.
l1: $ ~ a -> ~ a $ by id
l2: $ (~ a -> ~ a) -> a -> ~ ~ a $ by con2
l3: $ a -> ~ ~ a $ by ax_mp [l2, l1]

con3
----
-- (a -> b) -> ~ b -> ~ a.  MM1 recipe: syl con2 (imim2i notnot1).
l1: $ b -> ~ ~ b $ by notnot1
l2: $ (a -> b) -> a -> ~ ~ b $ by imim2i [l1]
l3: $ (a -> ~ ~ b) -> ~ b -> ~ a $ by con2
l4: $ (a -> b) -> ~ b -> ~ a $ by syl [l3, l2]

con1
----
-- (~ a -> b) -> ~ b -> a.  MM1 recipe: a3d (imim2i notnot1).
l1: $ b -> ~ ~ b $ by notnot1
l2: $ (~ a -> b) -> ~ a -> ~ ~ b $ by imim2i [l1]
l3: $ (~ a -> b) -> ~ b -> a $ by a3d [l2]

mt
--
-- h1: b -> a, h2: ~ a.  Conclude ~ b.  Apply con3 then two ax_mp's.
l1: $ (b -> a) -> ~ a -> ~ b $ by con3
l2: $ ~ a -> ~ b $ by ax_mp [l1, #1]
l3: $ ~ b $ by ax_mp [l2, #2]

eq_trans3
---------
-- Chain three equalities, explicitly instantiating eq_trans twice.
l1: $ a = b -> b = c -> a = c $ by eq_trans
l2: $ b = c -> a = c $ by ax_mp [l1, #1]
l3: $ a = c $ by ax_mp [l2, #2]
l4: $ a = c -> c = d -> a = d $ by eq_trans
l5: $ c = d -> a = d $ by ax_mp [l4, l3]
l6: $ a = d $ by ax_mp [l5, #3]

eq_euclid
---------
-- a = b  and  a = c  ⇒  b = c.  (Corresponds to peano.mm0's ax_7.)
l1: $ a = b -> b = a $ by eq_sym
l2: $ b = a $ by ax_mp [l1, #1]
l3: $ b = a -> a = c -> b = c $ by eq_trans
l4: $ a = c -> b = c $ by ax_mp [l3, l2]
l5: $ b = c $ by ax_mp [l4, #2]

suc_cong
--------
-- Apply peano2r twice, with ax_mp between each.
l1: $ a = b -> suc a = suc b $ by peano2r
l2: $ suc a = suc b $ by ax_mp [l1, #1]
l3: $ suc a = suc b -> suc (suc a) = suc (suc b) $ by peano2r
l4: $ suc (suc a) = suc (suc b) $ by ax_mp [l3, l2]

suc_zero_refl
-------------
l1: $ suc 0 = suc 0 $ by eq_refl

suc_chain
---------
-- a = b, b = c  ⇒  suc a = suc c.
l1: $ a = b -> b = c -> a = c $ by eq_trans
l2: $ b = c -> a = c $ by ax_mp [l1, #1]
l3: $ a = c $ by ax_mp [l2, #2]
l4: $ a = c -> suc a = suc c $ by peano2r
l5: $ suc a = suc c $ by ax_mp [l4, l3]

suc_inj_neg
-----------
-- Contrapose peano2r via con3.
l1: $ a = b -> suc a = suc b $ by peano2r
l2: $ (a = b -> suc a = suc b) -> ~ suc a = suc b -> ~ a = b $ by con3
l3: $ ~ suc a = suc b -> ~ a = b $ by ax_mp [l2, l1]
l4: $ ~ a = b $ by ax_mp [l3, #1]

zero_ne_suc
-----------
-- peano1 gives ~ suc a = 0; flip with eq_sym through con3.
l1: $ ~ suc a = 0 $ by peano1
l2: $ 0 = suc a -> suc a = 0 $ by eq_sym
l3: $ (0 = suc a -> suc a = 0) -> ~ suc a = 0 -> ~ 0 = suc a $ by con3
l4: $ ~ suc a = 0 -> ~ 0 = suc a $ by ax_mp [l3, l2]
l5: $ ~ 0 = suc a $ by ax_mp [l4, l1]

zero_ne_one
-----------
l1: $ ~ 0 = suc 0 $ by zero_ne_suc

suc_cancel
----------
-- peano2 twice.
l1: $ suc (suc a) = suc (suc b) -> suc a = suc b $ by peano2
l2: $ suc a = suc b $ by ax_mp [l1, #1]
l3: $ suc a = suc b -> a = b $ by peano2
l4: $ a = b $ by ax_mp [l3, l2]
