a1i
---
-- Given h: b.  Apply ax_1 at (b, a) to obtain b → a → b, then ax_mp.
l1: $ b → a → b $ by ax_1
l2: $ a → b $ by ax_mp [l1, #1]

a2i
---
-- Given h: a → b → c.  ax_2 is (a → b → c) → (a → b) → a → c.
l1: $ (a → b → c) → (a → b) → a → c $ by ax_2
l2: $ (a → b) → a → c $ by ax_mp [l1, #1]

mpd
---
-- h1: a → b, h2: a → b → c.  Conclude a → c.
l1: $ (a → b) → a → c $ by a2i [#2]
l2: $ a → c $ by ax_mp [l1, #1]

mpi
---
-- h1: b, h2: a → b → c.  Weaken h1 to a → b and feed mpd.
l1: $ a → b $ by a1i [#1]
l2: $ a → c $ by mpd [l1, #2]

id
---
-- a → a by the standard Lukasiewicz trick: ax_1 twice at different b's
-- and ax_2 to glue them together.
l1: $ a → (a → a) → a $ by ax_1
l2: $ a → a → a $ by ax_1
l3: $ (a → (a → a) → a) → (a → a → a) → a → a $ by ax_2
l4: $ (a → a → a) → a → a $ by ax_mp [l3, l1]
l5: $ a → a $ by ax_mp [l4, l2]

idd
---
-- a → b → b: take id at b, weaken with a1i.
l1: $ b → b $ by id
l2: $ a → b → b $ by a1i [l1]

syl
---
-- h1: b → c, h2: a → b.  Conclude a → c.
l1: $ a → b → c $ by a1i [#1]
l2: $ a → c $ by mpd [#2, l1]

rsyl
----
-- Reverse-argument version of syl.
l1: $ a → c $ by syl [#2, #1]

a1d
---
-- h: a → b.  Conclude a → c → b.
l1: $ b → c → b $ by ax_1
l2: $ a → c → b $ by syl [l1, #1]

a2d
---
-- h: a → b → c → d.  Conclude a → (b → c) → b → d.
l1: $ (b → c → d) → (b → c) → b → d $ by ax_2
l2: $ a → (b → c) → b → d $ by syl [l1, #1]

a3d
---
-- h: a → ¬ b → ¬ c.  Conclude a → c → b.
l1: $ (¬ b → ¬ c) → c → b $ by ax_3
l2: $ a → c → b $ by syl [l1, #1]

imim2
-----
-- (b → c) → (a → b) → a → c.  MM1 recipe: a2d ax_1.
l1: $ (b → c) → a → b → c $ by ax_1
l2: $ (b → c) → (a → b) → a → c $ by a2d [l1]

imim2i
------
-- h: b → c.  Feed imim2.
l1: $ (b → c) → (a → b) → a → c $ by imim2
l2: $ (a → b) → a → c $ by ax_mp [l1, #1]

com12
-----
-- h: a → b → c.  Conclude b → a → c.
l1: $ (a → b) → a → c $ by a2i [#1]
l2: $ b → a → b $ by ax_1
l3: $ b → a → c $ by syl [l1, l2]

imim1
-----
-- (a → b) → (b → c) → a → c.  Flip imim2 via com12.
l1: $ (b → c) → (a → b) → a → c $ by imim2
l2: $ (a → b) → (b → c) → a → c $ by com12 [l1]

imim1i
------
-- h: a → b.  Conclude (b → c) → (a → c).  One ax_mp against imim1.
l1: $ (a → b) → (b → c) → a → c $ by imim1
l2: $ (b → c) → a → c $ by ax_mp [l1, #1]

mpcom
-----
-- a → (a → b) → b.  Flip the id on (a → b).
l1: $ (a → b) → a → b $ by id
l2: $ a → (a → b) → b $ by com12 [l1]

absurd
------
-- ¬ a → a → b.  MM1 recipe: a3d ax_1.
l1: $ ¬ a → ¬ b → ¬ a $ by ax_1
l2: $ ¬ a → a → b $ by a3d [l1]

imidm
-----
-- (a → a → b) → a → b.  MM1 recipe: a2i mpcom.
l1: $ a → (a → b) → b $ by mpcom
l2: $ (a → a → b) → a → b $ by a2i [l1]

contra
------
-- (¬ a → a) → a.  Instantiate absurd with its "b" slot := ¬ (¬ a → a)
-- so that imidm collapses a double (¬ a → a) implication into a.
l1: $ ¬ a → a → ¬ (¬ a → a) $ by absurd
l2: $ (¬ a → a) → ¬ a → ¬ (¬ a → a) $ by a2i [l1]
l3: $ (¬ a → a) → (¬ a → a) → a $ by a3d [l2]
l4: $ ((¬ a → a) → (¬ a → a) → a) → (¬ a → a) → a $ by imidm
l5: $ (¬ a → a) → a $ by ax_mp [l4, l3]

syld
----
-- h1: a → b → c, h2: a → c → d.  Conclude a → b → d.
-- MM1 recipe: mpd h1 (a2d (a1d h2)).
l1: $ a → b → c → d $ by a1d [#2]
l2: $ a → (b → c) → b → d $ by a2d [l1]
l3: $ a → b → d $ by mpd [#1, l2]

syl5
----
-- h1: b → c, h2: a → c → d.  Conclude a → b → d.
l1: $ a → b → c $ by a1i [#1]
l2: $ a → b → d $ by syld [l1, #2]

dne
---
-- ¬ ¬ a → a.  MM1 recipe: syl contra absurd.
l1: $ (¬ a → a) → a $ by contra
l2: $ ¬ ¬ a → ¬ a → a $ by absurd
l3: $ ¬ ¬ a → a $ by syl [l1, l2]

con2
----
-- (a → ¬ b) → b → ¬ a.  MM1 recipe: a3d (syl5 dne id).
l1: $ ¬ ¬ a → a $ by dne
l2: $ (a → ¬ b) → a → ¬ b $ by id
l3: $ (a → ¬ b) → ¬ ¬ a → ¬ b $ by syl5 [l1, l2]
l4: $ (a → ¬ b) → b → ¬ a $ by a3d [l3]

notnot1
-------
-- a → ¬ ¬ a.  MM1 recipe: con2 id.
l1: $ ¬ a → ¬ a $ by id
l2: $ (¬ a → ¬ a) → a → ¬ ¬ a $ by con2
l3: $ a → ¬ ¬ a $ by ax_mp [l2, l1]

con3
----
-- (a → b) → ¬ b → ¬ a.  MM1 recipe: syl con2 (imim2i notnot1).
l1: $ b → ¬ ¬ b $ by notnot1
l2: $ (a → b) → a → ¬ ¬ b $ by imim2i [l1]
l3: $ (a → ¬ ¬ b) → ¬ b → ¬ a $ by con2
l4: $ (a → b) → ¬ b → ¬ a $ by syl [l3, l2]

con1
----
-- (¬ a → b) → ¬ b → a.  MM1 recipe: a3d (imim2i notnot1).
l1: $ b → ¬ ¬ b $ by notnot1
l2: $ (¬ a → b) → ¬ a → ¬ ¬ b $ by imim2i [l1]
l3: $ (¬ a → b) → ¬ b → a $ by a3d [l2]

mt
---
-- h1: b → a, h2: ¬ a.  Conclude ¬ b.  Apply con3 then two ax_mp's.
l1: $ (b → a) → ¬ a → ¬ b $ by con3
l2: $ ¬ a → ¬ b $ by ax_mp [l1, #1]
l3: $ ¬ b $ by ax_mp [l2, #2]

mt2
---
-- h1: b → ¬ a, h2: a.  Conclude ¬ b.  Classical variant: apply con2
-- to flip (b → ¬ a) into (a → ¬ b), then discharge a.
l1: $ (b → ¬ a) → a → ¬ b $ by con2
l2: $ a → ¬ b $ by ax_mp [l1, #1]
l3: $ ¬ b $ by ax_mp [l2, #2]

cases
-----
-- h1: a → b, h2: ¬ a → b.  Conclude b.  Contrapose h1 to ¬ b → ¬ a,
-- chain with h2 to ¬ b → b, and collapse with contra.
l1: $ (a → b) → ¬ b → ¬ a $ by con3
l2: $ ¬ b → ¬ a $ by ax_mp [l1, #1]
l3: $ ¬ b → b $ by syl [#2, l2]
l4: $ (¬ b → b) → b $ by contra
l5: $ b $ by ax_mp [l4, l3]

mp2
---
-- h1: a, h2: b, h3: a → b → c.  Apply mp twice to discharge both
-- antecedents.
l1: $ b → c $ by ax_mp [#3, #1]
l2: $ c $ by ax_mp [l1, #2]

eq_trans3
---------
-- Chain three equalities, explicitly instantiating eq_trans twice.
l1: $ a = b → b = c → a = c $ by eq_trans
l2: $ b = c → a = c $ by ax_mp [l1, #1]
l3: $ a = c $ by ax_mp [l2, #2]
l4: $ a = c → c = d → a = d $ by eq_trans
l5: $ c = d → a = d $ by ax_mp [l4, l3]
l6: $ a = d $ by ax_mp [l5, #3]

eq_trans4
---------
-- Chain four equalities by reusing eq_trans3 on the first three and
-- eq_trans for the final link.
l1: $ a = d $ by eq_trans3 [#1, #2, #3]
l2: $ a = d → d = e → a = e $ by eq_trans
l3: $ d = e → a = e $ by ax_mp [l2, l1]
l4: $ a = e $ by ax_mp [l3, #4]

eq_euclid
---------
-- a = b  and  a = c  ⇒  b = c.  (Corresponds to peano.mm0's ax_7.)
l1: $ a = b → b = a $ by eq_sym
l2: $ b = a $ by ax_mp [l1, #1]
l3: $ b = a → a = c → b = c $ by eq_trans
l4: $ a = c → b = c $ by ax_mp [l3, l2]
l5: $ b = c $ by ax_mp [l4, #2]

suc_cong
--------
-- Apply peano2r twice, with ax_mp between each.
l1: $ a = b → suc a = suc b $ by peano2r
l2: $ suc a = suc b $ by ax_mp [l1, #1]
l3: $ suc a = suc b → suc (suc a) = suc (suc b) $ by peano2r
l4: $ suc (suc a) = suc (suc b) $ by ax_mp [l3, l2]

suc_zero_refl
-------------
l1: $ suc 0 = suc 0 $ by eq_refl

suc_chain
---------
-- a = b, b = c  ⇒  suc a = suc c.
l1: $ a = b → b = c → a = c $ by eq_trans
l2: $ b = c → a = c $ by ax_mp [l1, #1]
l3: $ a = c $ by ax_mp [l2, #2]
l4: $ a = c → suc a = suc c $ by peano2r
l5: $ suc a = suc c $ by ax_mp [l4, l3]

suc_inj_neg
-----------
-- Contrapose peano2r via con3.
l1: $ a = b → suc a = suc b $ by peano2r
l2: $ (a = b → suc a = suc b) → ¬ suc a = suc b → ¬ a = b $ by con3
l3: $ ¬ suc a = suc b → ¬ a = b $ by ax_mp [l2, l1]
l4: $ ¬ a = b $ by ax_mp [l3, #1]

zero_ne_suc
-----------
-- peano1 gives ¬ suc a = 0; flip with eq_sym through con3.
l1: $ ¬ suc a = 0 $ by peano1
l2: $ 0 = suc a → suc a = 0 $ by eq_sym
l3: $ (0 = suc a → suc a = 0) → ¬ suc a = 0 → ¬ 0 = suc a $ by con3
l4: $ ¬ suc a = 0 → ¬ 0 = suc a $ by ax_mp [l3, l2]
l5: $ ¬ 0 = suc a $ by ax_mp [l4, l1]

zero_ne_one
-----------
l1: $ ¬ 0 = suc 0 $ by zero_ne_suc

suc_cancel
----------
-- peano2 twice.
l1: $ suc (suc a) = suc (suc b) → suc a = suc b $ by peano2
l2: $ suc a = suc b $ by ax_mp [l1, #1]
l3: $ suc a = suc b → a = b $ by peano2
l4: $ a = b $ by ax_mp [l3, l2]

gen_refl
--------
-- eq_refl at x, then generalise over x.
l1: $ x = x $ by eq_refl
l2: $ ∀ x (x = x) $ by ax_gen [l1]

alim
----
-- ax_4, then two ax_mp's pull the quantifier goals through.
l1: $ ∀ x (p → q) → ∀ x p → ∀ x q $ by ax_4
l2: $ ∀ x p → ∀ x q $ by ax_mp [l1, #1]
l3: $ ∀ x q $ by ax_mp [l2, #2]

gen_mono
--------
-- Lift #1 under the quantifier, then use alim-style dispatch.
l1: $ ∀ x (p → q) $ by ax_gen [#1]
l2: $ ∀ x (p → q) → ∀ x p → ∀ x q $ by ax_4
l3: $ ∀ x p → ∀ x q $ by ax_mp [l2, l1]

peano1_all
----------
-- peano1 already has no visible use-site of x beyond `suc x`, so
-- ax_gen directly universally-closes it.
l1: $ ¬ suc x = 0 $ by peano1
l2: $ ∀ x ¬ suc x = 0 $ by ax_gen [l1]

inst_refl
---------
-- sb_f (suc 0) x (x = x)  normalises via sb_f_eq + sb_t_var to
-- (suc 0 = suc 0), so conclusion normalization accepts the plain claim.
l1: $ suc 0 = suc 0 $ by ax_inst [#1]

inst_suc_suc
------------
-- Normalisation pushes sb_f through = and then sb_t through suc,
-- landing on (suc (suc 0) = suc (suc 0)).
l1: $ suc (suc 0) = suc (suc 0) $ by ax_inst [#1]

zero_ne_one_def
---------------
-- Reuse the pre-existing zero_ne_one theorem; the goal `0 ≠ suc 0`
-- is accepted because `≠` unfolds to `¬ 0 = suc 0` automatically.
l1: $ 0 ≠ suc 0 $ by zero_ne_one

ne_implies_neq
--------------
-- Hypothesis `#1: a ≠ b` is unfolded to `¬ a = b` when matched
-- against what `id` returns.
l1: $ a ≠ b → a ≠ b $ by id
l2: $ ¬ a = b $ by ax_mp [l1, #1]

ne_suc_self_all
---------------
-- Base:  ¬ 0 = suc 0  (zero_ne_suc at a := 0).
l1: $ ¬ 0 = suc 0 $ by zero_ne_suc
-- Step: suc x = suc (suc x) → x = suc x  (peano2).
l2: $ suc x = suc (suc x) → x = suc x $ by peano2
-- Contrapose to lift inequality one successor up.
l3: $ (suc x = suc (suc x) → x = suc x) → ¬ x = suc x → ¬ suc x = suc (suc x) $ by con3
l4: $ ¬ x = suc x → ¬ suc x = suc (suc x) $ by ax_mp [l3, l2]
l5: $ ∀ x (¬ x = suc x → ¬ suc x = suc (suc x)) $ by ax_gen [l4]
-- peano5 closes induction; sb_f_ne lets hypothesis normalization cross the ≠ def.
l6: $ ∀ x ¬ x = suc x $ by peano5 [l1, l5]

add_0_left
----------
-- Base: 0 + 0 = 0  (add_0 at 0).
l1: $ 0 + 0 = 0 $ by add_0
-- Step body: 0 + x = x  →  0 + suc x = suc x.
-- add_suc gives 0 + suc x = suc (0 + x).
l2: $ 0 + suc x = suc (0 + x) $ by add_suc
-- Use eq_trans to chain a = b and b = c.
l3: $ 0 + suc x = suc (0 + x) → suc (0 + x) = suc x → 0 + suc x = suc x $ by eq_trans
l4: $ suc (0 + x) = suc x → 0 + suc x = suc x $ by ax_mp [l3, l2]
-- peano2r lifts 0 + x = x into suc (0 + x) = suc x.
l5: $ 0 + x = x → suc (0 + x) = suc x $ by peano2r
-- Compose: 0 + x = x → 0 + suc x = suc x.
l6: $ 0 + x = x → 0 + suc x = suc x $ by syl [l4, l5]
-- Generalise the step over x.
l7: $ ∀ x (0 + x = x → 0 + suc x = suc x) $ by ax_gen [l6]
-- peano5 closes the induction; hypothesis normalization matches l1/l7
-- against sb_f 0 x (0 + x = x) and ∀ x ((0 + x = x) → sb_f (suc x) x (0 + x = x)).
l8: $ ∀ x (0 + x = x) $ by peano5 [l1, l7]

add_suc_left
------------
-- Base:  suc a + 0 = suc (a + 0).  Chain add_0 at (suc a) and at a.
l1: $ suc a + 0 = suc a $ by add_0
l2: $ a + 0 = a $ by add_0
l3: $ a + 0 = a → suc (a + 0) = suc a $ by peano2r
l4: $ suc (a + 0) = suc a $ by ax_mp [l3, l2]
l5: $ suc (a + 0) = suc a → suc a = suc (a + 0) $ by eq_sym
l6: $ suc a = suc (a + 0) $ by ax_mp [l5, l4]
l7: $ suc a + 0 = suc a → suc a = suc (a + 0) → suc a + 0 = suc (a + 0) $ by eq_trans
l8: $ suc a = suc (a + 0) → suc a + 0 = suc (a + 0) $ by ax_mp [l7, l1]
l9: $ suc a + 0 = suc (a + 0) $ by ax_mp [l8, l6]

-- Step body:  h: suc a + x = suc (a + x)  implies  suc a + suc x = suc (a + suc x).
-- Rename: A := suc a + suc x, B := suc (suc a + x), C := suc (suc (a + x)), D := suc (a + suc x).
-- add_suc at (suc a, x) gives A = B; l11 with peano2r gives C = D; l12 with peano2r
-- lifts h into B = C.
l10: $ suc a + suc x = suc (suc a + x) $ by add_suc
l11: $ a + suc x = suc (a + x) $ by add_suc
l12: $ suc a + x = suc (a + x) → suc (suc a + x) = suc (suc (a + x)) $ by peano2r
-- h → A = C:  eq_trans at (A, B, C), then syl h through B = C.
l13: $ suc a + suc x = suc (suc a + x) → suc (suc a + x) = suc (suc (a + x)) → suc a + suc x = suc (suc (a + x)) $ by eq_trans
l14: $ suc (suc a + x) = suc (suc (a + x)) → suc a + suc x = suc (suc (a + x)) $ by ax_mp [l13, l10]
l15: $ suc a + x = suc (a + x) → suc a + suc x = suc (suc (a + x)) $ by syl [l14, l12]
-- C = D:  flip l11 and lift with peano2r.
l16: $ a + suc x = suc (a + x) → suc (a + x) = a + suc x $ by eq_sym
l17: $ suc (a + x) = a + suc x $ by ax_mp [l16, l11]
l18: $ suc (a + x) = a + suc x → suc (suc (a + x)) = suc (a + suc x) $ by peano2r
l19: $ suc (suc (a + x)) = suc (a + suc x) $ by ax_mp [l18, l17]
-- (A = C) → (A = D):  eq_trans at (A, C, D), then ax_mp the C = D piece.
l20: $ suc a + suc x = suc (suc (a + x)) → suc (suc (a + x)) = suc (a + suc x) → suc a + suc x = suc (a + suc x) $ by eq_trans
l21: $ suc a + suc x = suc (suc (a + x)) → suc a + suc x = suc (a + suc x) $ by mpi [l19, l20]
-- Compose h → A = C with (A = C) → (A = D):  h → A = D.
l22: $ suc a + x = suc (a + x) → suc a + suc x = suc (a + suc x) $ by syl [l21, l15]
l23: $ ∀ x (suc a + x = suc (a + x) → suc a + suc x = suc (a + suc x)) $ by ax_gen [l22]
l24: $ ∀ x (suc a + x = suc (a + x)) $ by peano5 [l9, l23]

one_zero_eq
-----------
-- ax_inst at t := suc 0, p := (0 + x = x).  Normalisation gives
-- sb_f (suc 0) x (0 + x = x) → 0 + suc 0 = suc 0.
l1: $ 0 + suc 0 = suc 0 $ by ax_inst [#1]

add_0_left_inst
---------------
-- Specialise add_0_left at t := a.  conclusion normalization on ax_inst pushes
-- sb_f through = and sb_t via sb_t_zer / sb_t_var / sb_t_irrel to
-- land on (0 + a = a).
l1: $ ∀ x (0 + x = x) $ by add_0_left
l2: $ 0 + a = a $ by ax_inst [l1]

add_suc_left_inst
-----------------
-- Specialise add_suc_left at t := b with outer a := a.
l1: $ ∀ x (suc a + x = suc (a + x)) $ by add_suc_left
l2: $ suc a + b = suc (a + b) $ by ax_inst [l1]

add_suc_swap
------------
-- suc a + b = a + suc b.  add_suc_left_inst gives suc a + b = suc (a + b);
-- add_suc gives a + suc b = suc (a + b); flip the latter with eq_sym and
-- chain via eq_trans.
l1: $ suc a + b = suc (a + b) $ by add_suc_left_inst
l2: $ a + suc b = suc (a + b) $ by add_suc
l3: $ a + suc b = suc (a + b) → suc (a + b) = a + suc b $ by eq_sym
l4: $ suc (a + b) = a + suc b $ by ax_mp [l3, l2]
l5: $ suc a + b = suc (a + b) → suc (a + b) = a + suc b → suc a + b = a + suc b $ by eq_trans
l6: $ suc (a + b) = a + suc b → suc a + b = a + suc b $ by ax_mp [l5, l1]
l7: $ suc a + b = a + suc b $ by ax_mp [l6, l4]

add_comm
--------
-- Induction on the right argument x of (a + x = x + a).
-- Base:  a + 0 = 0 + a.  Chain add_0 and add_0_left_inst via eq_sym + eq_trans.
l1: $ a + 0 = a $ by add_0
l2: $ 0 + a = a $ by add_0_left_inst
l3: $ 0 + a = a → a = 0 + a $ by eq_sym
l4: $ a = 0 + a $ by ax_mp [l3, l2]
l5: $ a + 0 = a → a = 0 + a → a + 0 = 0 + a $ by eq_trans
l6: $ a = 0 + a → a + 0 = 0 + a $ by ax_mp [l5, l1]
l7: $ a + 0 = 0 + a $ by ax_mp [l6, l4]

-- Step body:  h: a + x = x + a  implies  a + suc x = suc x + a.
-- Let A := a + suc x, B := suc (a + x), C := suc (x + a), D := suc x + a.
-- add_suc at (a, x)          gives A = B.
-- peano2r h                  gives B = C.
-- add_suc_left_inst at (x,a) gives D = C; eq_sym gives C = D.
-- Chain eq_trans twice:  A = B, B = C  ⇒  A = C;  A = C, C = D  ⇒  A = D.
l8: $ a + suc x = suc (a + x) $ by add_suc
l9: $ a + x = x + a → suc (a + x) = suc (x + a) $ by peano2r
l10: $ suc x + a = suc (x + a) $ by add_suc_left_inst
l11: $ suc x + a = suc (x + a) → suc (x + a) = suc x + a $ by eq_sym
l12: $ suc (x + a) = suc x + a $ by ax_mp [l11, l10]
-- A = B, B = C  ⇒  A = C.
l13: $ a + suc x = suc (a + x) → suc (a + x) = suc (x + a) → a + suc x = suc (x + a) $ by eq_trans
l14: $ suc (a + x) = suc (x + a) → a + suc x = suc (x + a) $ by ax_mp [l13, l8]
l15: $ a + x = x + a → a + suc x = suc (x + a) $ by syl [l14, l9]
-- A = C, C = D  ⇒  A = D.
l16: $ a + suc x = suc (x + a) → suc (x + a) = suc x + a → a + suc x = suc x + a $ by eq_trans
l17: $ a + suc x = suc (x + a) → a + suc x = suc x + a $ by mpi [l12, l16]
l18: $ a + x = x + a → a + suc x = suc x + a $ by syl [l17, l15]
-- Generalise and close with peano5.
l19: $ ∀ x (a + x = x + a → a + suc x = suc x + a) $ by ax_gen [l18]
l20: $ ∀ x (a + x = x + a) $ by peano5 [l7, l19]

add_comm_inst
-------------
-- Specialise add_comm at x := b.
l1: $ ∀ x (a + x = x + a) $ by add_comm
l2: $ a + b = b + a $ by ax_inst [l1]

add_eq_left_all
---------------
-- Induction on x of (a = b → x + a = x + b).
-- Base: a = b → 0 + a = 0 + b.  Use add_0_left_inst on both sides
-- and chain via eq_sym + eq_trans.
l1: $ 0 + a = a $ by add_0_left_inst
l2: $ 0 + b = b $ by add_0_left_inst
l3: $ 0 + b = b → b = 0 + b $ by eq_sym
l4: $ b = 0 + b $ by ax_mp [l3, l2]
l5: $ 0 + a = a → a = b → 0 + a = b $ by eq_trans
l6: $ a = b → 0 + a = b $ by ax_mp [l5, l1]
l7: $ 0 + a = b → b = 0 + b → 0 + a = 0 + b $ by eq_trans
l8: $ 0 + a = b → 0 + a = 0 + b $ by mpi [l4, l7]
l9: $ a = b → 0 + a = 0 + b $ by syl [l8, l6]

-- Step: prove (x + a = x + b → suc x + a = suc x + b), then lift via imim2i.
l10: $ suc x + a = suc (x + a) $ by add_suc_left_inst
l11: $ suc x + b = suc (x + b) $ by add_suc_left_inst
l12: $ x + a = x + b → suc (x + a) = suc (x + b) $ by peano2r
l13: $ suc x + a = suc (x + a) → suc (x + a) = suc (x + b) → suc x + a = suc (x + b) $ by eq_trans
l14: $ suc (x + a) = suc (x + b) → suc x + a = suc (x + b) $ by ax_mp [l13, l10]
l15: $ x + a = x + b → suc x + a = suc (x + b) $ by syl [l14, l12]
l16: $ suc x + b = suc (x + b) → suc (x + b) = suc x + b $ by eq_sym
l17: $ suc (x + b) = suc x + b $ by ax_mp [l16, l11]
l18: $ suc x + a = suc (x + b) → suc (x + b) = suc x + b → suc x + a = suc x + b $ by eq_trans
l19: $ suc x + a = suc (x + b) → suc x + a = suc x + b $ by mpi [l17, l18]
l20: $ x + a = x + b → suc x + a = suc x + b $ by syl [l19, l15]
-- Lift through (a = b → _).
l21: $ (a = b → x + a = x + b) → (a = b → suc x + a = suc x + b) $ by imim2i [l20]
l22: $ ∀ x ((a = b → x + a = x + b) → (a = b → suc x + a = suc x + b)) $ by ax_gen [l21]
l23: $ ∀ x (a = b → x + a = x + b) $ by peano5 [l9, l22]

add_eq_left
-----------
-- Specialise add_eq_left_all at t := c.
l1: $ ∀ x (a = b → x + a = x + b) $ by add_eq_left_all
l2: $ a = b → c + a = c + b $ by ax_inst [l1]

add_eq_right_all
----------------
-- Induction on x of (a = b → a + x = b + x), mirror of add_eq_left_all
-- but stepping the right argument.
-- Base: a = b → a + 0 = b + 0.  Chain add_0 on both sides via eq_sym + eq_trans.
l1: $ a + 0 = a $ by add_0
l2: $ b + 0 = b $ by add_0
l3: $ b + 0 = b → b = b + 0 $ by eq_sym
l4: $ b = b + 0 $ by ax_mp [l3, l2]
l5: $ a + 0 = a → a = b → a + 0 = b $ by eq_trans
l6: $ a = b → a + 0 = b $ by ax_mp [l5, l1]
l7: $ a + 0 = b → b = b + 0 → a + 0 = b + 0 $ by eq_trans
l8: $ a + 0 = b → a + 0 = b + 0 $ by mpi [l4, l7]
l9: $ a = b → a + 0 = b + 0 $ by syl [l8, l6]

-- Step: prove (a + x = b + x → a + suc x = b + suc x), then lift via imim2i.
-- add_suc on both sides, peano2r to carry the IH through suc.
l10: $ a + suc x = suc (a + x) $ by add_suc
l11: $ b + suc x = suc (b + x) $ by add_suc
l12: $ a + x = b + x → suc (a + x) = suc (b + x) $ by peano2r
l13: $ a + suc x = suc (a + x) → suc (a + x) = suc (b + x) → a + suc x = suc (b + x) $ by eq_trans
l14: $ suc (a + x) = suc (b + x) → a + suc x = suc (b + x) $ by ax_mp [l13, l10]
l15: $ a + x = b + x → a + suc x = suc (b + x) $ by syl [l14, l12]
l16: $ b + suc x = suc (b + x) → suc (b + x) = b + suc x $ by eq_sym
l17: $ suc (b + x) = b + suc x $ by ax_mp [l16, l11]
l18: $ a + suc x = suc (b + x) → suc (b + x) = b + suc x → a + suc x = b + suc x $ by eq_trans
l19: $ a + suc x = suc (b + x) → a + suc x = b + suc x $ by mpi [l17, l18]
l20: $ a + x = b + x → a + suc x = b + suc x $ by syl [l19, l15]
-- Lift through (a = b → _).
l21: $ (a = b → a + x = b + x) → (a = b → a + suc x = b + suc x) $ by imim2i [l20]
l22: $ ∀ x ((a = b → a + x = b + x) → (a = b → a + suc x = b + suc x)) $ by ax_gen [l21]
l23: $ ∀ x (a = b → a + x = b + x) $ by peano5 [l9, l22]

add_eq_right
------------
-- Specialise add_eq_right_all at t := c.
l1: $ ∀ x (a = b → a + x = b + x) $ by add_eq_right_all
l2: $ a = b → a + c = b + c $ by ax_inst [l1]

add_cancel_right_all
--------------------
-- Induction on x of (a + x = b + x → a = b).  Base uses add_0
-- reflecting a + 0 back to a; the step peels a suc off both sides
-- with add_suc and peano2, then lifts into the IH via imim1i.
--
-- Base: a + 0 = b + 0 → a = b.  Chain a = a + 0 (eq_sym on add_0),
-- then a + 0 = b + 0 (h), then b + 0 = b (add_0).
l1: $ a + 0 = a $ by add_0
l2: $ b + 0 = b $ by add_0
l3: $ a + 0 = a → a = a + 0 $ by eq_sym
l4: $ a = a + 0 $ by ax_mp [l3, l1]
l5: $ a = a + 0 → a + 0 = b + 0 → a = b + 0 $ by eq_trans
l6: $ a + 0 = b + 0 → a = b + 0 $ by ax_mp [l5, l4]
l7: $ a = b + 0 → b + 0 = b → a = b $ by eq_trans
l8: $ a = b + 0 → a = b $ by mpi [l2, l7]
l9: $ a + 0 = b + 0 → a = b $ by syl [l8, l6]

-- Step: build l20 := (a + suc x = b + suc x → a + x = b + x),
-- then imim1i lifts (a + x = b + x → a = b) to
-- (a + suc x = b + suc x → a = b).
l10: $ a + suc x = suc (a + x) $ by add_suc
l11: $ b + suc x = suc (b + x) $ by add_suc
-- Flip l10: suc (a + x) = a + suc x.
l12: $ a + suc x = suc (a + x) → suc (a + x) = a + suc x $ by eq_sym
l13: $ suc (a + x) = a + suc x $ by ax_mp [l12, l10]
-- Chain suc (a + x) = a + suc x with h: a + suc x = b + suc x.
l14: $ suc (a + x) = a + suc x → a + suc x = b + suc x → suc (a + x) = b + suc x $ by eq_trans
l15: $ a + suc x = b + suc x → suc (a + x) = b + suc x $ by ax_mp [l14, l13]
-- Then chain with l11: b + suc x = suc (b + x) to land on suc (a+x) = suc (b+x).
l16: $ suc (a + x) = b + suc x → b + suc x = suc (b + x) → suc (a + x) = suc (b + x) $ by eq_trans
l17: $ suc (a + x) = b + suc x → suc (a + x) = suc (b + x) $ by mpi [l11, l16]
l18: $ a + suc x = b + suc x → suc (a + x) = suc (b + x) $ by syl [l17, l15]
-- peano2 peels the outer suc off.
l19: $ suc (a + x) = suc (b + x) → a + x = b + x $ by peano2
l20: $ a + suc x = b + suc x → a + x = b + x $ by syl [l19, l18]
-- imim1i composes with the IH shape.
l21: $ (a + x = b + x → a = b) → (a + suc x = b + suc x → a = b) $ by imim1i [l20]
l22: $ ∀ x ((a + x = b + x → a = b) → (a + suc x = b + suc x → a = b)) $ by ax_gen [l21]
l23: $ ∀ x (a + x = b + x → a = b) $ by peano5 [l9, l22]

add_cancel_right
----------------
-- Specialise add_cancel_right_all at t := c.
l1: $ ∀ x (a + x = b + x → a = b) $ by add_cancel_right_all
l2: $ a + c = b + c → a = b $ by ax_inst [l1]

add_cancel_left
---------------
-- Rewrite a + b = a + c into b + a = c + a via add_comm_inst on
-- both sides, then dispatch to add_cancel_right.
l1: $ a + b = b + a $ by add_comm_inst
l2: $ a + b = b + a → b + a = a + b $ by eq_sym
l3: $ b + a = a + b $ by ax_mp [l2, l1]
l4: $ a + c = c + a $ by add_comm_inst
l5: $ b + a = a + b → a + b = a + c → b + a = a + c $ by eq_trans
l6: $ a + b = a + c → b + a = a + c $ by ax_mp [l5, l3]
l7: $ b + a = a + c → a + c = c + a → b + a = c + a $ by eq_trans
l8: $ b + a = a + c → b + a = c + a $ by mpi [l4, l7]
l9: $ a + b = a + c → b + a = c + a $ by syl [l8, l6]
l10: $ b + a = c + a → b = c $ by add_cancel_right
l11: $ a + b = a + c → b = c $ by syl [l10, l9]

add_assoc
---------
-- Induction on x of (a + (b + x) = (a + b) + x).
-- Base: a + (b + 0) = (a + b) + 0.
-- (b + 0) = b lifted through `a + _` gives a + (b + 0) = a + b.
l1: $ b + 0 = b $ by add_0
l2: $ b + 0 = b → a + (b + 0) = a + b $ by add_eq_left
l3: $ a + (b + 0) = a + b $ by ax_mp [l2, l1]
l4: $ (a + b) + 0 = a + b $ by add_0
l5: $ (a + b) + 0 = a + b → a + b = (a + b) + 0 $ by eq_sym
l6: $ a + b = (a + b) + 0 $ by ax_mp [l5, l4]
l7: $ a + (b + 0) = a + b → a + b = (a + b) + 0 → a + (b + 0) = (a + b) + 0 $ by eq_trans
l8: $ a + b = (a + b) + 0 → a + (b + 0) = (a + b) + 0 $ by ax_mp [l7, l3]
l9: $ a + (b + 0) = (a + b) + 0 $ by ax_mp [l8, l6]

-- Step: prove (a + (b + x) = (a + b) + x) → (a + (b + suc x) = (a + b) + suc x).
-- Chain:  a + (b + suc x) = a + suc (b + x)        via add_eq_left + add_suc
--      = suc (a + (b + x))                          via add_suc
--      = suc ((a + b) + x)                          via peano2r on the IH
--      = (a + b) + suc x                            via eq_sym on add_suc.
l10: $ b + suc x = suc (b + x) $ by add_suc
l11: $ b + suc x = suc (b + x) → a + (b + suc x) = a + suc (b + x) $ by add_eq_left
l12: $ a + (b + suc x) = a + suc (b + x) $ by ax_mp [l11, l10]
l13: $ a + suc (b + x) = suc (a + (b + x)) $ by add_suc
l14: $ a + (b + suc x) = a + suc (b + x) → a + suc (b + x) = suc (a + (b + x)) → a + (b + suc x) = suc (a + (b + x)) $ by eq_trans
l15: $ a + suc (b + x) = suc (a + (b + x)) → a + (b + suc x) = suc (a + (b + x)) $ by ax_mp [l14, l12]
l16: $ a + (b + suc x) = suc (a + (b + x)) $ by ax_mp [l15, l13]
-- Lift the IH through suc.
l17: $ a + (b + x) = (a + b) + x → suc (a + (b + x)) = suc ((a + b) + x) $ by peano2r
-- (a + b) + suc x = suc ((a + b) + x), reversed for chaining.
l18: $ (a + b) + suc x = suc ((a + b) + x) $ by add_suc
l19: $ (a + b) + suc x = suc ((a + b) + x) → suc ((a + b) + x) = (a + b) + suc x $ by eq_sym
l20: $ suc ((a + b) + x) = (a + b) + suc x $ by ax_mp [l19, l18]
-- (a + (b + suc x) = suc (a + (b + x))) ∘ (suc(...) = suc((a+b)+x))  ⇒  a + (b + suc x) = suc ((a+b) + x).
l21: $ a + (b + suc x) = suc (a + (b + x)) → suc (a + (b + x)) = suc ((a + b) + x) → a + (b + suc x) = suc ((a + b) + x) $ by eq_trans
l22: $ suc (a + (b + x)) = suc ((a + b) + x) → a + (b + suc x) = suc ((a + b) + x) $ by ax_mp [l21, l16]
l23: $ a + (b + x) = (a + b) + x → a + (b + suc x) = suc ((a + b) + x) $ by syl [l22, l17]
-- Then chain to (a + b) + suc x via l20.
l24: $ a + (b + suc x) = suc ((a + b) + x) → suc ((a + b) + x) = (a + b) + suc x → a + (b + suc x) = (a + b) + suc x $ by eq_trans
l25: $ a + (b + suc x) = suc ((a + b) + x) → a + (b + suc x) = (a + b) + suc x $ by mpi [l20, l24]
l26: $ a + (b + x) = (a + b) + x → a + (b + suc x) = (a + b) + suc x $ by syl [l25, l23]
l27: $ ∀ x (a + (b + x) = (a + b) + x → a + (b + suc x) = (a + b) + suc x) $ by ax_gen [l26]
l28: $ ∀ x (a + (b + x) = (a + b) + x) $ by peano5 [l9, l27]

add_assoc_inst
--------------
-- Specialise add_assoc at x := c.
l1: $ ∀ x (a + (b + x) = (a + b) + x) $ by add_assoc
l2: $ a + (b + c) = (a + b) + c $ by ax_inst [l1]

add_lass
--------
-- a + (b + c)  =  (a + b) + c   (add_assoc_inst)
--             =  (b + a) + c    (add_eq_right of add_comm_inst)
--             =  b + (a + c)    (eq_sym on add_assoc_inst)
l1: $ a + (b + c) = (a + b) + c $ by add_assoc_inst
l2: $ a + b = b + a $ by add_comm_inst
l3: $ a + b = b + a → (a + b) + c = (b + a) + c $ by add_eq_right
l4: $ (a + b) + c = (b + a) + c $ by ax_mp [l3, l2]
l5: $ b + (a + c) = (b + a) + c $ by add_assoc_inst
l6: $ b + (a + c) = (b + a) + c → (b + a) + c = b + (a + c) $ by eq_sym
l7: $ (b + a) + c = b + (a + c) $ by ax_mp [l6, l5]
l8: $ a + (b + c) = (a + b) + c → (a + b) + c = (b + a) + c → a + (b + c) = (b + a) + c $ by eq_trans
l9: $ (a + b) + c = (b + a) + c → a + (b + c) = (b + a) + c $ by ax_mp [l8, l1]
l10: $ a + (b + c) = (b + a) + c $ by ax_mp [l9, l4]
l11: $ a + (b + c) = (b + a) + c → (b + a) + c = b + (a + c) → a + (b + c) = b + (a + c) $ by eq_trans
l12: $ (b + a) + c = b + (a + c) → a + (b + c) = b + (a + c) $ by ax_mp [l11, l10]
l13: $ a + (b + c) = b + (a + c) $ by ax_mp [l12, l7]

add_rass
--------
-- (a + b) + c  =  a + (b + c)   (eq_sym on add_assoc_inst)
--              =  a + (c + b)   (add_eq_left of add_comm_inst)
--              =  (a + c) + b   (add_assoc_inst)
l1: $ a + (b + c) = (a + b) + c $ by add_assoc_inst
l2: $ a + (b + c) = (a + b) + c → (a + b) + c = a + (b + c) $ by eq_sym
l3: $ (a + b) + c = a + (b + c) $ by ax_mp [l2, l1]
l4: $ b + c = c + b $ by add_comm_inst
l5: $ b + c = c + b → a + (b + c) = a + (c + b) $ by add_eq_left
l6: $ a + (b + c) = a + (c + b) $ by ax_mp [l5, l4]
l7: $ a + (c + b) = (a + c) + b $ by add_assoc_inst
l8: $ (a + b) + c = a + (b + c) → a + (b + c) = a + (c + b) → (a + b) + c = a + (c + b) $ by eq_trans
l9: $ a + (b + c) = a + (c + b) → (a + b) + c = a + (c + b) $ by ax_mp [l8, l3]
l10: $ (a + b) + c = a + (c + b) $ by ax_mp [l9, l6]
l11: $ (a + b) + c = a + (c + b) → a + (c + b) = (a + c) + b → (a + b) + c = (a + c) + b $ by eq_trans
l12: $ a + (c + b) = (a + c) + b → (a + b) + c = (a + c) + b $ by ax_mp [l11, l10]
l13: $ (a + b) + c = (a + c) + b $ by ax_mp [l12, l7]

two_plus_two
------------
-- Concrete numeric check:  2 + 2 = 4, where 2 := suc (suc 0) and
-- 4 := suc (suc (suc (suc 0))).  The proof is pure unfolding with
-- add_suc twice, add_0 once, and peano2r to lift through suc.
--
-- Step-by-step:
--   2 + 2 = suc (2 + 1)         by add_suc at (2, 1)
--   2 + 1 = suc (2 + 0)         by add_suc at (2, 0)
--   2 + 0 = 2                   by add_0 at 2
--   ⇒ suc (2 + 0) = suc 2       by peano2r
--   ⇒ 2 + 1 = suc 2             by eq_trans
--   ⇒ suc (2 + 1) = suc (suc 2) by peano2r
--   ⇒ 2 + 2 = suc (suc 2) = 4   by eq_trans.
l1: $ suc (suc 0) + suc (suc 0) = suc (suc (suc 0) + suc 0) $ by add_suc
l2: $ suc (suc 0) + suc 0 = suc (suc (suc 0) + 0) $ by add_suc
l3: $ suc (suc 0) + 0 = suc (suc 0) $ by add_0
-- Lift l3 through suc: suc (2 + 0) = suc 2.
l4: $ suc (suc 0) + 0 = suc (suc 0) → suc (suc (suc 0) + 0) = suc (suc (suc 0)) $ by peano2r
l5: $ suc (suc (suc 0) + 0) = suc (suc (suc 0)) $ by ax_mp [l4, l3]
-- Chain l2 and l5 to get 2 + 1 = suc 2.
l6: $ suc (suc 0) + suc 0 = suc (suc (suc 0) + 0) → suc (suc (suc 0) + 0) = suc (suc (suc 0)) → suc (suc 0) + suc 0 = suc (suc (suc 0)) $ by eq_trans
l7: $ suc (suc (suc 0) + 0) = suc (suc (suc 0)) → suc (suc 0) + suc 0 = suc (suc (suc 0)) $ by ax_mp [l6, l2]
l8: $ suc (suc 0) + suc 0 = suc (suc (suc 0)) $ by ax_mp [l7, l5]
-- Lift through suc: suc (2 + 1) = suc (suc 2).
l9: $ suc (suc 0) + suc 0 = suc (suc (suc 0)) → suc (suc (suc 0) + suc 0) = suc (suc (suc (suc 0))) $ by peano2r
l10: $ suc (suc (suc 0) + suc 0) = suc (suc (suc (suc 0))) $ by ax_mp [l9, l8]
-- Chain l1 and l10 to get 2 + 2 = 4.
l11: $ suc (suc 0) + suc (suc 0) = suc (suc (suc 0) + suc 0) → suc (suc (suc 0) + suc 0) = suc (suc (suc (suc 0))) → suc (suc 0) + suc (suc 0) = suc (suc (suc (suc 0))) $ by eq_trans
l12: $ suc (suc (suc 0) + suc 0) = suc (suc (suc (suc 0))) → suc (suc 0) + suc (suc 0) = suc (suc (suc (suc 0))) $ by ax_mp [l11, l1]
l13: $ suc (suc 0) + suc (suc 0) = suc (suc (suc (suc 0))) $ by ax_mp [l12, l10]

mul_0_left
----------
-- Induction on x of (0 * x = 0).  Base: mul_0 at 0.  Step collapses
-- 0 * suc x through mul_suc + add_0 back to 0 * x, then uses the IH.
l1: $ 0 * 0 = 0 $ by mul_0
l2: $ 0 * suc x = 0 * x + 0 $ by mul_suc
l3: $ 0 * x + 0 = 0 * x $ by add_0
l4: $ 0 * suc x = 0 * x + 0 → 0 * x + 0 = 0 * x → 0 * suc x = 0 * x $ by eq_trans
l5: $ 0 * x + 0 = 0 * x → 0 * suc x = 0 * x $ by ax_mp [l4, l2]
l6: $ 0 * suc x = 0 * x $ by ax_mp [l5, l3]
l7: $ 0 * suc x = 0 * x → 0 * x = 0 → 0 * suc x = 0 $ by eq_trans
l8: $ 0 * x = 0 → 0 * suc x = 0 $ by ax_mp [l7, l6]
l9: $ ∀ x (0 * x = 0 → 0 * suc x = 0) $ by ax_gen [l8]
l10: $ ∀ x (0 * x = 0) $ by peano5 [l1, l9]

mul_0_left_inst
---------------
-- Specialise mul_0_left at t := a.
l1: $ ∀ x (0 * x = 0) $ by mul_0_left
l2: $ 0 * a = 0 $ by ax_inst [l1]

mul_suc_left_all
----------------
-- Induction on x of (suc a * x = a * x + x).
-- Base: suc a * 0 = a * 0 + 0.  Both sides collapse to 0 via mul_0 and add_0.
l1: $ suc a * 0 = 0 $ by mul_0
l2: $ a * 0 = 0 $ by mul_0
l3: $ a * 0 = 0 → 0 = a * 0 $ by eq_sym
l4: $ 0 = a * 0 $ by ax_mp [l3, l2]
l5: $ a * 0 + 0 = a * 0 $ by add_0
l6: $ a * 0 + 0 = a * 0 → a * 0 = a * 0 + 0 $ by eq_sym
l7: $ a * 0 = a * 0 + 0 $ by ax_mp [l6, l5]
l8: $ suc a * 0 = a * 0 + 0 $ by eq_trans3 [l1, l4, l7]

-- Step body: (suc a * x = a * x + x) → (suc a * suc x = a * suc x + suc x).
-- Chain under IH:
--   suc a * suc x = suc a * x + suc a              (mul_suc)
--                = (a * x + x) + suc a             (IH via add_eq_right)
--                = (a * x + a) + suc x             (add_suc + add_rass + peano2r)
--                = a * suc x + suc x               (mul_suc via add_eq_right, reversed).

-- IH → (suc a * suc x = (a * x + x) + suc a).
l9: $ suc a * suc x = suc a * x + suc a $ by mul_suc
l10: $ suc a * x = a * x + x → suc a * x + suc a = (a * x + x) + suc a $ by add_eq_right
l11: $ suc a * suc x = suc a * x + suc a → suc a * x + suc a = (a * x + x) + suc a → suc a * suc x = (a * x + x) + suc a $ by eq_trans
l12: $ suc a * x + suc a = (a * x + x) + suc a → suc a * suc x = (a * x + x) + suc a $ by ax_mp [l11, l9]
l13: $ suc a * x = a * x + x → suc a * suc x = (a * x + x) + suc a $ by syl [l12, l10]

-- Pure bridge: (a * x + x) + suc a = (a * x + a) + suc x (no IH needed).
l14: $ (a * x + x) + suc a = suc ((a * x + x) + a) $ by add_suc
l15: $ (a * x + x) + a = (a * x + a) + x $ by add_rass
l16: $ (a * x + x) + a = (a * x + a) + x → suc ((a * x + x) + a) = suc ((a * x + a) + x) $ by peano2r
l17: $ suc ((a * x + x) + a) = suc ((a * x + a) + x) $ by ax_mp [l16, l15]
l18: $ (a * x + a) + suc x = suc ((a * x + a) + x) $ by add_suc
l19: $ (a * x + a) + suc x = suc ((a * x + a) + x) → suc ((a * x + a) + x) = (a * x + a) + suc x $ by eq_sym
l20: $ suc ((a * x + a) + x) = (a * x + a) + suc x $ by ax_mp [l19, l18]
l21: $ (a * x + x) + suc a = (a * x + a) + suc x $ by eq_trans3 [l14, l17, l20]

-- Pure bridge: (a * x + a) + suc x = a * suc x + suc x.
l22: $ a * suc x = a * x + a $ by mul_suc
l23: $ a * suc x = a * x + a → a * x + a = a * suc x $ by eq_sym
l24: $ a * x + a = a * suc x $ by ax_mp [l23, l22]
l25: $ a * x + a = a * suc x → (a * x + a) + suc x = a * suc x + suc x $ by add_eq_right
l26: $ (a * x + a) + suc x = a * suc x + suc x $ by ax_mp [l25, l24]

-- Combine l21 + l26 to get (a * x + x) + suc a = a * suc x + suc x.
l27: $ (a * x + x) + suc a = (a * x + a) + suc x → (a * x + a) + suc x = a * suc x + suc x → (a * x + x) + suc a = a * suc x + suc x $ by eq_trans
l28: $ (a * x + a) + suc x = a * suc x + suc x → (a * x + x) + suc a = a * suc x + suc x $ by ax_mp [l27, l21]
l29: $ (a * x + x) + suc a = a * suc x + suc x $ by ax_mp [l28, l26]

-- Compose l13 (IH → suc a * suc x = (a * x + x) + suc a) with l29 to close step.
l30: $ suc a * suc x = (a * x + x) + suc a → (a * x + x) + suc a = a * suc x + suc x → suc a * suc x = a * suc x + suc x $ by eq_trans
l31: $ suc a * x = a * x + x → ((a * x + x) + suc a = a * suc x + suc x → suc a * suc x = a * suc x + suc x) $ by syl [l30, l13]
l32: $ suc a * x = a * x + x → suc a * suc x = a * suc x + suc x $ by mpi [l29, l31]

l33: $ ∀ x (suc a * x = a * x + x → suc a * suc x = a * suc x + suc x) $ by ax_gen [l32]
l34: $ ∀ x (suc a * x = a * x + x) $ by peano5 [l8, l33]

mul_suc_left_inst
-----------------
-- Specialise mul_suc_left_all at t := b.
l1: $ ∀ x (suc a * x = a * x + x) $ by mul_suc_left_all
l2: $ suc a * b = a * b + b $ by ax_inst [l1]

mul_1_right
-----------
-- a * suc 0 = a * 0 + a (mul_suc) = 0 + a (add_eq_right on mul_0) = a (add_0_left_inst).
l1: $ a * suc 0 = a * 0 + a $ by mul_suc
l2: $ a * 0 = 0 $ by mul_0
l3: $ a * 0 = 0 → a * 0 + a = 0 + a $ by add_eq_right
l4: $ a * 0 + a = 0 + a $ by ax_mp [l3, l2]
l5: $ 0 + a = a $ by add_0_left_inst
l6: $ a * suc 0 = a $ by eq_trans3 [l1, l4, l5]

mul_1_left
----------
-- suc 0 * a = 0 * a + a (mul_suc_left_inst) = 0 + a (add_eq_right on mul_0_left_inst) = a.
l1: $ suc 0 * a = 0 * a + a $ by mul_suc_left_inst
l2: $ 0 * a = 0 $ by mul_0_left_inst
l3: $ 0 * a = 0 → 0 * a + a = 0 + a $ by add_eq_right
l4: $ 0 * a + a = 0 + a $ by ax_mp [l3, l2]
l5: $ 0 + a = a $ by add_0_left_inst
l6: $ suc 0 * a = a $ by eq_trans3 [l1, l4, l5]

mul_eq_left_all
---------------
-- Induction on x of (a = b → x * a = x * b).
-- Base: a = b → 0 * a = 0 * b.  mul_0_left_inst makes both sides 0.
l1: $ 0 * a = 0 $ by mul_0_left_inst
l2: $ 0 * b = 0 $ by mul_0_left_inst
l3: $ 0 * b = 0 → 0 = 0 * b $ by eq_sym
l4: $ 0 = 0 * b $ by ax_mp [l3, l2]
l5: $ 0 * a = 0 → 0 = 0 * b → 0 * a = 0 * b $ by eq_trans
l6: $ 0 = 0 * b → 0 * a = 0 * b $ by ax_mp [l5, l1]
l7: $ 0 * a = 0 * b $ by ax_mp [l6, l4]
l8: $ a = b → 0 * a = 0 * b $ by a1i [l7]

-- Step body: (a = b → x * a = x * b) → (a = b → suc x * a = suc x * b).
-- Route via the bridge U := (x * a + a = x * b + b); both sides suc_expand to U.

-- K = (x * a = x * b), H = (a = b).  K → x * a + a = x * b + a.
l9: $ x * a = x * b → x * a + a = x * b + a $ by add_eq_right
-- H → x * b + a = x * b + b.
l10: $ a = b → x * b + a = x * b + b $ by add_eq_left
-- eq_trans at (x * a + a, x * b + a, x * b + b).
l11: $ x * a + a = x * b + a → x * b + a = x * b + b → x * a + a = x * b + b $ by eq_trans
-- K → (x * b + a = x * b + b → x * a + a = x * b + b).
l12: $ x * a = x * b → x * b + a = x * b + b → x * a + a = x * b + b $ by syl [l11, l9]
-- K → (H → x * a + a = x * b + b) via syl5.
l13: $ x * a = x * b → a = b → x * a + a = x * b + b $ by syl5 [l10, l12]
-- com12: H → (K → U).
l14: $ a = b → x * a = x * b → x * a + a = x * b + b $ by com12 [l13]

-- U → V: x * a + a = x * b + b → suc x * a = suc x * b.
l15: $ suc x * a = x * a + a $ by mul_suc_left_inst
l16: $ suc x * b = x * b + b $ by mul_suc_left_inst
l17: $ suc x * b = x * b + b → x * b + b = suc x * b $ by eq_sym
l18: $ x * b + b = suc x * b $ by ax_mp [l17, l16]
l19: $ suc x * a = x * a + a → x * a + a = x * b + b → suc x * a = x * b + b $ by eq_trans
l20: $ x * a + a = x * b + b → suc x * a = x * b + b $ by ax_mp [l19, l15]
l21: $ suc x * a = x * b + b → x * b + b = suc x * b → suc x * a = suc x * b $ by eq_trans
l22: $ suc x * a = x * b + b → suc x * a = suc x * b $ by mpi [l18, l21]
l23: $ x * a + a = x * b + b → suc x * a = suc x * b $ by syl [l22, l20]

-- Lift U → V through (K → _) and (H → _) via imim2i twice.
l24: $ (x * a = x * b → x * a + a = x * b + b) → (x * a = x * b → suc x * a = suc x * b) $ by imim2i [l23]
l25: $ (a = b → x * a = x * b → x * a + a = x * b + b) → (a = b → x * a = x * b → suc x * a = suc x * b) $ by imim2i [l24]
l26: $ a = b → x * a = x * b → suc x * a = suc x * b $ by ax_mp [l25, l14]
-- a2i collapses (H → K → V) to (H → K) → (H → V).
l27: $ (a = b → x * a = x * b) → (a = b → suc x * a = suc x * b) $ by a2i [l26]

l28: $ ∀ x ((a = b → x * a = x * b) → (a = b → suc x * a = suc x * b)) $ by ax_gen [l27]
l29: $ ∀ x (a = b → x * a = x * b) $ by peano5 [l8, l28]

mul_eq_left
-----------
-- Specialise mul_eq_left_all at t := c.
l1: $ ∀ x (a = b → x * a = x * b) $ by mul_eq_left_all
l2: $ a = b → c * a = c * b $ by ax_inst [l1]

mul_eq_right_all
----------------
-- Induction on x of (a = b → a * x = b * x), mirror of mul_eq_left_all
-- but stepping the inner argument.
-- Base: a = b → a * 0 = b * 0.  Both sides collapse to 0 via mul_0.
l1: $ a * 0 = 0 $ by mul_0
l2: $ b * 0 = 0 $ by mul_0
l3: $ b * 0 = 0 → 0 = b * 0 $ by eq_sym
l4: $ 0 = b * 0 $ by ax_mp [l3, l2]
l5: $ a * 0 = 0 → 0 = b * 0 → a * 0 = b * 0 $ by eq_trans
l6: $ 0 = b * 0 → a * 0 = b * 0 $ by ax_mp [l5, l1]
l7: $ a * 0 = b * 0 $ by ax_mp [l6, l4]
l8: $ a = b → a * 0 = b * 0 $ by a1i [l7]

-- Step body: H = (a = b), K = (a * x = b * x); goal a * suc x = b * suc x.
-- Route via the bridge U := (a * x + a = b * x + b); both sides mul_suc to U.

-- K → a*x + a = b*x + a.
l9: $ a * x = b * x → a * x + a = b * x + a $ by add_eq_right
-- H → b*x + a = b*x + b.
l10: $ a = b → b * x + a = b * x + b $ by add_eq_left
-- eq_trans at (a*x + a, b*x + a, b*x + b).
l11: $ a * x + a = b * x + a → b * x + a = b * x + b → a * x + a = b * x + b $ by eq_trans
-- K → (b*x + a = b*x + b → a*x + a = b*x + b).
l12: $ a * x = b * x → b * x + a = b * x + b → a * x + a = b * x + b $ by syl [l11, l9]
-- K → (H → U) via syl5.
l13: $ a * x = b * x → a = b → a * x + a = b * x + b $ by syl5 [l10, l12]
-- com12: H → (K → U).
l14: $ a = b → a * x = b * x → a * x + a = b * x + b $ by com12 [l13]

-- U → V: a * x + a = b * x + b → a * suc x = b * suc x.
l15: $ a * suc x = a * x + a $ by mul_suc
l16: $ b * suc x = b * x + b $ by mul_suc
l17: $ b * suc x = b * x + b → b * x + b = b * suc x $ by eq_sym
l18: $ b * x + b = b * suc x $ by ax_mp [l17, l16]
l19: $ a * suc x = a * x + a → a * x + a = b * x + b → a * suc x = b * x + b $ by eq_trans
l20: $ a * x + a = b * x + b → a * suc x = b * x + b $ by ax_mp [l19, l15]
l21: $ a * suc x = b * x + b → b * x + b = b * suc x → a * suc x = b * suc x $ by eq_trans
l22: $ a * suc x = b * x + b → a * suc x = b * suc x $ by mpi [l18, l21]
l23: $ a * x + a = b * x + b → a * suc x = b * suc x $ by syl [l22, l20]

-- Lift U → V through (K → _) and (H → _) via imim2i twice.
l24: $ (a * x = b * x → a * x + a = b * x + b) → (a * x = b * x → a * suc x = b * suc x) $ by imim2i [l23]
l25: $ (a = b → a * x = b * x → a * x + a = b * x + b) → (a = b → a * x = b * x → a * suc x = b * suc x) $ by imim2i [l24]
l26: $ a = b → a * x = b * x → a * suc x = b * suc x $ by ax_mp [l25, l14]
-- a2i collapses (H → K → V) to (H → K) → (H → V).
l27: $ (a = b → a * x = b * x) → (a = b → a * suc x = b * suc x) $ by a2i [l26]

l28: $ ∀ x ((a = b → a * x = b * x) → (a = b → a * suc x = b * suc x)) $ by ax_gen [l27]
l29: $ ∀ x (a = b → a * x = b * x) $ by peano5 [l8, l28]

mul_eq_right
------------
-- Specialise mul_eq_right_all at t := c.
l1: $ ∀ x (a = b → a * x = b * x) $ by mul_eq_right_all
l2: $ a = b → a * c = b * c $ by ax_inst [l1]

mul_comm
--------
-- Induction on x of (a * x = x * a).
-- Base: a * 0 = 0 * a.  mul_0 + mul_0_left_inst make both 0.
l1: $ a * 0 = 0 $ by mul_0
l2: $ 0 * a = 0 $ by mul_0_left_inst
l3: $ 0 * a = 0 → 0 = 0 * a $ by eq_sym
l4: $ 0 = 0 * a $ by ax_mp [l3, l2]
l5: $ a * 0 = 0 → 0 = 0 * a → a * 0 = 0 * a $ by eq_trans
l6: $ 0 = 0 * a → a * 0 = 0 * a $ by ax_mp [l5, l1]
l7: $ a * 0 = 0 * a $ by ax_mp [l6, l4]

-- Step: a * x = x * a → a * suc x = suc x * a.
-- Chain: a * suc x = a * x + a = x * a + a = suc x * a via mul_suc,
--        IH + add_eq_right, and eq_sym of mul_suc_left_inst.
l8: $ a * suc x = a * x + a $ by mul_suc
l9: $ a * x = x * a → a * x + a = x * a + a $ by add_eq_right
l10: $ a * suc x = a * x + a → a * x + a = x * a + a → a * suc x = x * a + a $ by eq_trans
l11: $ a * x + a = x * a + a → a * suc x = x * a + a $ by ax_mp [l10, l8]
l12: $ a * x = x * a → a * suc x = x * a + a $ by syl [l11, l9]
l13: $ suc x * a = x * a + a $ by mul_suc_left_inst
l14: $ suc x * a = x * a + a → x * a + a = suc x * a $ by eq_sym
l15: $ x * a + a = suc x * a $ by ax_mp [l14, l13]
l16: $ a * suc x = x * a + a → x * a + a = suc x * a → a * suc x = suc x * a $ by eq_trans
l17: $ a * x = x * a → (x * a + a = suc x * a → a * suc x = suc x * a) $ by syl [l16, l12]
l18: $ a * x = x * a → a * suc x = suc x * a $ by mpi [l15, l17]

l19: $ ∀ x (a * x = x * a → a * suc x = suc x * a) $ by ax_gen [l18]
l20: $ ∀ x (a * x = x * a) $ by peano5 [l7, l19]

mul_comm_inst
-------------
-- Specialise mul_comm at t := b.
l1: $ ∀ x (a * x = x * a) $ by mul_comm
l2: $ a * b = b * a $ by ax_inst [l1]

mul_distrib_left_all
--------------------
-- Induction on x of (a * (b + x) = a * b + a * x).
-- Base: a * (b + 0) = a * b + a * 0.  Both sides collapse to a * b.
--   a * (b + 0) = a * b (mul_eq_left on add_0),
--   a * b = a * b + 0 (eq_sym add_0),
--   a * b + 0 = a * b + a * 0 (add_eq_left on eq_sym mul_0).
l1: $ b + 0 = b $ by add_0
l2: $ b + 0 = b → a * (b + 0) = a * b $ by mul_eq_left
l3: $ a * (b + 0) = a * b $ by ax_mp [l2, l1]
l4: $ a * b + 0 = a * b $ by add_0
l5: $ a * b + 0 = a * b → a * b = a * b + 0 $ by eq_sym
l6: $ a * b = a * b + 0 $ by ax_mp [l5, l4]
l7: $ a * 0 = 0 $ by mul_0
l8: $ a * 0 = 0 → 0 = a * 0 $ by eq_sym
l9: $ 0 = a * 0 $ by ax_mp [l8, l7]
l10: $ 0 = a * 0 → a * b + 0 = a * b + a * 0 $ by add_eq_left
l11: $ a * b + 0 = a * b + a * 0 $ by ax_mp [l10, l9]
l12: $ a * (b + 0) = a * b + a * 0 $ by eq_trans3 [l3, l6, l11]

-- Step body: (a * (b + x) = a * b + a * x) → (a * (b + suc x) = a * b + a * suc x).
-- Let A := a * (b + suc x), B := a * suc (b + x), C := a * (b + x) + a,
--     D := (a * b + a * x) + a, E := a * b + (a * x + a), F := a * b + a * suc x.
-- A = B (mul_eq_left on add_suc); B = C (mul_suc); C = D (IH via add_eq_right);
-- D = E (eq_sym add_assoc_inst); E = F (add_eq_left on eq_sym mul_suc).

l13: $ b + suc x = suc (b + x) $ by add_suc
l14: $ b + suc x = suc (b + x) → a * (b + suc x) = a * suc (b + x) $ by mul_eq_left
l15: $ a * (b + suc x) = a * suc (b + x) $ by ax_mp [l14, l13]
l16: $ a * suc (b + x) = a * (b + x) + a $ by mul_suc
l17: $ a * (b + suc x) = a * suc (b + x) → a * suc (b + x) = a * (b + x) + a → a * (b + suc x) = a * (b + x) + a $ by eq_trans
l18: $ a * suc (b + x) = a * (b + x) + a → a * (b + suc x) = a * (b + x) + a $ by ax_mp [l17, l15]
l19: $ a * (b + suc x) = a * (b + x) + a $ by ax_mp [l18, l16]

-- IH → (C = D).
l20: $ a * (b + x) = a * b + a * x → a * (b + x) + a = (a * b + a * x) + a $ by add_eq_right

-- IH → (A = D).
l21: $ a * (b + suc x) = a * (b + x) + a → a * (b + x) + a = (a * b + a * x) + a → a * (b + suc x) = (a * b + a * x) + a $ by eq_trans
l22: $ a * (b + x) + a = (a * b + a * x) + a → a * (b + suc x) = (a * b + a * x) + a $ by ax_mp [l21, l19]
l23: $ a * (b + x) = a * b + a * x → a * (b + suc x) = (a * b + a * x) + a $ by syl [l22, l20]

-- D = E via eq_sym of add_assoc_inst.
l24: $ a * b + (a * x + a) = (a * b + a * x) + a $ by add_assoc_inst
l25: $ a * b + (a * x + a) = (a * b + a * x) + a → (a * b + a * x) + a = a * b + (a * x + a) $ by eq_sym
l26: $ (a * b + a * x) + a = a * b + (a * x + a) $ by ax_mp [l25, l24]

-- E = F via add_eq_left on (a * x + a = a * suc x).
l27: $ a * suc x = a * x + a $ by mul_suc
l28: $ a * suc x = a * x + a → a * x + a = a * suc x $ by eq_sym
l29: $ a * x + a = a * suc x $ by ax_mp [l28, l27]
l30: $ a * x + a = a * suc x → a * b + (a * x + a) = a * b + a * suc x $ by add_eq_left
l31: $ a * b + (a * x + a) = a * b + a * suc x $ by ax_mp [l30, l29]

-- D = F via eq_trans (D = E, E = F).
l32: $ (a * b + a * x) + a = a * b + (a * x + a) → a * b + (a * x + a) = a * b + a * suc x → (a * b + a * x) + a = a * b + a * suc x $ by eq_trans
l33: $ a * b + (a * x + a) = a * b + a * suc x → (a * b + a * x) + a = a * b + a * suc x $ by ax_mp [l32, l26]
l34: $ (a * b + a * x) + a = a * b + a * suc x $ by ax_mp [l33, l31]

-- IH → (A = F) by chaining IH → (A = D) with (D = F).
l35: $ a * (b + suc x) = (a * b + a * x) + a → (a * b + a * x) + a = a * b + a * suc x → a * (b + suc x) = a * b + a * suc x $ by eq_trans
l36: $ a * (b + suc x) = (a * b + a * x) + a → a * (b + suc x) = a * b + a * suc x $ by mpi [l34, l35]
l37: $ a * (b + x) = a * b + a * x → a * (b + suc x) = a * b + a * suc x $ by syl [l36, l23]

l38: $ ∀ x (a * (b + x) = a * b + a * x → a * (b + suc x) = a * b + a * suc x) $ by ax_gen [l37]
l39: $ ∀ x (a * (b + x) = a * b + a * x) $ by peano5 [l12, l38]

mul_distrib_left
----------------
-- Specialise mul_distrib_left_all at t := c.
l1: $ ∀ x (a * (b + x) = a * b + a * x) $ by mul_distrib_left_all
l2: $ a * (b + c) = a * b + a * c $ by ax_inst [l1]

mul_distrib_right
-----------------
-- Chain:  (a + b) * c  =  c * (a + b)      (mul_comm_inst)
--                     =  c * a + c * b    (mul_distrib_left)
--                     =  a * c + c * b    (add_eq_right on mul_comm_inst)
--                     =  a * c + b * c    (add_eq_left on mul_comm_inst).
l1: $ (a + b) * c = c * (a + b) $ by mul_comm_inst
l2: $ c * (a + b) = c * a + c * b $ by mul_distrib_left
l3: $ c * a = a * c $ by mul_comm_inst
l4: $ c * a = a * c → c * a + c * b = a * c + c * b $ by add_eq_right
l5: $ c * a + c * b = a * c + c * b $ by ax_mp [l4, l3]
l6: $ c * b = b * c $ by mul_comm_inst
l7: $ c * b = b * c → a * c + c * b = a * c + b * c $ by add_eq_left
l8: $ a * c + c * b = a * c + b * c $ by ax_mp [l7, l6]
l9: $ (a + b) * c = a * c + b * c $ by eq_trans4 [l1, l2, l5, l8]

mul_assoc
---------
-- Induction on x of ((a * b) * x = a * (b * x)).
-- Base: both sides collapse to 0.
l1: $ (a * b) * 0 = 0 $ by mul_0
l2: $ b * 0 = 0 $ by mul_0
l3: $ b * 0 = 0 → a * (b * 0) = a * 0 $ by mul_eq_left
l4: $ a * (b * 0) = a * 0 $ by ax_mp [l3, l2]
l5: $ a * 0 = 0 $ by mul_0
l6: $ a * (b * 0) = a * 0 → a * 0 = 0 → a * (b * 0) = 0 $ by eq_trans
l7: $ a * 0 = 0 → a * (b * 0) = 0 $ by ax_mp [l6, l4]
l8: $ a * (b * 0) = 0 $ by ax_mp [l7, l5]
l9: $ a * (b * 0) = 0 → 0 = a * (b * 0) $ by eq_sym
l10: $ 0 = a * (b * 0) $ by ax_mp [l9, l8]
l11: $ (a * b) * 0 = 0 → 0 = a * (b * 0) → (a * b) * 0 = a * (b * 0) $ by eq_trans
l12: $ 0 = a * (b * 0) → (a * b) * 0 = a * (b * 0) $ by ax_mp [l11, l1]
l13: $ (a * b) * 0 = a * (b * 0) $ by ax_mp [l12, l10]

-- Step body: IH: (a * b) * x = a * (b * x); goal (a * b) * suc x = a * (b * suc x).
-- LHS expands as (a * b) * x + a * b; RHS expands to a * (b * x + b) = a * (b * x) + a * b.
-- Both sides equal a * (b * x) + a * b under IH.
l14: $ (a * b) * suc x = (a * b) * x + a * b $ by mul_suc
l15: $ (a * b) * x = a * (b * x) → (a * b) * x + a * b = a * (b * x) + a * b $ by add_eq_right
l16: $ (a * b) * suc x = (a * b) * x + a * b → (a * b) * x + a * b = a * (b * x) + a * b → (a * b) * suc x = a * (b * x) + a * b $ by eq_trans
l17: $ (a * b) * x + a * b = a * (b * x) + a * b → (a * b) * suc x = a * (b * x) + a * b $ by ax_mp [l16, l14]
l18: $ (a * b) * x = a * (b * x) → (a * b) * suc x = a * (b * x) + a * b $ by syl [l17, l15]

-- S = T via mul_eq_left on (b * suc x = b * x + b).
l19: $ b * suc x = b * x + b $ by mul_suc
l20: $ b * suc x = b * x + b → a * (b * suc x) = a * (b * x + b) $ by mul_eq_left
l21: $ a * (b * suc x) = a * (b * x + b) $ by ax_mp [l20, l19]

-- T = U via mul_distrib_left.
l22: $ a * (b * x + b) = a * (b * x) + a * b $ by mul_distrib_left

-- S = U via eq_trans.
l23: $ a * (b * suc x) = a * (b * x + b) → a * (b * x + b) = a * (b * x) + a * b → a * (b * suc x) = a * (b * x) + a * b $ by eq_trans
l24: $ a * (b * x + b) = a * (b * x) + a * b → a * (b * suc x) = a * (b * x) + a * b $ by ax_mp [l23, l21]
l25: $ a * (b * suc x) = a * (b * x) + a * b $ by ax_mp [l24, l22]
l26: $ a * (b * suc x) = a * (b * x) + a * b → a * (b * x) + a * b = a * (b * suc x) $ by eq_sym
l27: $ a * (b * x) + a * b = a * (b * suc x) $ by ax_mp [l26, l25]

-- IH → (P = S) by chaining (P = U) + (U = S).
l28: $ (a * b) * suc x = a * (b * x) + a * b → a * (b * x) + a * b = a * (b * suc x) → (a * b) * suc x = a * (b * suc x) $ by eq_trans
l29: $ (a * b) * suc x = a * (b * x) + a * b → (a * b) * suc x = a * (b * suc x) $ by mpi [l27, l28]
l30: $ (a * b) * x = a * (b * x) → (a * b) * suc x = a * (b * suc x) $ by syl [l29, l18]

l31: $ ∀ x ((a * b) * x = a * (b * x) → (a * b) * suc x = a * (b * suc x)) $ by ax_gen [l30]
l32: $ ∀ x ((a * b) * x = a * (b * x)) $ by peano5 [l13, l31]

mul_assoc_inst
--------------
-- Specialise mul_assoc at t := c.
l1: $ ∀ x ((a * b) * x = a * (b * x)) $ by mul_assoc
l2: $ (a * b) * c = a * (b * c) $ by ax_inst [l1]

mul_lass
--------
-- a * (b * c)  =  (a * b) * c   (eq_sym on mul_assoc_inst)
--             =  (b * a) * c    (mul_eq_right of mul_comm_inst)
--             =  b * (a * c)    (mul_assoc_inst).
l1: $ (a * b) * c = a * (b * c) $ by mul_assoc_inst
l2: $ (a * b) * c = a * (b * c) → a * (b * c) = (a * b) * c $ by eq_sym
l3: $ a * (b * c) = (a * b) * c $ by ax_mp [l2, l1]
l4: $ a * b = b * a $ by mul_comm_inst
l5: $ a * b = b * a → (a * b) * c = (b * a) * c $ by mul_eq_right
l6: $ (a * b) * c = (b * a) * c $ by ax_mp [l5, l4]
l7: $ (b * a) * c = b * (a * c) $ by mul_assoc_inst
l8: $ a * (b * c) = (a * b) * c → (a * b) * c = (b * a) * c → a * (b * c) = (b * a) * c $ by eq_trans
l9: $ (a * b) * c = (b * a) * c → a * (b * c) = (b * a) * c $ by ax_mp [l8, l3]
l10: $ a * (b * c) = (b * a) * c $ by ax_mp [l9, l6]
l11: $ a * (b * c) = (b * a) * c → (b * a) * c = b * (a * c) → a * (b * c) = b * (a * c) $ by eq_trans
l12: $ (b * a) * c = b * (a * c) → a * (b * c) = b * (a * c) $ by ax_mp [l11, l10]
l13: $ a * (b * c) = b * (a * c) $ by ax_mp [l12, l7]

mul_rass
--------
-- (a * b) * c  =  a * (b * c)   (mul_assoc_inst)
--              =  a * (c * b)   (mul_eq_left of mul_comm_inst)
--              =  (a * c) * b   (eq_sym on mul_assoc_inst).
l1: $ (a * b) * c = a * (b * c) $ by mul_assoc_inst
l2: $ b * c = c * b $ by mul_comm_inst
l3: $ b * c = c * b → a * (b * c) = a * (c * b) $ by mul_eq_left
l4: $ a * (b * c) = a * (c * b) $ by ax_mp [l3, l2]
l5: $ (a * c) * b = a * (c * b) $ by mul_assoc_inst
l6: $ (a * c) * b = a * (c * b) → a * (c * b) = (a * c) * b $ by eq_sym
l7: $ a * (c * b) = (a * c) * b $ by ax_mp [l6, l5]
l8: $ (a * b) * c = a * (b * c) → a * (b * c) = a * (c * b) → (a * b) * c = a * (c * b) $ by eq_trans
l9: $ a * (b * c) = a * (c * b) → (a * b) * c = a * (c * b) $ by ax_mp [l8, l1]
l10: $ (a * b) * c = a * (c * b) $ by ax_mp [l9, l4]
l11: $ (a * b) * c = a * (c * b) → a * (c * b) = (a * c) * b → (a * b) * c = (a * c) * b $ by eq_trans
l12: $ a * (c * b) = (a * c) * b → (a * b) * c = (a * c) * b $ by ax_mp [l11, l10]
l13: $ (a * b) * c = (a * c) * b $ by ax_mp [l12, l7]

pncan2
------
-- a + b - a unfolds to `the {x | a + x = a + b}`.  By theid this
-- equals b once the witness set is shown equal to the singleton `{x | x = b}`.
-- The biconditional proof is lifted to set equality by ab_congr.
l1: $ a + x = a + b → x = b $ by add_cancel_left
l2: $ x = b → a + x = a + b $ by add_eq_left
l3: $ (a + x = a + b) ↔ (x = b) $ by ibii [l1, l2]
l4: $ {x | a + x = a + b} == {x | x = b} $ by ab_congr [l3]
l5: $ (the {x | a + x = a + b}) = b $ by theid [l4]

pncan
-----
-- a + b - b unfolds to `the {x | b + x = a + b}`.  Cancellation now
-- needs a commutativity bridge: rewrite b + x to b + a so
-- add_cancel_left applies.  Forward and backward directions both route
-- through add_comm_inst; ibii, ab_congr, and theid finish the job.

-- Forward: b + x = a + b → x = a, via the bridge b + x = b + a.
l1: $ a + b = b + a $ by add_comm_inst
l2: $ b + x = a + b → a + b = b + a → b + x = b + a $ by eq_trans
l3: $ a + b = b + a → b + x = a + b → b + x = b + a $ by com12 [l2]
l4: $ b + x = a + b → b + x = b + a $ by ax_mp [l3, l1]
l5: $ b + x = b + a → x = a $ by add_cancel_left
l6: $ b + x = a + b → x = a $ by syl [l5, l4]

-- Backward: x = a → b + x = a + b, via the bridge b + x = b + a = a + b.
l7: $ x = a → b + x = b + a $ by add_eq_left
l8: $ b + a = a + b $ by add_comm_inst
l9: $ b + x = b + a → b + a = a + b → b + x = a + b $ by eq_trans
l10: $ b + a = a + b → b + x = b + a → b + x = a + b $ by com12 [l9]
l11: $ b + x = b + a → b + x = a + b $ by ax_mp [l10, l8]
l12: $ x = a → b + x = a + b $ by syl [l11, l7]

l13: $ (b + x = a + b) ↔ (x = a) $ by ibii [l6, l12]
l14: $ {x | b + x = a + b} == {x | x = a} $ by ab_congr [l13]
l15: $ (the {x | b + x = a + b}) = a $ by theid [l14]
