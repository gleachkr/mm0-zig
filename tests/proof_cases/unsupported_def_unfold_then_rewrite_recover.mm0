delimiter $ ( ) [ / ] $;
provable sort wff;
sort ctx;
sort mor;

term imp (a b: wff): wff;
infixr imp: $->$ prec 25;
term iff (a b: wff): wff;
infixr iff: $<->$ prec 20;
term all {x: mor} (p: wff x): wff;
prefix all: $A.$ prec 41;

term mor_eq (f g: mor): wff;
infixl mor_eq: $~$ prec 15;
term comp (f g: mor): mor;
infixl comp: $o$ prec 35;

term sb_m {x: mor} (t: mor x) (a: mor x): mor;
notation sb_m {x: mor} (t: mor x) (a: mor x): mor =
  ($subst$:41) x ($/$:0) t a;
term sb_f {x: mor} (t: mor x) (p: wff x): wff;
notation sb_f {x: mor} (t: mor x) (p: wff x): wff =
  ($[$:41) x ($/$:0) t ($]$:0) p;

term ctx_eq (g h: ctx): wff;
term emp: ctx;
notation emp: ctx = ($_$:max);
--| @acui ctx_assoc ctx_comm emp ctx_idem
term join (g h: ctx): ctx;
infixl join: $,$ prec 5;
term hyp (a: wff): ctx;
coercion hyp: wff > ctx;
term nd (g: ctx) (a: wff): wff;
infixl nd: $|-$ prec 0;

--| @relation wff iff iff_refl iff_trans iff_sym iff_mp
axiom iff_refl (a: wff): $ a <-> a $;
axiom iff_trans (a b c: wff): $ a <-> b $ > $ b <-> c $ > $ a <-> c $;
axiom iff_sym (a b: wff): $ a <-> b $ > $ b <-> a $;
axiom iff_mp (a b: wff): $ a <-> b $ > $ a $ > $ b $;

--| @relation ctx ctx_eq ctx_refl ctx_trans ctx_sym _
axiom ctx_refl (g: ctx): $ ctx_eq g g $;
axiom ctx_trans (g h i: ctx):
  $ ctx_eq g h $ > $ ctx_eq h i $ > $ ctx_eq g i $;
axiom ctx_sym (g h: ctx): $ ctx_eq g h $ > $ ctx_eq h g $;
axiom ctx_assoc (g h i: ctx):
  $ ctx_eq ((g , h) , i) (g , (h , i)) $;
axiom ctx_comm (g h: ctx): $ ctx_eq (g , h) (h , g) $;
axiom ctx_idem (g: ctx): $ ctx_eq (g , g) g $;
axiom ctx_unit (g: ctx): $ ctx_eq (emp , g) g $;

--| @congr
axiom join_congr (g1 g2 h1 h2: ctx):
  $ ctx_eq g1 g2 $ > $ ctx_eq h1 h2 $ >
  $ ctx_eq (g1 , h1) (g2 , h2) $;
--| @congr
axiom hyp_congr (a b: wff): $ a <-> b $ > $ ctx_eq (hyp a) (hyp b) $;
--| @congr
axiom nd_congr (g h: ctx) (a b: wff):
  $ ctx_eq g h $ > $ a <-> b $ > $ (g |- a) <-> (h |- b) $;
--| @congr
axiom imp_congr (a b c d: wff):
  $ a <-> b $ > $ c <-> d $ > $ (a -> c) <-> (b -> d) $;
--| @congr
axiom all_congr {x: mor} (p q: wff x):
  $ p <-> q $ > $ A. x p <-> A. x q $;
--| @congr
axiom mor_eq_congr (f1 f2 g1 g2: mor):
  $ f1 ~ f2 $ > $ g1 ~ g2 $ > $ (f1 ~ g1) <-> (f2 ~ g2) $;
--| @congr
axiom comp_congr (f1 f2 g1 g2: mor):
  $ f1 ~ f2 $ > $ g1 ~ g2 $ > $ f1 o g1 ~ f2 o g2 $;

--| @rewrite
axiom comp_assoc (f g h: mor): $ (f o g) o h ~ f o (g o h) $;

--| @rewrite
axiom sb_m_var {x: mor} (t: mor x): $ subst x / t x ~ t $;
--| @rewrite
axiom sb_m_other {x y: mor} (t: mor x): $ subst x / t y ~ y $;
--| @rewrite
axiom sb_m_irrel {x: mor} (t: mor x) (a: mor): $ subst x / t a ~ a $;
--| @rewrite
axiom sb_m_comp {x: mor} (t: mor x) (a b: mor x):
  $ subst x / t (a o b) ~ (subst x / t a o subst x / t b) $;
--| @rewrite
axiom sb_f_mor_eq {x: mor} (t: mor x) (a b: mor x):
  $ [x/t] (a ~ b) <-> (subst x / t a ~ subst x / t b) $;
--| @rewrite
axiom sb_f_imp {x: mor} (t: mor x) (p q: wff x):
  $ [x/t] (p -> q) <-> ([x/t] p -> [x/t] q) $;
--| @rewrite
axiom sb_f_all {x y: mor} (t: mor x) (p: wff x y):
  $ [x/t] (A. y p) <-> A. y ([x/t] p) $;

--| @view (g: ctx) {x: mor} (t: mor x) (p: wff x) (q c: wff): $ g , q |- c $ > $ g , A. x p |- c $
--| @recover t q p x
--| @normalize hyp0 conc
axiom all_left (g: ctx) {x: mor} (t: mor x) (p: wff x) (c: wff):
  $ g , [x/t] p |- c $ > $ g , A. x p |- c $;

-- A hidden-dummy def whose exposed body reveals comp_assoc redexes only
-- after view matching has committed to the witness recovered from the ref.
def mono {.a .b: mor} (f: mor): wff =
  $ A. a A. b ((f o a ~ f o b) -> (a ~ b)) $;

-- This is a less direct @recover case than plain all_elim:
-- matching the line against all_left's conclusion must expose mono (g o f),
-- and then matching the cited ref against hyp0 needs comp_assoc after the
-- recovered witness t := alpha has been threaded through that exposure.
--| @dummy y
theorem unsupported_def_unfold_then_rewrite_recover
    {alpha y: mor} (f g: mor) (c: wff):
  $ emp , A. y ((g o (f o alpha) ~ (g o f) o y) -> (alpha ~ y)) |- c $
  > $ emp , mono (g o f) |- c $;
