alice_imp
---------

-- Alice's hypothesis H abbreviates  (ka Ôćĺ (ka Ôćĺ kb)) Ôłž ((ka Ôćĺ kb) Ôćĺ ka)
-- through the def `says`. and_elim_l/r unfold `says` transparently.
--
-- `ax` lines anchor the active context; every derived line uses `_ctx ÔŐó`
-- and lets the matcher recover the context from the cited refs.

-- Step 1. Derive H ÔŐó ka Ôćĺ kb directly: assume ka, then H's first
-- conjunct gives ka Ôćĺ (ka Ôćĺ kb), apply twice with ka to obtain kb.
l1: $ says ka "ka Ôćĺ kb" , ka ÔŐó says ka "ka Ôćĺ kb" $ by ax
l2: $ _ctx ÔŐó ka Ôćĺ (ka Ôćĺ kb) $ by and_elim_l [l1]
l3: $ says ka "ka Ôćĺ kb" , ka ÔŐó ka $ by ax
l4: $ _ctx ÔŐó ka Ôćĺ kb $ by imp_elim [l2, l3]
l5: $ _ctx ÔŐó kb $ by imp_elim [l4, l3]
l6: $ _ctx ÔŐó ka Ôćĺ kb $ by imp_intro [l5]

-- Step 2. Use H's second conjunct (ka Ôćĺ kb) Ôćĺ ka to obtain ka.
l7: $ says ka "ka Ôćĺ kb" ÔŐó says ka "ka Ôćĺ kb" $ by ax
l8: $ _ctx ÔŐó (ka Ôćĺ kb) Ôćĺ ka $ by and_elim_r [l7]
l9: $ _ctx ÔŐó ka $ by imp_elim [l8, l6]

-- Step 3. Use ka Ôćĺ kb on ka to extract kb, then bundle.
l10: $ _ctx ÔŐó kb $ by imp_elim [l6, l9]
l11: $ _ctx ÔŐó ka Ôłž kb $ by and_intro [l9, l10]

alice_both_knaves
-----------------

-- Step 1. Derive ┬Č ka. Under H, ka the first conjunct of H gives
-- ka Ôćĺ (┬Č ka Ôłž ┬Č kb), so we can extract ┬Č ka and contradict ka.
l1: $ says ka "┬Č ka Ôłž ┬Č kb" , ka ÔŐó says ka "┬Č ka Ôłž ┬Č kb" $ by ax
l2: $ _ctx ÔŐó ka Ôćĺ (┬Č ka Ôłž ┬Č kb) $ by and_elim_l [l1]
l3: $ says ka "┬Č ka Ôłž ┬Č kb" , ka ÔŐó ka $ by ax
l4: $ _ctx ÔŐó ┬Č ka Ôłž ┬Č kb $ by imp_elim [l2, l3]
l5: $ _ctx ÔŐó ┬Č ka $ by and_elim_l [l4]
l6: $ _ctx ÔŐó bot $ by bot_intro [l3, l5]
l7: $ _ctx ÔŐó ┬Č ka $ by neg_intro [l6]

-- Step 2. Derive kb classically. Re-derive ┬Č ka in the larger context
-- H, ┬Č kb (no implicit weakening here), then assemble ┬Č ka Ôłž ┬Č kb
-- and apply H's second conjunct to land at ka ÔÇö contradicting ┬Č ka.
l8: $ says ka "┬Č ka Ôłž ┬Č kb" , ┬Č kb , ka ÔŐó says ka "┬Č ka Ôłž ┬Č kb" $ by ax
l9: $ _ctx ÔŐó ka Ôćĺ (┬Č ka Ôłž ┬Č kb) $ by and_elim_l [l8]
l10: $ says ka "┬Č ka Ôłž ┬Č kb" , ┬Č kb , ka ÔŐó ka $ by ax
l11: $ _ctx ÔŐó ┬Č ka Ôłž ┬Č kb $ by imp_elim [l9, l10]
l12: $ _ctx ÔŐó ┬Č ka $ by and_elim_l [l11]
l13: $ _ctx ÔŐó bot $ by bot_intro [l10, l12]
l14: $ _ctx ÔŐó ┬Č ka $ by neg_intro [l13]
l15: $ says ka "┬Č ka Ôłž ┬Č kb" , ┬Č kb ÔŐó ┬Č kb $ by ax
l16: $ _ctx ÔŐó ┬Č ka Ôłž ┬Č kb $ by and_intro [l14, l15]
l17: $ says ka "┬Č ka Ôłž ┬Č kb" , ┬Č kb ÔŐó says ka "┬Č ka Ôłž ┬Č kb" $ by ax
l18: $ _ctx ÔŐó (┬Č ka Ôłž ┬Č kb) Ôćĺ ka $ by and_elim_r [l17]
l19: $ _ctx ÔŐó ka $ by imp_elim [l18, l16]
l20: $ _ctx ÔŐó bot $ by bot_intro [l19, l14]
l21: $ _ctx ÔŐó ┬Č ┬Č kb $ by neg_intro [l20]
l22: $ _ctx ÔŐó kb $ by dne [l21]

l23: $ _ctx ÔŐó ┬Č ka Ôłž kb $ by and_intro [l7, l22]

alice_one_knave
---------------

-- Step 1. Derive ka by classical reasoning. Under H, ┬Č ka, build
-- ┬Č ka ÔłĘ ┬Č kb on the cheap (or_intro_l on ┬Č ka), then H's second
-- conjunct yields ka, contradicting ┬Č ka.
l1: $ says ka "┬Č ka ÔłĘ ┬Č kb" , ┬Č ka ÔŐó ┬Č ka $ by ax
l2: $ _ctx ÔŐó ┬Č ka ÔłĘ ┬Č kb $ by or_intro_l [l1]
l3: $ says ka "┬Č ka ÔłĘ ┬Č kb" , ┬Č ka ÔŐó says ka "┬Č ka ÔłĘ ┬Č kb" $ by ax
l4: $ _ctx ÔŐó (┬Č ka ÔłĘ ┬Č kb) Ôćĺ ka $ by and_elim_r [l3]
l5: $ _ctx ÔŐó ka $ by imp_elim [l4, l2]
l6: $ _ctx ÔŐó bot $ by bot_intro [l5, l1]
l7: $ _ctx ÔŐó ┬Č ┬Č ka $ by neg_intro [l6]
l8: $ _ctx ÔŐó ka $ by dne [l7]

-- Step 2. Derive ┬Č kb by case-split. Under H, kb, re-derive ka in
-- the larger context, apply H's first conjunct to get ┬Č ka ÔłĘ ┬Č kb,
-- then or_elim sends both branches to bot.

-- Re-derive ka under H, kb (same shape as Step 1 with extra `, kb`).
l9: $ says ka "┬Č ka ÔłĘ ┬Č kb" , kb , ┬Č ka ÔŐó ┬Č ka $ by ax
l10: $ _ctx ÔŐó ┬Č ka ÔłĘ ┬Č kb $ by or_intro_l [l9]
l11: $ says ka "┬Č ka ÔłĘ ┬Č kb" , kb , ┬Č ka ÔŐó says ka "┬Č ka ÔłĘ ┬Č kb" $ by ax
l12: $ _ctx ÔŐó (┬Č ka ÔłĘ ┬Č kb) Ôćĺ ka $ by and_elim_r [l11]
l13: $ _ctx ÔŐó ka $ by imp_elim [l12, l10]
l14: $ _ctx ÔŐó bot $ by bot_intro [l13, l9]
l15: $ _ctx ÔŐó ┬Č ┬Č ka $ by neg_intro [l14]
l16: $ _ctx ÔŐó ka $ by dne [l15]

-- Apply H's first conjunct to get the disjunction under H, kb.
l17: $ says ka "┬Č ka ÔłĘ ┬Č kb" , kb ÔŐó says ka "┬Č ka ÔłĘ ┬Č kb" $ by ax
l18: $ _ctx ÔŐó ka Ôćĺ (┬Č ka ÔłĘ ┬Č kb) $ by and_elim_l [l17]
l19: $ _ctx ÔŐó ┬Č ka ÔłĘ ┬Č kb $ by imp_elim [l18, l16]

-- Branch 1 (┬Č ka): contradict the ka we already have. l14 fits.
-- Branch 2 (┬Č kb): contradict the kb sitting in the context.
l20: $ says ka "┬Č ka ÔłĘ ┬Č kb" , kb , ┬Č kb ÔŐó kb $ by ax
l21: $ says ka "┬Č ka ÔłĘ ┬Č kb" , kb , ┬Č kb ÔŐó ┬Č kb $ by ax
l22: $ _ctx ÔŐó bot $ by bot_intro [l20, l21]

l23: $ _ctx ÔŐó bot $ by or_elim [l19, l14, l22]
l24: $ _ctx ÔŐó ┬Č kb $ by neg_intro [l23]

l25: $ _ctx ÔŐó ka Ôłž ┬Č kb $ by and_intro [l8, l24]
