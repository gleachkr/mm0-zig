alice_imp
---------

-- Multiplicative reading: each `ax` gives only P ⊢ P, and rule
-- applications combine the contexts of their premises via ACUI union.
-- The same `ka ⊢ ka` line gets reused across both uses of imp_elim,
-- and the discharged H ⊢ H from line 1 doubles as Step 2's anchor.

l1: $ says ka "ka → kb" ⊢ says ka "ka → kb" $ by ax
l2: $ _ctx ⊢ ka → (ka → kb) $ by and_elim_l [l1]
l3: $ ka ⊢ ka $ by ax
l4: $ _ctx ⊢ ka → kb $ by imp_elim [l2, l3]
l5: $ _ctx ⊢ kb $ by imp_elim [l4, l3]
l6: $ _ctx ⊢ ka → kb $ by imp_intro [l5]

-- Step 2: H's second conjunct gives ka.
l7: $ _ctx ⊢ (ka → kb) → ka $ by and_elim_r [l1]
l8: $ _ctx ⊢ ka $ by imp_elim [l7, l6]

-- Step 3: chain ka through ka → kb, bundle.
l9: $ _ctx ⊢ kb $ by imp_elim [l6, l8]
l10: $ _ctx ⊢ ka ∧ kb $ by and_intro [l8, l9]

alice_both_knaves
-----------------

-- Step 1: derive ¬ ka. Assume ka, run it through H's first conjunct
-- ka → (¬ ka ∧ ¬ kb), pull out ¬ ka, and contradict the assumed ka.
l1: $ says ka "¬ ka ∧ ¬ kb" ⊢ says ka "¬ ka ∧ ¬ kb" $ by ax
l2: $ _ctx ⊢ ka → (¬ ka ∧ ¬ kb) $ by and_elim_l [l1]
l3: $ ka ⊢ ka $ by ax
l4: $ _ctx ⊢ ¬ ka ∧ ¬ kb $ by imp_elim [l2, l3]
l5: $ _ctx ⊢ ¬ ka $ by and_elim_l [l4]
l6: $ _ctx ⊢ bot $ by bot_intro [l3, l5]
l7: $ _ctx ⊢ ¬ ka $ by neg_intro [l6]

-- Step 2: derive kb classically. Assume ¬ kb, combine with the ¬ ka
-- we already have, send through H's second conjunct, and contradict.
-- No re-derivation needed: l7 carries cleanly into the larger context.
l8: $ ¬ kb ⊢ ¬ kb $ by ax
l9: $ _ctx ⊢ ¬ ka ∧ ¬ kb $ by and_intro [l7, l8]
l10: $ _ctx ⊢ (¬ ka ∧ ¬ kb) → ka $ by and_elim_r [l1]
l11: $ _ctx ⊢ ka $ by imp_elim [l10, l9]
l12: $ _ctx ⊢ bot $ by bot_intro [l11, l7]
l13: $ _ctx ⊢ ¬ ¬ kb $ by neg_intro [l12]
l14: $ _ctx ⊢ kb $ by dne [l13]

l15: $ _ctx ⊢ ¬ ka ∧ kb $ by and_intro [l7, l14]

alice_one_knave
---------------

-- Step 1: derive ka by classical reasoning. Assume ¬ ka, build
-- ¬ ka ∨ ¬ kb on the cheap, run it through H's second conjunct to
-- get ka, contradict.
l1: $ says ka "¬ ka ∨ ¬ kb" ⊢ says ka "¬ ka ∨ ¬ kb" $ by ax
l2: $ _ctx ⊢ (¬ ka ∨ ¬ kb) → ka $ by and_elim_r [l1]
l3: $ ¬ ka ⊢ ¬ ka $ by ax
l4: $ _ctx ⊢ ¬ ka ∨ ¬ kb $ by or_intro_l [l3]
l5: $ _ctx ⊢ ka $ by imp_elim [l2, l4]
l6: $ _ctx ⊢ bot $ by bot_intro [l5, l3]
l7: $ _ctx ⊢ ¬ ¬ ka $ by neg_intro [l6]
l8: $ _ctx ⊢ ka $ by dne [l7]

-- Step 2: derive ¬ kb. Apply H's first conjunct to ka to get the
-- disjunction, then or_elim. Branch 1 (¬ ka) contradicts l8 with l3
-- already in scope; Branch 2 (¬ kb) contradicts an assumed kb.
l9: $ _ctx ⊢ ka → (¬ ka ∨ ¬ kb) $ by and_elim_l [l1]
l10: $ _ctx ⊢ ¬ ka ∨ ¬ kb $ by imp_elim [l9, l8]

l11: $ _ctx ⊢ bot $ by bot_intro [l8, l3]
l12: $ kb ⊢ kb $ by ax
l13: $ ¬ kb ⊢ ¬ kb $ by ax
l14: $ _ctx ⊢ bot $ by bot_intro [l12, l13]

l15: $ _ctx ⊢ bot $ by or_elim [l10, l11, l14]
l16: $ _ctx ⊢ ¬ kb $ by neg_intro [l15]

l17: $ _ctx ⊢ ka ∧ ¬ kb $ by and_intro [l8, l16]

alice_liar
----------

-- Step 1: assume ka. H's first conjunct ka → ¬ ka collapses under
-- ka to ¬ ka — contradiction. So ¬ ka, with H alone in scope.
l1: $ says ka "¬ ka" ⊢ says ka "¬ ka" $ by ax
l2: $ _ctx ⊢ ka → ¬ ka $ by and_elim_l [l1]
l3: $ ka ⊢ ka $ by ax
l4: $ _ctx ⊢ ¬ ka $ by imp_elim [l2, l3]
l5: $ _ctx ⊢ bot $ by bot_intro [l3, l4]
l6: $ _ctx ⊢ ¬ ka $ by neg_intro [l5]

-- Step 2: H's second conjunct ¬ ka → ka lights up that ¬ ka and
-- yields ka, contradicting the ¬ ka we just derived.
l7: $ _ctx ⊢ ¬ ka → ka $ by and_elim_r [l1]
l8: $ _ctx ⊢ ka $ by imp_elim [l7, l6]
l9: $ _ctx ⊢ bot $ by bot_intro [l8, l6]

-- Step 3: discharge H to obtain the empty-context refutation.
-- Alice cannot say "I am a knave."
l10: $ _ ⊢ ¬ says ka "¬ ka" $ by neg_intro [l9]
