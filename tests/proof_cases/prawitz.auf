de_morgan_or
------------

-- Forward: ~(a \/ b) -> (~a /\ ~b)
l1: $ ┬Č (a ÔłĘ b) ÔŐó ┬Č (a ÔłĘ b) $ by ax []
l2: $ a ÔŐó a $ by ax []
l3: $ a ÔŐó a ÔłĘ b $ by or_intro_l [l2]
l4: $ ┬Č (a ÔłĘ b) , a ÔŐó ÔŐą $ by not_elim [l1, l3]
l5: $ ┬Č (a ÔłĘ b) ÔŐó ┬Č a $ by not_intro [l4]
l6: $ b ÔŐó b $ by ax []
l7: $ b ÔŐó a ÔłĘ b $ by or_intro_r [l6]
l8: $ ┬Č (a ÔłĘ b) , b ÔŐó ÔŐą $ by not_elim [l1, l7]
l9: $ ┬Č (a ÔłĘ b) ÔŐó ┬Č b $ by not_intro [l8]
l10: $ ┬Č (a ÔłĘ b) ÔŐó ┬Č a Ôłž ┬Č b $ by and_intro [l5, l9]
l11: $ _ ÔŐó ┬Č (a ÔłĘ b) Ôćĺ (┬Č a Ôłž ┬Č b) $ by imp_intro [l10]
-- Backward: (~a /\ ~b) -> ~(a \/ b)
l12: $ (┬Č a Ôłž ┬Č b) ÔŐó ┬Č a Ôłž ┬Č b $ by ax []
l13: $ (┬Č a Ôłž ┬Č b) ÔŐó ┬Č a $ by and_elim_l [l12]
l14: $ (┬Č a Ôłž ┬Č b) ÔŐó ┬Č b $ by and_elim_r [l12]
l15: $ (a ÔłĘ b) ÔŐó a ÔłĘ b $ by ax []
l16: $ a ÔŐó a $ by ax []
l17: $ (┬Č a Ôłž ┬Č b) , a ÔŐó ÔŐą $ by not_elim [l13, l16]
l18: $ b ÔŐó b $ by ax []
l19: $ (┬Č a Ôłž ┬Č b) , b ÔŐó ÔŐą $ by not_elim [l14, l18]
l20: $ (┬Č a Ôłž ┬Č b) , (a ÔłĘ b) ÔŐó ÔŐą $ by or_elim [l15, l17, l19]
l21: $ (┬Č a Ôłž ┬Č b) ÔŐó ┬Č (a ÔłĘ b) $ by not_intro [l20]
l22: $ _ ÔŐó (┬Č a Ôłž ┬Č b) Ôćĺ ┬Č (a ÔłĘ b) $ by imp_intro [l21]
-- Combine
l23: $ _ ÔŐó ┬Č (a ÔłĘ b) Ôćö (┬Č a Ôłž ┬Č b) $ by iff_intro [l11, l22]

curry_iff
---------

-- Forward: ((a /\ b) -> c) -> (a -> b -> c)
l1: $ (a Ôłž b) Ôćĺ c ÔŐó (a Ôłž b) Ôćĺ c $ by ax []
l2: $ a , b ÔŐó a $ by ax []
l3: $ a , b ÔŐó b $ by ax []
l4: $ a , b ÔŐó a Ôłž b $ by and_intro [l2, l3]
l5: $ (a Ôłž b) Ôćĺ c , a , b ÔŐó c $ by imp_elim [l1, l4]
l6: $ (a Ôłž b) Ôćĺ c , a ÔŐó b Ôćĺ c $ by imp_intro [l5]
l7: $ (a Ôłž b) Ôćĺ c ÔŐó a Ôćĺ b Ôćĺ c $ by imp_intro [l6]
l8: $ _ ÔŐó ((a Ôłž b) Ôćĺ c) Ôćĺ (a Ôćĺ b Ôćĺ c) $ by imp_intro [l7]
-- Backward: (a -> b -> c) -> ((a /\ b) -> c)
l9: $ a Ôćĺ b Ôćĺ c ÔŐó a Ôćĺ b Ôćĺ c $ by ax []
l10: $ (a Ôłž b) ÔŐó a Ôłž b $ by ax []
l11: $ (a Ôłž b) ÔŐó a $ by and_elim_l [l10]
l12: $ (a Ôłž b) ÔŐó b $ by and_elim_r [l10]
l13: $ (a Ôćĺ b Ôćĺ c) , (a Ôłž b) ÔŐó b Ôćĺ c $ by imp_elim [l9, l11]
l14: $ (a Ôćĺ b Ôćĺ c) , (a Ôłž b) ÔŐó c $ by imp_elim [l13, l12]
l15: $ (a Ôćĺ b Ôćĺ c) ÔŐó (a Ôłž b) Ôćĺ c $ by imp_intro [l14]
l16: $ _ ÔŐó (a Ôćĺ b Ôćĺ c) Ôćĺ ((a Ôłž b) Ôćĺ c) $ by imp_intro [l15]
-- Combine
l17: $ _ ÔŐó ((a Ôłž b) Ôćĺ c) Ôćö (a Ôćĺ b Ôćĺ c) $ by iff_intro [l8, l16]

imp_trans
---------

l1: $ (a Ôćĺ b) ÔŐó a Ôćĺ b $ by ax []
l2: $ (b Ôćĺ c) ÔŐó b Ôćĺ c $ by ax []
l3: $ a ÔŐó a $ by ax []
l4: $ (a Ôćĺ b) , a ÔŐó b $ by imp_elim [l1, l3]
l5: $ (b Ôćĺ c) , (a Ôćĺ b) , a ÔŐó c $ by imp_elim [l2, l4]
l6: $ (b Ôćĺ c) , (a Ôćĺ b) ÔŐó a Ôćĺ c $ by imp_intro [l5]
l7: $ (a Ôćĺ b) ÔŐó (b Ôćĺ c) Ôćĺ (a Ôćĺ c) $ by imp_intro [l6]
l8: $ _ ÔŐó (a Ôćĺ b) Ôćĺ (b Ôćĺ c) Ôćĺ (a Ôćĺ c) $ by imp_intro [l7]

not_not_lem
-----------

-- Proof that ~~(a \/ ~a) is intuitionistically valid
l1: $ ┬Č (a ÔłĘ ┬Č a) ÔŐó ┬Č (a ÔłĘ ┬Č a) $ by ax []
-- Derive ~a from ~(a \/ ~a)
l2: $ a ÔŐó a $ by ax []
l3: $ a ÔŐó a ÔłĘ ┬Č a $ by or_intro_l [l2]
l4: $ ┬Č (a ÔłĘ ┬Č a) , a ÔŐó ÔŐą $ by not_elim [l1, l3]
l5: $ ┬Č (a ÔłĘ ┬Č a) ÔŐó ┬Č a $ by not_intro [l4]
-- Now a \/ ~a from ~a
l6: $ ┬Č (a ÔłĘ ┬Č a) ÔŐó a ÔłĘ ┬Č a $ by or_intro_r [l5]
-- Contradiction
l7: $ ┬Č (a ÔłĘ ┬Č a) ÔŐó ÔŐą $ by not_elim [l1, l6]
-- Conclude ~~(a \/ ~a)
l8: $ _ ÔŐó ┬Č ┬Č (a ÔłĘ ┬Č a) $ by not_intro [l7]

