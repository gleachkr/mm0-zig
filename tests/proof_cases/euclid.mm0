-- Toward Euclid's theorem: infinitely many primes.
--
-- This file lays down the foundation needed to state and prove
--
--   ∀ n. ∃ p. prime p ∧ n < p
--
-- by Euclid's classical n!+1 argument.  Logic is classical natural
-- deduction with ACUI hypothesis contexts (so exchange and contraction
-- are built in).  Arithmetic is the usual Peano signature for 0, suc,
-- +, *, with first-order induction stated via substitution into an
-- open predicate.  Factorial is introduced as an additional function
-- symbol with primitive-recursive defining axioms; this is conservative
-- over PA via the primitive recursion theorem.  Order, divisibility,
-- and primality are transparent definitions on top of the arithmetic
-- signature.
--
-- Status:
--
-- Proven (no axiomatic shortcut on the number-theoretic content):
--   * basic order / dvd plumbing  (dvd_refl, dvd_zero, one_dvd,
--     dvd_mul_right, dvd_mul_left, dvd_add, dvd_trans, dvd_one_implies)
--   * prime_not_dvd_one                : prime p → ¬ p ∣ 1
--   * fact_pos                          : 1 ≤ ! n
--   * one_lt_fact_succ                  : 1 < ! n + 1
--   * nat_cases                         : n = 0 ∨ ∃ k. n = suc k
--   * nat_compare                       : a ≤ b ∨ b < a
--   * le_suc_cases                      : a ≤ suc b → a ≤ b ∨ a = suc b
--   * dvd_add_cancel                    : a ∣ b → a ∣ (b + c) → a ∣ c
--   * dvd_fact                          : (1 < d ∧ d ≤ n) → d ∣ ! n
--   * classical de Morgan + drinker:    not_and_imp_or_not, dne,
--     not_or_imp_and_not, not_imp_imp_and_not,
--     not_forall_imp_exists_not
--   * exists_prime_factor               : ∀ m. 1 < m → ∃ p.
--                                          prime p ∧ p ∣ m
--   * euclid                            : ∀ n. ∃ p. prime p ∧ n < p

delimiter $ ( ) [ / | ] $;

provable sort wff;
sort ctx;

--| @vars a b c d e i j k m n p q r y z
sort nat;

-- ============================================================
-- Propositional + first-order natural deduction (classical)
-- ============================================================

term im (a b: wff): wff;
infixr im: $→$ prec 25;
infixr im: $->$ prec 25;
term and (a b: wff): wff;
infixr and: $∧$ prec 30;
infixr and: $/\\$ prec 30;
term or (a b: wff): wff;
infixr or: $∨$ prec 28;
infixr or: $\\/$ prec 28;
term not (a: wff): wff;
prefix not: $¬$ prec 35;
prefix not: $~$ prec 35;
term bot: wff;
notation bot: wff = ($⊥$:max);
term bi (a b: wff): wff;
infixl bi: $↔$ prec 20;
infixl bi: $<->$ prec 20;

term all {x: nat} (p: wff x): wff;
prefix all: $∀$ prec 41;
prefix all: $A.$ prec 41;
term ex {x: nat} (p: wff x): wff;
prefix ex: $∃$ prec 41;
prefix ex: $E.$ prec 41;

term sb_f {x: nat} (t: nat x) (p: wff x): wff;
notation sb_f {x: nat} (t: nat x) (p: wff x): wff =
  ($[$:41) x ($/$:0) t ($]$:0) p;
term sb_t {x: nat} (t: nat x) (a: nat x): nat;
notation sb_t {x: nat} (t: nat x) (a: nat x): nat =
  ($⟦$:41) x ($/$:0) t ($⟧$:0) a;

term ctx_eq (g h: ctx): wff;
term emp: ctx;
notation emp: ctx = ($_$:max);

--| @acui ctx_assoc ctx_comm emp ctx_idem
term join (g h: ctx): ctx;
infixl join: $,$ prec 5;
term hyp (a: wff): ctx;
coercion hyp: wff > ctx;

term nd (g: ctx) (a: wff): wff;
infixl nd: $⊢$ prec 0;

term eq (a b: nat): wff;
infixl eq: $=$ prec 50;
term ne (a b: nat): wff;
infixl ne: $≠$ prec 50;
infixl ne: $!=$ prec 50;

-- The bi-conditional is the rewrite relation on wff.
--| @relation wff bi biid bitr bisym mpbi
axiom biid (a: wff): $ a ↔ a $;
axiom bitr (a b c: wff):
  $ a ↔ b $ > $ b ↔ c $ > $ a ↔ c $;
axiom bisym (a b: wff): $ a ↔ b $ > $ b ↔ a $;
axiom mpbi (a b: wff): $ a ↔ b $ > $ a $ > $ b $;

-- ACUI equality on contexts.
--| @relation ctx ctx_eq ctx_refl ctx_trans ctx_sym _
axiom ctx_refl (g: ctx): $ ctx_eq g g $;
axiom ctx_trans (g h i: ctx):
  $ ctx_eq g h $ > $ ctx_eq h i $ > $ ctx_eq g i $;
axiom ctx_sym (g h: ctx): $ ctx_eq g h $ > $ ctx_eq h g $;
axiom ctx_assoc (g h i: ctx):
  $ ctx_eq ((g , h) , i) (g , (h , i)) $;
axiom ctx_comm (g h: ctx): $ ctx_eq (g , h) (h , g) $;
axiom ctx_idem (g: ctx): $ ctx_eq (g , g) g $;
axiom ctx_unit (g: ctx): $ ctx_eq (emp , g) g $;

--| @congr
axiom join_congr (g1 g2 h1 h2: ctx):
  $ ctx_eq g1 g2 $ > $ ctx_eq h1 h2 $ >
  $ ctx_eq (g1 , h1) (g2 , h2) $;
--| @congr
axiom hyp_congr (a b: wff): $ a ↔ b $ > $ ctx_eq (hyp a) (hyp b) $;
--| @congr
axiom nd_congr (g h: ctx) (a b: wff):
  $ ctx_eq g h $ > $ a ↔ b $ > $ (g ⊢ a) ↔ (h ⊢ b) $;

--| @congr
axiom im_congr (a b c d: wff):
  $ a ↔ b $ > $ c ↔ d $ > $ (a → c) ↔ (b → d) $;
--| @congr
axiom and_congr (a b c d: wff):
  $ a ↔ b $ > $ c ↔ d $ > $ (a ∧ c) ↔ (b ∧ d) $;
--| @congr
axiom or_congr (a b c d: wff):
  $ a ↔ b $ > $ c ↔ d $ > $ (a ∨ c) ↔ (b ∨ d) $;
--| @congr
axiom not_congr (a b: wff):
  $ a ↔ b $ > $ ¬ a ↔ ¬ b $;
--| @congr
axiom bi_congr (a b c d: wff):
  $ a ↔ b $ > $ c ↔ d $ > $ (a ↔ c) ↔ (b ↔ d) $;
--| @congr
axiom all_congr {x: nat} (p q: wff x):
  $ p ↔ q $ > $ ∀ x p ↔ ∀ x q $;
--| @congr
axiom ex_congr {x: nat} (p q: wff x):
  $ p ↔ q $ > $ ∃ x p ↔ ∃ x q $;

-- Alpha-renaming rules used by @freshen when a context contains the
-- same bound variable that a quantifier rule is trying to bind.
--| @alpha x y
axiom all_alpha {x y: nat} (p: wff x y):
  $ ∀ x p ↔ ∀ y ([x/y] p) $;
--| @alpha x y
axiom ex_alpha {x y: nat} (p: wff x y):
  $ ∃ x p ↔ ∃ y ([x/y] p) $;

-- Equality on naturals is an equivalence relation; eq_replace below
-- gives Leibniz substitutivity, so the explicit refl / trans / sym are
-- redundant once eq_replace is in scope, but they make rewriting fast.
--| @relation nat eq eq_refl eq_trans eq_sym _
axiom eq_refl (a: nat): $ a = a $;
axiom eq_trans (a b c: nat):
  $ a = b $ > $ b = c $ > $ a = c $;
axiom eq_sym (a b: nat): $ a = b $ > $ b = a $;

--| @congr
axiom eq_congr (a b c d: nat):
  $ a = b $ > $ c = d $ > $ (a = c) ↔ (b = d) $;
--| @congr
axiom ne_congr (a b c d: nat):
  $ a = b $ > $ c = d $ > $ (a ≠ c) ↔ (b ≠ d) $;

-- Disequality as the negation of equality.
--| @rewrite
axiom ne_def (a b: nat): $ a ≠ b ↔ ¬ a = b $;

-- ND structural and connective rules.
axiom ax (g: ctx) (a: wff): $ g , a ⊢ a $;
axiom imp_intro (g: ctx) (a b: wff):
  $ g , a ⊢ b $ > $ g ⊢ a → b $;
axiom imp_elim (g h: ctx) (a b: wff):
  $ g ⊢ a → b $ > $ h ⊢ a $ > $ g , h ⊢ b $;
axiom and_intro (g h: ctx) (a b: wff):
  $ g ⊢ a $ > $ h ⊢ b $ > $ g , h ⊢ a ∧ b $;
axiom and_elim_l (g: ctx) (a b: wff):
  $ g ⊢ a ∧ b $ > $ g ⊢ a $;
axiom and_elim_r (g: ctx) (a b: wff):
  $ g ⊢ a ∧ b $ > $ g ⊢ b $;
axiom or_intro_l (g: ctx) (a b: wff):
  $ g ⊢ a $ > $ g ⊢ a ∨ b $;
axiom or_intro_r (g: ctx) (a b: wff):
  $ g ⊢ b $ > $ g ⊢ a ∨ b $;
axiom or_elim (g h k: ctx) (a b c: wff):
  $ g ⊢ a ∨ b $ > $ h , a ⊢ c $ > $ k , b ⊢ c $ >
  $ g , h , k ⊢ c $;
axiom not_intro (g: ctx) (a: wff):
  $ g , a ⊢ ⊥ $ > $ g ⊢ ¬ a $;
axiom not_elim (g h: ctx) (a: wff):
  $ g ⊢ ¬ a $ > $ h ⊢ a $ > $ g , h ⊢ ⊥ $;
axiom bot_elim (g: ctx) (a: wff): $ g ⊢ ⊥ $ > $ g ⊢ a $;
axiom bi_intro (g h: ctx) (a b: wff):
  $ g , a ⊢ b $ > $ h , b ⊢ a $ > $ g , h ⊢ a ↔ b $;
axiom bi_elim_l (g h: ctx) (a b: wff):
  $ g ⊢ a ↔ b $ > $ h ⊢ a $ > $ g , h ⊢ b $;
axiom bi_elim_r (g h: ctx) (a b: wff):
  $ g ⊢ a ↔ b $ > $ h ⊢ b $ > $ g , h ⊢ a $;

-- Classical excluded middle.  Without this the foundation is intuition-
-- istic; Euclid's proof itself does not need LEM, but having it on hand
-- keeps the underlying logic the standard textbook one.
axiom lem (g: ctx) (a: wff): $ g ⊢ a ∨ ¬ a $;

--| @view {x u: nat} (g: ctx x) (p q: wff x): $ g ⊢ q $ > $ g ⊢ ∀ x p $
--| @recover u q p x
axiom all_intro_sub {x u: nat} (g: ctx x) (p: wff x):
  $ g ⊢ [x/u] p $ > $ g ⊢ ∀ x p $;

-- Two ∀-introduction forms.
--   * Simple `all_intro`: the standard ND form.  The raw binder type
--     `g: ctx` is the real eigenvariable side condition: g may not
--     depend on x.  The @freshen only repairs harmless alpha-collisions
--     where g contains an unrelated quantifier that also binds x.
--   * Substitution-form `all_intro_sub`: body proved as [x/u] p for a
--     fresh u.  This handles the user-facing case where the proved body
--     already names the eigenvariable differently from the ∀ binder.
--| @freshen g x
--| @fallback all_intro_sub
axiom all_intro (g: ctx) {x: nat} (p: wff x):
  $ g ⊢ p $ > $ g ⊢ ∀ x p $;

--| @view {x: nat} (g: ctx x) (t: nat x) (p: wff x) (q: wff): $ g ⊢ ∀ x p $ > $ g ⊢ q $
--| @recover t q p x
axiom all_elim {x: nat} (g: ctx x) (t: nat x) (p: wff x):
  $ g ⊢ ∀ x p $ > $ g ⊢ [x/t] p $;

--| @view {x: nat} (g: ctx x) (t: nat x) (p: wff x) (q: wff): $ g ⊢ q $ > $ g ⊢ ∃ x p $
--| @recover t q p x
axiom ex_intro {x: nat} (g: ctx x) (t: nat x) (p: wff x):
  $ g ⊢ [x/t] p $ > $ g ⊢ ∃ x p $;

-- Substitution-form existential elimination, used when the proof names
-- the opened witness differently from the existential binder.  The
-- binder type `c: wff` is the eigenvariable side condition: c must not
-- depend on either x or u.  The @freshen annotations only repair bound
-- occurrences of those names inside c by alpha-renaming them away.
--| @view {x u: nat} (g h: ctx x u) (p: wff x) (q c: wff): $ g ⊢ ∃ x p $ > $ h , q ⊢ c $ > $ g , h ⊢ c $
--| @recover u q p x
--| @freshen c x
--| @freshen c u
axiom ex_elim_sub {x u: nat} (g h: ctx x u) (p: wff x) (c: wff):
  $ g ⊢ ∃ x p $ > $ h , [x/u] p ⊢ c $ > $ g , h ⊢ c $;

-- Simple existential elimination.  As above, `c: wff` is the real side
-- condition, while @freshen c x repairs alpha-collisions in c.
--| @view {x: nat} (g h: ctx x) (p: wff x) (c: wff): $ g ⊢ ∃ x p $ > $ h , p ⊢ c $ > $ g , h ⊢ c $
--| @freshen c x
--| @fallback ex_elim_sub
axiom ex_elim {x: nat} (g h: ctx x) (p: wff x) (c: wff):
  $ g ⊢ ∃ x p $ > $ h , p ⊢ c $ > $ g , h ⊢ c $;

-- Equality rules (Leibniz substitution).
axiom eq_intro_nd (g: ctx) (a: nat): $ g ⊢ a = a $;

--| @view (g h: ctx) {z: nat} (a b: nat) (p: wff z) (q r: wff): $ g ⊢ a = b $ > $ h ⊢ q $ > $ g , h ⊢ r $
--| @abstract p q r z a b
--| @fresh z
axiom eq_replace (g h: ctx) {z: nat} (a b: nat) (p: wff z):
  $ g ⊢ a = b $ > $ h ⊢ [z/a] p $ > $ g , h ⊢ [z/b] p $;

-- ============================================================
-- Arithmetic signature
-- ============================================================

term d0: nat;
prefix d0: $0$ prec max;
term suc (n: nat): nat;
term add (a b: nat): nat;
infixl add: $+$ prec 60;
term mul (a b: nat): nat;
infixl mul: $*$ prec 70;
term fact (n: nat): nat;
prefix fact: $!$ prec 75;

--| @congr
axiom suc_congr_eq (a b: nat): $ a = b $ > $ suc a = suc b $;
--| @congr
axiom add_congr_eq (a b c d: nat):
  $ a = b $ > $ c = d $ > $ a + c = b + d $;
--| @congr
axiom mul_congr_eq (a b c d: nat):
  $ a = b $ > $ c = d $ > $ a * c = b * d $;
--| @congr
axiom fact_congr_eq (a b: nat): $ a = b $ > $ ! a = ! b $;

-- ============================================================
-- Substitution rewriting
-- ============================================================
--
-- These axioms push sb_f / sb_t through the syntactic operators so the
-- compiler's @rewrite automation can normalise substitution expressions
-- that arise from all_elim, ex_intro, eq_replace, and the induction
-- axiom below.

--| @rewrite
axiom sb_f_im {x: nat} (t: nat x) (p q: wff x):
  $ [x/t] (p → q) ↔ ([x/t] p → [x/t] q) $;
--| @rewrite
axiom sb_f_and {x: nat} (t: nat x) (p q: wff x):
  $ [x/t] (p ∧ q) ↔ ([x/t] p ∧ [x/t] q) $;
--| @rewrite
axiom sb_f_or {x: nat} (t: nat x) (p q: wff x):
  $ [x/t] (p ∨ q) ↔ ([x/t] p ∨ [x/t] q) $;
--| @rewrite
axiom sb_f_not {x: nat} (t: nat x) (p: wff x):
  $ [x/t] (¬ p) ↔ ¬ [x/t] p $;
--| @rewrite
axiom sb_f_bi {x: nat} (t: nat x) (p q: wff x):
  $ [x/t] (p ↔ q) ↔ ([x/t] p ↔ [x/t] q) $;
--| @rewrite
axiom sb_f_bot {x: nat} (t: nat x): $ [x/t] ⊥ ↔ ⊥ $;
--| @rewrite
axiom sb_f_eq {x: nat} (t: nat x) (a b: nat x):
  $ [x/t] (a = b) ↔ (⟦ x/t ⟧ a) = (⟦ x/t ⟧ b) $;
--| @rewrite
axiom sb_f_ne {x: nat} (t: nat x) (a b: nat x):
  $ [x/t] (a ≠ b) ↔ (⟦ x/t ⟧ a) ≠ (⟦ x/t ⟧ b) $;
--| @rewrite
axiom sb_f_all {x y: nat} (t: nat x) (p: wff x y):
  $ [x/t] (∀ y p) ↔ ∀ y [x/t] p $;
--| @rewrite
axiom sb_f_ex {x y: nat} (t: nat x) (p: wff x y):
  $ [x/t] (∃ y p) ↔ ∃ y [x/t] p $;
--| @rewrite
axiom sb_f_id {x: nat} (p: wff x): $ [x/x] p ↔ p $;
--| @rewrite
axiom sb_f_irrel {x: nat} (t: nat x) (p: wff): $ [x/t] p ↔ p $;

--| @rewrite
axiom sb_t_var {x: nat} (t: nat x): $ (⟦ x/t ⟧ x) = t $;
--| @rewrite
axiom sb_t_irrel {x: nat} (t: nat x) (a: nat): $ (⟦ x/t ⟧ a) = a $;
--| @rewrite
axiom sb_t_zer {x: nat} (t: nat x): $ (⟦ x/t ⟧ 0) = 0 $;
--| @rewrite
axiom sb_t_suc {x: nat} (t: nat x) (a: nat x):
  $ (⟦ x/t ⟧ suc a) = suc (⟦ x/t ⟧ a) $;
--| @rewrite
axiom sb_t_add {x: nat} (t: nat x) (a b: nat x):
  $ (⟦ x/t ⟧ (a + b)) = (⟦ x/t ⟧ a) + (⟦ x/t ⟧ b) $;
--| @rewrite
axiom sb_t_mul {x: nat} (t: nat x) (a b: nat x):
  $ (⟦ x/t ⟧ (a * b)) = (⟦ x/t ⟧ a) * (⟦ x/t ⟧ b) $;
--| @rewrite
axiom sb_t_fact {x: nat} (t: nat x) (a: nat x):
  $ (⟦ x/t ⟧ ! a) = ! (⟦ x/t ⟧ a) $;

-- ============================================================
-- Peano arithmetic
-- ============================================================
--
-- We axiomatise the standard Peano signature (0, suc, +, *) and the
-- familiar routine identities (commutativity, associativity,
-- distributivity, cancellation, identities).  Each routine identity
-- is derivable from Robinson arithmetic by induction; the user could
-- (laboriously) prove every one from the bare Robinson axioms plus
-- peano5, but here we take them as part of the foundation so the
-- interesting content of the file lives in the order, divisibility,
-- primality, and Euclid lemmas further down.

-- Robinson Q.  All arithmetic axioms are stated context-polymorphically
-- so they can be used inside any open ND derivation.
axiom peano1 (g: ctx) (a: nat): $ g ⊢ ¬ suc a = 0 $;
axiom peano2 (g: ctx) (a b: nat): $ g ⊢ suc a = suc b → a = b $;
axiom add_0_ax (g: ctx) (a: nat): $ g ⊢ a + 0 = a $;
axiom add_suc_ax (g: ctx) (a b: nat): $ g ⊢ a + suc b = suc (a + b) $;
axiom mul_0_ax (g: ctx) (a: nat): $ g ⊢ a * 0 = 0 $;
axiom mul_suc_ax (g: ctx) (a b: nat): $ g ⊢ a * suc b = a * b + a $;
axiom fact_0_ax (g: ctx): $ g ⊢ ! 0 = suc 0 $;
axiom fact_suc_ax (g: ctx) (n: nat): $ g ⊢ ! suc n = suc n * ! n $;

-- First-order induction (Peano's fifth postulate).
--| @view {x: nat} (p: wff x) (base step: wff): $ emp ⊢ base $ > $ emp ⊢ ∀ x (p → step) $ > $ emp ⊢ ∀ x p $
axiom peano5 {x: nat} (p: wff x):
  $ emp ⊢ [x/0] p $ >
  $ emp ⊢ ∀ x (p → [x/(suc x)] p) $ >
  $ emp ⊢ ∀ x p $;

-- Routine identities of addition (derivable from Robinson + peano5).
axiom add_zero_left_ax (a: nat): $ emp ⊢ 0 + a = a $;
axiom add_suc_left_ax (a b: nat): $ emp ⊢ suc a + b = suc (a + b) $;
axiom add_comm_ax (a b: nat): $ emp ⊢ a + b = b + a $;
axiom add_assoc_ax (a b c: nat): $ emp ⊢ (a + b) + c = a + (b + c) $;
axiom add_cancel_left_ax (g: ctx) (x y z: nat):
  $ g ⊢ x + y = x + z $ > $ g ⊢ y = z $;

-- Routine identities of multiplication.
axiom mul_zero_left_ax (a: nat): $ emp ⊢ 0 * a = 0 $;
axiom mul_one_left_ax (a: nat): $ emp ⊢ suc 0 * a = a $;
axiom mul_one_right_ax (a: nat): $ emp ⊢ a * suc 0 = a $;
axiom mul_comm_ax (a b: nat): $ emp ⊢ a * b = b * a $;
axiom mul_assoc_ax (a b c: nat): $ emp ⊢ (a * b) * c = a * (b * c) $;
axiom mul_distrib_left_ax (a b c: nat):
  $ emp ⊢ a * (b + c) = a * b + a * c $;
axiom mul_distrib_right_ax (a b c: nat):
  $ emp ⊢ (a + b) * c = a * c + b * c $;

-- a + b = 0 forces both summands to be zero.
axiom add_eq_zero_ax (g: ctx) (x y: nat):
  $ g ⊢ x + y = 0 $ > $ g ⊢ x = 0 ∧ y = 0 $;

-- a * b = 1 forces both factors to be 1.
axiom mul_eq_one_ax (g: ctx) (x y: nat):
  $ g ⊢ x * y = suc 0 $ > $ g ⊢ x = suc 0 ∧ y = suc 0 $;

-- Multiplicative cancellation by a non-zero factor.
axiom mul_cancel_left_ax (g: ctx) (x y z: nat):
  $ g ⊢ ¬ z = 0 $ > $ g ⊢ z * x = z * y $ > $ g ⊢ x = y $;

-- ============================================================
-- Order, divisibility, primality
-- ============================================================
--
-- ≤ is the usual additive preorder, < is defined by successor, and
-- divisibility is existential.  Their introduction / elimination rules
-- are proved from the definitions instead of trusted as primitives.

def le {.k: nat} (a b: nat): wff = $ ∃ k (a + k = b) $;
infixl le: $≤$ prec 45;
infixl le: $<=$ prec 45;
def lt (a b: nat): wff = $ suc a ≤ b $;
infixl lt: $<$ prec 45;

--| @congr
axiom le_congr_eq (a b c d: nat):
  $ a = b $ > $ c = d $ > $ (a ≤ c) ↔ (b ≤ d) $;
--| @congr
theorem lt_congr_eq (a b c d: nat):
  $ a = b $ > $ c = d $ > $ (a < c) ↔ (b < d) $;
--| @rewrite
axiom sb_f_le {x: nat} (t: nat x) (a b: nat x):
  $ [x/t] (a ≤ b) ↔ (⟦ x/t ⟧ a) ≤ (⟦ x/t ⟧ b) $;
--| @rewrite
axiom sb_f_lt {x: nat} (t: nat x) (a b: nat x):
  $ [x/t] (a < b) ↔ (⟦ x/t ⟧ a) < (⟦ x/t ⟧ b) $;

-- Characterisations of ≤ via addition.  Context-polymorphic so they
-- compose inside open derivations.
theorem le_iff_add (g: ctx) (x y: nat) {k: nat}:
  $ g ⊢ x ≤ y $ > $ g ⊢ ∃ k (x + k = y) $;
theorem le_from_add (g: ctx) (x y k: nat):
  $ g ⊢ x + k = y $ > $ g ⊢ x ≤ y $;

-- Symmetry of equality, in derivation form.
theorem eq_sym_nd (g: ctx) (a b: nat): $ g ⊢ a = b $ > $ g ⊢ b = a $;

-- No natural number is its own successor.
theorem no_suc_eq_self {n: nat}: $ emp ⊢ ∀ n (¬ suc n = n) $;
theorem no_suc_eq_self_inst (a: nat): $ emp ⊢ ¬ suc a = a $;

-- ≤ antisymmetry is derived below.
theorem le_antisym_ax (g h: ctx) (a b: nat):
  $ g ⊢ a ≤ b $ > $ h ⊢ b ≤ a $ > $ g , h ⊢ a = b $;

-- 0 is the bottom of ≤.
theorem zero_le_ax (a: nat): $ emp ⊢ 0 ≤ a $;
-- ≤ is reflexive.
theorem le_refl_ax (a: nat): $ emp ⊢ a ≤ a $;

-- Transitivity of ≤.
theorem le_trans_ax (g h: ctx) (x y z: nat):
  $ g ⊢ x ≤ y $ > $ h ⊢ y ≤ z $ > $ g , h ⊢ x ≤ z $;

-- a + 1 = suc a  and  1 + a = suc a.
theorem add_one_eq_suc_ax (g: ctx) (a: nat): $ g ⊢ a + suc 0 = suc a $;
theorem one_add_eq_suc_ax (g: ctx) (a: nat):
  $ g ⊢ suc 0 + a = suc a $;

-- Successor is positive:  1 ≤ suc n.
theorem suc_pos_ax (g: ctx) (n: nat): $ g ⊢ suc 0 ≤ suc n $;

-- Product of positives is positive.
theorem pos_mul_pos_ax (g h: ctx) (a b: nat):
  $ g ⊢ suc 0 ≤ a $ > $ h ⊢ suc 0 ≤ b $ > $ g , h ⊢ suc 0 ≤ a * b $;

-- Monotonicity of suc with respect to ≤.
theorem le_suc_suc_ax (g: ctx) (a b: nat):
  $ g ⊢ a ≤ b $ > $ g ⊢ suc a ≤ suc b $;

-- A 4-term re-association used in dvd_add_cancel:
--   ((a + b) + c) + d  =  a + (b + c + d).
theorem add_assoc4_ax (g: ctx) (a b c d: nat):
  $ g ⊢ ((a + b) + c) + d = a + (b + c + d) $;

-- Strong (course-of-values) induction.  Derivable from peano5 by an
-- inner induction on a bounding parameter.
--| @view {x y: nat} (p: wff x) (ih: wff x y): $ emp ⊢ ∀ x ((∀ y (y < x → ih)) → p) $ > $ emp ⊢ ∀ x p $
axiom peano5_strong {x y: nat} (p: wff x):
  $ emp ⊢ ∀ x ((∀ y (y < x → [x/y] p)) → p) $ >
  $ emp ⊢ ∀ x p $;

-- Derived strict-order facts.
theorem lt_iff_suc_le (g: ctx) (x y: nat):
  $ g ⊢ (x < y) ↔ (suc x ≤ y) $;
theorem lt_from_suc_le (g: ctx) (x y: nat):
  $ g ⊢ suc x ≤ y $ > $ g ⊢ x < y $;
theorem suc_le_from_lt (g: ctx) (x y: nat):
  $ g ⊢ x < y $ > $ g ⊢ suc x ≤ y $;
theorem lt_irrefl_ax (a: nat): $ emp ⊢ ¬ a < a $;
theorem lt_trans_ax (a b c: nat):
  $ emp ⊢ a < b $ > $ emp ⊢ b < c $ > $ emp ⊢ a < c $;
theorem le_lt_trans_ax (a b c: nat):
  $ emp ⊢ a ≤ b $ > $ emp ⊢ b < c $ > $ emp ⊢ a < c $;
theorem lt_le_trans_ax (a b c: nat):
  $ emp ⊢ a < b $ > $ emp ⊢ b ≤ c $ > $ emp ⊢ a < c $;
theorem not_lt_zero_ax (a: nat): $ emp ⊢ ¬ a < 0 $;
theorem suc_lt_suc_ax (a b: nat):
  $ emp ⊢ a < b $ > $ emp ⊢ suc a < suc b $;
theorem lt_implies_le_ax (g: ctx) (x y: nat):
  $ g ⊢ x < y $ > $ g ⊢ x ≤ y $;
theorem pos_of_one_lt_ax (g: ctx) (x: nat):
  $ g ⊢ suc 0 < x $ > $ g ⊢ 0 < x $;
theorem lt_suc_self_ax (g: ctx) (a: nat): $ g ⊢ a < suc a $;

-- a ∣ b  is just  ∃ k. b = a * k.  The companion intro / elim
-- theorems below recover the old user-facing surface while delegating
-- the logical content to ∃-introduction and ∃-elimination.
def dvd {.k: nat} (a b: nat): wff = $ ∃ k (b = a * k) $;
infixl dvd: $∣$ prec 50;
infixl dvd: $||$ prec 50;

-- These normalization helpers remain trusted for now.  Proving them
-- from the ∃-definition needs more quantified rewrite plumbing than
-- this file currently has.
--| @congr
axiom dvd_congr_eq (a b c d: nat):
  $ a = b $ > $ c = d $ > $ (a ∣ c) ↔ (b ∣ d) $;
--| @rewrite
axiom sb_f_dvd {x: nat} (t: nat x) (a b: nat x):
  $ [x/t] (a ∣ b) ↔ (⟦ x/t ⟧ a) ∣ (⟦ x/t ⟧ b) $;

theorem dvd_intro (g: ctx) (a b k: nat):
  $ g ⊢ b = a * k $ > $ g ⊢ a ∣ b $;

-- Divisibility elimination is existential elimination for the hidden
-- witness k in `a ∣ b`.  The raw argument types are the side condition:
-- g, h, a, b, and c must not depend on k.  The @freshen line below does
-- not make a witness-dependent conclusion legal; it only alpha-renames
-- unrelated bound occurrences of k inside c before the MM0 dependency
-- check runs.
--| @freshen c k
theorem dvd_elim (g h: ctx) {k: nat} (a b: nat) (c: wff):
  $ g ⊢ a ∣ b $ > $ h , b = a * k ⊢ c $ > $ g , h ⊢ c $;

-- Basic divisibility facts (companions to the basic order facts above).
theorem dvd_zero_imp_eq_zero_ax (g: ctx) (x: nat):
  $ g ⊢ 0 ∣ x $ > $ g ⊢ x = 0 $;

-- p is prime iff 1 < p and every divisor of p is either 1 or p itself.
def prime {.d: nat} (p: nat): wff =
  $ suc 0 < p ∧ ∀ d (d ∣ p → (d = suc 0 ∨ d = p)) $;

--| @congr
axiom prime_congr (a b: nat):
  $ a = b $ > $ prime a ↔ prime b $;
--| @rewrite
axiom sb_f_prime {x: nat} (t: nat x) (p: nat x):
  $ [x/t] (prime p) ↔ prime (⟦ x/t ⟧ p) $;

-- ============================================================
-- Order, divisibility: basic lemmas
-- ============================================================

theorem le_refl (a: nat): $ emp ⊢ a ≤ a $;
theorem le_refl_all {a: nat}: $ emp ⊢ ∀ a (a ≤ a) $;

-- Divisibility is reflexive: a = a * 1, so a ∣ a.
theorem dvd_refl (a: nat): $ emp ⊢ a ∣ a $;

-- Every nat is at least 0.  Witness k = a since 0 + a = a.
theorem zero_le (a: nat): $ emp ⊢ 0 ≤ a $;

-- Every nat divides 0:  0 = a * 0.
theorem dvd_zero (a: nat): $ emp ⊢ a ∣ 0 $;

-- 1 divides everything:  a = 1 * a.
theorem one_dvd (a: nat): $ emp ⊢ suc 0 ∣ a $;

-- If a ∣ b, then a divides any multiple of b.
theorem dvd_mul_right (g: ctx) (a b c: nat):
  $ g ⊢ a ∣ b $ > $ g ⊢ a ∣ (b * c) $;

-- If a ∣ b and a ∣ c, then a ∣ (b + c).
theorem dvd_add (a b c: nat):
  $ emp ⊢ a ∣ b $ > $ emp ⊢ a ∣ c $ > $ emp ⊢ a ∣ (b + c) $;

-- Transitivity of divisibility.
theorem dvd_trans (g h: ctx) (x y z: nat):
  $ g ⊢ x ∣ y $ > $ h ⊢ y ∣ z $ > $ g , h ⊢ x ∣ z $;

-- If a ∣ 1 then a = 1.
theorem dvd_one_implies (g: ctx) (a: nat):
  $ g ⊢ a ∣ suc 0 $ > $ g ⊢ a = suc 0 $;

-- No prime divides 1.
theorem prime_not_dvd_one (g: ctx) (p: nat):
  $ g ⊢ prime p $ > $ g ⊢ ¬ p ∣ suc 0 $;

-- 1 ≤ ! n, for every n.  First substantive induction proof in the file.
theorem fact_pos {n: nat}: $ emp ⊢ ∀ n (suc 0 ≤ ! n) $;
theorem fact_pos_inst (m: nat): $ emp ⊢ suc 0 ≤ ! m $;

-- 1 < ! n + 1.  Direct from fact_pos by lifting through suc.
theorem one_lt_fact_succ (m: nat): $ emp ⊢ suc 0 < ! m + suc 0 $;

-- Case decomposition on naturals: every n is 0 or suc k for some k.
theorem nat_cases {n k: nat}:
  $ emp ⊢ ∀ n (n = 0 ∨ ∃ k (n = suc k)) $;
theorem nat_cases_inst (m: nat) {k: nat}:
  $ emp ⊢ m = 0 ∨ ∃ k (m = suc k) $;

-- Order is total on naturals.
theorem le_total_all {i j: nat}:
  $ emp ⊢ ∀ i (∀ j (i ≤ j ∨ j ≤ i)) $;
theorem le_total_ax (a b: nat): $ emp ⊢ a ≤ b ∨ b ≤ a $;

-- Basic order facts derived from the definitions and nat_cases.
theorem ne_zero_of_pos_ax (g: ctx) (x: nat):
  $ g ⊢ 0 < x $ > $ g ⊢ ¬ x = 0 $;
theorem one_lt_of_ne_zero_ne_one_ax (g h: ctx) (x: nat):
  $ g ⊢ ¬ x = 0 $ > $ h ⊢ ¬ x = suc 0 $ > $ g , h ⊢ suc 0 < x $;

-- If x ≤ y and x ≠ y, then x < y.
theorem lt_of_le_ne_ax (g h: ctx) (x y: nat):
  $ g ⊢ x ≤ y $ > $ h ⊢ ¬ x = y $ > $ g , h ⊢ x < y $;

-- A positive multiple is at least its factor.
theorem dvd_pos_imp_le_ax (g h: ctx) (x y: nat):
  $ g ⊢ x ∣ y $ > $ h ⊢ 0 < y $ > $ g , h ⊢ x ≤ y $;

-- Strict comparison: for any two naturals, a ≤ b or b < a.
theorem nat_compare (a b: nat): $ emp ⊢ a ≤ b ∨ b < a $;

-- a ∣ b and a ∣ (b + c) imply a ∣ c.  The arithmetic core of Euclid.
theorem dvd_add_cancel (g h: ctx) (a b c: nat):
  $ g ⊢ a ∣ b $ > $ h ⊢ a ∣ (b + c) $ > $ g , h ⊢ a ∣ c $;

-- If a ≤ suc b then either a ≤ b or a = suc b.
theorem le_suc_cases (g: ctx) (a b: nat):
  $ g ⊢ a ≤ suc b $ > $ g ⊢ a ≤ b ∨ a = suc b $;

-- Symmetric form of dvd_mul_right:  a ∣ b implies a ∣ (c * b).
theorem dvd_mul_left (g: ctx) (a b c: nat):
  $ g ⊢ a ∣ b $ > $ g ⊢ a ∣ (c * b) $;

-- If 1 < d and d ≤ n then d divides n!.
theorem dvd_fact {n: nat} (d: nat):
  $ emp ⊢ ∀ n ((suc 0 < d ∧ d ≤ n) → d ∣ ! n) $;

-- Classical de Morgan:  ¬ (a ∧ b)  implies  ¬a ∨ ¬b.
theorem not_and_imp_or_not (g: ctx) (a b: wff):
  $ g ⊢ ¬ (a ∧ b) $ > $ g ⊢ ¬ a ∨ ¬ b $;

-- Double-negation elimination, available because we have LEM.
theorem dne (g: ctx) (a: wff): $ g ⊢ ¬ ¬ a $ > $ g ⊢ a $;

-- Classical de Morgan over ∨:  ¬ (a ∨ b)  implies  ¬a ∧ ¬b.
theorem not_or_imp_and_not (g: ctx) (a b: wff):
  $ g ⊢ ¬ (a ∨ b) $ > $ g ⊢ ¬ a ∧ ¬ b $;

-- Classical:  ¬ (a → b)  implies  a ∧ ¬ b.
theorem not_imp_imp_and_not (g: ctx) (a b: wff):
  $ g ⊢ ¬ (a → b) $ > $ g ⊢ a ∧ ¬ b $;

-- Classical drinker:  ¬ ∀ x. P x  →  ∃ x. ¬ P x.
-- The ambient context may depend on x; this rule does not generalize
-- over x, so there is no eigenvariable side condition on g.
theorem not_forall_imp_exists_not {x: nat} (g: ctx x) (P: wff x):
  $ g ⊢ ¬ (∀ x P) $ > $ g ⊢ ∃ x (¬ P) $;


-- ============================================================
-- Every m > 1 has a prime divisor
-- ============================================================

-- Strong induction:  by peano5_strong on m, with case-split on
-- prime m  vs  ¬ prime m.  The non-prime branch peels off a
-- non-trivial divisor d (via the classical drinker on the negated
-- ∀-conjunct of `prime m`), shows 1 < d < m, applies the IH, and
-- chains the prime witness through d via dvd_trans.
theorem exists_prime_factor {m p: nat}:
  $ emp ⊢ ∀ m (suc 0 < m → ∃ p (prime p ∧ p ∣ m)) $;

theorem exists_prime_factor_inst (z: nat) {p: nat}:
  $ emp ⊢ suc 0 < z → ∃ p (prime p ∧ p ∣ z) $;

-- ============================================================
-- Main theorem:  there are infinitely many primes.
-- ============================================================

-- The main theorem.  The existential binder is named q so the proof can
-- use p for the prime divisor of !n + 1 without triggering a bound-variable
-- aliasing conflict during the final generalisation.
theorem euclid {n q: nat}:
  $ emp ⊢ ∀ n (∃ q (prime q ∧ n < q)) $;

-- ============================================================
-- Toward Euclid
-- ============================================================
--
-- Substantive lemmas already proven below (no axiomatic shortcuts):
--
--   * dvd plumbing         : dvd_refl, dvd_zero, one_dvd, dvd_mul_right,
--                            dvd_mul_left, dvd_add, dvd_trans, dvd_one_implies.
--   * prime_not_dvd_one    : prime p → ¬ p ∣ suc 0.
--   * fact_pos             : suc 0 ≤ ! n              (peano5 induction).
--   * one_lt_fact_succ     : suc 0 < ! n + suc 0      (chained algebra).
--   * nat_cases            : n = 0 ∨ ∃ k. n = suc k   (peano5 induction).
--   * nat_compare          : a ≤ b ∨ b < a            (case-split on
--                                                      le_iff_add witness).
--   * le_suc_cases         : a ≤ suc b → a ≤ b ∨ a = suc b.
--   * dvd_add_cancel       : a ∣ b → a ∣ (b + c) → a ∣ c
--                                                     (the arithmetic core,
--                                                      case-split on
--                                                      nat_compare).
--   * dvd_fact             : (1 < d ∧ d ≤ n) → d ∣ ! n
--                                                     (induction with a
--                                                      le_suc_cases split).
--   * classical helpers    : not_and_imp_or_not, dne,
--                            not_or_imp_and_not, not_imp_imp_and_not
--                                                     (LEM-driven de Morgan).
--
-- The prime-factor theorem is proved by strong induction on m.  The
-- non-prime branch extracts a non-trivial divisor d, applies the IH to
-- d, and chains the resulting prime divisor through d via dvd_trans.
--
-- The Euclid assembly sets m := !n + 1, invokes exists_prime_factor,
-- case-splits on p ≤ n vs n < p, and derives a contradiction in the
-- p ≤ n branch via dvd_fact, dvd_add_cancel, and
-- prime_not_dvd_one.
