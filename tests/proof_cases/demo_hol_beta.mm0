-- Higher-order logic demo inspired by third_party/mm0/examples/hol.mm0.
--
-- This file keeps the object theory tiny, but it tries to show a few
-- frontend features in one place:
--   * Unicode notation for a small HOL-style О»-calculus
--   * ОІ and О· reasoning
--   * congruence-driven rewriting
--   * substitution rules whose raw binders disappear after normalization
--
-- There are two equalities in play:
--   * `в‰ѓ[A] t = u` is a Boolean-valued term
--   * `в‰Ў[A] t = u` is a wff-level judgmental equality proposition

strict provable sort wff;

delimiter $ ( @ [ / ! ~ $ $ . : ; ) ] $;

term im: wff > wff > wff;
infixr im: $вЉў$ prec 0;
infixr im: $|-$ prec 0;

term an: wff > wff > wff;
infixl an: $в€§$ prec 1;
infixl an: $;$ prec 1;

axiom id (P: wff): $ P вЉў P $;
axiom syl (P Q R: wff): $ P вЉў Q $ > $ Q вЉў R $ > $ P вЉў R $;
axiom ian (G P Q: wff): $ G вЉў P $ > $ G вЉў Q $ > $ G вЉў P в€§ Q $;
axiom anl (P Q: wff): $ P в€§ Q вЉў P $;
axiom anr (P Q: wff): $ P в€§ Q вЉў Q $;

term iff: wff > wff > wff;
infixr iff: $в†”$ prec 20;
infixr iff: $<->$ prec 20;

--| @relation wff iff iff_refl iff_trans iff_sym iff_mp
axiom iff_refl (P: wff): $ P в†” P $;
axiom iff_trans (P Q R: wff): $ P в†” Q $ > $ Q в†” R $ > $ P в†” R $;
axiom iff_sym (P Q: wff): $ P в†” Q $ > $ Q в†” P $;
axiom iff_mp (P Q: wff): $ P в†” Q $ > $ P $ > $ Q $;

-- Propositions, types, and terms.

strict sort type;

term bool: type;
notation bool: type = ($рќ”№$:max);

term fun: type > type > type;
infixr fun: $в†’$ prec 25;
infixr fun: $->$ prec 25;

term tyeq: type > type > wff;
infixl tyeq: $в‰ђ$ prec 15;

--| @relation type tyeq tyeq_refl tyeq_trans tyeq_sym _
axiom tyeq_refl (A: type): $ A в‰ђ A $;
axiom tyeq_trans (A B C: type):
  $ A в‰ђ B $ > $ B в‰ђ C $ > $ A в‰ђ C $;
axiom tyeq_sym (A B: type): $ A в‰ђ B $ > $ B в‰ђ A $;

--| @vars О± ОІ Оі x y z p q r f g h u v w
sort term;

term ty: term > type > wff;
infixl ty: $:$ prec 2;

term app: term > term > term;
infixl app: $В·$ prec 1000;
infixl app: $@$ prec 1000;

term lam {x: term}: type > term x > term;
notation lam {x: term} (A: type) (t: term x): term =
  ($О»$:20) x ($:$:2) A ($.$:0) t;
notation lam {x: term} (A: type) (t: term x): term =
  ($\\$:20) x ($:$:2) A ($.$:0) t;

axiom appT (G: wff) (A B: type) (f x: term):
  $ G вЉў f: A в†’ B $ > $ G вЉў x: A $ > $ G вЉў f В· x: B $;

axiom lamT (G: wff) (A B: type) {x: term} (t: term x):
  $ G в€§ x: A вЉў t: B $ > $ G вЉў О» x: A. t: A в†’ B $;

term eq: type > term;
axiom eqT (G: wff) (A: type): $ G вЉў eq A: A в†’ A в†’ рќ”№ $;

def eqc (A: type) (t u: term): term = $ eq A В· t В· u $;
notation eqc (A: type) (t u: term): term =
  ($в‰ѓ[$:50) A ($]$:0) t ($=$:50) u;
notation eqc (A: type) (t u: term): term =
  ($=[$:50) A ($]$:0) t ($=$:50) u;

term jeq: type > term > term > wff;
notation jeq (A: type) (t u: term): wff =
  ($в‰Ў[$:50) A ($]$:0) t ($=$:50) u;
notation jeq (A: type) (t u: term): wff =
  ($==[$:50) A ($]$:0) t ($=$:50) u;

term thm: term > wff;
coercion thm: term > wff;

def bic (p q: term): term = $ в‰ѓ[рќ”№] p = q $;
infixr bic: $в‡”$ prec 20;
infixr bic: $<->$ prec 20;

axiom eqmp (G: wff) (P Q: term):
  $ G вЉў P в‡” Q $ > $ G вЉў P $ > $ G вЉў Q $;

axiom ded (G: wff) (P Q: term):
  $ G в€§ P вЉў Q $ > $ G в€§ Q вЉў P $ > $ G вЉў P в‡” Q $;

axiom thmR (G: wff) (A: term): $ G вЉў A $ > $ G вЉў A: рќ”№ $;

axiom refl (G: wff) (A: type) (t: term):
  $ G вЉў t: A $ > $ G вЉў в‰Ў[A] t = t $;

axiom aeq (G: wff) (A B: type) (f g a b: term):
  $ G вЉў в‰Ў[A в†’ B] f = g $ > $ G вЉў в‰Ў[A] a = b $ >
  $ G вЉў в‰Ў[B] f В· a = g В· b $;

axiom leq (G: wff) (A B: type) {x: term} (a b: term x):
  $ G в€§ x: A вЉў в‰Ў[B] a = b $ >
  $ G вЉў в‰Ў[A в†’ B] (О» x: A. a) = (О» x: A. b) $;

axiom beta (A B: type) {x: term} (G: wff x) (t: term x):
  $ G вЉў (О» x: A. t) В· x: B $ >
  $ G вЉў в‰Ў[B] (О» x: A. t) В· x = t $;

axiom betat (A B: type) {x: term} (G: wff x) (t: term x):
  $ G вЉў (О» x: A. t) В· x: B $ >
  $ G вЉў в‰ѓ[B] (О» x: A. t) В· x = t $;

axiom inst (G: wff) (A: type) {x: term} (t a: term x):
  $ G вЉў a: рќ”№ $ > $ G вЉў t: A $ > $ G в€§ в‰ѓ[A] x = t вЉў a $ > $ G вЉў a $;

axiom eta (G: wff) (A B: type) {x: term} (e: term x):
  $ G вЉў e: A в†’ B $ >
  $ G вЉў в‰Ў[A в†’ B] (О» x: A. e В· x) = e $;

axiom eqsym (G: wff) (A: type) (a b: term):
  $ G вЉў в‰Ў[A] a = b $ > $ G вЉў в‰Ў[A] b = a $;

axiom eqtrans (G: wff) (A: type) (a b c: term):
  $ G вЉў в‰Ў[A] a = b $ > $ G вЉў в‰Ў[A] b = c $ >
  $ G вЉў в‰Ў[A] a = c $;

axiom eqTR1 (G: wff) (A: type) (a b: term):
  $ G вЉў в‰Ў[A] a = b $ > $ G вЉў a: A $;

axiom eqTR2 (G: wff) (A: type) (a b: term):
  $ G вЉў в‰Ў[A] a = b $ > $ G вЉў b: A $;

-- Raw term-level equality used by the normalization machinery.

term teq: term > term > wff;
infixl teq: $в‰€$ prec 15;

--| @relation term teq teq_refl teq_trans teq_sym _
axiom teq_refl (t: term): $ t в‰€ t $;
axiom teq_trans (t u v: term): $ t в‰€ u $ > $ u в‰€ v $ > $ t в‰€ v $;
axiom teq_sym (t u: term): $ t в‰€ u $ > $ u в‰€ t $;

--| @congr
axiom teq_congr (a b c d: term):
  $ a в‰€ b $ > $ c в‰€ d $ > $ (a в‰€ c) в†” (b в‰€ d) $;

--| @congr
axiom judg_congr (G H P Q: wff):
  $ G в†” H $ > $ P в†” Q $ > $ (G вЉў P) в†” (H вЉў Q) $;

--| @congr
axiom eq_congr (A B: type) (a b c d: term):
  $ A в‰ђ B $ > $ a в‰€ b $ > $ c в‰€ d $ > $ в‰Ў[A] a = c в†” в‰Ў[B] b = d $;

--| @congr
axiom app_congr (f g a b: term):
  $ f в‰€ g $ > $ a в‰€ b $ > $ f В· a в‰€ g В· b $;

-- Explicit substitution for term rewrites.

term sb {x: term}: term > term x > term;
notation sb {x: term} (t: term) (u: term x): term =
  ($[$:41) x ($/$:0) t ($]$:0) u;

--| @rewrite
axiom sb_var {x: term} (t: term): $ [x / t] x в‰€ t $;

--| @rewrite
axiom sb_irrel {x: term} (t u: term): $ [x / t] u в‰€ u $;

--| @rewrite
axiom sb_app {x: term} (t: term) (f a: term x):
  $ [x / t] (f В· a) в‰€ ([x / t] f) В· ([x / t] a) $;

-- Substitution rules. The raw binder `{x}` is hidden by normalization, so we
-- expose a cleaner user-facing surface with `@view`, `@abstract`, and
-- `@fresh`, as in the calculus demo.

--| @view {x: term} (G: wff) (A: type) (a b: term) (r: term x) (p q: term): $ G вЉў в‰Ў[A] a = b $ > $ G вЉў в‰Ў[A] p = q $
--| @abstract r p q x a b
--| @fresh x
--| @normalize conc
axiom subst_eq {x: term} (G: wff) (A: type) (a b: term) (r: term x):
  $ G вЉў в‰Ў[A] a = b $ >
  $ G вЉў в‰Ў[A] ([x / a] r) = ([x / b] r) $;

--| @view {x: term} (a b: term) (r: term x) (p q: term): $ a в‰€ b $ > $ p в‰€ q $
--| @abstract r p q x a b
--| @fresh x
--| @normalize conc
axiom subst_teq {x: term} (a b: term) (r: term x):
  $ a в‰€ b $ >
  $ ([x / a] r) в‰€ ([x / b] r) $;

-- Derived term-level equality rules used for the propositional basis.

axiom appTR1 (G: wff) (A B: type) (f x: term):
  $ G вЉў f В· x: B $ > $ G вЉў x: A $ > $ G вЉў f: A в†’ B $;

axiom appTR2 (G: wff) (A B: type) (f x: term):
  $ G вЉў f В· x: B $ > $ G вЉў f: A в†’ B $ > $ G вЉў x: A $;

axiom appTR22 (G: wff) (A B C: type) (f x y: term):
  $ G вЉў f В· x В· y: C $ > $ G вЉў f: A в†’ B в†’ C $ > $ G вЉў x: A в€§ y: B $;

theorem eqcT (G: wff) (A: type) (t u: term):
  $ G вЉў t: A $ > $ G вЉў u: A $ > $ G вЉў (в‰ѓ[A] t = u): рќ”№ $;

axiom reflt (G: wff) (A: type) (t: term):
  $ G вЉў t: A $ > $ G вЉў в‰ѓ[A] t = t $;

axiom aeqt (G: wff) (A B: type) (f g a b: term):
  $ G вЉў в‰ѓ[A в†’ B] f = g $ > $ G вЉў в‰ѓ[A] a = b $ >
  $ G вЉў в‰ѓ[B] f В· a = g В· b $;

axiom leqt (G: wff) (A B: type) {x: term} (a b: term x):
  $ G в€§ x: A вЉў в‰ѓ[B] a = b $ >
  $ G вЉў в‰ѓ[A в†’ B] (О» x: A. a) = (О» x: A. b) $;

axiom betac (G: wff) (A B: type) {x: term} (t: term x) (u: term):
  $ G вЉў u: A $ > $ G вЉў в‰ѓ[B] (О» x: A. t) В· u = ([x / u] t) $;

axiom symt (G: wff) (A: type) (a b: term):
  $ G вЉў в‰ѓ[A] a = b $ > $ G вЉў в‰ѓ[A] b = a $;

axiom transt (G: wff) (A: type) (a b c: term):
  $ G вЉў в‰ѓ[A] a = b $ > $ G вЉў в‰ѓ[A] b = c $ >
  $ G вЉў в‰ѓ[A] a = c $;

axiom eqR1 (G: wff) (A: type) (a b: term):
  $ G вЉў в‰ѓ[A] a = b $ > $ G вЉў a: A $;

axiom eqR2 (G: wff) (A: type) (a b: term):
  $ G вЉў в‰ѓ[A] a = b $ > $ G вЉў b: A $;

theorem aeq1 (G: wff) (A B: type) (f g a: term):
  $ G вЉў в‰ѓ[A в†’ B] f = g $ > $ G вЉў a: A $ >
  $ G вЉў в‰ѓ[B] f В· a = g В· a $;

theorem aeq2 (G: wff) (A B: type) (f a b: term):
  $ G вЉў f: A в†’ B $ > $ G вЉў в‰ѓ[A] a = b $ >
  $ G вЉў в‰ѓ[B] f В· a = f В· b $;

theorem bineq (G: wff) (A B C: type) (f a1 a2 b1 b2: term):
  $ G вЉў f: A в†’ B в†’ C $ > $ G вЉў в‰ѓ[A] a1 = a2 $ >
  $ G вЉў в‰ѓ[B] b1 = b2 $ > $ G вЉў в‰ѓ[C] f В· a1 В· b1 = f В· a2 В· b2 $;

theorem bineq1 (G: wff) (A B C: type) (f a1 a2 b: term):
  $ G вЉў f: A в†’ B в†’ C $ > $ G вЉў в‰ѓ[A] a1 = a2 $ > $ G вЉў b: B $ >
  $ G вЉў в‰ѓ[C] f В· a1 В· b = f В· a2 В· b $;

theorem bineq2 (G: wff) (A B C: type) (f a b1 b2: term):
  $ G вЉў f: A в†’ B в†’ C $ > $ G вЉў a: A $ > $ G вЉў в‰ѓ[B] b1 = b2 $ >
  $ G вЉў в‰ѓ[C] f В· a В· b1 = f В· a В· b2 $;

theorem sym (G: wff) (A: type) (a b: term):
  $ G вЉў в‰ѓ[A] a = b $ > $ G вЉў в‰ѓ[A] b = a $;

theorem trans (G: wff) (A: type) (a b c: term):
  $ G вЉў в‰ѓ[A] a = b $ > $ G вЉў в‰ѓ[A] b = c $ >
  $ G вЉў в‰ѓ[A] a = c $;

theorem eqmpr (G: wff) (P Q: term):
  $ G вЉў Q в‡” P $ > $ G вЉў P $ > $ G вЉў Q $;

-- Small helper lemmas plus a few user-facing examples.

theorem weaken_ctx (G H P: wff):
  $ G вЉў P $ > $ G в€§ H вЉў P $;

theorem lamTR (A B: type) {x: term} (G: wff x) (t: term x):
  $ G вЉў О» x: A. t: A в†’ B $ > $ G в€§ x: A вЉў t: B $;

theorem betacv (G: wff) (A B: type) {x: term} (t u v: term x):
  $ G в€§ x: A вЉў u: B $ >
  $ G вЉў t: A $ >
  $ G вЉў v: B $ >
  $ G в€§ в‰ѓ[A] x = t вЉў в‰ѓ[B] u = v $ >
  $ G вЉў в‰ѓ[B] (О» x: A. u) В· t = v $;

theorem id_bool_has_type (G: wff) {x: term}:
  $ G вЉў О» x: рќ”№. x: рќ”№ в†’ рќ”№ $;

theorem id_bool_refl (G: wff) {x: term}:
  $ G вЉў в‰Ў[рќ”№ в†’ рќ”№] (О» x: рќ”№. x) = (О» x: рќ”№. x) $;

theorem id_bool_beta (G: wff) {x: term}:
  $ G вЉў x: рќ”№ $ > $ G вЉў в‰Ў[рќ”№] ((О» x: рќ”№. x) В· x) = x $;

theorem eq_subst_id (G: wff) {x y: term}:
  $ G вЉў в‰Ў[рќ”№] x = y $ >
  $ G вЉў в‰Ў[рќ”№] ((О» x: рќ”№. x) В· x) = y $;

theorem id_bool_eta (G: wff) {x y: term}:
  $ G вЉў в‰Ў[рќ”№ в†’ рќ”№] (О» x: рќ”№. (О» y: рќ”№. y) В· x) = (О» y: рќ”№. y) $;

def T {.x: term}: term =
  $ в‰ѓ[рќ”№ в†’ рќ”№] (О» x: рќ”№. x) = (О» x: рќ”№. x) $;
notation T: term = ($вЉ¤$:max);

theorem T_DEF (G: wff) {x: term}:
  $ G вЉў в‰ѓ[рќ”№] T = =[рќ”№ в†’ рќ”№] (О» x: рќ”№. x) = (О» x: рќ”№. x) $;

theorem TT (G: wff):
  $ G вЉў T: рќ”№ $;

theorem TRUTH (G: wff):
  $ G вЉў T $;

theorem EQT_ELIM (G: wff) (P: term):
  $ G вЉў P в‡” T $ > $ G вЉў P $;

theorem EQT_INTRO (G: wff) (P: term):
  $ G вЉў P $ > $ G вЉў P в‡” T $;

def and {.x .y .f: term}: term =
  $ О» x: рќ”№. О» y: рќ”№. в‰ѓ[(рќ”№ в†’ рќ”№ в†’ рќ”№) в†’ рќ”№]
      (О» f: рќ”№ в†’ рќ”№ в†’ рќ”№. f В· x В· y) =
      (О» f: рќ”№ в†’ рќ”№ в†’ рќ”№. f В· T В· T) $;

theorem AND_DEF (G: wff) {x y f: term}:
  $ G вЉў в‰ѓ[рќ”№ в†’ рќ”№ в†’ рќ”№] and =
      (О» x: рќ”№. О» y: рќ”№. в‰ѓ[(рќ”№ в†’ рќ”№ в†’ рќ”№) в†’ рќ”№]
        (О» f: рќ”№ в†’ рќ”№ в†’ рќ”№. f В· x В· y) =
        (О» f: рќ”№ в†’ рќ”№ в†’ рќ”№. f В· T В· T)) $;

theorem andT (G: wff):
  $ G вЉў and: рќ”№ в†’ рќ”№ в†’ рќ”№ $;

def andc (p q: term): term = $ and В· p В· q $;
infixl andc: $в‹Џ$ prec 35;

theorem andcT (G: wff) (p q: term):
  $ G вЉў p: рќ”№ $ > $ G вЉў q: рќ”№ $ > $ G вЉў p в‹Џ q: рќ”№ $;

def imp {.p .q: term}: term =
  $ О» p: рќ”№. О» q: рќ”№. p в‹Џ q в‡” p $;

theorem IMP_DEF (G: wff) {p q: term}:
  $ G вЉў в‰ѓ[рќ”№ в†’ рќ”№ в†’ рќ”№] imp =
      (О» p: рќ”№. О» q: рќ”№. p в‹Џ q в‡” p) $;

theorem impT (G: wff):
  $ G вЉў imp: рќ”№ в†’ рќ”№ в†’ рќ”№ $;

def impc (p q: term): term = $ imp В· p В· q $;
infixr impc: $в‡’$ prec 30;

theorem impcT (G: wff) (p q: term):
  $ G вЉў p: рќ”№ $ > $ G вЉў q: рќ”№ $ > $ G вЉў p в‡’ q: рќ”№ $;

theorem impR (G: wff) (p q: term):
  $ G вЉў p в‡’ q $ > $ G вЉў p: рќ”№ в€§ q: рќ”№ $;

theorem IMPC_DEF (G: wff) (a b: term):
  $ G вЉў a: рќ”№ $ > $ G вЉў b: рќ”№ $ > $ G вЉў a в‡’ b в‡” (a в‹Џ b в‡” a) $;

axiom CONJ (G: wff) (p q: term):
  $ G вЉў p $ > $ G вЉў q $ > $ G вЉў p в‹Џ q $;

axiom CONJUNCT1 (G: wff) (p q: term):
  $ G вЉў p в‹Џ q $ > $ G вЉў p $;

axiom CONJUNCT2 (G: wff) (p q: term):
  $ G вЉў p в‹Џ q $ > $ G вЉў q $;

theorem MP (G: wff) (p q: term):
  $ G вЉў p в‡’ q $ > $ G вЉў p $ > $ G вЉў q $;

theorem DISCH (G: wff) (p q: term):
  $ G вЉў p: рќ”№ $ > $ G вЉў q: рќ”№ $ > $ G в€§ p вЉў q $ > $ G вЉў p в‡’ q $;

theorem UNDISCH (G: wff) (p q: term):
  $ G вЉў p в‡’ q $ > $ G в€§ p вЉў q $;

theorem IMP_ID (G: wff) (p: term):
  $ G вЉў p: рќ”№ $ > $ G вЉў p в‡’ p $;

theorem IMP_TRANS (G: wff) (p q r: term):
  $ G вЉў p в‡’ q $ > $ G вЉў q в‡’ r $ > $ G вЉў p в‡’ r $;

theorem CONJ_COMM (G: wff) (p q: term):
  $ G вЉў p: рќ”№ $ > $ G вЉў q: рќ”№ $ > $ G вЉў p в‹Џ q в‡’ q в‹Џ p $;

theorem CONJ_ASSOC (G: wff) (p q r: term):
  $ G вЉў p: рќ”№ $ > $ G вЉў q: рќ”№ $ > $ G вЉў r: рќ”№ $ >
  $ G вЉў (p в‹Џ q) в‹Џ r в‡’ p в‹Џ (q в‹Џ r) $;

theorem IMP_CONJ_CHAIN (G: wff) (p q r: term):
  $ G вЉў p в‡’ q $ > $ G вЉў q в‡’ r $ > $ G вЉў p в‡’ q в‹Џ r $;

def all (A: type) {.P .x: term}: term =
  $ О» P: A в†’ рќ”№. в‰ѓ[A в†’ рќ”№] P = (О» x: A. T) $;

theorem FORALL_DEF (G: wff) (A: type) {P x: term}:
  $ G вЉў в‰ѓ[(A в†’ рќ”№) в†’ рќ”№] all A =
      (О» P: A в†’ рќ”№. в‰ѓ[A в†’ рќ”№] P = (О» x: A. T)) $;

theorem allT (G: wff) (A: type):
  $ G вЉў all A: (A в†’ рќ”№) в†’ рќ”№ $;

def allc {x: term} (A: type) (t: term x): term =
  $ all A В· (О» x: A. t) $;
notation allc {x: term} (A: type) (t: term x): term =
  ($!$:20) x ($:$:2) A ($.$:0) t;

theorem allcT (G: wff) (A: type) {x: term} (t: term x):
  $ G в€§ x: A вЉў t: рќ”№ $ > $ G вЉў !x: A. t: рќ”№ $;

theorem alleq (G: wff) (A: type) {x: term} (t u: term x):
  $ G в€§ x: A вЉў t в‡” u $ >
  $ G вЉў all A В· (О» x: A. t) в‡” (all A В· (О» x: A. u)) $;

def or {.p .q .r: term}: term =
  $ О» p: рќ”№. О» q: рќ”№. !r: рќ”№. (p в‡’ r) в‡’ (q в‡’ r) в‡’ r $;

theorem OR_DEF (G: wff) {p q r: term}:
  $ G вЉў в‰ѓ[рќ”№ в†’ рќ”№ в†’ рќ”№] or =
      (О» p: рќ”№. О» q: рќ”№. !r: рќ”№. (p в‡’ r) в‡’ (q в‡’ r) в‡’ r) $;

theorem orT (G: wff):
  $ G вЉў or: рќ”№ в†’ рќ”№ в†’ рќ”№ $;

def orc (p q: term): term = $ or В· p В· q $;
infixl orc: $в€Ё$ prec 31;
infixl orc: $\/$ prec 31;

theorem orcT (G: wff) (p q: term):
  $ G вЉў p: рќ”№ $ > $ G вЉў q: рќ”№ $ > $ G вЉў p в€Ё q: рќ”№ $;

theorem orR (G: wff) (p q: term):
  $ G вЉў p в€Ё q $ > $ G вЉў p: рќ”№ в€§ q: рќ”№ $;

def F {.p: term}: term =
  $ !p: рќ”№. p $;

theorem F_DEF (G: wff) {p: term}:
  $ G вЉў F в‡” (!p: рќ”№. p) $;

theorem FT (G: wff):
  $ G вЉў F: рќ”№ $;

def not {.p: term}: term =
  $ О» p: рќ”№. p в‡’ F $;

theorem NOT_DEF (G: wff) {p: term}:
  $ G вЉў в‰ѓ[рќ”№ в†’ рќ”№] not = (О» p: рќ”№. p в‡’ F) $;

theorem notT (G: wff):
  $ G вЉў not: рќ”№ в†’ рќ”№ $;

def notc (p: term): term = $ not В· p $;
prefix notc: $В¬$ prec 100;
prefix notc: $~$ prec 100;

theorem notcT (G: wff) (p: term):
  $ G вЉў p: рќ”№ $ > $ G вЉў В¬ p: рќ”№ $;

theorem notR (G: wff) (p: term):
  $ G вЉў В¬ p $ > $ G вЉў p: рќ”№ $;

theorem notc_def (G: wff) (p: term):
  $ G вЉў p: рќ”№ $ > $ G вЉў В¬ p в‡” (p в‡’ F) $;

theorem NOT_ELIM (G: wff) (p: term):
  $ G вЉў В¬ p $ > $ G вЉў p в‡’ F $;

theorem NOT_INTRO (G: wff) (p: term):
  $ G вЉў p в‡’ F $ > $ G вЉў В¬ p $;

-- A term-level normalization example. The surface proof line never mentions
-- the raw substitution binder.
theorem normalize_subst_nested {x y z: term}:
  $ ((О» y: рќ”№. y) В· x) в‰€ z $ >
  $ ((О» y: рќ”№. y) В· x) В· ((О» y: рќ”№. y) В· x) в‰€ z В· z $;

-- A larger chain using ОІ-reduction, congruence, and transitivity.
theorem double_id_congr_chain (G: wff) {x y: term}:
  $ G вЉў в‰Ў[рќ”№] x = y $ >
  $ G вЉў в‰Ў[рќ”№] ((О» y: рќ”№. y) В· ((О» x: рќ”№. x) В· x)) = y $;

-- Judgment-level substitution with a hidden raw binder recovered through the
-- normalized surface shape.
theorem subst_eq_demo (G: wff) {x y z: term}:
  $ G вЉў в‰Ў[рќ”№] ((О» y: рќ”№. y) В· x) = z $ >
  $ G вЉў в‰Ў[рќ”№] ((О» y: рќ”№. y) В· x) В· ((О» y: рќ”№. y) В· x) = z В· z $;

-- A slightly larger chain combining ОІ-reduction with judgmental substitution.
theorem square_id_subst (G: wff) {x y: term}:
  $ G вЉў в‰Ў[рќ”№] x = y $ >
  $ G вЉў в‰Ў[рќ”№] ((О» x: рќ”№. x) В· x) В· ((О» x: рќ”№. x) В· x) = y В· y $;
